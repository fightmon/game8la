    </div>

    <!-- Game Categories Column -->
    <div class="footer-col">
      <h4>遊戲分類</h4>
      <a href="/#games">🎰 老虎機遊戲</a>
      <a href="/#games">🃏 百家樂</a>
      <a href="/#games">📹 真人娛樂</a>
      <a href="/#games">⚽ 體育投注</a>
      <a href="/#games">🐟 捕魚遊戲</a>
      <a href="/#games">♟️ 棋牌遊戲</a>
