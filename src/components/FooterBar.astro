    <!-- TG Group Column -->
    <div class="footer-col footer-col-tg">
      <h4>加入 Game8la TG 討論群</h4>
      <p class="tg-sub">老虎機攻略、數據討論、詐騙預警，玩家即時交流</p>
      <a href="https://t.me/game8la" target="_blank" rel="noopener" class="tg-qr-link">
        <img src="/images/tg-qr.webp" alt="Game8la Telegram QR Code" width="280" height="335" loading="lazy" class="tg-qr-img" />
