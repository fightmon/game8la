<style>
  /* === FOOTER === */
  .footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
    padding: 3rem 2rem 1.5rem;
    padding-bottom: calc(1.5rem + env(safe-area-inset-bottom, 0px));
  }

  .footer-grid {
    max-width: 1300px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .footer-col h4 {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .footer-col p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .footer-col a {
    display: block;
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.3rem 0;
    font-size: 0.9rem;
    transition: color 0.3s;
  }

  .footer-col a:hover {
    color: var(--gold-light);
  }

  .footer-disclaimer {
    max-width: 1300px;
    margin: 0 auto;
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.8rem;
    line-height: 1.7;
  }
  .footer-disclaimer p { margin-bottom: 0.6rem; }
  .footer-disclaimer strong { color: #ffb347; }
  .footer-disclaimer a {
    color: #ffd966;
    text-decoration: underline;
    font-weight: 700;
  }

  .trust-badge {
    max-width: 1300px;
    margin: 1rem auto 0;
    padding: 0.9rem 1.2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    background: linear-gradient(135deg, rgba(57,255,20,0.08), rgba(255,16,240,0.06));
    border: 1px solid rgba(57,255,20,0.35);
    border-radius: 12px;
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.25s;
  }
  .trust-badge:hover {
    border-color: #39FF14;
    box-shadow: 0 6px 20px rgba(57,255,20,0.18);
    transform: translateY(-1px);
  }
  .trust-badge .tb-shield {
    width: 40px; height: 40px; flex: 0 0 40px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(57,255,20,0.15);
    border: 1px solid rgba(57,255,20,0.5);
    border-radius: 50%;
    color: #39FF14;
  }
  .trust-badge .tb-text { flex: 1; display: flex; flex-direction: column; gap: 0.15rem; line-height: 1.4; }
  .trust-badge .tb-text strong {
    color: #39FF14;
    font-size: 0.95rem;
    letter-spacing: 0.5px;
  }
  .trust-badge .tb-text small { color: var(--text-muted); font-size: 0.8rem; }
  .trust-badge .tb-arrow {
    color: var(--gold-light);
    font-weight: 800;
    font-size: 0.85rem;
    white-space: nowrap;
  }

  .footer-bottom {
    max-width: 1300px;
    margin: 0 auto;
    text-align: center;
    padding: 1.5rem 0 1rem;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .footer .logo-footer {
    margin-bottom: 0.5rem;
  }

  .footer .footer-logo-img {
    height: 100px;
    width: auto;
    filter: drop-shadow(0 0 6px rgba(57, 255, 20, 0.25));
  }

  .social-links {
    display: flex;
    gap: 0.8rem;
    margin-top: 1rem;
  }

  .social-links a,
  .social-links button {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    transition: all 0.3s;
    text-decoration: none;
    padding: 0;
    cursor: pointer;
    font-size: 1rem;
  }

  .social-links a:hover,
  .social-links button:hover {
    background: var(--gold);
    color: #000000;
    border-color: var(--gold);
  }

  /* === RESPONSIVE === */
  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .trust-badge { flex-wrap: wrap; padding: 0.9rem 1rem; }
    .trust-badge .tb-arrow { width: 100%; text-align: right; }

    .footer {
      padding-bottom: 2.5rem;
    }

    .footer-bottom {
      padding-bottom: 1.5rem;
    }
  }
</style>
