          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 5.83 2 10.5c0 4.14 3.67 7.61 8.62 8.37.34.07.8.22.91.5.1.26.07.66.03.92l-.15.88c-.04.26-.2 1.01.88.55s5.87-3.46 8.01-5.92C22.16 13.73 22 12.18 22 10.5 22 5.83 17.52 2 12 2zm-3.5 11.5h-2a.75.75 0 01-.75-.75v-4a.75.75 0 011.5 0v3.25H8.5a.75.75 0 010 1.5zm2.5-.75a.75.75 0 01-1.5 0v-4a.75.75 0 011.5 0v4zm4.5 0a.75.75 0 01-.6.74.75.75 0 01-.65-.3L12.5 10.9v1.85a.75.75 0 01-1.5 0v-4a.75.75 0 01.6-.74.75.75 0 01.65.3l1.75 2.28V8.75a.75.75 0 011.5 0v4zm3-3.25a.75.75 0 010 1.5H17v1h1.5a.75.75 0 010 1.5h-2a.75.75 0 01-.75-.75v-4a.75.75 0 01.75-.75h2a.75.75 0 010 1.5H17v1h1.5z"/></svg>
