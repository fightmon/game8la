---
import Icon from './Icon.astro';

interface Props {
  currentPage?: string;
}

const { currentPage = 'home' } = Astro.props;
---

<nav class="navbar">
  <div class="logo">
    <a href="/">
      <img src="/images/index/game8la_logo_21x9.webp" alt="GAME8LA Logo" class="logo-img" width="120" height="51" loading="eager" fetchpriority="high">
    </a>
  </div>
  <div class="nav-links">
    <a href="/" class={currentPage === 'home' ? 'active' : ''}>首頁</a>
    <a href="/atg-seth/" class={currentPage === 'atg-seth' ? 'active' : ''}>金8LA賽特</a>
    <a href="/articles/" class={currentPage === 'articles' ? 'active' : ''}>芭樂攻略</a>
    <a href="/game-ranking/" class={currentPage === 'rankings' ? 'active' : ''}>芭樂遊戲</a>
    <div class="nav-dropdown">
      <a href="/lottery/" class={currentPage === 'lottery' ? 'active' : ''}>芭樂好彩 <span class="dd-arrow">▾</span></a>
      <div class="nav-dropdown-menu">
        <div class="nav-dropdown-menu-inner">
          <a href="/lottery/">🎱 最新開獎</a>
          <a href="/lottery/analysis/">🔢 樂透數據站</a>
        </div>
      </div>
    </div>
    <div class="nav-dropdown">
      <a href="/tools/" class={currentPage === 'tools' || currentPage === 'casino-check' ? 'active' : ''} style="color:#f5b800">🔧 8LA 工具箱 <span class="dd-arrow">▾</span></a>
      <div class="nav-dropdown-menu">
        <div class="nav-dropdown-menu-inner">
          <a href="/tools/bankroll-calculator/">🧮 資金管理計算器</a>
          <a href="/tools/rtp-tracker/">🎰 老虎機 RTP 紀錄器</a>
          <a href="/tools/slot-simulator/">🎲 芭樂轉轉機</a>
          <a href="/lottery/analysis/">🔢 樂透數據站</a>
          <a href="/casino-check/">🛡️ 娛樂城體檢</a>
        </div>
      </div>
    </div>
  </div>
  <div class="nav-search" role="button" tabindex="0" aria-label="搜尋遊戲、攻略、遊戲平台" onclick="openSearch()" onkeydown="if(event.key==='Enter'||event.key===' ')openSearch()">
    <Icon name="search" />
    <span class="nav-search-text">搜尋遊戲...</span>
  </div>
  <div class="mobile-actions">
    <button type="button" class="icon-btn" aria-label="開啟搜尋" onclick="openSearch()">
      <Icon name="search" />
    </button>
    <button type="button" class="icon-btn" id="menuToggle" aria-label="開啟選單" aria-expanded="false" onclick="toggleMenu()">
      <Icon name="menu" />
    </button>
  </div>
</nav>

<!-- MOBILE MENU PANEL -->
<div class="mobile-menu" id="mobileMenu" onclick="closeMenu(event)">
  <div class="mobile-menu-inner">
    <a href="/" class={currentPage === 'home' ? 'active' : ''}>🏠 首頁</a>
    <a href="/atg-seth/" class={currentPage === 'atg-seth' ? 'active' : ''}>⚡ 金8LA賽特</a>
    <a href="/articles/" class={currentPage === 'articles' ? 'active' : ''}>📖 芭樂攻略</a>
    <a href="/game-ranking/" class={currentPage === 'rankings' ? 'active' : ''}>🎰 芭樂遊戲</a>
    <a href="/lottery/" class={currentPage === 'lottery' ? 'active' : ''}>🎱 芭樂好彩</a>
    <a href="/lottery/analysis/" class="mobile-sub-link" style="padding-left:2.5rem;font-size:0.9rem;color:var(--text-muted)">🔢 樂透數據站</a>
    <a href="/tools/" class={currentPage === 'tools' ? 'active' : ''} style="color:#f5b800;font-weight:700">🔧 8LA 工具箱</a>
    <a href="/tools/bankroll-calculator/" class="mobile-sub-link" style="padding-left:2.5rem;font-size:0.9rem;color:var(--text-muted)">🧮 資金管理計算器</a>
    <a href="/tools/rtp-tracker/" class="mobile-sub-link" style="padding-left:2.5rem;font-size:0.9rem;color:var(--text-muted)">🎰 老虎機 RTP 紀錄器</a>
    <a href="/tools/slot-simulator/" class="mobile-sub-link" style="padding-left:2.5rem;font-size:0.9rem;color:var(--text-muted)">🎲 芭樂轉轉機</a>
    <a href="/lottery/analysis/" class="mobile-sub-link" style="padding-left:2.5rem;font-size:0.9rem;color:var(--text-muted)">🔢 樂透數據站</a>
    <a href="/casino-check/" class="mobile-sub-link" style="padding-left:2.5rem;font-size:0.9rem;color:var(--text-muted)">🛡️ 娛樂城體檢</a>
  </div>
</div>

<!-- SEARCH MODAL -->
<div class="search-modal" id="searchModal" onclick="closeSearch(event)">
  <div class="search-box">
    <input type="text" id="searchInput" placeholder="搜尋遊戲、攻略、遊戲平台..." aria-label="搜尋輸入框" oninput="handleSearch(this.value)">
    <div class="search-results" id="searchResults"></div>
  </div>
</div>

<style>
  /* === NAVBAR === */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(18, 18, 18, 0.95);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .navbar .logo {
    cursor: pointer;
    display: flex;
    align-items: center;
  }

  .navbar .logo a {
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .navbar .logo-img {
    height: 45px;
    width: auto;
    filter: drop-shadow(0 0 8px rgba(57, 255, 20, 0.3));
    transition: filter 0.3s;
  }

  .navbar .logo:hover .logo-img {
    filter: drop-shadow(0 0 14px rgba(57, 255, 20, 0.5));
  }

  .nav-links {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .nav-links a {
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-size: 0.95rem;
    transition: all 0.3s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--gold-light);
    background: rgba(57, 255, 20, 0.1);
    text-decoration: none;
  }

  .nav-search {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    padding: 0.7rem 1rem;
    min-height: 44px;
    border-radius: 25px;
    cursor: pointer;
  }

  .nav-search-text {
    color: var(--text-muted);
    width: 150px;
    font-size: 0.9rem;
    font-family: inherit;
    pointer-events: none;
    user-select: none;
  }

  .nav-search i {
    color: var(--text-muted);
  }

  /* Mobile actions (search + hamburger) - hidden on desktop */
  .mobile-actions {
    display: none;
    gap: 0.5rem;
    align-items: center;
  }
  .icon-btn {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #e5e5ea;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
  }
  .icon-btn svg {
    width: 20px;
    height: 20px;
  }
  .icon-btn:hover,
  .icon-btn:focus-visible {
    background: rgba(245, 184, 0, 0.15);
    border-color: var(--gold);
    color: var(--gold-light);
  }

  /* Mobile menu panel */
  .mobile-menu {
    display: none;
    position: fixed;
    top: 70px;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 999;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(8px);
  }
  .mobile-menu.open {
    display: block;
  }
  .mobile-menu-inner {
    background: rgba(18, 18, 18, 0.98);
    border-bottom: 1px solid var(--border);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .mobile-menu-inner a {
    color: var(--text-primary);
    text-decoration: none;
    padding: 0.9rem 1rem;
    border-radius: 10px;
    font-size: 1rem;
    border: 1px solid transparent;
  }
  .mobile-menu-inner a:hover,
  .mobile-menu-inner a.active {
    background: rgba(57, 255, 20, 0.1);
    border-color: rgba(57, 255, 20, 0.3);
    color: var(--gold-light);
  }

  /* === SEARCH MODAL === */
  .search-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 2000;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(10px);
    align-items: flex-start;
    justify-content: center;
    padding-top: 15vh;
  }

  .search-modal.open {
    display: flex;
  }

  .search-box {
    width: 90%;
    max-width: 600px;
    background: var(--bg-card);
    border-radius: 16px;
    border: 1px solid var(--gold);
    overflow: hidden;
    box-shadow: 0 0 40px var(--gold-glow);
  }

  .search-box input {
    width: 100%;
    padding: 1.2rem 1.5rem;
    background: none;
    border: none;
    color: var(--text-primary);
    font-size: 1.2rem;
    outline: none;
    font-family: inherit;
  }

  .search-results {
    border-top: 1px solid var(--border);
    max-height: 400px;
    overflow-y: auto;
  }

  /* === NAV DROPDOWN === */
  .nav-dropdown {
    position: relative;
  }
  .nav-dropdown > a {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .dd-arrow {
    font-size: 0.7rem;
    transition: transform 0.2s;
  }
  .nav-dropdown:hover .dd-arrow {
    transform: rotate(180deg);
  }
  .nav-dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    padding-top: 0.5rem; /* invisible bridge so hover doesn't break */
    z-index: 1001;
  }
  .nav-dropdown-menu-inner {
    background: rgba(30, 30, 30, 0.98);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.4rem;
    min-width: 180px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.5);
    display: flex;
    flex-direction: column;
  }
  .nav-dropdown:hover .nav-dropdown-menu {
    display: block;
  }
  .nav-dropdown-menu a {
    padding: 0.6rem 0.8rem !important;
    border-radius: 8px;
    font-size: 0.9rem;
    white-space: nowrap;
    color: var(--text-secondary);
    text-decoration: none;
    transition: all 0.2s;
    display: block;
  }
  .nav-dropdown-menu a:hover {
    background: rgba(57, 255, 20, 0.1);
    color: var(--gold-light);
  }

  /* === RESPONSIVE === */
  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }

    .navbar {
      padding: 0 1rem;
    }

    .nav-search {
      display: none;
    }
    .mobile-actions {
      display: flex;
    }
  }
</style>

<script is:inline>
  function openSearch() {
    const modal = document.getElementById('searchModal');
    if (modal) {
      modal.classList.add('open');
      const input = document.getElementById('searchInput');
      if (input) input.focus();
    }
  }

  function closeSearch(event) {
    if (event && event.target.id !== 'searchModal') return;
    const modal = document.getElementById('searchModal');
    if (modal) modal.classList.remove('open');
  }

  function toggleMenu() {
    const menu = document.getElementById('mobileMenu');
    const btn = document.getElementById('menuToggle');
    if (!menu) return;
    const opened = menu.classList.toggle('open');
    if (btn) {
      btn.setAttribute('aria-expanded', opened ? 'true' : 'false');
      btn.setAttribute('aria-label', opened ? '關閉選單' : '開啟選單');
    }
  }

  function closeMenu(event) {
    const menu = document.getElementById('mobileMenu');
    if (!menu) return;
    // Close when clicking backdrop or a link
    if (event.target === menu || event.target.tagName === 'A') {
      menu.classList.remove('open');
      const btn = document.getElementById('menuToggle');
      if (btn) {
        btn.setAttribute('aria-expanded', 'false');
        btn.setAttribute('aria-label', '開啟選單');
      }
    }
  }

  const SEARCH_INDEX = [
    { t: '戰神賽特2：覺醒之力', d: 'ATG電子老虎機 RTP 96.89%', u: '/games/seth-2/', c: '遊戲' },
    { t: '奇幻魔藥', d: 'RG電子蜂巢消除老虎機 RTP 98.28%', u: '/games/fantasy-potion/', c: '遊戲' },
    { t: '2026 老虎機評分總排名', d: '9款熱門Slot完整評比', u: '/game-ranking/', c: '排行' },
    { t: '芭樂攻略', d: '老虎機、百家樂、真人娛樂教學', u: '/articles/', c: '攻略' },
    { t: '老虎機攻略完整指南', d: 'RTP、波動性、Free Game、爆分機制', u: '/articles/slots-guide/', c: '攻略' },
    { t: '百家樂完整教學', d: '規則、算牌、投注法、常見迷思', u: '/articles/baccarat-guide/', c: '攻略' },
    { t: '真人荷官大評比', d: '2026 各平台最美荷官盤點', u: '/articles/dealers-guide/', c: '攻略' },
    { t: '芭樂好彩', d: '大樂透、威力彩、今彩539 開獎', u: '/lottery/', c: '彩券' },
    { t: '樂透數據站', d: '威力彩・大樂透・539 冷熱號回測、選號參考、包牌產生器', u: '/lottery/analysis/', c: '彩券' },
    { t: '富遊娛樂城', d: '台灣老牌娛樂城評測', u: '/casinos/fuyou/', c: '娛樂城' },
    { t: 'MaiSpin 娛樂城', d: '完整平台評測', u: '/casinos/maispin/', c: '娛樂城' },
    { t: 'bet365', d: '國際大廠評測', u: '/casinos/bet365/', c: '娛樂城' },
    { t: 'Shuffle', d: '加密貨幣娛樂城', u: '/casinos/shuffle/', c: '娛樂城' },
    { t: 'K8 娛樂城', d: '平台評測', u: '/casinos/k8/', c: '娛樂城' },
    { t: 'U-Town 優創', d: '平台評測', u: '/casinos/utown/', c: '娛樂城' },
    { t: 'YABO 亞博', d: '平台評測', u: '/casinos/yabo/', c: '娛樂城' },
    { t: 'PM 娛樂城', d: '平台評測', u: '/casinos/pm/', c: '娛樂城' },
    { t: '8LA 工具箱', d: '老虎機 RTP 紀錄器、樂透數據站、娛樂城體檢', u: '/tools/', c: '工具' },
    { t: '老虎機 RTP 實測紀錄器', d: '記錄投入回收，算出實測 RTP，比對官方理論值', u: '/tools/rtp-tracker/', c: '工具' },
    { t: '老虎機資金管理計算器', d: '算出你的錢能撐多久，設好停損停利再上桌', u: '/tools/bankroll-calculator/', c: '工具' },
    { t: '芭樂轉轉機', d: '自己設定 RTP 和波動度，體驗老虎機的數學真相', u: '/tools/slot-simulator/', c: '工具' },
    { t: '娛樂城體檢', d: 'WHOIS查網域、流水計算器、165反詐騙快查', u: '/casino-check/', c: '工具' },
    { t: '娛樂城出金攻略', d: '5大卡關原因與自救SOP、流水、KYC、風控、黑網', u: '/articles/casino-payout-guide/', c: '攻略' },
    { t: '5招識破娛樂城詐騙套路', d: 'WHOIS、流水陷阱、支付安全完整拆解', u: '/articles/5-tips-spot-casino-scam/', c: '攻略' },
    { t: '連娛樂城都怕的黑名單', d: '5大導流站交叉比對地雷名單', u: '/articles/casino-not-recommended-by-casinos/', c: '攻略' },
    { t: '第一次玩娛樂城 10 個新手必知', d: '現金版信用版、流水陷阱、KYC、代操詐騙', u: '/articles/casino-beginner-guide/', c: '攻略' },
  ];

  function handleSearch(value) {
    const results = document.getElementById('searchResults');
    if (!results) return;
    const q = value.trim().toLowerCase();
    if (!q) { results.innerHTML = ''; return; }
    const hits = SEARCH_INDEX.filter(i =>
      i.t.toLowerCase().includes(q) || i.d.toLowerCase().includes(q) || i.c.toLowerCase().includes(q)
    ).slice(0, 10);
    if (hits.length === 0) {
      results.innerHTML = '<div style="padding:1rem;color:var(--text-muted)">找不到相關結果</div>';
      return;
    }
    results.innerHTML = hits.map(i => `
      <a href="${i.u}" style="display:block;padding:0.9rem 1rem;border-bottom:1px solid var(--border);text-decoration:none;color:var(--text-primary)">
        <div style="display:flex;justify-content:space-between;align-items:center;gap:0.8rem">
          <div>
            <div style="font-weight:600;margin-bottom:0.2rem">${i.t}</div>
            <div style="font-size:0.82rem;color:var(--text-muted)">${i.d}</div>
          </div>
          <span style="font-size:0.7rem;padding:0.15rem 0.6rem;background:rgba(57,255,20,0.15);color:var(--gold-light);border-radius:10px;white-space:nowrap">${i.c}</span>
        </div>
      </a>
    `).join('');
  }

  // Close search on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch(null);
  });
</script>
