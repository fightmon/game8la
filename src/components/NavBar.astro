<!-- SEARCH MODAL -->
<div class="search-modal" id="searchModal" onclick="closeSearch(event)">
  <div class="search-box">
    <input type="text" id="searchInput" placeholder="搜尋遊戲、攻略、遊戲平台..." aria-label="搜尋輸入框" oninput="handleSearch(this.value)">
    <div class="search-results" id="searchResults"></div>
  </div>
</div>

<style>
  /* === NAVBAR === */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(18, 18, 18, 0.95);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .navbar .logo {
    cursor: pointer;
    display: flex;
    align-items: center;
  }

  .navbar .logo a {
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .navbar .logo-img {
    height: 45px;
    width: auto;
    filter: drop-shadow(0 0 8px rgba(57, 255, 20, 0.3));
    transition: filter 0.3s;
  }

  .navbar .logo:hover .logo-img {
    filter: drop-shadow(0 0 14px rgba(57, 255, 20, 0.5));
  }

  .nav-links {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .nav-links a {
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-size: 0.95rem;
    transition: all 0.3s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--gold-light);
    background: rgba(57, 255, 20, 0.1);
    text-decoration: none;
  }

  .nav-search {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    padding: 0.7rem 1rem;
    min-height: 44px;
    border-radius: 25px;
    cursor: pointer;
  }

  .nav-search-text {
    color: var(--text-muted);
    width: 150px;
    font-size: 0.9rem;
    font-family: inherit;
    pointer-events: none;
    user-select: none;
  }

  .nav-search i {
    color: var(--text-muted);
  }

  /* === 會員入口（桌機膠囊鈕） === */
  .nav-member {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    background: linear-gradient(135deg, rgba(245,184,0,0.2), rgba(245,184,0,0.08));
    border: 1px solid var(--gold);
    color: var(--gold-light);
    padding: 0 1rem;
    min-height: 44px;
    border-radius: 25px;
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.2s;
    margin-left: 0.5rem;
  }
  .nav-member:hover {
    background: rgba(245,184,0,0.3);
    box-shadow: 0 0 14px var(--gold-glow);
    color: var(--gold-light);
    text-decoration: none;
  }
  .nav-member.logged-in {
    border-color: #39ff14;
    color: #aaffaa;
    background: linear-gradient(135deg, rgba(57,255,20,0.18), rgba(57,255,20,0.06));
  }
  .icon-btn-member {
    text-decoration: none;
    font-size: 1.2rem;
  }
  .icon-btn-member:hover { text-decoration: none; }
  .mobile-member {
    background: linear-gradient(135deg, rgba(245,184,0,0.2), rgba(245,184,0,0.06)) !important;
    border: 1px solid var(--gold) !important;
    color: var(--gold-light) !important;
    font-weight: 700;
  }

  /* Mobile actions (search + hamburger) - hidden on desktop */
  .mobile-actions {
    display: none;
    gap: 0.5rem;
    align-items: center;
  }
  .icon-btn {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #e5e5ea;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
  }
  .icon-btn svg {
    width: 20px;
    height: 20px;
  }
  .icon-btn:hover,
  .icon-btn:focus-visible {
    background: rgba(245, 184, 0, 0.15);
    border-color: var(--gold);
    color: var(--gold-light);
  }

  /* Mobile menu panel */
  .mobile-menu {
    display: none;
    position: fixed;
    top: 70px;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 999;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(8px);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
  }
  .mobile-menu.open {
    display: block;
  }
  .mobile-menu-inner {
    background: rgba(18, 18, 18, 0.98);
    border-bottom: 1px solid var(--border);
    padding: 1rem 1rem 3rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-height: min-content;
  }
  .mobile-menu-inner a {
    color: var(--text-primary);
    text-decoration: none;
    padding: 0.9rem 1rem;
    border-radius: 10px;
    font-size: 1rem;
    border: 1px solid transparent;
  }
  .mobile-menu-inner a:hover,
  .mobile-menu-inner a.active {
    background: rgba(57, 255, 20, 0.1);
    border-color: rgba(57, 255, 20, 0.3);
    color: var(--gold-light);
  }

  /* === 手機選單手風琴（8LA 工具箱 展開／收合） === */
  .m-acc { display: flex; flex-direction: column; }
  .m-acc-head {
    list-style: none;
    cursor: pointer;
    color: #f5b800;
    font-weight: 700;
    font-size: 1rem;
    padding: 0.9rem 1rem;
    border-radius: 10px;
    border: 1px solid transparent;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .m-acc-head::-webkit-details-marker { display: none; }
  .m-acc-head:hover { background: rgba(245, 184, 0, 0.08); }
  .m-acc-chev { color: var(--text-muted); transition: transform 0.25s; font-size: 0.85rem; }
  .m-acc[open] .m-acc-chev { transform: rotate(180deg); }
  .m-acc-body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.2rem 0 0.4rem;
  }
  .mobile-menu-inner .m-acc-body a {
    padding: 0.7rem 1rem 0.7rem 2.5rem;
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 400;
  }
  .mobile-menu-inner .m-acc-body a:hover,
  .mobile-menu-inner .m-acc-body a.active {
    color: var(--gold-light);
  }
  .m-cat {
    padding-left: 2.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin: 0.5rem 0 0.1rem;
  }

  /* === SEARCH MODAL === */
  .search-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 2000;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(10px);
    align-items: flex-start;
    justify-content: center;
    padding-top: 15vh;
  }

  .search-modal.open {
    display: flex;
  }

  .search-box {
    width: 90%;
    max-width: 600px;
    background: var(--bg-card);
    border-radius: 16px;
    border: 1px solid var(--gold);
    overflow: hidden;
    box-shadow: 0 0 40px var(--gold-glow);
  }

  .search-box input {
    width: 100%;
    padding: 1.2rem 1.5rem;
    background: none;
    border: none;
    color: var(--text-primary);
    font-size: 1.2rem;
    outline: none;
    font-family: inherit;
  }

  .search-results {
    border-top: 1px solid var(--border);
    max-height: 400px;
    overflow-y: auto;
  }

  /* === NAV DROPDOWN === */
  .nav-dropdown {
    position: relative;
  }
  .nav-dropdown > a {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .dd-arrow {
    font-size: 0.7rem;
    transition: transform 0.2s;
  }
  .nav-dropdown:hover .dd-arrow {
    transform: rotate(180deg);
  }
  .nav-dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    padding-top: 0.5rem; /* invisible bridge so hover doesn't break */
    z-index: 1001;
  }
  .nav-dropdown-menu-inner {
    background: rgba(30, 30, 30, 0.98);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.4rem;
    min-width: 180px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.5);
    display: flex;
    flex-direction: column;
  }
  /* 工具箱：分類 2 欄流式排版，避免下拉過長（桌機 ≥768px 才顯示，寬度安全） */
  .nav-tools-menu {
    display: block;
    column-count: 2;
    column-gap: 0.8rem;
    min-width: 470px;
  }
  .nav-tools-menu .dd-group {
    break-inside: avoid;
    -webkit-column-break-inside: avoid;
    page-break-inside: avoid;
    display: flex;
    flex-direction: column;
  }
  .nav-tools-menu .dropdown-group-label {
    margin-top: 0.5rem;
  }
  .nav-tools-menu .dd-group:first-child .dropdown-group-label {
    margin-top: 0;
  }
  .nav-dropdown:hover .nav-dropdown-menu {
    display: block;
  }
  .dropdown-group-label {
    padding: 0.5rem 0.8rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-top: 0.4rem;
  }
  .dropdown-group-label:first-child {
    margin-top: 0;
  }
  .nav-dropdown-menu a {
    padding: 0.6rem 0.8rem !important;
    border-radius: 8px;
    font-size: 0.9rem;
    white-space: nowrap;
    color: var(--text-secondary);
    text-decoration: none;
    transition: all 0.2s;
    display: block;
  }
  .nav-dropdown-menu a:hover {
    background: rgba(57, 255, 20, 0.1);
    color: var(--gold-light);
  }

  /* === RESPONSIVE === */
  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }

    .navbar {
      padding: 0 1rem;
    }

    .nav-search {
      display: none;
    }
    .nav-member {
      display: none;
    }
    .mobile-actions {
      display: flex;
    }
  }
</style>

<script define:vars={{ searchIndex }}>
  window.__SEARCH_INDEX = JSON.parse(searchIndex);
</script>

<script is:inline>
  function openSearch() {
    const modal = document.getElementById('searchModal');
    if (modal) {
      modal.classList.add('open');
      const input = document.getElementById('searchInput');
      if (input) input.focus();
    }
  }

  function closeSearch(event) {
    if (event && event.target.id !== 'searchModal') return;
    const modal = document.getElementById('searchModal');
    if (modal) modal.classList.remove('open');
  }

  function toggleMenu() {
    const menu = document.getElementById('mobileMenu');
    const btn = document.getElementById('menuToggle');
    if (!menu) return;
    const opened = menu.classList.toggle('open');
    document.body.style.overflow = opened ? 'hidden' : '';
    if (btn) {
      btn.setAttribute('aria-expanded', opened ? 'true' : 'false');
      btn.setAttribute('aria-label', opened ? '關閉選單' : '開啟選單');
    }
  }

  function closeMenu(event) {
    const menu = document.getElementById('mobileMenu');
    if (!menu) return;
    // Close when clicking backdrop or a link
    if (event.target === menu || event.target.tagName === 'A') {
      menu.classList.remove('open');
      document.body.style.overflow = '';
      const btn = document.getElementById('menuToggle');
      if (btn) {
        btn.setAttribute('aria-expanded', 'false');
        btn.setAttribute('aria-label', '開啟選單');
      }
    }
  }

  const SEARCH_INDEX = window.__SEARCH_INDEX || [];

  function handleSearch(value) {
    const results = document.getElementById('searchResults');
    if (!results) return;
    const q = value.trim().toLowerCase();
    if (!q) { results.innerHTML = ''; return; }
    const hits = SEARCH_INDEX.filter(i =>
      i.t.toLowerCase().includes(q) || i.d.toLowerCase().includes(q) || i.c.toLowerCase().includes(q)
    ).slice(0, 10);
    if (hits.length === 0) {
      results.innerHTML = '<div style="padding:1rem;color:var(--text-muted)">找不到相關結果</div>';
      return;
    }
    results.innerHTML = hits.map(i => `
      <a href="${i.u}" style="display:block;padding:0.9rem 1rem;border-bottom:1px solid var(--border);text-decoration:none;color:var(--text-primary)">
        <div style="display:flex;justify-content:space-between;align-items:center;gap:0.8rem">
          <div>
            <div style="font-weight:600;margin-bottom:0.2rem">${i.t}</div>
            <div style="font-size:0.82rem;color:var(--text-muted)">${i.d}</div>
          </div>
          <span style="font-size:0.7rem;padding:0.15rem 0.6rem;background:rgba(57,255,20,0.15);color:var(--gold-light);border-radius:10px;white-space:nowrap">${i.c}</span>
        </div>
      </a>
    `).join('');
  }

  // Close search on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch(null);
  });

  // 會員入口：登入後顯示點數（閒置時再抓，不擋首屏）
  (function () {
    function paintMember(m) {
      if (!m) return;
      var pts = (m.points || 0).toLocaleString();
      var lbl = document.getElementById('navMemberLabel');
      var btn = document.getElementById('navMember');
      if (lbl) lbl.textContent = pts;
      if (btn) { btn.classList.add('logged-in'); btn.setAttribute('aria-label', '會員中心 · ' + pts + ' 點'); btn.title = (m.nickname || '會員') + '｜' + pts + ' 點'; }
      var mob = document.getElementById('navMemberMobileMenu');
      if (mob) mob.textContent = '🪙 ' + (m.nickname || '會員') + '｜' + pts + ' 點';
    }
    function check() {
      fetch('/api/me', { cache: 'no-store' })
        .then(function (r) { return r.json(); })
        .then(function (j) { if (j && j.member) paintMember(j.member); })
        .catch(function () {});
    }
    if ('requestIdleCallback' in window) requestIdleCallback(check, { timeout: 3000 });
    else setTimeout(check, 1200);
  })();
</script>
