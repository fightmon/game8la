---
import Icon from './Icon.astro';
import { articles } from '../data/articles.js';

interface Props {
  currentPage?: string;
}

const { currentPage = 'home' } = Astro.props;

// 靜態頁面（非文章）搜尋索引
const staticSearchItems = [
  { t: '戰神賽特2：覺醒之力', d: 'ATG電子老虎機 RTP 96.89%', u: '/games/seth-2/', c: '遊戲' },
  { t: '奇幻魔藥', d: 'RG電子蜂巢消除老虎機 RTP 98.28%', u: '/games/fantasy-potion/', c: '遊戲' },
  { t: '2026 老虎機評分總排名', d: '9款熱門Slot完整評比', u: '/game-ranking/', c: '排行' },
  { t: '芭樂攻略', d: '老虎機、百家樂、真人娛樂教學', u: '/articles/', c: '攻略' },
  { t: '世足8LA專區', d: '2026 世界盃賽程、轉播、規則、冠軍預測一站看', u: '/worldcup/', c: '世足' },
  { t: '芭樂好彩', d: '大樂透、威力彩、今彩539 開獎', u: '/lottery/', c: '彩券' },
  { t: '樂透數據站', d: '威力彩・大樂透・539 冷熱號回測、選號參考、包牌產生器', u: '/lottery/analysis/', c: '彩券' },
  { t: '富遊娛樂城', d: '台灣老牌娛樂城評測', u: '/casinos/fuyou/', c: '娛樂城' },
  { t: 'MaiSpin 娛樂城', d: '完整平台評測', u: '/casinos/maispin/', c: '娛樂城' },
  { t: 'bet365', d: '國際大廠評測', u: '/casinos/bet365/', c: '娛樂城' },
  { t: 'Shuffle', d: '加密貨幣娛樂城', u: '/casinos/shuffle/', c: '娛樂城' },
  { t: 'K8 娛樂城', d: '平台評測', u: '/casinos/k8/', c: '娛樂城' },
  { t: 'U-Town 優創', d: '平台評測', u: '/casinos/utown/', c: '娛樂城' },
  { t: 'YABO 亞博', d: '平台評測', u: '/casinos/yabo/', c: '娛樂城' },
  { t: 'PM 娛樂城', d: '平台評測', u: '/casinos/pm/', c: '娛樂城' },
  { t: '8LA 工具箱', d: '老虎機 RTP 紀錄器、樂透數據站、娛樂城體檢', u: '/tools/', c: '工具' },
  { t: '老虎機 RTP 紀錄器', d: '記錄投入回收，算出你的 RTP，比對官方理論值', u: '/tools/rtp-tracker/', c: '工具' },
  { t: '老虎機資金管理計算器', d: '算出你的錢能撐多久，設好停損停利再上桌', u: '/tools/bankroll-calculator/', c: '工具' },
  { t: '8LA 老虎機 RTP 測試器', d: '自己設定 RTP 和波動度，體驗老虎機的數學真相', u: '/tools/slot-simulator/', c: '工具' },
  { t: '百家樂策略模擬器', d: '五種下注策略模擬，1000局跑給你看，看清莊家優勢', u: '/tools/baccarat-simulator/', c: '工具' },
  { t: '百家樂看路模擬器', d: '即時記錄＋練習看路，大路、大眼仔、小路、蟑螂路四條路', u: '/tools/baccarat-roadmap/', c: '工具' },
  { t: 'Game8la 線上擲筊', d: '線上擲筊求籤，問神明也問機率，芭樂子吐槽加料', u: '/tools/bless-blocks/', c: '工具' },
  { t: '娛樂城體檢', d: 'WHOIS查網域、流水計算器、165反詐騙快查', u: '/casino-check/', c: '工具' },
  { t: 'PGSI 賭博成癮自我檢測', d: '國際 PGSI 量表 9 題快速評估博弈習慣是否健康', u: '/tools/gambling-self-check/', c: '工具' },
  { t: '539 包牌計算器', d: '選碼數秒算注數花費中獎機率，支援預算反推與期望值模擬', u: '/tools/539-wheel-calculator/', c: '工具' },
  { t: '威力彩包牌計算器', d: '第一區＋第二區包牌注數費用秒算，冷熱號推薦＋模擬', u: '/tools/power-lottery-calculator/', c: '工具' },
  { t: '大樂透包牌計算器', d: '大樂透 6/49 包牌（連碰）注數費用中獎率秒算，含特別號期望值模擬與冷熱號推薦', u: '/tools/lotto649-wheel-calculator/', c: '工具' },
  { t: '統一發票對獎工具', d: '填中獎號碼、貼上發票一鍵對獎，算總獎金＋獎項金額對照，純前端不收個資', u: '/tools/invoice-checker/', c: '工具' },
  { t: 'AI 21 點', d: '免費練牌＋基本策略即時教學，每手牌都有 AI 建議', u: '/tools/blackjack/', c: '工具' },
  { t: '2026 世足冠軍預測', d: '48 隊你猜誰奪冠？即時投票統計', u: '/tools/worldcup-2026/', c: '工具' },
  { t: '麻將碰吃槓練習器', d: '碰吃槓搞不清楚？互動判斷練習器一題一張教，上家才能吃、字牌只能碰，麻將新手規則入門', u: '/tools/mahjong-rules-trainer/', c: '工具' },
  { t: '麻將聽牌練習器', d: '差一張就胡了，你看得出聽什麼牌嗎？兩面嵌張邊張單吊雙碰五種聽牌型互動練習', u: '/tools/mahjong-tenpai-trainer/', c: '工具' },
  { t: '麻將算台練習器', d: '看牌猜台數，門清自摸碰碰胡清一色大三元，台灣16張算台教學', u: '/tools/mahjong-suan-tai-trainer/', c: '工具' },
];

// 從 articles.js 自動生成文章搜尋索引
const articleSearchItems = articles.map(a => ({
  t: a.title,
  d: a.excerpt.substring(0, 80),
  u: a.href || `/articles/${a.slug}/`,
  c: a.categoryLabel
}));

const searchIndex = JSON.stringify([...staticSearchItems, ...articleSearchItems]);
---

