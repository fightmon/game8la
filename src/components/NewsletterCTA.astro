---
// ============================================================================
// NewsletterCTA — Benchmark Email 訂閱表單元件
// ----------------------------------------------------------------------------
// 用法：
//   <NewsletterCTA variant="article" />  ← 文章末尾用
//   <NewsletterCTA variant="author" />   ← About 頁用
//   <NewsletterCTA variant="tool" />     ← 工具頁用（未來）
// ============================================================================

interface Props {
  variant?: 'article' | 'author' | 'tool';
}

const { variant = 'article' } = Astro.props;
---

{variant === 'article' && (
  <aside class="newsletter-cta newsletter-article">
    <h3 class="newsletter-cta-title">看完這篇了？訂閱芭樂子週報</h3>
    <p class="newsletter-cta-desc">每週一封博弈觀察 + 防詐快報，鐵粉先看。</p>
    <ul class="newsletter-perks">
      <li>未來電子書 8 折優惠碼</li>
      <li>每月會員限定數據報告</li>
      <li>防詐警報搶先收到</li>
    </ul>
    <div data-bme-form-id="WOZykcfC7_M7Dzy1vRYjr"></div>
    <p class="newsletter-cta-note">隨時可取消訂閱，我們不轉售名單</p>
  </aside>
)}

{variant === 'author' && (
  <section class="newsletter-cta newsletter-author">
    <h3 class="newsletter-cta-title">跟芭樂子保持聯絡</h3>
    <p class="newsletter-cta-desc">訂閱電子報，每週一封我親寫的博弈觀察。</p>
    <div data-bme-form-id="WOZykcfC7_M7Dzy1vRYjr"></div>
    <p class="newsletter-cta-note">隨時可取消訂閱</p>
  </section>
)}

{variant === 'tool' && (
  <aside class="newsletter-cta newsletter-tool">
    <h3 class="newsletter-cta-title">喜歡這個工具？</h3>
    <p class="newsletter-cta-desc">訂閱電子報，送限量試算模板 + 進階教學</p>
    <div data-bme-form-id="WOZykcfC7_M7Dzy1vRYjr"></div>
    <p class="newsletter-cta-note">隨時可取消訂閱</p>
  </aside>
)}

<style>
  .newsletter-cta {
    margin: 2.5rem 0;
    padding: 1.5rem;
    background: linear-gradient(135deg, rgba(57, 255, 20, 0.05), rgba(255, 16, 240, 0.05));
    border: 1px solid rgba(57, 255, 20, 0.25);
    border-radius: 12px;
  }

  .newsletter-cta-title {
    margin: 0 0 0.6rem;
    color: var(--guava-green);
    font-size: 1.15rem;
    font-weight: 700;
  }

  .newsletter-cta-desc {
    margin: 0 0 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .newsletter-perks {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
  }

  .newsletter-perks li {
    margin: 0.3rem 0;
    color: var(--text-primary);
    font-size: 0.9rem;
    line-height: 1.5;
    padding-left: 1.2rem;
    position: relative;
  }

  .newsletter-perks li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--guava-green);
  }

  .newsletter-cta-note {
    margin-top: 0.8rem;
    font-size: 0.78rem;
    color: var(--text-muted);
    text-align: center;
    font-style: italic;
  }

  /* variant 差異 */
  .newsletter-article {
    border-left: 4px solid var(--guava-green);
  }

  .newsletter-author {
    border-color: var(--guava-pink);
    background: linear-gradient(135deg, rgba(255, 16, 240, 0.05), rgba(57, 255, 20, 0.03));
  }

  .newsletter-author .newsletter-cta-title {
    color: var(--guava-pink);
  }

  .newsletter-tool {
    border-color: var(--gold-light);
    background: linear-gradient(135deg, rgba(57, 255, 20, 0.06), rgba(245, 184, 0, 0.04));
  }

  .newsletter-tool .newsletter-cta-title {
    color: var(--gold-light);
  }

  /* Benchmark 表單深色主題：反色 + 色相修正 */
  .newsletter-cta [data-bme-form-id] {
    filter: invert(0.88) hue-rotate(180deg);
    border-radius: 8px;
    overflow: hidden;
    transform: scale(0.82);
    transform-origin: top left;
    width: calc(100% / 0.82);
    margin-bottom: -40px;
  }

  .newsletter-cta :global([data-bme-form-id] .u_content_text div) {
    font-size: 18px !important;
    line-height: 1.4 !important;
  }

  /* RWD */
  @media (max-width: 768px) {
    .newsletter-cta {
      margin: 2rem 0;
      padding: 1.2rem;
    }
    .newsletter-cta-title {
      font-size: 1.05rem;
    }
  }
</style>
