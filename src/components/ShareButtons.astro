---
interface Props {
  title?: string;
  description?: string;
  url?: string;
}

const {
  title = document.title || '戰神賽特2覺醒之力完整攻略｜GAME8LA',
  description = 'GAME8LA - 台灣最敢說真話的線上遊戲評測平台',
  url = typeof window !== 'undefined' ? location.href : 'https://game8la.com'
} = Astro.props;
---

<div class="share-buttons">
  <a
    href="javascript:void(0)"
    onclick="shareOnLINE()"
    class="share-btn line-btn"
    title="分享到 LINE"
  >
    <i class="fab fa-line"></i> LINE
  </a>

  <a
    href="javascript:void(0)"
    onclick="shareOnFacebook()"
    class="share-btn facebook-btn"
    title="分享到 Facebook"
  >
    <i class="fab fa-facebook-f"></i> Facebook
  </a>

  <a
    href="javascript:void(0)"
    onclick="shareOnTwitter()"
    class="share-btn twitter-btn"
    title="分享到 Twitter"
  >
    <i class="fab fa-twitter"></i> Twitter
  </a>

  <a
    href="javascript:void(0)"
    onclick="copyToClipboard()"
    class="share-btn copy-btn"
    title="複製連結"
  >
    <i class="fas fa-copy"></i> 複製連結
  </a>
</div>

<style>
  .share-buttons {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin: 2rem 0;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    transition: all 0.3s;
    border: none;
    cursor: pointer;
    color: #fff;
  }

  .line-btn {
    background: #06C755;
  }

  .line-btn:hover {
    background: #05a74a;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(6, 199, 85, 0.3);
  }

  .facebook-btn {
    background: #1877F2;
  }

  .facebook-btn:hover {
    background: #1467da;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(24, 119, 242, 0.3);
  }

  .twitter-btn {
    background: #1DA1F2;
  }

  .twitter-btn:hover {
    background: #1a8cd8;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(29, 161, 242, 0.3);
  }

  .copy-btn {
    background: var(--gold);
    color: #000;
  }

  .copy-btn:hover {
    background: var(--gold-light);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(57, 255, 20, 0.3);
  }

  /* === RESPONSIVE === */
  @media (max-width: 768px) {
    .share-buttons {
      gap: 0.5rem;
    }

    .share-btn {
      padding: 0.5rem 1rem;
      font-size: 0.85rem;
    }
  }
</style>

<script is:inline>
  function shareOnLINE() {
    const url = encodeURIComponent(window.location.href);
    window.open(
      `https://social-plugins.line.me/lineit/share?url=${url}`,
      '_blank',
      'width=600,height=500'
    );
  }

  function shareOnFacebook() {
    const url = encodeURIComponent(window.location.href);
    window.open(
      `https://www.facebook.com/sharer/sharer.php?u=${url}`,
      '_blank',
      'width=600,height=500'
    );
  }

  function shareOnTwitter() {
    const url = encodeURIComponent(window.location.href);
    const text = encodeURIComponent(document.title || 'Check this out!');
    window.open(
      `https://twitter.com/intent/tweet?url=${url}&text=${text}`,
      '_blank',
      'width=600,height=500'
    );
  }

  function copyToClipboard() {
    const url = window.location.href;
    navigator.clipboard.writeText(url).then(() => {
      alert('連結已複製到剪貼板！');
    }).catch(() => {
      alert('複製失敗，請手動複製：' + url);
    });
  }
</script>
