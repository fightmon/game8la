// Get the icon SVG content
const svgInner = icons[name] || '<circle cx="12" cy="12" r="10" opacity="0.5"/>';

// Calculate dimensions for sizing
const numericSize = size.endsWith('em')
  ? parseFloat(size)
  : size.endsWith('px')
    ? parseFloat(size) + 'px'
    : size;
---

<svg
  viewBox="0 0 24 24"
  width={numericSize}
  height={numericSize}
  stroke="currentColor"
  fill="none"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  style={style}
  {...rest}
  set:html={svgInner}
/>
