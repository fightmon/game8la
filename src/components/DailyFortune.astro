  }
  .fab-toggle:hover { background: rgba(55, 55, 55, 0.95); }
  html.fabs-collapsed .fab-toggle { transform: rotate(180deg); }
  /* 用 right 位移收合，避免和 hover 的 transform 打架 */
  .bless-float-icon, .fortune-btn, .scroll-top {
