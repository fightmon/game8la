---
// ============================================================================
// DailyFortune — 芭樂子今日運勢浮動元件
// ----------------------------------------------------------------------------
// 放在 TOP 按鈕上方，點擊展開翻牌卡片
// 用天干地支 seed 每日自動抽取 宜/忌/金句/幸運數字
// ============================================================================
---

<!-- 擲筊浮動 ICON -->
<a class="bless-float-icon" href="/tools/bless-blocks/" aria-label="Game8la 線上擲筊" title="線上擲筊">
  <img src="/images/tools/icon-bless-float.webp" alt="線上擲筊" width="52" height="52" loading="lazy" />
</a>

<!-- 浮動按鈕（TOP 上方） -->
<button class="fortune-btn" id="fortuneBtn" type="button" aria-label="game8la玩家今日運勢" title="今日運勢">
  <span class="fortune-btn-text">今日</span>
  <span class="fortune-btn-text">運勢</span>
</button>

<!-- 浮動按鈕收合握把（手機把擲筊／運勢／TOP 往右收） -->
<button class="fab-toggle" id="fabToggle" type="button" aria-label="收合浮動按鈕" title="收合／展開浮動按鈕">›</button>

<!-- 運勢卡片 -->
<div class="fortune-overlay" id="fortuneOverlay">
  <div class="fortune-card" id="fortuneCard">
    <!-- 卡片正面（未翻） -->
    <div class="fortune-front" id="fortuneFront">
      <div class="fortune-front-glow"></div>
      <img src="/images/fortune-qian.webp" alt="籤筒" class="fortune-front-icon-img" width="80" height="132" loading="lazy" />
      <p class="fortune-front-title">game8la玩家今日運勢</p>
      <p class="fortune-front-sub">點擊翻牌</p>
    </div>

    <!-- 卡片背面（結果） -->
    <div class="fortune-back" id="fortuneBack">
      <div class="fortune-header">
        <span class="fortune-date" id="fortuneDate"></span>
        <button class="fortune-close" id="fortuneClose" type="button" aria-label="關閉">&times;</button>
      </div>

      <div class="fortune-ganzhi" id="fortuneGanzhi"></div>

      <div class="fortune-yi-ji">
        <div class="fortune-yi">
          <span class="fortune-tag fortune-tag-yi">宜</span>
          <span class="fortune-yi-text" id="fortuneYi"></span>
        </div>
        <div class="fortune-ji">
          <span class="fortune-tag fortune-tag-ji">忌</span>
          <span class="fortune-ji-text" id="fortuneJi"></span>
        </div>
      </div>

      <div class="fortune-quote" id="fortuneQuote"></div>

      <div class="fortune-lucky">
        <p class="fortune-lucky-title">今日幸運號碼</p>
        <div class="fortune-lucky-row">
          <span class="fortune-lucky-label">威力彩</span>
          <span class="fortune-lucky-nums" id="fortunePower"></span>
        </div>
      </div>

      <div class="fortune-disclaimer">
        本運勢純屬參考，芭樂子不保證農民曆能打敗機率。
      </div>
    </div>
  </div>
</div>

<style>
  /* === 擲筊浮動 ICON === */
  .bless-float-icon {
    position: fixed;
    bottom: 164px;
    right: 30px;
    z-index: 998;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #f5b800, #b8860b);
    border: 2px solid rgba(245, 184, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    box-shadow: 0 4px 18px rgba(245, 184, 0, 0.35);
    animation: blessWiggle 4s ease-in-out infinite;
    overflow: hidden;
  }
  .bless-float-icon::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid rgba(245, 184, 0, 0.5);
    animation: blessRing 4s ease-in-out infinite;
    pointer-events: none;
  }
  .bless-float-icon img {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    object-fit: cover;
  }
  .bless-float-icon:hover {
    animation: none;
    transform: scale(1.2);
    box-shadow: 0 0 24px rgba(245, 184, 0, 0.7), 0 0 48px rgba(57, 255, 20, 0.3);
  }
  .bless-float-icon:hover::after {
    animation: none;
    opacity: 0;
  }
  @keyframes blessWiggle {
    0%, 65%, 100% { transform: rotate(0deg); }
    70% { transform: rotate(-12deg) scale(1.1); }
    75% { transform: rotate(10deg) scale(1.1); }
    80% { transform: rotate(-8deg); }
    85% { transform: rotate(6deg); }
    90% { transform: rotate(0deg); }
  }
  @keyframes blessRing {
    0%, 65%, 100% { transform: scale(1); opacity: 0; }
    70% { opacity: 0.8; transform: scale(1); }
    90% { opacity: 0; transform: scale(1.6); }
  }

  /* === 浮動按鈕 === */
  .fortune-btn {
    position: fixed;
    bottom: 96px;
    right: 30px;
    z-index: 998;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, #39FF14, #FF10F0);
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 15px rgba(57, 255, 20, 0.3);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
    line-height: 1;
    padding: 0;
    animation: fortuneBounce 2.5s ease-in-out infinite;
  }

  .fortune-btn:hover {
    animation: none;
    transform: scale(1.12);
    box-shadow: 0 8px 25px rgba(57, 255, 20, 0.5);
  }

  .fortune-btn-text {
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 1px;
    color: #000;
    line-height: 1.15;
    display: block;
    background: linear-gradient(90deg, #000, #39FF14, #FF10F0, #f5b800, #39FF14, #000);
    background-size: 300% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: fortuneTextShift 3s linear infinite;
  }

  @keyframes fortuneTextShift {
    0% { background-position: 300% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* 放大縮小 + 呼吸光暈動畫 */
  @keyframes fortuneBounce {
    0%, 100% {
      transform: scale(1);
      box-shadow: 0 4px 15px rgba(57, 255, 20, 0.3);
    }
    50% {
      transform: scale(1.15);
      box-shadow: 0 6px 28px rgba(255, 16, 240, 0.45);
    }
  }

  /* === 遮罩層 === */
  .fortune-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1100;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    justify-content: center;
    align-items: center;
    padding: 20px;
  }

  .fortune-overlay.open {
    display: flex;
  }

  /* === 卡片 === */
  .fortune-card {
    width: 360px;
    min-height: 480px;
    perspective: 1000px;
    position: relative;
    cursor: pointer;
  }

  .fortune-card.flipped {
    cursor: default;
  }

  .fortune-front,
  .fortune-back {
    width: 100%;
    border-radius: 16px;
    backface-visibility: hidden;
    transition: transform 0.6s ease;
  }

  .fortune-front {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #1a1a1a, #121212);
    border: 2px solid rgba(57, 255, 20, 0.4);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 40px;
    transform: rotateY(0deg);
    z-index: 2;
    overflow: hidden;
  }

  .fortune-card.flipped .fortune-front {
    transform: rotateY(180deg);
    pointer-events: none;
  }

  .fortune-front-glow {
    position: absolute;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(57,255,20,0.12), transparent 70%);
    animation: fortuneGlow 4s ease-in-out infinite;
  }

  @keyframes fortuneGlow {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    50% { transform: scale(1.3); opacity: 1; }
  }

  .fortune-front-icon-img {
    width: 80px;
    height: auto;
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 0 12px rgba(57, 255, 20, 0.4));
  }

  .fortune-front-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #39FF14;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .fortune-front-sub {
    font-size: 0.85rem;
    color: #999;
    margin: 0;
    position: relative;
    z-index: 1;
    animation: fortuneBlink 2s ease-in-out infinite;
  }

  @keyframes fortuneBlink {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  /* === 卡片背面 === */
  .fortune-back {
    background: linear-gradient(135deg, #1a1a1a, #121212);
    border: 2px solid rgba(57, 255, 20, 0.4);
    padding: 22px 26px;
    transform: rotateY(-180deg);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .fortune-card.flipped .fortune-back {
    transform: rotateY(0deg);
  }

  .fortune-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .fortune-date {
    font-size: 1rem;
    color: #ddd;
  }

  .fortune-close {
    background: none;
    border: none;
    color: #ccc;
    font-size: 1.6rem;
    cursor: pointer;
    padding: 0;
    line-height: 1;
    transition: color 0.2s;
  }

  .fortune-close:hover {
    color: #fff;
  }

  .fortune-ganzhi {
    text-align: center;
    font-size: 1.6rem;
    font-weight: 700;
    color: #39FF14;
    letter-spacing: 4px;
    padding: 6px 0;
  }

  /* 宜忌 */
  .fortune-yi-ji {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .fortune-yi,
  .fortune-ji {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.05);
  }

  .fortune-tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 6px;
    font-size: 1.1rem;
    font-weight: 800;
    flex-shrink: 0;
  }

  .fortune-tag-yi {
    background: rgba(57, 255, 20, 0.2);
    color: #39FF14;
    border: 1px solid rgba(57, 255, 20, 0.4);
  }

  .fortune-tag-ji {
    background: rgba(255, 16, 240, 0.15);
    color: #FF10F0;
    border: 1px solid rgba(255, 16, 240, 0.35);
  }

  .fortune-yi-text,
  .fortune-ji-text {
    font-size: 1.1rem;
    color: #fff;
  }

  /* 金句 */
  .fortune-quote {
    background: rgba(57, 255, 20, 0.06);
    border-left: 3px solid #39FF14;
    border-radius: 0 8px 8px 0;
    padding: 14px 16px;
    font-size: 1.05rem;
    line-height: 1.75;
    color: #fff;
    font-style: italic;
  }

  /* 幸運號碼 */
  .fortune-lucky {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    padding: 14px 16px;
  }

  .fortune-lucky-title {
    font-size: 1rem;
    color: #f5b800;
    margin: 0 0 10px;
    letter-spacing: 1px;
    font-weight: 700;
  }

  .fortune-lucky-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .fortune-lucky-label {
    font-size: 1rem;
    color: #eee;
    min-width: 50px;
    font-weight: 600;
  }

  .fortune-lucky-nums {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }

  /* 免責 */
  .fortune-disclaimer {
    font-size: 0.9rem;
    color: #ccc;
    text-align: center;
    line-height: 1.6;
    padding-top: 8px;
    border-top: 1px solid #444;
  }

  /* === RWD === */
  @media (max-width: 768px) {
    .bless-float-icon {
      bottom: 138px;
      right: 16px;
      width: 48px;
      height: 48px;
    }
    .bless-float-icon img {
      width: 44px;
      height: 44px;
    }
    .fortune-btn {
      bottom: 78px;
      right: 16px;
      width: 48px;
      height: 48px;
    }
    .fortune-btn-text { font-size: 0.65rem; }
    .fortune-card { width: 340px; min-height: auto; }
    .fortune-back { padding: 18px 20px; gap: 12px; max-height: calc(100dvh - 60px); overflow-y: auto; }
  }
</style>

