  // === 天干地支 ===
  var TIAN_GAN = ['甲','乙','丙','丁','戊','己','庚','辛','壬','癸'];
  var DI_ZHI = ['子','丑','寅','卯','辰','巳','午','未','申','酉','戌','亥'];

  // 計算天干地支（簡化：以 2024-02-10 甲辰年正月初一為基準日）
  function getDayGanZhi(date) {
    var base = new Date(2024, 1, 10); // 2024-02-10
    var diff = Math.floor((date.getTime() - base.getTime()) / 86400000);
    // 基準日天干地支序號（甲辰日 = 甲0, 辰4 → 干支序 = 0*12+4 不對，用查表）
    // 2024-02-10 是甲子日（干支序第1天）
    var ganIdx = ((diff % 10) + 10) % 10;
    var zhiIdx = ((diff % 12) + 12) % 12;
    return {
      gan: TIAN_GAN[ganIdx],
      zhi: DI_ZHI[zhiIdx],
      ganIdx: ganIdx,
      zhiIdx: zhiIdx,
      text: TIAN_GAN[ganIdx] + DI_ZHI[zhiIdx] + '日'
    };
  }

  // 簡易 seeded random（線性同餘）
  function seededRandom(seed) {
    var s = seed;
    return function() {
      s = (s * 1664525 + 1013904223) & 0x7fffffff;
      return s / 0x7fffffff;
    };
  }

  // 從陣列中用 seed 選一個
  function pick(arr, rng) {
    return arr[Math.floor(rng() * arr.length)];
  }

  // 產生不重複的幸運號碼
  function luckyNums(rng, max, count) {
    var nums = [];
    while (nums.length < count) {
      var n = Math.floor(rng() * max) + 1;
      if (nums.indexOf(n) === -1) nums.push(n);
    }
    return nums.sort(function(a, b) { return a - b; });
  }

  // 產生號碼球 HTML
  function numBall(n, cls) {
    return '<span class="fortune-ball ' + (cls || '') + '">' + (n < 10 ? '0' + n : n) + '</span>';
  }

  // === 主邏輯 ===
  function generateFortune() {
    var now = new Date();
    var gz = getDayGanZhi(now);

    // seed = 年月日組合 + 干支
    var dayKey = now.getFullYear() * 10000 + (now.getMonth() + 1) * 100 + now.getDate();
    var seed = dayKey * 60 + gz.ganIdx * 12 + gz.zhiIdx;
    var rng = seededRandom(seed);

    var yi = pick(YI, rng);
    var ji = pick(JI, rng);
    var quote = pick(QUOTES, rng);

    var powerNums = luckyNums(rng, 38, 2);
    var powerSpecial = Math.floor(rng() * 8) + 1;
    // 日期格式
    var dateStr = now.getFullYear() + '/' + (now.getMonth() + 1) + '/' + now.getDate();

    return {
      date: dateStr,
      ganzhi: gz.text,
      yi: yi,
      ji: ji,
      quote: quote,
      power: powerNums,
      powerSpecial: powerSpecial,
    };
  }

  // === DOM 操作 ===
  var btn = document.getElementById('fortuneBtn');
  var overlay = document.getElementById('fortuneOverlay');
  var card = document.getElementById('fortuneCard');
  var closeBtn = document.getElementById('fortuneClose');

  if (!btn || !overlay || !card) return;

  // 按鈕直接可見（不需要 scroll 觸發）

  // 點按鈕開啟
  btn.addEventListener('click', function() {
    overlay.classList.add('open');
    card.classList.remove('flipped');

    // 預先填入資料
    var f = generateFortune();
    document.getElementById('fortuneDate').textContent = f.date;
    document.getElementById('fortuneGanzhi').textContent = f.ganzhi;
    document.getElementById('fortuneYi').textContent = f.yi;
    document.getElementById('fortuneJi').textContent = f.ji;
    document.getElementById('fortuneQuote').textContent = '「' + f.quote + '」';

    // 威力彩號碼
    var pH = f.power.map(function(n) { return numBall(n, 'ball-power'); }).join('') +
      '<span class="fortune-ball-plus">+</span>' +
      numBall(f.powerSpecial, 'ball-special');
    document.getElementById('fortunePower').innerHTML = pH;

  });

  // 點卡片翻牌
  card.addEventListener('click', function(e) {
    if (!card.classList.contains('flipped') && !e.target.closest('.fortune-close')) {
      card.classList.add('flipped');
    }
  });

  // 關閉
  function closeFortune() {
    overlay.classList.remove('open');
    setTimeout(function() { card.classList.remove('flipped'); }, 300);
  }

  if (closeBtn) closeBtn.addEventListener('click', function(e) {
    e.stopPropagation();
    closeFortune();
  });

  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) closeFortune();
  });

  // ESC 關閉
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && overlay.classList.contains('open')) closeFortune();
  });

  // === 浮動按鈕收合（手機往右收，記憶選擇、換頁也記得） ===
  (function() {
    var tog = document.getElementById('fabToggle');
    if (!tog) return;
    var KEY = 'fabsCollapsed';
    try { if (localStorage.getItem(KEY) === '1') document.documentElement.classList.add('fabs-collapsed'); } catch (e) {}
    tog.addEventListener('click', function() {
      var collapsed = document.documentElement.classList.toggle('fabs-collapsed');
      try { localStorage.setItem(KEY, collapsed ? '1' : '0'); } catch (e) {}
    });
  })();
})();
</script>

