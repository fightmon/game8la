---
// AntiScamSeries.astro
// 「防詐三部曲」系列文章導覽元件
// 嵌在 AT99 / 防詐 8LA / 零業配宣言 3 篇文章頂端，建立內部連結 topic cluster
//
// 用法：
//   import AntiScamSeries from '../../components/AntiScamSeries.astro';
//   <AntiScamSeries current={1} />  // AT99 封鎖分析為第 1 部（現場篇）
//   <AntiScamSeries current={2} />  // 8 大詐騙手法為第 2 部（手法篇）
//   <AntiScamSeries current={3} />  // 零業配宣言為第 3 部（宣言篇）
import Icon from './Icon.astro';

interface Props {
  current: 1 | 2 | 3;
}

const { current } = Astro.props;

const parts = [
  {
    n: 1,
    label: '現場篇',
    title: 'AT99 封鎖事件深度解析',
    desc: '從刑事警察局函令看懂黑網真相',
    href: '/articles/at99-blocked-analysis/',
    glyph: '①',
    accent: '#ec4899', // pink
  },
  {
    n: 2,
    label: '手法篇',
    title: '娛樂城詐騙 8 大手法',
    desc: '誘導儲值、洗碼量、假客服…完全拆解',
    href: '/articles/anti-scam-8la-guide/',
    glyph: '②',
    accent: '#FFD700', // gold
  },
  {
    n: 3,
    label: '宣言篇',
    title: 'GAME8LA 零業配創站宣言',
    desc: '為什麼我們敢說這些話？看完你就懂',
    href: '/articles/game8la-manifesto/',
    glyph: '③',
    accent: '#39FF14', // neon green
  },
];
---

<nav class="series-box" aria-label="防詐三部曲系列導覽">
  <header class="series-header">
    <div class="series-badge">
      <Icon name="shield" size="0.9rem" />
      <span>防詐三部曲</span>
    </div>
    <span class="series-meta">Anti-Scam Trilogy｜共 3 篇 · 目前在第 {current} 篇</span>
  </header>

  <ol class="series-list">
    {parts.map((p) => {
      const active = p.n === current;
      const Wrapper = active ? 'div' : 'a';
      return (
        <li class:list={['series-item', { 'is-active': active }]} style={`--accent:${p.accent}`}>
          <Wrapper
            class="series-link"
            {...(active ? {} : { href: p.href })}
            {...(active ? { 'aria-current': 'page' } : {})}
          >
            <span class="series-glyph" aria-hidden="true">{p.glyph}</span>
            <span class="series-body">
              <span class="series-label">{p.label}{active && <span class="series-here">← 你在這裡</span>}</span>
              <span class="series-title">{p.title}</span>
              <span class="series-desc">{p.desc}</span>
            </span>
            {!active && <span class="series-arrow" aria-hidden="true"><Icon name="arrow-right" size="1rem" /></span>}
          </Wrapper>
        </li>
      );
    })}
  </ol>
</nav>

<style>
  .series-box {
    margin: 1.5rem 0 2rem;
    padding: 1.2rem 1.3rem 1rem;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(236,72,153,0.06) 0%, rgba(255,215,0,0.05) 50%, rgba(57,255,20,0.06) 100%);
    border: 1px solid rgba(255,255,255,0.08);
    position: relative;
    overflow: hidden;
  }
  .series-box::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, #ec4899 0%, #FFD700 50%, #39FF14 100%);
  }

  .series-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    margin-bottom: 0.9rem;
    padding-bottom: 0.7rem;
    border-bottom: 1px dashed rgba(255,255,255,0.1);
  }

  .series-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.8rem;
    background: rgba(57,255,20,0.12);
    border: 1px solid rgba(57,255,20,0.4);
    color: #39FF14;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.5px;
  }

  .series-meta {
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .series-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .series-item {
    position: relative;
  }

  .series-link {
    display: flex;
    align-items: stretch;
    gap: 0.9rem;
    padding: 0.85rem 1rem;
    border-radius: 10px;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.2s ease;
  }

  a.series-link:hover {
    background: rgba(255,255,255,0.05);
    border-color: var(--accent);
    transform: translateX(3px);
    box-shadow: 0 6px 18px rgba(0,0,0,0.25), 0 0 0 1px var(--accent) inset;
  }

  .series-item.is-active .series-link {
    background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 15%, transparent) 0%, rgba(0,0,0,0.2) 100%);
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent) inset, 0 0 20px color-mix(in srgb, var(--accent) 25%, transparent);
    cursor: default;
  }

  .series-glyph {
    flex: 0 0 auto;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-size: 1.35rem;
    font-weight: 900;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 50%, transparent);
  }

  .series-item.is-active .series-glyph {
    background: var(--accent);
    color: #111;
    box-shadow: 0 0 16px color-mix(in srgb, var(--accent) 60%, transparent);
  }

  .series-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    line-height: 1.4;
  }

  .series-label {
    font-size: 0.72rem;
    font-weight: 800;
    color: var(--accent);
    letter-spacing: 1px;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .series-here {
    font-size: 0.7rem;
    padding: 0.1rem 0.5rem;
    background: var(--accent);
    color: #111;
    border-radius: 4px;
    letter-spacing: 0;
  }

  .series-title {
    font-size: 0.98rem;
    font-weight: 800;
    color: var(--text-primary);
  }

  .series-desc {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .series-arrow {
    align-self: center;
    color: var(--accent);
    opacity: 0.7;
    transition: transform 0.2s, opacity 0.2s;
  }

  a.series-link:hover .series-arrow {
    opacity: 1;
    transform: translateX(3px);
  }

  @media (max-width: 640px) {
    .series-box {
      padding: 1rem 0.9rem 0.8rem;
    }
    .series-link {
      padding: 0.7rem 0.75rem;
      gap: 0.65rem;
    }
    .series-glyph {
      width: 34px;
      height: 34px;
      font-size: 1.15rem;
    }
    .series-title {
      font-size: 0.9rem;
    }
    .series-desc {
      font-size: 0.76rem;
    }
    .series-meta {
      width: 100%;
      font-size: 0.74rem;
    }
  }
</style>
