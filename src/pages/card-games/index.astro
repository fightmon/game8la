          <tr><td style="padding:0.6rem;border:1px solid var(--border)"><strong>21 點</strong></td><td style="padding:0.6rem;border:1px solid var(--border)">玩家 vs 莊家</td><td style="padding:0.6rem;border:1px solid var(--border)">★★★★☆</td><td style="padding:0.6rem;border:1px solid var(--border)">30 秒~1 分鐘</td><td style="padding:0.6rem;border:1px solid var(--border)">莊家優勢 0.5%（最優策略下）</td></tr>
          <tr><td style="padding:0.6rem;border:1px solid var(--border)"><strong>炸金花</strong></td><td style="padding:0.6rem;border:1px solid var(--border)">玩家 vs 玩家*</td><td style="padding:0.6rem;border:1px solid var(--border)">★★☆☆☆</td><td style="padding:0.6rem;border:1px solid var(--border)">30 秒~1 分鐘</td><td style="padding:0.6rem;border:1px solid var(--border)">抽水 3~5%</td></tr>
