        <thead style="background:var(--bg-card)">
          <tr>
            <th style="padding:0.6rem;border:1px solid var(--border);text-align:left">遊戲</th>
            <th style="padding:0.6rem;border:1px solid var(--border);text-align:left">技術佔比</th>
            <th style="padding:0.6rem;border:1px solid var(--border);text-align:left">運氣佔比</th>
            <th style="padding:0.6rem;border:1px solid var(--border);text-align:left">長期獲利可能性</th>
            <th style="padding:0.6rem;border:1px solid var(--border);text-align:left">適合什麼人</th>
