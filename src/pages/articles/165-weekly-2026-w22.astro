];

/* ── 假投資平台（本週財務詐騙大宗，取通報量前段） ── */
const investScams = [
  { name: '華訊電能事業股份有限公司', url: 'fafago.com.tw', count: 15 },
  { name: 'D.V.E', url: 'www.dvegif.com', count: 11 },
  { name: 'XT（冒名交易所）', url: 'xttw1028…cloudflare.net', count: 8 },
  { name: 'Wallet', url: 'www.wallatkyxba.com', count: 8 },
  { name: '財富e通', url: 'www.egrtsds.com', count: 7 },
  { name: 'TimeeCoin', url: 'sybjk.com', count: 7 },
  { name: 'Nest Markets', url: 'www.mtscrmnest.com', count: 6 },
  { name: '中信證券（冒名券商）', url: 'bw.citis35017.com', count: 4 },
];

/* ── 殺豬盤（假交友 → 假投資） ── */
const romanceScams = [
  { name: 'Flirting', url: 'qt.uidsjfjfjsf.cc', count: 9 },
  { name: 'One Night', url: 'night520.love', count: 4 },
  { name: 'LOVE GOLD（假交友＋黃金投資）', url: 'www.goldxetrade.com', count: 3 },
  { name: 'Romance Club', url: 'www.yhdjfhdoxe39.cc', count: 2 },
  { name: 'Boldly Meet', url: 'ogvghjfbnas.cc', count: 2 },
  { name: '波樂 Busty & fun', url: 'bustyfunapp.cc', count: 1 },
];
---

<ArticleSchema
  url="https://game8la.com/articles/165-weekly-2026-w22/"
  title={`【165 週報】${weekLabel}：錢盈539娛樂城換皮回歸、假投資與殺豬盤暴增`}
  description={`內政部警政署 165 全民防騙網 ${weekLabel} 詐騙通報週報。錢盈539娛樂城以新域名 admin.539lotterybuy.com 換皮回歸；本週假投資（華訊電能 15 件）與殺豬盤（Flirting 9 件）為通報大宗，165 共列逾 140 個詐騙網站。GAME8LA 165 監測站每週追蹤。`}
  image="https://game8la.com/images/articles/165-weekly-default-cover.webp"
  datePublished={publishDate}
  dateModified={publishDate}
  breadcrumbs={[
    { name: '首頁', url: 'https://game8la.com/' },
    { name: '芭樂攻略', url: 'https://game8la.com/articles/' },
    { name: '165 週報', url: 'https://game8la.com/articles/165-weekly-2026-w22/' },
  ]}
/>
<BaseLayout
  currentPage="articles"
  title={`【165 週報】${weekLabel}：錢盈539娛樂城換皮回歸｜GAME8LA 165 監測站`}
  description={`165 全民防騙網 ${weekLabel} 通報彙整：錢盈539娛樂城換新域名回歸，假投資（華訊電能）、殺豬盤（Flirting）為本週大宗。芭樂子每週追蹤整理，保護你的錢包。`}
>
  <div class="container">
    <div class="breadcrumb"><a href="/">首頁</a> &gt; <a href="/articles/">芭樂攻略</a> &gt; 165 週報</div>
    <div style="color:var(--text-muted);font-size:0.8rem;margin-bottom:0.5rem">
      <Icon name="clock" /> 發佈日：{publishDate} ｜
      <Icon name="user-pen" /> 作者：芭樂子｜
      <Icon name="book-open" /> 預估閱讀 4 分鐘 ｜
      <span style="color:#f5b800;font-weight:700">🔍 165 監測站週報</span>
    </div>
    <a href="/articles/" class="back-link"><Icon name="arrow-left" /> 回攻略列表</a>
    <div class="hero-banner" style="background:linear-gradient(135deg,#0a0a1a,#1a1a3a,#ef4444)"></div>

    <article class="article-content" style="max-width:820px;margin:0 auto">
      <h1 style="font-size:1.8rem;line-height:1.3">🔍 165 監測站週報｜{weekLabel}<br /><em>錢盈539娛樂城換皮回歸，假投資與殺豬盤本週暴增</em></h1>

      <p style="color:var(--text-muted);font-size:0.95rem">各位 8LA 鄉民好，我是芭樂子。每週我會從<strong>內政部警政署 165 全民防騙網</strong>的最新通報中，挑出跟<strong>娛樂城、博弈、假投資、殺豬盤</strong>這類「會把你錢騙光」的財務詐騙整理成週報。目的很簡單——<strong>讓你在入金、匯款之前，多一道防線</strong>。（冒用品牌的假購物詐騙不是本站專長，僅在文末帶過。）</p>

      <!-- === 本週摘要 === -->
      <div class="card" style="border-left:4px solid #ef4444;margin:1.5rem 0">
        <h3 style="margin-top:0;color:#ef4444">⚠️ 本週摘要</h3>
        <p style="margin:0">165 本週（5/21–5/27）公布逾 <strong>140 筆</strong>「假投資（博弈）」詐騙通報，通報量前三為 <strong>華訊電能</strong>（假投資）15 件、<strong>TikTok</strong>（冒用品牌假購物）14 件、<strong>D.V.E</strong>（假投資）11 件。娛樂城類本週主角是 <strong>錢盈539娛樂城</strong>——這集團上週才改名洗白，這週又換皮回歸。整體看，<strong>假投資平台仍是壓倒性大宗</strong>，且<strong>殺豬盤（假交友→投資）明顯增加</strong>，Flirting 一個品牌就被通報 9 件。</p>
      </div>

      <!-- === 165 總覽 === -->
      <div class="card" style="border-left:4px solid #44aaff;margin:1.5rem 0">
        <h3 style="margin-top:0;color:#44aaff">📈 本週 165 通報總覽</h3>
        <p>本週「假投資（博弈）」類公告共列出逾 <strong>140 個</strong>詐騙網站，通報量前段：</p>
        <ul style="margin:0.5rem 0;line-height:2">
          <li><strong>華訊電能事業股份有限公司</strong>（假投資）— 15 件</li>
          <li><strong>TikTok</strong>（冒用品牌假購物）— 14 件</li>
          <li><strong>D.V.E</strong>（假投資）— 11 件</li>
          <li><strong>Flirting</strong>（殺豬盤假交友）— 9 件</li>
        </ul>
        <p style="margin-bottom:0">類型分布上，<strong>假投資平台</strong>（冒名券商、虛擬貨幣交易所、AI 量化）佔絕大多數；<strong>殺豬盤</strong>本週竄升；娛樂城／博弈品牌通報量低，但這不代表變少——它們多半轉往社群、廣告、LINE 群這些更難被通報的管道。</p>
      </div>

      <!-- === 娛樂城／博弈 === -->
      <h2 id="casino" style="color:#ef4444">🎰 娛樂城／博弈：錢盈539 換皮回歸</h2>
      <p>本週 165 通報中，娛樂城／博弈類由「換皮之王」<strong>錢盈539</strong>領銜：</p>
      <div class="weekly-brand-list">
        {casinoBrands.map(brand => (
          <div class="weekly-brand-card new-brand">
            <div class="brand-header">
              <span class="brand-badge updated">🔁 換皮</span>
              <strong>{brand.name}</strong>
              <span class="brand-count">{brand.count} 件</span>
            </div>
            <div class="brand-url">🌐 <code>{brand.url}</code></div>
            <p class="brand-note">💡 {brand.note}</p>
          </div>
        ))}
      </div>

      <!-- === 假投資 === -->
      <h2 id="invest" style="color:#f5b800">💰 假投資平台（本週大宗）</h2>
      <p>假投資是本週絕對主流——冒名券商、假交易所、AI 量化、虛擬貨幣，話術千變萬化，但結局都一樣：<strong>初期讓你看到帳面獲利，等你加碼，提領時就「不出金」</strong>。跟詐騙娛樂城是同一套劇本，只是包裝不同。本週通報量前段：</p>
      <div class="scam-table-wrap">
        <table class="scam-table">
          <thead><tr><th>品牌</th><th>網址</th><th>件數</th></tr></thead>
          <tbody>
            {investScams.map(s => (
              <tr><td>{s.name}</td><td><code>{s.url}</code></td><td class="ct">{s.count}</td></tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- === 殺豬盤 === -->
      <h2 id="romance" style="color:#ec4899">💔 殺豬盤：先談感情，再騙你投資</h2>
      <p>本週殺豬盤明顯增加。套路是<strong>先用「正妹／帥哥」假交友養感情</strong>，幾天後再「不小心」透露自己有內線投資管道，把你導去假平台或假博弈。世足、大賽期間這種特別多。本週上榜的假交友幌子：</p>
      <div class="scam-table-wrap">
        <table class="scam-table">
          <thead><tr><th>品牌</th><th>網址</th><th>件數</th></tr></thead>
          <tbody>
            {romanceScams.map(s => (
              <tr><td>{s.name}</td><td><code>{s.url}</code></td><td class="ct">{s.count}</td></tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- === 趨勢觀察 === -->
      <h2 id="trend">📊 本週趨勢觀察</h2>
      <div class="card" style="border-left:4px solid #f5b800;margin:1.5rem 0">
        <h3 style="margin-top:0;color:#f5b800">芭樂子觀察筆記</h3>
        <p><strong>1. 錢盈539 一週換一個皮，鄉民別追名字</strong>——lottery539.com →（拿掉539）qywin88.com →（裝回539）admin.539lotterybuy.com，三個禮拜三個樣。這證明詐騙娛樂城根本不在乎「品牌信譽」，賺一票就換殼跑。<strong>判斷該不該信，要看網域與紀錄，不是看名字。</strong></p>
        <p><strong>2. 假投資 ＝ 不出金娛樂城的雙胞胎</strong>——華訊電能、財富e通、Nest Markets 這些假投資平台，跟詐騙娛樂城是同一套：帳面假獲利 → 誘你加碼 → 提領各種理由拖延凍結。手法一模一樣，只是一個包成「投資」、一個包成「博弈」。看懂一個，就看得懂另一個。</p>
        <p style="margin-bottom:0"><strong>3. 殺豬盤把「假交友＋假投資」合體</strong>——Flirting、One Night、LOVE GOLD 這類，先騙感情再騙錢。記住一條鐵則：<strong>網路上認識、聊沒幾天就「報你明牌、帶你投資」的，100% 是詐騙</strong>，不管對方多正多帥。還有，這週一堆 <code>.cc</code>、<code>.pro</code>、<code>.top</code>、<code>.love</code> 的怪域名——正規平台不會用這種便宜即丟的頂級域名。</p>
      </div>

      <!-- === CTA === -->
