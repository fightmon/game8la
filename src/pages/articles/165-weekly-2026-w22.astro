  .brand-note { font-size: 0.85rem; color: var(--text-muted); margin: 0; line-height: 1.6; }

  .scam-table-wrap { overflow-x: auto; margin: 1rem 0 1.5rem; }
  .scam-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  .scam-table th { text-align: left; color: var(--text-muted); font-weight: 600; padding: 0.5rem 0.7rem; border-bottom: 1px solid var(--border); font-size: 0.82rem; }
  .scam-table td { padding: 0.55rem 0.7rem; border-bottom: 1px solid rgba(255,255,255,0.06); vertical-align: top; }
  .scam-table td code { background: rgba(255,255,255,0.08); padding: 0.1rem 0.35rem; border-radius: 4px; font-size: 0.8rem; color: #ff9999; word-break: break-all; }
  .scam-table td.ct { text-align: center; font-weight: 800; color: #ef4444; white-space: nowrap; }

  @media (max-width: 768px) {
    .weekly-brand-card { padding: 1rem; }
