<script is:inline>
/* === 義大利文章 - 世足倒數計時器 mini === */
(function(){
  var KICKOFF = new Date('2026-06-11T00:00:00+00:00').getTime();
  var FINAL = new Date('2026-07-19T20:00:00-04:00').getTime();
  var elD = document.getElementById('itCdMiniDays');
  var elH = document.getElementById('itCdMiniHours');
  var elM = document.getElementById('itCdMiniMins');
  var elLabel = document.getElementById('itCdMiniLabel');
  if(!elD||!elH||!elM) return;

  function pad(n){ return n < 10 ? '0' + n : '' + n; }

  function tick(){
    var now = Date.now();
    var diffStart = KICKOFF - now;
    var diffEnd = FINAL - now;
    var target;

    if(diffStart > 0){
      target = diffStart;
      elLabel.textContent = '距離 2026 世足開踢還剩';
    } else if(diffEnd > 0){
      target = diffEnd;
      elLabel.textContent = '🔥 世足進行中（義大利不在現場）距離決賽還剩';
    } else {
      elLabel.textContent = '🏁 2026 世足已結束，義大利球迷請繼續等 2030';
      elD.textContent = '~';
      elH.textContent = '~';
      elM.textContent = '~';
      return;
    }

    var totalSec = Math.floor(target / 1000);
    var days = Math.floor(totalSec / 86400);
    var hours = Math.floor((totalSec % 86400) / 3600);
    var mins = Math.floor((totalSec % 3600) / 60);
    elD.textContent = days;
    elH.textContent = pad(hours);
    elM.textContent = pad(mins);
  }
  tick();
  setInterval(tick, 60000);  // 每分鐘 tick，不需要秒
})();
</script>

