  <script is:inline>
    (function () {
      var lb = document.getElementById('offsideLightbox');
      var inner = document.getElementById('offsideLightboxInner');
      if (!lb || !inner) return;
      function open(svg) {
        var clone = svg.cloneNode(true);
        clone.removeAttribute('data-zoomable');
        clone.style.cursor = 'default';
        inner.innerHTML = '';
        inner.appendChild(clone);
        lb.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }
      function close() {
        lb.classList.remove('is-open');
        document.body.style.overflow = '';
        inner.innerHTML = '';
      }
      window._closeOffsideLightbox = close;
      // 點 SVG 開啟
      document.querySelectorAll('.offside-svg[data-zoomable]').forEach(function (svg) {
        svg.addEventListener('click', function () { open(svg); });
      });
      // 點黑底 / ESC 關閉
      lb.addEventListener('click', close);
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && lb.classList.contains('is-open')) close();
      });
    })();
  </script>
