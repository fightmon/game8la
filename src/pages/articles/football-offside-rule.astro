const faqs = [
  { q: '越位是什麼意思？', a: '越位（Offside）是足球規則之一，目的是防止進攻球員站在對方球門前面「等球」。簡單說：傳球瞬間，如果接球的進攻球員前面的防守球員不到兩個（含守門員），就是越位。裁判會吹哨停止比賽，由防守方獲得自由球。' },
  { q: '守門員算不算防守球員？', a: '算！守門員也算防守球員。所以「倒數第二個防守球員」通常是指除了守門員之外，站最後面的那個後衛。如果守門員跑到前面去了（比如補時階段上前頭球），那越位線就要看最後面的兩個球員是誰——不一定包含守門員。' },
  { q: '越位的時候球員可以碰球嗎？', a: '如果你站在越位位置，但沒有碰球、沒有影響比賽、也沒有干擾對手，裁判不會判越位。越位犯規要同時滿足「在越位位置」和「參與進攻」兩個條件。但實務上，只要球朝你飛過來，基本上就會被認定為參與進攻。' },
  { q: '角球有越位嗎？', a: '<strong>角球沒有越位。</strong>根據 FIFA 規則，球門球、界外球、角球這三種情況不適用越位規則。所以你會看到角球時，進攻球員全部擠在門前搶頭球——因為不管站多前面都不會越位。' },
  { q: 'VAR 是什麼？', a: 'VAR 全名是 Video Assistant Referee（影像輔助裁判），2018 年世界盃開始正式啟用。VAR 可以協助主裁判判定進球、紅牌、罰球、球員身份四種情況。越位判定是 VAR 最常介入的場景之一，透過精確畫線技術來判斷進攻球員是否超過越位線。' },
  { q: '為什麼越位規則這麼重要？', a: '如果沒有越位規則，進攻球員可以直接站在對方球門口等傳球，比賽就會變成「大腳長傳找前鋒」的無聊遊戲。越位規則迫使進攻球員不能一直往前站，鼓勵球隊用短傳配合和跑位來創造機會，讓足球比賽更好看、更有戰術深度。' },
  { q: '越位被吹之後怎麼辦？', a: '越位被吹之後，比賽暫停，由防守方在越位發生的位置獲得一個<strong>間接自由球</strong>（Indirect Free Kick）。進攻方的進球不算，之前的動作全部作廢。如果 VAR 介入確認，等確認結果出來才會做最終判決。' },
];
