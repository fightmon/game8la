  .oq-explain-text { background: rgba(57,255,20,0.05); border-left: 3px solid var(--guava-green, #39FF14); border-radius: 0 10px 10px 0; padding: 14px 18px; font-size: 1.05rem; line-height: 1.8; color: #ddd; margin-bottom: 1rem; }
  .oq-next-btn { display: block; margin: 0 auto; background: transparent; border: 1.5px solid #555; color: #ccc; font-size: 1.05rem; padding: 10px 36px; border-radius: 10px; cursor: pointer; transition: all 0.2s; }
  .oq-next-btn:hover { border-color: var(--guava-green, #39FF14); color: #fff; }

  .oq-final { text-align: center; animation: oqFadeIn 0.5s ease-out; }
  .oq-final-score { font-size: 3rem; font-weight: 900; color: var(--guava-green, #39FF14); margin-bottom: 0.3rem; }
  .oq-final-title { font-size: 1.4rem; font-weight: 700; color: #fbbf24; margin-bottom: 0.5rem; }
  .oq-final-msg { font-size: 1rem; color: #bbb; margin-bottom: 1.2rem; line-height: 1.7; }
  .oq-replay-btn { background: linear-gradient(135deg, #b8860b, #d4a056); border: 2px solid #c9983a; color: #1a1a1a; font-size: 1.15rem; font-weight: 800; padding: 14px 40px; border-radius: 12px; cursor: pointer; transition: all 0.3s; letter-spacing: 2px; }
  .oq-replay-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(184,134,11,0.4); }
  .oq-share-prompt { margin-top: 1rem; font-size: 0.95rem; color: #888; }

  .oq-stats-card { max-width: 600px; margin: 2rem auto; padding: 1.2rem 1.5rem; background: var(--bg-card, rgba(255,255,255,0.03)); border: 1px solid #333; border-radius: 14px; }
  .oq-stats-title { font-size: 1.05rem; font-weight: 700; color: #eee; margin-bottom: 0.8rem; }
  .oq-stats-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .oq-stat { background: rgba(255,255,255,0.04); border-radius: 8px; padding: 8px 16px; font-size: 0.95rem; color: #bbb; }
  .oq-stat strong { font-size: 1.2rem; margin-left: 4px; color: var(--guava-green, #39FF14); }

  @media (max-width: 768px) {
    .oq-quiz-area { padding: 1rem; }
    .oq-btn { font-size: 1.05rem; padding: 12px 24px; }
    .oq-question { font-size: 1.05rem; }
    .oq-final-score { font-size: 2.5rem; }
    .oq-final-title { font-size: 1.2rem; }
  }
  @media (max-width: 480px) {
    .oq-btn { font-size: 0.95rem; padding: 10px 20px; flex: 1; min-width: 120px; }
    .oq-explain-text { font-size: 0.95rem; padding: 10px 14px; }
    .oq-stat { padding: 6px 12px; font-size: 0.9rem; }
  }
</style>

<script is:inline>
(function(){
  var SCENARIOS = [
    { id:1, attackers:[{x:30,y:50,isPasser:true},{x:63,y:30,isReceiver:true}], defenders:[{x:70,y:60,isGoalkeeper:false},{x:95,y:50,isGoalkeeper:true}], ball:{x:30,y:50}, passTo:{x:63,y:30}, isOffside:false, explanation:'芭樂子：接球的 A 在 x=63，防守者 D 在 x=70，守門員在 x=95。倒數第二位防守者是 D(x=70)。A(63) < D(70)，接球者在防守者後面，沒有越位！這是最基本的情境——進攻球員只要沒跑過最後一個後衛，就安全。', difficulty:'easy' },
    { id:2, attackers:[{x:40,y:40,isPasser:true},{x:85,y:60,isReceiver:true}], defenders:[{x:72,y:35,isGoalkeeper:false},{x:68,y:70,isGoalkeeper:false},{x:95,y:50,isGoalkeeper:true}], ball:{x:40,y:40}, passTo:{x:85,y:60}, isOffside:true, explanation:'芭樂子：接球的 A 在 x=85，防守方最靠近底線的是守門員 x=95，倒數第二位是 D(x=72)。A(85) 比 D(72) 更靠近底線、比球(x=40)更前面、又在對方半場——三個條件全中，標準越位！這種明顯衝太前面的，連芭樂子閉著眼都能判。', difficulty:'easy' },
    { id:3, attackers:[{x:35,y:55,isPasser:true},{x:60,y:30,isReceiver:true}], defenders:[{x:65,y:45,isGoalkeeper:false},{x:62,y:75,isGoalkeeper:false},{x:95,y:50,isGoalkeeper:true}], ball:{x:35,y:55}, passTo:{x:60,y:30}, isOffside:false, explanation:'芭樂子：接球的 A 在 x=60，倒數第二位防守者在 x=62。A(60) < D(62)，接球者比防守者更遠離底線，所以沒越位。記住：進攻球員必須「超過」防守者才算越位，在後面或同一條線都不算。', difficulty:'easy' },
    { id:4, attackers:[{x:25,y:60,isPasser:true},{x:80,y:45,isReceiver:true},{x:55,y:25}], defenders:[{x:78,y:70,isGoalkeeper:false},{x:95,y:50,isGoalkeeper:true}], ball:{x:25,y:60}, passTo:{x:80,y:45}, isOffside:true, explanation:'芭樂子：接球的 A 在 x=80，倒數第二位防守者（D）在 x=78。A(80) > D(78)，雖然只差 2，但越位就是越位。在真正的比賽裡，VAR 會畫一條超精準的線——差一根腳趾也是越位。所以不要跟我說「很接近」，規則不看感覺看數字。', difficulty:'medium' },
    { id:5, attackers:[{x:30,y:35,isPasser:true},{x:70,y:65,isReceiver:true}], defenders:[{x:70,y:40,isGoalkeeper:false},{x:95,y:50,isGoalkeeper:true}], ball:{x:30,y:35}, passTo:{x:70,y:65}, isOffside:false, explanation:'芭樂子：接球的 A 在 x=70，倒數第二位防守者（D）也在 x=70——兩個人在同一條線上！根據 FIFA 規則，同一條線不算越位。記住這個口訣：「齊平不算越」。這種判決在比賽中最容易引發爭議，但規則寫得很清楚。', difficulty:'medium' },
    { id:6, attackers:[{x:55,y:30,isPasser:true},{x:82,y:55,isReceiver:true}], defenders:[{x:60,y:50,isGoalkeeper:false},{x:75,y:70,isGoalkeeper:true}], ball:{x:55,y:30}, passTo:{x:82,y:55}, isOffside:true, explanation:'芭樂子：這題的陷阱是守門員跑出來了！守門員在 x=75，後衛在 x=60。越位看「倒數第二個防守球員」，現在倒數第二個是後衛 x=60（不是守門員）。接球 A 在 x=82，遠遠超過 D(x=60)，當然越位。守門員不一定是最後一個人，他衝出來的時候後衛就變成關鍵。', difficulty:'medium' },
    { id:7, attackers:[{x:45,y:40,isPasser:true},{x:45,y:70,isReceiver:true}], defenders:[{x:70,y:50,isGoalkeeper:false},{x:75,y:30,isGoalkeeper:false},{x:95,y:50,isGoalkeeper:true}], ball:{x:45,y:40}, passTo:{x:45,y:70}, isOffside:false, explanation:'芭樂子：接球的 A 在 x=45，這是在自己的半場（x<50 = 中線以內）。不管防守球員在哪裡，只要你在自己半場，就絕對不會越位。這是很多新手不知道的規則——中線以內是安全區。', difficulty:'easy' },
    { id:8, attackers:[{x:60,y:25,isPasser:true},{x:85,y:50,isReceiver:true},{x:72,y:75}], defenders:[{x:80,y:40,isGoalkeeper:false},{x:95,y:50,isGoalkeeper:true}], ball:{x:60,y:25}, passTo:{x:85,y:50}, isOffside:true, explanation:'芭樂子：場上有兩個進攻球員在前場：x=85（接球者）和 x=72（沒接球的）。倒數第二個防守者在 x=80。球傳給 x=85 的 A，A(85) > D(80)，越位！注意看另一個 A 在 x=72，他沒越位——但球不是給他的。越位判的是「接球的那個人」有沒有超線。', difficulty:'hard' },
    { id:9, attackers:[{x:70,y:40,isPasser:true},{x:68,y:70,isReceiver:true}], defenders:[{x:65,y:55,isGoalkeeper:false},{x:95,y:50,isGoalkeeper:true}], ball:{x:70,y:40}, passTo:{x:68,y:70}, isOffside:false, explanation:'芭樂子：接球的 A 在 x=68，球在 x=70。A(68) < 球(70)——接球者比球更遠離底線！越位的第三個條件是「比球更靠近底線」，這裡 A 在球的後面，所以不算越位。就算 A 比防守者更前面也沒關係，只要 A 在球後面就安全。', difficulty:'medium' },
    { id:10, attackers:[{x:35,y:50,isPasser:true},{x:88,y:40,isReceiver:true}], defenders:[{x:55,y:30,isGoalkeeper:false},{x:60,y:65,isGoalkeeper:false},{x:95,y:50,isGoalkeeper:true}], ball:{x:35,y:50}, passTo:{x:88,y:40}, isOffside:true, explanation:'芭樂子：A 在 x=88，倒數第二個防守者在 x=60。A 比 D 前面了 28 個單位——這不是越位，這是越位的教科書範本。連邊裁都不用跑，直接舉旗。芭樂子建議這位前鋒先回去練習站位。', difficulty:'easy' },
    { id:11, attackers:[{x:50,y:30,isPasser:true},{x:76,y:55,isReceiver:true}], defenders:[{x:76,y:35,isGoalkeeper:false},{x:72,y:70,isGoalkeeper:false},{x:95,y:50,isGoalkeeper:true}], ball:{x:50,y:30}, passTo:{x:76,y:55}, isOffside:false, explanation:'芭樂子：接球 A 在 x=76，兩個防守者分別在 x=76 和 x=72，守門員在 x=95。倒數第二位防守者是 x=76 的 D。A(76) = D(76)，齊平！齊平不算越位——FIFA 規則第 11 條寫得很清楚。差 0.01 公分也要超過才算，同一條線就是安全的。', difficulty:'medium' },
    { id:12, attackers:[{x:65,y:45,isPasser:true},{x:90,y:30,isReceiver:true}], defenders:[{x:82,y:60,isGoalkeeper:false},{x:97,y:50,isGoalkeeper:true}], ball:{x:65,y:45}, passTo:{x:90,y:30}, isOffside:true, explanation:'芭樂子：A 在 x=90，倒數第二個防守者在 x=82。A(90) > D(82)，比球(x=65)更前面，在對方半場——三個條件都中。這種「插入禁區」的跑位如果沒有抓好時機，就是越位。好的前鋒會算好起跑時間，差的前鋒只會抱怨裁判。', difficulty:'easy' },
    { id:13, attackers:[{x:40,y:55,isPasser:true},{x:72,y:35,isReceiver:true},{x:83,y:70}], defenders:[{x:75,y:50,isGoalkeeper:false},{x:80,y:25,isGoalkeeper:false},{x:95,y:50,isGoalkeeper:true}], ball:{x:40,y:55}, passTo:{x:72,y:35}, isOffside:false, explanation:'芭樂子：場上有兩個進攻球員在前場——x=72（接球者）和 x=83（沒接球的）。防守者在 x=75 和 x=80，守門員 x=95。倒數第二位防守者是 x=80 的 D。接球 A 在 x=72，D 在 x=80——A(72) < D(80)，接球者沒有超過倒數第二個防守者。雖然另一個進攻球員 x=83 超過了，但球不是給他的。', difficulty:'hard' },
    { id:14, attackers:[{x:55,y:40,isPasser:true},{x:92,y:60,isReceiver:true}], defenders:[{x:100,y:80,isGoalkeeper:false},{x:88,y:50,isGoalkeeper:true}], ball:{x:55,y:40}, passTo:{x:92,y:60}, isOffside:true, explanation:'芭樂子：這題有個防守者站在 x=100（底線上），守門員在 x=88。倒數第二個防守者是守門員 x=88。接球 A 在 x=92，A(92) > GK(88)——越位！那個站在底線的 D 是最後一個防守者，但越位看的是「倒數第二個」。守門員跑出來了，越位線就跟著往前移。這種守門員出擊的場面最容易出事。', difficulty:'hard' },
    { id:15, attackers:[{x:48,y:50,isPasser:true},{x:78,y:35,isReceiver:true}], defenders:[{x:73,y:55,isGoalkeeper:false},{x:69,y:30,isGoalkeeper:false},{x:95,y:50,isGoalkeeper:true}], ball:{x:48,y:50}, passTo:{x:78,y:35}, isOffside:true, explanation:'芭樂子：防守者在 x=73 和 x=69，守門員在 x=95。倒數第二位是 x=73 的 D。接球 A 在 x=78，A(78) > D(73)，越位！這種情況在比賽中超常見——前鋒想搶點但比後衛早跑了一步。差 5 個單位，VAR 畫線出來就很明顯了。' , difficulty:'medium' }
  ];

  var LS_KEY = 'oq_stats';
  var state = { current: 0, score: 0, streak: 0, answered: false, questions: [], done: false };

  function shuffle(arr) {
    for (var i = arr.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = arr[i]; arr[i] = arr[j]; arr[j] = tmp;
    }
    return arr;
  }

  function pickQuestions() {
    var indices = [];
    for (var i = 0; i < SCENARIOS.length; i++) indices.push(i);
    shuffle(indices);
    return indices.slice(0, 10);
  }

  function loadStats() {
    try { var s = JSON.parse(localStorage.getItem(LS_KEY)); return s || { attempts: 0, scores: [] }; } catch(e) { return { attempts: 0, scores: [] }; }
  }
  function saveStats(score) {
    var s = loadStats();
    s.attempts++;
    s.scores.push(score);
    try { localStorage.setItem(LS_KEY, JSON.stringify(s)); } catch(e) {}
    renderStats();
  }
  function renderStats() {
    var s = loadStats();
    document.getElementById('statAttempts').textContent = s.attempts;
    if (s.scores.length > 0) {
      document.getElementById('statBest').textContent = Math.max.apply(null, s.scores) + '/10';
      var sum = 0; for (var i = 0; i < s.scores.length; i++) sum += s.scores[i];
      document.getElementById('statAvg').textContent = (sum / s.scores.length).toFixed(1) + '/10';
    } else {
      document.getElementById('statBest').textContent = '-';
      document.getElementById('statAvg').textContent = '-';
    }
  }

  function drawPitch(scenario, showLine) {
    var svg = document.getElementById('pitchSvg');
    var w = 400, h = 200;
    function sx(v) { return 20 + v * 3.6; }
    function sy(v) { return 10 + v * 1.8; }

    var html = '';
    html += '<defs><linearGradient id="oqGrass" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#2d8a4e"/><stop offset="100%" stop-color="#1a5c33"/></linearGradient>';
    html += '<marker id="oqArrow" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto"><path d="M0,0 L8,3 L0,6 Z" fill="#fff" opacity="0.8"/></marker></defs>';
    html += '<rect x="0" y="0" width="'+w+'" height="'+h+'" fill="url(#oqGrass)"/>';
    for (var gs = 0; gs < 10; gs++) {
      if (gs % 2 === 0) html += '<rect x="'+( 20 + gs * 36)+'" y="10" width="36" height="180" fill="rgba(255,255,255,0.03)"/>';
    }
    html += '<rect x="20" y="10" width="360" height="180" fill="none" stroke="#fff" stroke-width="1.5" rx="2"/>';
    html += '<line x1="200" y1="10" x2="200" y2="190" stroke="#fff" stroke-width="1" opacity="0.6"/>';
    html += '<circle cx="200" cy="100" r="30" fill="none" stroke="#fff" stroke-width="1" opacity="0.5"/>';
    html += '<rect x="20" y="60" width="30" height="80" fill="none" stroke="#fff" stroke-width="1" opacity="0.5"/>';
    html += '<rect x="20" y="35" width="55" height="130" fill="none" stroke="#fff" stroke-width="1" opacity="0.4"/>';
    html += '<rect x="350" y="60" width="30" height="80" fill="none" stroke="#fff" stroke-width="1" opacity="0.5"/>';
    html += '<rect x="325" y="35" width="55" height="130" fill="none" stroke="#fff" stroke-width="1" opacity="0.4"/>';
    html += '<rect x="14" y="75" width="6" height="50" fill="none" stroke="#fff" stroke-width="1.5" opacity="0.7"/>';
    html += '<rect x="380" y="75" width="6" height="50" fill="none" stroke="#fff" stroke-width="1.5" opacity="0.7"/>';

    var passer = null, receiver = null;
    for (var i = 0; i < scenario.attackers.length; i++) {
      if (scenario.attackers[i].isPasser) passer = scenario.attackers[i];
      if (scenario.attackers[i].isReceiver) receiver = scenario.attackers[i];
    }
    if (passer && scenario.passTo) {
      html += '<line x1="'+sx(passer.x)+'" y1="'+sy(passer.y)+'" x2="'+sx(scenario.passTo.x)+'" y2="'+sy(scenario.passTo.y)+'" stroke="#fff" stroke-width="1.5" stroke-dasharray="6,4" opacity="0.7" marker-end="url(#oqArrow)"/>';
    }

    if (showLine) {
      var defXs = [];
      for (var i = 0; i < scenario.defenders.length; i++) defXs.push(scenario.defenders[i].x);
      defXs.sort(function(a,b){return b-a;});
      var ofsLineX = defXs.length >= 2 ? defXs[1] : defXs[0];
      var lineColor = scenario.isOffside ? '#ef4444' : '#22c55e';
      html += '<line class="oq-line-anim" x1="'+sx(ofsLineX)+'" y1="10" x2="'+sx(ofsLineX)+'" y2="190" stroke="'+lineColor+'" stroke-width="3" stroke-dasharray="8,4" opacity="0.9"/>';
      html += '<rect x="'+(sx(ofsLineX)-2)+'" y="12" width="56" height="18" rx="4" fill="rgba(0,0,0,0.7)"/>';
      html += '<text x="'+(sx(ofsLineX)+26)+'" y="26" text-anchor="middle" fill="'+lineColor+'" font-size="13" font-weight="bold">越位線</text>';
    }

    for (var i = 0; i < scenario.defenders.length; i++) {
      var d = scenario.defenders[i];
      var cx = sx(d.x), cy = sy(d.y);
      var col = d.isGoalkeeper ? '#84cc16' : '#3b82f6';
      var label = d.isGoalkeeper ? 'G' : 'D';
      html += '<circle cx="'+cx+'" cy="'+cy+'" r="14" fill="'+col+'" stroke="#fff" stroke-width="2" opacity="0.9"/>';
      html += '<text x="'+cx+'" y="'+(cy+5)+'" text-anchor="middle" fill="#fff" font-size="13" font-weight="bold">'+label+'</text>';
    }

    for (var i = 0; i < scenario.attackers.length; i++) {
      var a = scenario.attackers[i];
      var cx = sx(a.x), cy = sy(a.y);
      html += '<circle cx="'+cx+'" cy="'+cy+'" r="14" fill="#ef4444" stroke="#fff" stroke-width="2" opacity="0.9"/>';
      if (a.isPasser) {
        html += '<circle cx="'+cx+'" cy="'+cy+'" r="19" fill="none" stroke="#fbbf24" stroke-width="2.5" opacity="0.8" class="oq-pulse-ring"/>';
      }
      if (a.isReceiver && showLine) {
        var rc = scenario.isOffside ? '#ef4444' : '#22c55e';
        html += '<circle cx="'+cx+'" cy="'+cy+'" r="19" fill="none" stroke="'+rc+'" stroke-width="3" class="oq-blink-ring"/>';
      }
      var aLabel = a.isPasser ? 'P' : (a.isReceiver ? 'A' : 'A');
      html += '<text x="'+cx+'" y="'+(cy+5)+'" text-anchor="middle" fill="#fff" font-size="13" font-weight="bold">'+aLabel+'</text>';
    }

    html += '<circle cx="'+sx(scenario.ball.x)+'" cy="'+sy(scenario.ball.y)+'" r="8" fill="#fbbf24" stroke="#fff" stroke-width="1.5" class="oq-ball-glow"/>';

    html += '<rect x="0" y="188" width="400" height="26" fill="rgba(0,0,0,0.6)" rx="0"/>';
    html += '<text x="200" y="204" text-anchor="middle" fill="#fff" font-size="10">';
    html += '<tspan fill="#fbbf24">●</tspan> 球　';
    html += '<tspan fill="#ef4444">●</tspan> P傳球　';
    html += '<tspan fill="#fff">●</tspan> A接球　';
    html += '<tspan fill="#3b82f6">●</tspan> D防守　';
    html += '<tspan fill="#84cc16">●</tspan> G守門員';
    html += '</text>';

    svg.innerHTML = html;
  }

  function renderQuestion() {
    if (state.current >= state.questions.length) { showFinal(); return; }
    var idx = state.questions[state.current];
    var sc = SCENARIOS[idx];
    state.answered = false;

    document.getElementById('progressText').textContent = '第 ' + (state.current + 1) + '/10 題';
    document.getElementById('progressFill').style.width = ((state.current + 1) * 10) + '%';
    document.getElementById('questionText').textContent = '這個傳球瞬間，接球的進攻球員越位了嗎？';

    document.getElementById('answerBtns').style.display = 'flex';
    document.getElementById('explanation').style.display = 'none';
    document.getElementById('finalPanel').style.display = 'none';
    document.getElementById('progressBar').style.display = 'block';

    var bo = document.getElementById('btnOffside');
    var bn = document.getElementById('btnOnside');
    bo.disabled = false; bn.disabled = false;
    bo.className = 'oq-btn oq-btn-offside';
    bn.className = 'oq-btn oq-btn-onside';

    drawPitch(sc, false);
  }

  window._oqAnswer = function(userSaysOffside) {
    if (state.answered || state.done) return;
    state.answered = true;
    var idx = state.questions[state.current];
    var sc = SCENARIOS[idx];
    var correct = (userSaysOffside === sc.isOffside);
    if (correct) { state.score++; state.streak++; } else { state.streak = 0; }

    var bo = document.getElementById('btnOffside');
    var bn = document.getElementById('btnOnside');
    bo.disabled = true; bn.disabled = true;

    if (userSaysOffside) {
      bo.className = 'oq-btn oq-btn-offside ' + (correct ? 'oq-correct' : 'oq-wrong');
      if (correct) bn.className = 'oq-btn oq-btn-onside';
    } else {
      bn.className = 'oq-btn oq-btn-onside ' + (correct ? 'oq-correct' : 'oq-wrong');
      if (correct) bo.className = 'oq-btn oq-btn-offside';
    }

    drawPitch(sc, true);

    var badge = document.getElementById('resultBadge');
    var streakMsg = '';
    if (correct && state.streak >= 2) {
      var streakMsgs = {
        2: '連對 2 題！有點東西哦',
        3: '3 連對！越位對你來說沒什麼難度了',
        4: '連續 4 題！你是不是偷偷在看英超？',
        5: '5 連對！芭樂子開始覺得你比我懂',
        6: '6 連對！這個程度可以去考裁判了吧？',
        7: '7 連對！VAR 都沒你準',
        8: '8 連對！FIFA 應該直接發你裁判證',
        9: '9 連對！全場起立鼓掌中',
        10: '10 連對！你不去當世足裁判真的太可惜了'
      };
      streakMsg = streakMsgs[state.streak] || '🔥 連續 ' + state.streak + ' 題！神了';
    }
    var badgeText = correct ? '✅ 答對了！' : '❌ 答錯了！連續紀錄歸零，重新開始累積！';
    if (streakMsg) badgeText += '\n🔥 ' + streakMsg;
    badge.textContent = badgeText;
    badge.style.whiteSpace = 'pre-line';
    badge.className = 'oq-result-badge ' + (correct ? 'oq-badge-correct' : 'oq-badge-wrong');
    document.getElementById('explainText').textContent = sc.explanation;
    document.getElementById('explanation').style.display = 'block';

    if (state.current >= state.questions.length - 1) {
      document.getElementById('nextBtn').textContent = '看結果 →';
    } else {
      document.getElementById('nextBtn').textContent = '下一題 →';
    }
  };

  window._oqNext = function() {
    state.current++;
    if (state.current >= state.questions.length) {
      showFinal();
    } else {
      renderQuestion();
      document.getElementById('quizArea').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  };

  function showFinal() {
    state.done = true;
    document.getElementById('answerBtns').style.display = 'none';
    document.getElementById('explanation').style.display = 'none';
    document.getElementById('progressBar').style.display = 'none';
    document.getElementById('questionText').textContent = '';
    document.getElementById('pitchWrap').style.display = 'none';

    var s = state.score;
    document.getElementById('finalScore').textContent = s + ' / 10';
    var title = '', msg = '';
    if (s === 10) { title = '🏆 VAR 認證裁判！你比真的裁判還準'; msg = '滿分！芭樂子拜服。你的越位判斷力已經超越大部分邊裁了。2026 世足考慮讓你去現場吹哨吧。'; }
    else if (s >= 8) { title = '⭐ 越位判官！偽球迷退散'; msg = '厲害，幾乎全對。你對越位規則的理解已經是專業等級了。朋友圈裡應該沒人敢跟你爭論判決。'; }
    else if (s >= 6) { title = '👍 還行，多看幾場就會了'; msg = '基本概念有了，但一些邊界情況還需要加強。多看幾場 VAR 回放，很快就能進步。'; }
    else if (s >= 4) { title = '😅 建議重看一次規則'; msg = '嗯⋯芭樂子建議你把上面的文章再讀一遍。越位規則不難，但魔鬼在細節裡。再挑戰一次？'; }
    else { title = '💀 你可能在看另一種運動'; msg = '芭樂子懷疑你是不是在想籃球的越位⋯啊不，籃球沒有越位。沒關係，再來一次，這次認真看圖！'; }

    document.getElementById('finalTitle').textContent = title;
    document.getElementById('finalMsg').textContent = msg;
    document.getElementById('finalPanel').style.display = 'block';

    saveStats(s);
    document.getElementById('quizArea').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  window._oqReplay = function() {
    state.current = 0;
    state.score = 0;
    state.streak = 0;
    state.answered = false;
    state.done = false;
    state.questions = pickQuestions();
    document.getElementById('pitchWrap').style.display = 'block';
    document.getElementById('finalPanel').style.display = 'none';
    renderQuestion();
    document.getElementById('quizArea').scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  // Init
  state.questions = pickQuestions();
  renderStats();
  renderQuestion();
})();
</script>
