          </tr>
          <tr>
            <td style="padding:0.6rem;border:1px solid var(--border)"><strong>波動率</strong></td>
            <td style="padding:0.6rem;border:1px solid var(--border)">高</td>
            <td style="padding:0.6rem;border:1px solid var(--border)">高</td>
          </tr>
          <tr>
            <td style="padding:0.6rem;border:1px solid var(--border)"><strong>線路</strong></td>
            <td style="padding:0.6rem;border:1px solid var(--border)">無賠付線</td>
