const faqs = [
  { q: '點球距離球門多遠？為什麼叫 12 碼？', a: '點球罰球點距離球門線 <strong>11 公尺（等於 12 碼）</strong>，所以俗稱「12 碼」。罰球時球放在這個點上，由一名罰球員對上守門員一對一，是足球裡得分機率最高的定位球（職業比賽進球率大約七到八成）。' },
  { q: '什麼情況會判點球？', a: '當<strong>防守方在自己的禁區內犯規</strong>，而且該犯規若發生在禁區外會被判「直接自由球」時，就會判點球。最常見的是：禁區內絆倒、推人、拉人，或<strong>手球（非守門員用手臂碰到球）</strong>。關鍵是「犯規發生在禁區內」，差一步在線上或線外，判罰天差地別。' },
  { q: '罰點球時守門員可以動嗎？', a: '可以左右移動，但<strong>在球被踢出之前，守門員必須至少有一隻腳踩在（或對齊）球門線上，不能提前往前衝</strong>。2019 年規則修改後，門將若提前離線撲到球、導致罰丟，可能會被要求重罰。所以你會看到門將在線上跳來跳去做假動作干擾，但腳不能離線太早。' },
  { q: '點球罰丟可以自己補射嗎？', a: '可以補，但<strong>罰球員不能連續兩次碰球</strong>。意思是：你射門被門將擋出來、球彈回場內，你不能馬上自己再補一腳（除非中間有別人碰到球）。但<strong>其他球員可以衝進去補射</strong>——這就是為什麼罰球瞬間，兩隊球員都會往禁區裡衝，搶第一時間的補射或解圍。' },
  { q: 'PK 大戰（互射 12 碼）怎麼比？', a: '淘汰賽如果 120 分鐘打平，就用 PK 大戰決勝。規則是<strong>兩隊各派 5 名球員輪流主罰，進球多的獲勝</strong>。如果 5 輪結束還是平手，就進入<strong>「驟死」（Sudden Death）</strong>：兩隊各再派一人，一輪定生死，直到分出高下。每個球員只能罰一次，全隊輪完才能再輪第二輪。' },
  { q: '點球和 PK 大戰是一樣的東西嗎？', a: '不一樣。<strong>點球（Penalty Kick）是「比賽進行中」因禁區犯規而判的罰球</strong>，算在比賽時間與比分裡；<strong>PK 大戰（Penalty Shootout）是「比賽 120 分鐘打平後」用來決定勝負的互射</strong>，不算進正規比分（紀錄上算平手，但晉級的是 PK 贏的那隊）。兩者罰球方式一樣（都是 12 碼一對一），但意義完全不同。' },
];

const URL = 'https://game8la.com/articles/football-penalty-kick-guide/';
