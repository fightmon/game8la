          <g fill="#9e9e9e">
            <circle cx="430" cy="120" r="16"/><circle cx="400" cy="220" r="16"/><circle cx="430" cy="320" r="16"/>
            <circle cx="350" cy="170" r="16"/><circle cx="350" cy="280" r="16"/>
