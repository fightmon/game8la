  var elS = document.getElementById('wcCdSecs');
  var elLabel = document.getElementById('wcCdLabel');
  var elMeta = document.getElementById('wcCdMeta');
  var elBox = document.getElementById('wcCountdown');
  if(!elD||!elH||!elM||!elS||!elBox) return;

  function pad(n){ return n < 10 ? '0' + n : '' + n; }

  function tick(){
    var now = Date.now();
    var diffStart = KICKOFF - now;
    var diffEnd = FINAL - now;
    var target, mode;

    if(diffStart > 0){
      target = diffStart;
      mode = 'pre';
      elLabel.textContent = '距離 2026 世足開踢還剩';
      elMeta.textContent = '📅 開幕戰：2026/06/11 ｜ 🏆 決賽：2026/07/19';
      elBox.classList.remove('wc-live','wc-ended');
    } else if(diffEnd > 0){
      target = diffEnd;
      mode = 'live';
      elLabel.textContent = '🔥 世足賽事進行中，距離決賽還剩';
      elMeta.textContent = '🏆 決賽：MetLife Stadium 紐約紐澤西 ｜ 台灣時間 7/20 凌晨 3 點';
      elBox.classList.add('wc-live');
      elBox.classList.remove('wc-ended');
    } else {
      // 已結束
      elLabel.textContent = '🏁 2026 世足已結束，距離 2030 世足開踢';
      elD.textContent = '~';
      elH.textContent = '~';
      elM.textContent = '~';
      elS.textContent = '~';
      elMeta.textContent = '⏳ 下屆 2030 西班牙＋葡萄牙＋摩洛哥三國聯辦，再等四年';
      elBox.classList.add('wc-ended');
      elBox.classList.remove('wc-live');
      return;
    }

    var totalSec = Math.floor(target / 1000);
    var days = Math.floor(totalSec / 86400);
    var hours = Math.floor((totalSec % 86400) / 3600);
    var mins = Math.floor((totalSec % 3600) / 60);
    var secs = totalSec % 60;
    elD.textContent = days;
    elH.textContent = pad(hours);
    elM.textContent = pad(mins);
    elS.textContent = pad(secs);
  }

  tick();
  setInterval(tick, 1000);
})();
</script>

<script is:inline>
(function(){
  var WF_QUIZ = [
    { q:'2026 世界盃有幾隊參加？', opts:['32 隊','48 隊','64 隊','96 隊'], ans:1, explain:'48 隊！比 2022 卡達多了 16 隊。選 96 隊的朋友，你是不是把世界盃跟聯合國大會搞混了？' },
    { q:'48 隊分成幾組？', opts:['8 組','12 組','16 組','24 組'], ans:1, explain:'12 組，每組 4 隊。以前是 8 組，現在多了 4 組，裁判工會表示加班費要調整。' },
    { q:'小組第三名有機會晉級嗎？', opts:['有，最佳 8 個第三名可以','沒有，第三名直接回家','有，全部第三名都晉級','要看裁判心情'], ans:0, explain:'12 個第三名裡取最好的 8 個！所以就算你在小組排第三，只要成績夠好，還是有機會繼續踢。選「看裁判心情」的人......你對 FIFA 的信任度也太高了。' },
    { q:'淘汰賽從幾強開始？', opts:['16 強','32 強','64 強','128 強'], ans:1, explain:'32 強！這是 2026 新增的一輪。以前小組賽結束直接打 16 強，現在多了一輪 32 強，等於多看 16 場比賽。選 128 強的人，你可能在想另一種比賽。' },
    { q:'2026 世界盃在哪裡舉辦？', opts:['卡達','美國＋加拿大＋墨西哥','日本＋韓國','巴西'], ans:1, explain:'美國、加拿大、墨西哥三國聯辦，史上第一次！16 個城市、3 個國家，球迷要帶三本護照。（好啦其實不用，北美免簽很方便。）' },
    { q:'總共要踢幾場比賽？', opts:['64 場','80 場','104 場','200 場'], ans:2, explain:'104 場！比 2022 的 64 場多了 40 場。FIFA 表示：比賽越多，轉播費越多，錢越多。資本主義萬歲。' },
    { q:'決賽在哪個球場？', opts:['阿茲台克球場（墨西哥城）','SoFi 球場（洛杉磯）','MetLife 球場（紐約紐澤西）','BMO 球場（多倫多）'], ans:2, explain:'MetLife Stadium，在紐約旁邊的紐澤西。台灣時間大約是 7/20 凌晨 3 點。建議那天直接不要睡了。' },
    { q:'小組賽每隊踢幾場？', opts:['2 場','3 場','4 場','5 場'], ans:1, explain:'還是 3 場，跟以前一樣。每組 4 隊，跟其他 3 隊各踢一場。這個沒變，別被 48 隊嚇到。' },
    { q:'小組賽平手時，先看什麼決定排名？', opts:['FIFA 世界排名','淨勝球','積分','教練長相'], ans:2, explain:'先看積分！勝 3 分、平 1 分、負 0 分。積分一樣再看淨勝球，再看進球數。選「教練長相」的......芭樂子欣賞你的幽默感，但 FIFA 還沒採用這個標準。' },
    { q:'以下哪個國家三度連續缺席世界盃？', opts:['巴西','義大利','德國','英格蘭'], ans:1, explain:'義大利！四屆冠軍竟然連續三屆（2018、2022、2026）都沒進世界盃。2026 附加賽被波士尼亞在 PK 大戰淘汰。義大利球迷表示：我們的心已經碎成義大利麵了。' }
  ];

  var TOTAL = WF_QUIZ.length;
  var LS_KEY = 'wf_stats';
  var state = { current: 0, score: 0, streak: 0, answered: false, done: false };

  function loadStats() {
    try { var s = JSON.parse(localStorage.getItem(LS_KEY)); return s || { attempts: 0, scores: [] }; } catch(e) { return { attempts: 0, scores: [] }; }
  }
  function saveStats(score) {
    var s = loadStats();
    s.attempts++;
    s.scores.push(score);
    try { localStorage.setItem(LS_KEY, JSON.stringify(s)); } catch(e) {}
    renderStats();
  }
  function renderStats() {
    var s = loadStats();
    document.getElementById('wfStatAttempts').textContent = s.attempts;
    if (s.scores.length > 0) {
      document.getElementById('wfStatBest').textContent = Math.max.apply(null, s.scores) + '/' + TOTAL;
      var sum = 0; for (var i = 0; i < s.scores.length; i++) sum += s.scores[i];
      document.getElementById('wfStatAvg').textContent = (sum / s.scores.length).toFixed(1) + '/' + TOTAL;
    } else {
      document.getElementById('wfStatBest').textContent = '-';
      document.getElementById('wfStatAvg').textContent = '-';
    }
  }

  function renderQuestion() {
    if (state.current >= TOTAL) { showFinal(); return; }
    var q = WF_QUIZ[state.current];
    state.answered = false;

    document.getElementById('wfProgressText').textContent = '第 ' + (state.current + 1) + '/' + TOTAL + ' 題';
    document.getElementById('wfProgressFill').style.width = ((state.current + 1) / TOTAL * 100) + '%';
    document.getElementById('wfQuestionText').textContent = q.q;

    document.getElementById('wfAnswerBtns').style.display = 'grid';
    document.getElementById('wfExplanation').style.display = 'none';
    document.getElementById('wfFinalPanel').style.display = 'none';
    document.getElementById('wfProgressBar').style.display = 'block';

    var btns = document.getElementById('wfAnswerBtns').querySelectorAll('button');
    for (var i = 0; i < btns.length; i++) {
      btns[i].disabled = false;
      btns[i].className = 'wf-btn';
      btns[i].textContent = q.opts[i];
    }
  }

  window._wfAnswer = function(idx) {
    if (state.answered || state.done) return;
    state.answered = true;
    var q = WF_QUIZ[state.current];
    var correct = (idx === q.ans);
    if (correct) { state.score++; state.streak++; } else { state.streak = 0; }

    var btns = document.getElementById('wfAnswerBtns').querySelectorAll('button');
    for (var i = 0; i < btns.length; i++) {
      btns[i].disabled = true;
      if (i === idx) {
        btns[i].className = 'wf-btn ' + (correct ? 'wf-correct' : 'wf-wrong');
      }
      if (!correct && i === q.ans) {
        btns[i].className = 'wf-btn wf-correct';
      }
    }

    var badge = document.getElementById('wfResultBadge');
    var streakMsg = '';
    if (correct && state.streak >= 2) {
      var streakMsgs = {
        2: '連對 2 題！你不是偽球迷',
        3: '3 連對！可以去當世足解說了',
        4: '4 連對！FIFA 想請你當規則顧問',
        5: '5 連對！你對賽制的理解比半數球評還強',
        6: '6 連對！朋友圈裡的世足百科就是你',
        7: '7 連對！體育台應該請你去講解賽制',
        8: '8 連對！你可能比 FIFA 主席還懂規則',
        9: '9 連對！全場起立鼓掌中',
        10: '10 題全對！你就是行走的世足賽制維基百科'
      };
      streakMsg = streakMsgs[state.streak] || '連續 ' + state.streak + ' 題全對！';
    }
    var badgeText = correct ? '答對了！' : '❌ 答錯了！連續紀錄歸零';
    if (streakMsg) badgeText += '\n' + streakMsg;
    badge.textContent = badgeText;
    badge.className = 'wf-result-badge ' + (correct ? 'wf-badge-correct' : 'wf-badge-wrong');
    document.getElementById('wfExplainText').textContent = q.explain;
    document.getElementById('wfExplanation').style.display = 'block';

    if (state.current >= TOTAL - 1) {
      document.getElementById('wfNextBtn').textContent = '看結果 →';
    } else {
      document.getElementById('wfNextBtn').textContent = '下一題 →';
    }
  };

  window._wfNext = function() {
    state.current++;
    if (state.current >= TOTAL) {
      showFinal();
    } else {
      renderQuestion();
      document.getElementById('wfQuizArea').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  };

  function showFinal() {
    state.done = true;
    document.getElementById('wfAnswerBtns').style.display = 'none';
    document.getElementById('wfExplanation').style.display = 'none';
    document.getElementById('wfProgressBar').style.display = 'none';
    document.getElementById('wfQuestionText').textContent = '';

    var s = state.score;
    document.getElementById('wfFinalScore').textContent = s + ' / ' + TOTAL;
    var title = '', msg = '';
    if (s === 10) { title = '🏆 世足百科全書'; msg = '滿分！芭樂子對你五體投地。你對 2026 世界盃賽制的理解已經超越 99% 的球迷了。朋友圈裡有你在，大家看球不用 Google。'; }
    else if (s >= 8) { title = '⭐ 資深球迷'; msg = '非常厲害！幾乎全對。你對新賽制的掌握已經是專家等級了，看球的時候你就是那個什麼都能解釋的人。'; }
    else if (s >= 6) { title = '👍 不錯，及格了'; msg = '基本概念有了，但一些細節還可以再加強。不過沒關係，比賽開始之後看幾場就會越來越懂了。'; }
    else if (s >= 3) { title = '😅 建議重看一次'; msg = '嗯......芭樂子建議你把上面的文章再讀一遍。新賽制確實跟以前不一樣，搞混很正常。再來一次？'; }
    else { title = '💀 你可能需要從頭來'; msg = '沒事沒事，世界盃四年才一次，規則記不住很正常。把文章仔細看完再來挑戰，芭樂子等你。'; }

    document.getElementById('wfFinalTitle').textContent = title;
    document.getElementById('wfFinalMsg').textContent = msg;
    document.getElementById('wfFinalPanel').style.display = 'block';

    saveStats(s);
    document.getElementById('wfQuizArea').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  window._wfReplay = function() {
    state.current = 0;
    state.score = 0;
    state.streak = 0;
    state.answered = false;
    state.done = false;
    document.getElementById('wfFinalPanel').style.display = 'none';
    renderQuestion();
    document.getElementById('wfQuizArea').scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  // Init
  renderStats();
  renderQuestion();
})();
</script>
