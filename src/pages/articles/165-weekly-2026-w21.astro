---
import Icon from '../../components/Icon.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import ManifestoBox from '../../components/ManifestoBox.astro';
import ShareButtons from '../../components/ShareButtons.astro';

const weekLabel = '2026 第 21 週（5/14–5/20）';
const publishDate = '2026-05-23';

/* ── 本週新增/更新品牌 ── */
const newBrands = [
  { name: 'SUPER娛樂城', url: 'www.sp88.bet', isNew: true, note: '使用 sp88.bet 這種「超短好記」的博弈域名，.bet 頂級域名幾乎是詐騙娛樂城標配。品牌名稱取「SUPER」走國際路線，但套路還是老招——短命域名 + 高額回饋誘騙入金' },
  { name: '錢盈娛樂城', url: 'qywin88.com', isNew: true, note: '與先前上榜的「錢盈539娛樂城」（lottery539.com 等）疑似同一集團。這次換了新域名 qywin88.com，品牌名稱也拿掉「539」字樣，看來是在切割舊品牌的負面紀錄、重新包裝上線' },
];

const newCount = newBrands.filter(b => b.isNew).length;
const updatedCount = newBrands.filter(b => !b.isNew).length;
---

<ArticleSchema
  url="https://game8la.com/articles/165-weekly-2026-w21/"
  title={`【165 週報】${weekLabel}：新增 ${newCount} 個詐騙娛樂城品牌`}
  description={`內政部警政署 165 全民防騙網 ${weekLabel} 詐騙通報週報。本週新增 SUPER娛樂城、錢盈娛樂城等 ${newCount} 個全新詐騙品牌。165 公告總計約 157 個詐騙網站，假投資平台持續佔大宗。GAME8LA 165 監測站即時追蹤更新。`}
  image="https://game8la.com/images/articles/165-weekly-default-cover.webp"
  datePublished={publishDate}
  dateModified={publishDate}
  breadcrumbs={[
    { name: '首頁', url: 'https://game8la.com/' },
    { name: '芭樂攻略', url: 'https://game8la.com/articles/' },
    { name: '165 週報', url: 'https://game8la.com/articles/165-weekly-2026-w21/' },
  ]}
/>
<BaseLayout
  currentPage="articles"
  title={`【165 週報】${weekLabel}新增 ${newCount} 個詐騙娛樂城｜GAME8LA 165 監測站`}
  description={`165 全民防騙網 ${weekLabel} 通報彙整：新增 ${newCount} 個詐騙娛樂城品牌。SUPER娛樂城、錢盈娛樂城全新上榜。芭樂子每週追蹤整理，保護你的錢包。`}
>
  <div class="container">
    <div class="breadcrumb"><a href="/">首頁</a> &gt; <a href="/articles/">芭樂攻略</a> &gt; 165 週報</div>
    <div style="color:var(--text-muted);font-size:0.8rem;margin-bottom:0.5rem">
      <Icon name="clock" /> 發佈日：{publishDate} ｜
      <Icon name="user-pen" /> 作者：芭樂子｜
      <Icon name="book-open" /> 預估閱讀 3 分鐘 ｜
      <span style="color:#f5b800;font-weight:700">🔍 165 監測站週報</span>
    </div>
    <a href="/articles/" class="back-link"><Icon name="arrow-left" /> 回攻略列表</a>
    <div class="hero-banner" style="background:linear-gradient(135deg,#0a0a1a,#1a1a3a,#ef4444)"></div>

    <article class="article-content" style="max-width:820px;margin:0 auto">
      <h1 style="font-size:1.8rem;line-height:1.3">🔍 165 監測站週報｜{weekLabel}<br /><em>錢盈娛樂城換皮重來，SUPER娛樂城用 .bet 域名搶客</em></h1>

      <p style="color:var(--text-muted);font-size:0.95rem">各位 8LA 鄉民好，我是芭樂子。每週我會從<strong>內政部警政署 165 全民防騙網</strong>的最新通報中，篩選出跟娛樂城、博弈相關的詐騙品牌，整理成這份週報。目的很簡單——<strong>讓你在入金之前，多一道防線</strong>。</p>

      <!-- === 本週摘要 === -->
      <div class="card" style="border-left:4px solid #ef4444;margin:1.5rem 0">
        <h3 style="margin-top:0;color:#ef4444">⚠️ 本週摘要</h3>
        <p style="margin:0">165 本週公布了約 <strong>157 筆</strong>詐騙通報，以<strong>領航e策略</strong>（假投資）15 件、<strong>Nest Markets</strong>（假投資）15 件、<strong>TikTok</strong>（冒用品牌）11 件居首。芭樂子從中篩選出 <strong>{newBrands.length} 個</strong>與娛樂城相關的品牌，<strong>全部都是新面孔</strong>。值得注意的是「錢盈娛樂城」與先前上榜的「錢盈539娛樂城」疑似同一集團換皮操作，品牌名稱拿掉「539」、網域整個換新，想甩掉之前的黑紀錄。</p>
      </div>

      <!-- === 跳週說明 === -->
      <div class="card" style="border-left:4px solid #888;margin:1.5rem 0">
        <h3 style="margin-top:0;color:#aaa">📅 為什麼跳了兩週？</h3>
        <p style="margin:0">W19（4/30–5/6）和 W20（5/7–5/13）的 165 通報中<strong>沒有任何娛樂城相關品牌</strong>被通報，所以芭樂子就沒出週報。沒消息就是好消息……嗎？其實不一定，也可能是詐騙集團在蟄伏、準備下一波。果然這週就冒出兩個新品牌了。</p>
      </div>

      <!-- === 165 總覽數據 === -->
      <div class="card" style="border-left:4px solid #44aaff;margin:1.5rem 0">
        <h3 style="margin-top:0;color:#44aaff">📈 本週 165 通報總覽</h3>
        <p>本週 165 公告共列出約 <strong>157 個</strong>詐騙網站品牌，通報量前三名分別為：</p>
        <ul style="margin:0.5rem 0;line-height:2">
          <li><strong>領航e策略</strong>（假投資）— 15 件</li>
          <li><strong>Nest Markets</strong>（假投資）— 15 件</li>
          <li><strong>TikTok</strong>（冒用品牌假購物）— 11 件</li>
        </ul>
        <p style="margin-bottom:0">整體趨勢上，<strong>假投資平台</strong>仍是通報大宗，且本週出現不少新品牌。冒用 TikTok 品牌的假購物詐騙連續多週上榜，已成固定班底。博弈類通報量偏低（僅 2 個品牌各 1 件），但這不代表詐騙娛樂城減少——更可能是它們轉往社群、廣告等更難被通報的管道運作。</p>
      </div>

      <!-- === 全新品牌 === -->
      <h2 id="new-brands" style="color:#ef4444">🆕 本週新增詐騙品牌（{newCount} 個）</h2>
      <p>以下品牌是<strong>首次</strong>被 165 通報、並由芭樂子確認為娛樂城／博弈類型的詐騙網站：</p>

      <div class="weekly-brand-list">
        {newBrands.filter(b => b.isNew).map(brand => (
          <div class="weekly-brand-card new-brand">
            <div class="brand-header">
              <span class="brand-badge new">🆕 新增</span>
              <strong>{brand.name}</strong>
            </div>
            <div class="brand-url">🌐 <code>{brand.url}</code></div>
            <p class="brand-note">💡 {brand.note}</p>
          </div>
        ))}
      </div>

      <!-- === 趨勢觀察 === -->
      <h2 id="trend">📊 本週趨勢觀察</h2>
      <div class="card" style="border-left:4px solid #f5b800;margin:1.5rem 0">
        <h3 style="margin-top:0;color:#f5b800">芭樂子觀察筆記</h3>
        <p><strong>1. 「錢盈」品牌換皮重來——拿掉 539、換掉域名、企圖洗白</strong>——錢盈539娛樂城（lottery539.com 系列）早在 2024 年就被 165 通報過 6 次。這次以「錢盈娛樂城」名義用全新域名 qywin88.com 再次出現，明顯是切割舊品牌的黑紀錄。這種「換皮」操作在詐騙娛樂城圈非常常見，玩家千萬別因為「名字不一樣」就以為是新平台。</p>
        <p><strong>2. .bet 域名持續是詐騙娛樂城的愛用款</strong>——SUPER娛樂城用 sp88.bet，這種 .bet 頂級域名幾乎已經成為詐騙博弈的標配。原因很簡單：便宜、好申請、用完即丟。看到 .bet 結尾的娛樂城網址，風險指數請自動 +50。</p>
        <p style="margin-bottom:0"><strong>3. 連續兩週沒有娛樂城通報後突然冒出兩個新品牌</strong>——W19、W20 兩週「空白期」後，本週馬上出現 2 個新品牌。詐騙集團不會真的休息，他們只是在準備新的域名和品牌包裝。這也再次提醒大家：沒被 165 通報不代表安全，被通報的只是冰山一角。</p>
      </div>

      <!-- === CTA === -->
      <div class="casino-check-cta" style="background:linear-gradient(135deg,#0a1a2e,#1a2a4a);border:2px solid #f5b800;border-radius:12px;padding:2rem;text-align:center;margin:2rem 0">
        <h3 style="color:#f5b800;margin-top:0;font-size:1.3rem">🔍 擔心你玩的娛樂城在黑名單上？</h3>
        <p style="color:#ccc;margin-bottom:1.2rem">使用「娛樂城體檢」工具，一秒比對 165 詐騙黑名單 + WHOIS 網域資訊</p>
        <a href="/casino-check/" class="cta-button" style="display:inline-block;background:#f5b800;color:#000;padding:0.8rem 2rem;border-radius:8px;font-weight:700;text-decoration:none;font-size:1.1rem">立即查詢 →</a>
      </div>

      <!-- === 資料來源 === -->
      <div style="margin-top:2rem;padding:1rem;background:rgba(255,255,255,0.05);border-radius:8px;font-size:0.85rem;color:var(--text-muted)">
        <p style="margin:0"><strong>📋 資料來源</strong>：<a href="https://165.npa.gov.tw/#/article/9/1766" target="_blank" rel="noopener noreferrer">內政部警政署 165 全民防騙網 — 115/5/14-115/5/20 民眾通報假投資(博弈)詐騙網站</a></p>
        <p style="margin:0.5rem 0 0">本站僅整理娛樂城／博弈相關通報，完整名單請參考 165 官方公告。資料更新時間：{publishDate}</p>
      </div>

      <!-- === 延伸閱讀 === -->
      <h2>📚 延伸閱讀</h2>
      <ul style="line-height:2">
        <li><a href="/casino-check/">🔍 娛樂城體檢工具 — 一鍵查詢 165 黑名單 + WHOIS</a></li>
        <li><a href="/articles/165-weekly-2026-w18/">🔍 上期週報：2026 第 18 週（4/23–4/29）</a></li>
        <li><a href="/articles/5-tips-spot-casino-scam/">🛡️ 5 招識破娛樂城詐騙套路</a></li>
        <li><a href="/articles/domain-hopping-scam-truth/">🔗 娛樂城網址一直換？金蟬脫殼詐騙真相</a></li>
        <li><a href="/articles/anti-scam-8la-guide/">🚨 防詐騙 8LA 指南：8 大手法完整解析</a></li>
      </ul>

      <ShareButtons />
      <ManifestoBox />
    </article>
  </div>
</BaseLayout>

<style>
  .weekly-brand-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 1rem 0;
  }
  .weekly-brand-card {
    background: rgba(255,255,255,0.04);
    border-radius: 10px;
    padding: 1.2rem;
    border-left: 4px solid;
  }
  .weekly-brand-card.new-brand {
    border-left-color: #ef4444;
  }
  .weekly-brand-card.updated-brand {
    border-left-color: #f5b800;
  }
  .brand-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
  }
  .brand-badge {
    font-size: 0.75rem;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-weight: 700;
    white-space: nowrap;
  }
  .brand-badge.new {
    background: rgba(239,68,68,0.2);
    color: #ef4444;
  }
  .brand-badge.updated {
    background: rgba(245,184,0,0.2);
    color: #f5b800;
  }
  .brand-url {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.4rem;
  }
  .brand-url code {
    background: rgba(255,255,255,0.08);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.85rem;
    color: #ff9999;
  }
  .brand-note {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }
  @media (max-width: 768px) {
    .weekly-brand-card { padding: 1rem; }
    .brand-header { font-size: 1rem; }
  }
</style>
