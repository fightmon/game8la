          btn.classList.add('active');
          var cf={
            '1':{path:[5,6,7,8,9],hit:[5,6,7],win:true,txt:'✅ 線 1（中排）：前 3 格都是 💎，從左連續 → 中獎！'},
            '2':{path:[0,1,2,3,4],hit:[],win:false,txt:'❌ 線 2（上排）：🍒🔔⭐🍋🍇 全不同 → 沒中'},
            '3':{path:[10,11,12,13,14],hit:[10,11,12],win:true,txt:'✅ 線 3（下排）：前 3 格都是 🔔，從左連續 → 也中獎！'}
          };
          var c=cf[line];
          cells.forEach(function(cell,i){
            cell.classList.remove('sc--hit','sc--line','sc--dim');
            if(c.hit.indexOf(i)>=0)cell.classList.add('sc--hit');
            else if(c.path.indexOf(i)>=0)cell.classList.add('sc--line');
            else cell.classList.add('sc--dim');
          });
          msg.textContent=c.txt;
          msg.className='slot-demo__note '+(c.win?'note--win':'note--lose');
        });

        // Megaways 中獎偵測（Ways to Win 邏輯：從左起相鄰轉輪有相同符號）
        var mwSym=['🍒','💎','⭐','🔔','🍋','🍇','👑','7️⃣'];
        function mwFindWins(grid){
          var cols=grid.querySelectorAll('.mw-col');
          var reels=[];
          cols.forEach(function(col){
            var cells=Array.from(col.querySelector('.mw-reel').querySelectorAll('.sc'));
            reels.push({cells:cells,syms:cells.map(function(c){return c.textContent.trim()})});
          });
          reels.forEach(function(r){r.cells.forEach(function(c){c.classList.remove('sc--hit','sc--drop');c.style.removeProperty('animation-delay')})});
          var uniq={};
          reels.forEach(function(r){r.syms.forEach(function(s){uniq[s]=true})});
          var wins=[];
          Object.keys(uniq).forEach(function(sym){
            var len=0;
            for(var i=0;i<reels.length;i++){
              if(reels[i].syms.indexOf(sym)>=0)len++;else break;
            }
            if(len>=3){
              wins.push({sym:sym,len:len});
              for(var i=0;i<len;i++){
                reels[i].cells.forEach(function(cell){
                  if(cell.textContent.trim()===sym)cell.classList.add('sc--hit');
                });
              }
            }
          });
          wins.sort(function(a,b){return b.len-a.len});
          return wins;
        }
        // 頁面載入時偵測初始盤面的中獎
        var mwG=document.getElementById('mw-grid');
        if(mwG)mwFindWins(mwG);

        document.getElementById('mw-spin')?.addEventListener('click',function(){
          var wrap=document.getElementById('mw-grid');
          var cols=wrap.querySelectorAll('.mw-col');
          var parts=[];
          cols.forEach(function(col){
            var reel=col.querySelector('.mw-reel');
            var cnt=col.querySelector('.mw-cnt');
            var n=Math.floor(Math.random()*6)+2;
            reel.innerHTML='';
            reel.style.gridTemplateRows='repeat('+n+', 1fr)';
            for(var i=0;i<n;i++){
              var cell=document.createElement('div');
              cell.className='sc';
              cell.textContent=mwSym[Math.floor(Math.random()*mwSym.length)];
              cell.classList.add('sc--drop');
              cell.style.animationDelay=(i*0.04)+'s';
              reel.appendChild(cell);
            }
            cnt.textContent=n;
            parts.push(n);
          });
          var total=parts.reduce(function(a,b){return a*b},1);
          document.getElementById('mw-calc').innerHTML=parts.join(' × ')+' = <span>'+total.toLocaleString()+' Ways</span>';
          // 等掉落動畫結束後再偵測中獎
          setTimeout(function(){
            var wins=mwFindWins(wrap);
            var note=document.getElementById('mw-note');
            if(wins.length>0){
              var desc=wins.map(function(w){return w.sym+'('+w.len+'連)'}).join(' ');
              note.innerHTML='✅ 中獎！'+desc+' — <span style="color:var(--guava-green)">綠框</span> = 從左起連續出現在相鄰轉輪';
              note.className='slot-demo__note note--win';
            }else{
              note.textContent='❌ 沒中 — 沒有符號從左起連續出現在 3 條以上轉輪';
              note.className='slot-demo__note note--lose';
            }
          },500);
        });
      </script>

    </article>
  </div>
</BaseLayout>

