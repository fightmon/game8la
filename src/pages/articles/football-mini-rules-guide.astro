  .article-content li { margin-bottom: 0.5rem; line-height: 1.85; font-size: clamp(16px, 4.2vw, 17.5px); }

  .article-img-caption { text-align: center; font-size: 0.92rem; line-height: 1.7; color: var(--text-muted); margin: 0.5rem auto 1.2rem; max-width: 680px; }
  .content-img { display: block; width: 100%; max-width: 820px; height: auto; border-radius: 12px; margin: 1rem auto 0; border: 1px solid var(--border); }

  .card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 1.2rem 1.4rem; }
  .card h3 { font-size: 1.15rem; }
  .card p { font-size: 1rem; line-height: 1.85; }

  .quick-tool-bar { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; padding: 0.8rem 1rem; margin: 1rem 0 1.5rem; font-size: 0.95rem; }
  .quick-tool-bar span { color: var(--text-muted); }
  .quick-tool-bar a { color: var(--guava-green); text-decoration: none; background: rgba(57,255,20,0.08); padding: 5px 12px; border-radius: 6px; }
  .quick-tool-bar a:hover { background: rgba(57,255,20,0.18); }

  .faq-item { border: 1px solid var(--border); border-radius: 10px; margin-bottom: 0.6rem; overflow: hidden; }
  .faq-q { padding: 1.1rem 1.3rem; cursor: pointer; font-weight: 600; font-size: 1.05rem; list-style: none; display: flex; justify-content: flex-start; gap: 0.5rem; }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-q::before { content: '▸'; color: var(--guava-green); flex-shrink: 0; }
  .faq-item[open] .faq-q::before { content: '▾ '; }
  .faq-a { margin: 0 1.3rem 1.1rem; color: var(--text-secondary); font-size: 1rem; line-height: 1.85; }

  .related-links { display: flex; flex-direction: column; gap: 0.7rem; margin: 1rem 0 2rem; }
  .rl-item { display: block; padding: 1rem 1.2rem; border: 1px solid var(--border); border-radius: 10px; text-decoration: none; color: inherit; transition: border-color 0.15s, transform 0.15s; }
  .rl-item:hover { border-color: var(--guava-green); transform: translateX(4px); }
  .rl-cat { font-size: 0.78rem; color: var(--guava-green); text-transform: uppercase; letter-spacing: 0.5px; }
  .rl-item strong { display: block; margin: 0.2rem 0; font-size: 1.02rem; }
  .rl-desc { font-size: 0.9rem; color: var(--text-muted); }

  table { width: 100%; border-collapse: collapse; font-size: 0.97rem; }
  th, td { padding: 0.75rem 0.9rem; text-align: left; border-bottom: 1px solid var(--border); line-height: 1.7; }
  th { font-weight: 700; font-size: 0.92rem; color: var(--text-muted); }

  /* === 規則圖 SVG === */
  .pitch-diagram { margin: 1.2rem 0 1.8rem; padding: 0; border: none; }
  .pitch-svg { width: 100%; max-width: 720px; height: auto; display: block; margin: 0 auto; border-radius: 12px; }
  .pitch-svg[data-zoomable] { cursor: zoom-in; transition: filter 0.2s, transform 0.2s; }
  .pitch-svg[data-zoomable]:hover { filter: brightness(1.06); transform: translateY(-1px); }
  .pitch-zoom-tip { display: block; text-align: center; font-size: 0.88rem; color: var(--text-muted); margin: 0.3rem 0 0.4rem; }

  /* === 規則快問快答 === */
  .rq-quiz { background: rgba(255,255,255,0.02); border: 1px solid var(--border); border-radius: 16px; padding: 1.4rem 1.3rem; margin: 1.2rem 0 1.8rem; }
  .rq-prog-text { display: block; text-align: center; font-size: 1rem; color: var(--text-secondary); font-weight: 700; margin-bottom: 0.5rem; }
  .rq-track { height: 7px; background: rgba(255,255,255,0.1); border-radius: 4px; overflow: hidden; }
  .rq-fill { height: 100%; background: var(--guava-green); border-radius: 4px; transition: width 0.4s ease; }
  .rq-question { text-align: center; font-size: 1.15rem; font-weight: 700; color: #eee; line-height: 1.7; margin: 1.2rem 0; }
  .rq-opts { display: flex; flex-direction: column; gap: 10px; max-width: 460px; margin: 0 auto; }
  .rq-opt { width: 100%; text-align: left; font-size: 1.05rem; font-weight: 600; padding: 13px 18px; border-radius: 12px; border: 2px solid var(--border); background: var(--bg-card); color: #eee; cursor: pointer; transition: transform 0.15s, border-color 0.2s, box-shadow 0.2s, opacity 0.2s; }
  .rq-opt:hover { transform: translateX(3px); border-color: var(--guava-green); }
  .rq-opt:disabled { cursor: default; }
  .rq-opt.rq-correct { border-color: #22c55e; box-shadow: 0 0 20px rgba(34,197,94,0.5); animation: rqPop 0.4s ease; }
  .rq-opt.rq-wrong { border-color: #ef4444; opacity: 0.5; animation: rqShake 0.5s ease; }
  @keyframes rqPop { 0% { transform: scale(1.05); } 100% { transform: scale(1); } }
  @keyframes rqShake { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-7px)} 40%{transform:translateX(7px)} 60%{transform:translateX(-4px)} 80%{transform:translateX(4px)} }
  .rq-explain { margin-top: 1.2rem; animation: rqFade 0.35s ease-out; }
  @keyframes rqFade { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }
  .rq-badge { text-align: center; font-size: 1.3rem; font-weight: 900; margin-bottom: 0.5rem; }
  .rq-badge.ok { color: #22c55e; } .rq-badge.no { color: #ef4444; }
  .rq-exp-text { background: rgba(57,255,20,0.05); border-left: 3px solid var(--guava-green); border-radius: 0 10px 10px 0; padding: 13px 17px; font-size: 1.02rem; line-height: 1.8; color: #ddd; margin-bottom: 1rem; }
  .rq-next, .rq-replay { display: block; margin: 0 auto; cursor: pointer; }
  .rq-next { background: transparent; border: 1.5px solid #555; color: #ccc; font-size: 1.02rem; padding: 10px 34px; border-radius: 10px; transition: border-color 0.2s, color 0.2s; }
  .rq-next:hover { border-color: var(--guava-green); color: #fff; }
  .rq-final { text-align: center; animation: rqFade 0.5s ease-out; }
  .rq-score { font-size: 3rem; font-weight: 900; color: var(--guava-green); }
  .rq-final-title { font-size: 1.35rem; font-weight: 800; color: #f5b800; margin: 0.3rem 0 0.5rem; }
  .rq-final-msg { font-size: 1rem; color: #bbb; line-height: 1.7; margin-bottom: 1.2rem; }
  .rq-replay { background: linear-gradient(135deg,#b8860b,#d4a056); border: none; color: #1a1a1a; font-size: 1.1rem; font-weight: 800; padding: 13px 38px; border-radius: 12px; transition: transform 0.2s, box-shadow 0.2s; }
  .rq-replay:hover { transform: translateY(-2px); box-shadow: 0 8px 22px rgba(184,134,11,0.4); }
  @media (prefers-reduced-motion: reduce) { .rq-opt.rq-correct, .rq-opt.rq-wrong, .rq-explain, .rq-final { animation: none; } }

  /* === Lightbox modal === */
  .lightbox { position: fixed; inset: 0; background: rgba(0,0,0,0.93); z-index: 9999; display: none; align-items: center; justify-content: center; padding: 24px; cursor: zoom-out; animation: lbFadeIn 0.18s ease-out; }
  .lightbox.is-open { display: flex; }
  @keyframes lbFadeIn { from { opacity: 0; } to { opacity: 1; } }
  .lightbox__inner { width: 100%; max-width: 1100px; max-height: 90vh; overflow: auto; -webkit-overflow-scrolling: touch; cursor: default; }
  .lightbox__inner svg { width: 100%; height: auto; display: block; border-radius: 12px; }
  .lightbox__close { position: fixed; top: 16px; right: 16px; width: 48px; height: 48px; border-radius: 50%; background: rgba(255,255,255,0.18); color: #fff; border: none; font-size: 26px; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10001; }
  .lightbox__close:hover { background: rgba(255,255,255,0.28); }
  .lightbox__hint { position: fixed; bottom: 18px; left: 50%; transform: translateX(-50%); color: rgba(255,255,255,0.7); font-size: 14px; pointer-events: none; }

  @media (max-width: 600px) {
    .article-content h1 { font-size: 1.55rem; }
    .article-content h2 { font-size: 1.25rem; }
  }
</style>
