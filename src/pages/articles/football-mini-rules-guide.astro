  .hero-banner { width: 100%; height: 4px; border-radius: 8px; margin-bottom: 1.5rem; }

  .article-content h1 em { font-style: normal; display: block; font-size: 0.65em; color: var(--text-muted); margin-top: 0.3rem; font-weight: 400; }
