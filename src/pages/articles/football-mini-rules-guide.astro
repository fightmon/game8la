const faqs = [
  { q: '一場足球可以換幾個人？', a: '世界盃與多數正式賽事現在是<strong>每隊最多換 5 人</strong>（90 分鐘內），但<strong>只有 3 次換人「機會」</strong>（中場休息換人不算次數）。如果踢進延長賽，可以再多換 1 人、多 1 次機會。所以你會看到教練常常一次換 2 個，就是為了省「換人次數」。' },
  { q: '界外球（擲邊）怎麼丟才不算犯規？', a: '界外球有三個鐵則：<strong>(1) 雙手同時持球、從頭頂後方過頂丟出；(2) 丟球瞬間雙腳都要在地上（不能墊腳跳起或踩線內）；(3) 面向球場丟</strong>。違反任何一條（單手、腳離地、丟法不對）就是「擲球違例」，改由對方擲邊。所以你看球員丟界外球姿勢都很固定，不是耍帥，是規則逼的。' },
  { q: '守門員可以拿球幾秒？可以接隊友回傳嗎？', a: '守門員<strong>用手控球後不能超過 6 秒</strong>（雖然裁判通常很寬鬆），超過會被判間接自由球。另外一條超重要：<strong>隊友「用腳」故意回傳給門將，門將不能用手接</strong>（叫「回傳球規則」），只能用腳處理；但如果隊友是用頭或胸口回傳，門將就可以用手。這條規則是為了防止球隊用門將無限拖時間。' },
  { q: '球門球（球門踢）是什麼？跟角球差在哪？', a: '<strong>進攻方</strong>最後碰球、讓球越過底線（球門線、沒進門），就判防守方<strong>球門球</strong>，由守門員或後衛從球門區開球發動進攻。剛好跟角球相反——<strong>角球是「防守方」把球弄出底線（送對方角球），球門球是「進攻方」把球弄出底線（還給防守方開球）</strong>。記住誰最後碰球就知道判哪個。' },
  { q: '淘汰賽平手怎麼辦？延長賽踢多久？還有「金球」嗎？', a: '世界盃淘汰賽 90 分鐘打平，先踢<strong>延長賽（上下半場各 15 分鐘，共 30 分鐘）</strong>；延長賽還是平手才進<strong>PK 大戰</strong>。現在<strong>沒有「金球制」了</strong>——以前延長賽誰先進球就直接結束（黃金進球），2004 年後廢除，現在延長賽一定踢滿 30 分鐘才算。' },
  { q: '這些小規則記不住怎麼辦？', a: '芭樂子的建議：不用一次背完。看球時遇到「咦這是什麼」再回來查，看個幾場自然就記住了。最常用的就是<strong>換人（5 換 3）、界外球丟法、角球 vs 球門球的差別</strong>，其他的遇到再說。重點是看球開心，規則是讓你看得更懂，不是考試。' },
];

const URL = 'https://game8la.com/articles/football-mini-rules-guide/';
