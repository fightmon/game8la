          <tr><td>伍獎</td><td>4 + 1</td><td>1/13,064</td><td>1.3 萬注</td><td>2,000 元</td></tr>
          <tr><td>陸獎</td><td>4</td><td>1/1,866</td><td>1,866 注</td><td>800 元</td></tr>
          <tr><td>柒獎</td><td>3 + 1</td><td>1/387</td><td>387 注</td><td>400 元</td></tr>
          <tr><td>捌獎</td><td>2 + 1</td><td>1/60</td><td>60 注</td><td>200 元</td></tr>
