import ArticleSchema from '../../components/ArticleSchema.astro';
import ManifestoBox from '../../components/ManifestoBox.astro';
import ShareButtons from '../../components/ShareButtons.astro';

const faqs = [
  { q: '直接自由球和間接自由球差在哪？', a: '<strong>直接自由球（Direct Free Kick）可以「一腳直接射門得分」</strong>，通常是對方踢人、推人、絆倒、手球等較嚴重犯規造成的；<strong>間接自由球（Indirect Free Kick）一定要先碰到第二個人，球才算進</strong>（自己直接射進不算），通常是越位、危險動作、守門員違例等情況。裁判判間接自由球時會<strong>單手高舉</strong>直到球碰到第二人，這是辨認的關鍵。' },
  { q: '罰自由球時，對方球員要退多遠？', a: '所有防守球員必須距離球<strong>至少 9.15 公尺（10 碼）</strong>，這也是「人牆」站的位置。如果防守方故意不退或站太近干擾，裁判可以出<strong>黃牌</strong>。進攻方可以要求裁判「量距離」把人牆推到 9.15 公尺外，也可以趁對方還沒排好牆<strong>快發（Quick Free Kick）</strong>偷襲。' },
  { q: '角球是怎麼產生的？', a: '當<strong>防守方球員最後碰到球、讓球越過自己的底線（球門線，但沒進球門）</strong>，就由進攻方獲得角球。球放在最靠近出界點那一側的角球區（角旗旁的四分之一圓弧）開出。簡單說：你把球擋出自己的底線，就送對方一個角球。' },
  { q: '角球可以直接射門得分嗎？', a: '可以！<strong>角球直接開進球門算進球</strong>，這叫「橄欖球式進球」或「奧林匹克進球」（Olympic Goal）。雖然角度很刁難、實際很少見，但規則允許。多數角球還是會開到禁區裡讓隊友搶頭球，因為角球<strong>不適用越位</strong>，進攻球員可以擠在門前不怕被吹。' },
  { q: '人牆可以跳起來嗎？可以排幾個人？', a: '<strong>人牆可以跳、可以排任意人數</strong>（通常 2～5 人，看自由球的角度和距離）。但 2019 年規則修改後，<strong>進攻方球員不能站進或貼著人牆裡面干擾</strong>（要距離人牆至少 1 公尺），這是為了避免推擠混亂。人牆的目的是擋住直接射門的角度，所以越靠近球門、越正面的自由球，人牆排越多人。' },
  { q: '罰自由球可以「快發」偷襲嗎？', a: '可以，而且這是聰明的戰術。只要球放定位、裁判沒有特別要求「等哨音」，進攻方就能<strong>趁對方人牆還沒排好快速開出</strong>，常常能製造絕佳機會。但如果裁判已經舉手要求「等哨」（通常是要量人牆距離或出牌），就必須等哨音，否則要重發。' },
];

const URL = 'https://game8la.com/articles/football-corner-freekick/';
