            <div class="faq-a" set:html={faq.a} />
          </details>
        ))}
      </div>

      <!-- === 免責聲明 === -->
      <div style="margin:2rem 0;padding:1rem 1.2rem;background:rgba(255,255,255,0.03);border:1px solid var(--border);border-radius:10px;font-size:0.95rem;color:var(--text-muted)">
        <p style="margin:0"><strong>芭樂子免責聲明：</strong>本文為足球教育類內容，規則以 FIFA 最新版《Laws of the Game》為準。人牆距離、快發判定裁判有判斷空間，實際以場上判罰為準。看球愉快，別在角球時跑去裝水錯過進球。</p>
      </div>

      <!-- === 延伸閱讀 === -->
      <h2 style="margin-top:2.5rem">2026 世足相關延伸閱讀</h2>
      <p>看懂定位球之後，這些規則一起補齊，看球功力直接升級：</p>
      <div class="related-links">
        <a href="/articles/football-offside-rule/" class="rl-item">
          <span class="rl-cat">足球教室</span>
          <strong>越位是什麼？看完這篇你比裁判還懂｜圖解＋互動測驗</strong>
          <span class="rl-desc">為什麼角球不算越位？這篇把越位線講到你會教別人</span>
        </a>
        <a href="/articles/football-penalty-kick-guide/" class="rl-item">
          <span class="rl-cat">足球教室</span>
          <strong>點球（12 碼）是什麼？PK 規則、流程與 PK 大戰圖解</strong>
          <span class="rl-desc">同樣是定位球，點球的規則與 PK 大戰一次看懂</span>
        </a>
        <a href="/articles/football-stoppage-time/" class="rl-item">
          <span class="rl-cat">足球教室</span>
          <strong>傷停補時是什麼？為什麼越補越長？</strong>
          <span class="rl-desc">補時補去哪了、誰決定、拖時間到底有沒有用</span>
        </a>
      </div>

      <ManifestoBox />
      <ShareButtons title="角球與自由球規則圖解：人牆退幾公尺、直接 vs 間接差在哪" url={URL} />
    </article>
  </div>

  <!-- Lightbox 圖片放大 modal -->
  <div class="lightbox" id="pitchLightbox" role="dialog" aria-modal="true" aria-label="放大圖解">
    <button type="button" class="lightbox__close" aria-label="關閉放大檢視" onclick="window._closePitchLightbox()">×</button>
    <div class="lightbox__inner" id="pitchLightboxInner" onclick="event.stopPropagation()"></div>
    <div class="lightbox__hint">點空白處或按 ESC 關閉</div>
  </div>
  <script is:inline>
    (function () {
      var lb = document.getElementById('pitchLightbox');
      var inner = document.getElementById('pitchLightboxInner');
      if (!lb || !inner) return;
      function open(svg) {
        var clone = svg.cloneNode(true);
        clone.removeAttribute('data-zoomable');
        clone.style.cursor = 'default';
        inner.innerHTML = '';
        inner.appendChild(clone);
        lb.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }
      function close() {
        lb.classList.remove('is-open');
        document.body.style.overflow = '';
        inner.innerHTML = '';
      }
      window._closePitchLightbox = close;
      document.querySelectorAll('.pitch-svg[data-zoomable]').forEach(function (svg) {
        svg.addEventListener('click', function () { open(svg); });
      });
      lb.addEventListener('click', close);
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && lb.classList.contains('is-open')) close();
      });
    })();
  </script>

  <!-- 直接/間接自由球小測驗 -->
  <script is:inline>
    (function(){
      var quiz = document.getElementById('fqQuiz');
      if (!quiz) return;
      // a: 0 = 直接, 1 = 間接
      var Q = [
        { s:'後衛在中場絆倒帶球的對方前鋒。', a:0, e:'絆倒屬於「直接犯規」→ 直接自由球，可以一腳直接射門（同樣動作發生在禁區內就升級成點球）。' },
        { s:'守門員用手接住球後，抱著超過 6 秒不放。', a:1, e:'守門員 6 秒違例 → 間接自由球，要先碰到第二個人球才算進。' },
        { s:'進攻球員站在越位位置，接到隊友的傳球。', a:1, e:'越位 → 間接自由球，由防守方在越位發生的位置開球。' },
        { s:'防守球員（非守門員）用手臂把飛來的球擋掉。', a:0, e:'手球屬於直接犯規 → 直接自由球（在禁區內就是點球）。' },
        { s:'球員高抬腿、鞋釘對著對方頭部（危險動作，但沒碰到人）。', a:1, e:'危險動作但沒有身體接觸 → 間接自由球。' },
        { s:'球員從後方鏟球，踢到對方的小腿。', a:0, e:'鏟人犯規 → 直接自由球，而且很可能吃黃牌或紅牌。' },
        { s:'隊友用腳把球回傳，守門員竟然用手把它接起來。', a:1, e:'回傳球規則違例 → 在禁區內判間接自由球，這顆超危險。' },
        { s:'沒有球的狀況下，防守球員故意用身體擋住對方的跑動路線。', a:1, e:'阻擋（無球）→ 間接自由球。' }
      ];
      var i = 0, score = 0, answered = false;
      var elProg = document.getElementById('fqProg'), elFill = document.getElementById('fqFill'),
          elScen = document.getElementById('fqScenario'), elBtns = document.getElementById('fqBtns'),
          elExplain = document.getElementById('fqExplain'), elBadge = document.getElementById('fqBadge'),
          elExpText = document.getElementById('fqExpText'), elFinal = document.getElementById('fqFinal');
      var opts = elBtns.querySelectorAll('.fq-opt');
      function show(){
        answered = false;
        elProg.textContent = '第 ' + (i + 1) + ' / ' + Q.length + ' 題';
        elFill.style.width = ((i) / Q.length * 100) + '%';
        elScen.textContent = Q[i].s;
        elBtns.style.display = 'flex';
        elExplain.hidden = true;
        opts.forEach(function(b){ b.disabled = false; b.classList.remove('fq-correct','fq-wrong'); });
      }
      function answer(choice){
        if (answered) return; answered = true;
        var correct = Q[i].a;
        if (choice === correct) score++;
        opts.forEach(function(b){
          var bi = parseInt(b.getAttribute('data-i'), 10);
          b.disabled = true;
          if (bi === correct) b.classList.add('fq-correct');
          else if (bi === choice) b.classList.add('fq-wrong');
        });
        elBadge.textContent = (choice === correct) ? '✅ 答對了！' : '❌ 答錯了';
        elBadge.className = 'fq-badge ' + (choice === correct ? 'ok' : 'no');
        elExpText.innerHTML = '<b style="color:var(--guava-green)">芭樂子：</b>' + Q[i].e;
        elFill.style.width = ((i + 1) / Q.length * 100) + '%';
        elExplain.hidden = false;
      }
      function next(){
        i++;
        if (i >= Q.length) { finish(); return; }
        show();
      }
      function finish(){
        elBtns.style.display = 'none';
        elExplain.hidden = true;
        document.getElementById('fqScore').textContent = score + ' / ' + Q.length;
        var t, m;
        if (score >= 7) { t = '🫡 準裁判等級！'; m = '直接、間接你分得一清二楚，下次看球換你糾正旁邊的老球迷。'; }
        else if (score >= 5) { t = '👍 不錯喔！'; m = '大方向都對，少數細節再熟一下就能滿分。'; }
        else if (score >= 3) { t = '😅 及格邊緣'; m = '回上面「直接 vs 間接」那張表格再複習一下，你會進步很快。'; }
        else { t = '🐣 裁判證先別考'; m = '別灰心，再看一次芭樂子的圖解，重玩一次保證進步。'; }
        document.getElementById('fqTitle').textContent = t;
        document.getElementById('fqMsg').textContent = m;
        elFinal.hidden = false;
      }
      elBtns.addEventListener('click', function(e){
        var b = e.target.closest('.fq-opt'); if (!b) return;
        answer(parseInt(b.getAttribute('data-i'), 10));
      });
      document.getElementById('fqNext').addEventListener('click', next);
      document.getElementById('fqReplay').addEventListener('click', function(){
        i = 0; score = 0; elFinal.hidden = true; show();
      });
      show();
    })();
  </script>
</BaseLayout>

