<script is:inline>
(function(){
  const $ = id => document.getElementById(id);
  const fmt = n => n.toLocaleString('zh-TW');

  function calc(){
    const dep = parseFloat($('wcDeposit').value) || 0;
    const bon = parseFloat($('wcBonus').value) || 0;
    const mul = parseFloat($('wcMulti').value) || 1;
    const total = (dep + bon) * mul;
    const houseEdge = 0.0124; // baccarat
    const loss = total * houseEdge;
    const net = bon - loss;

    $('wcTotal').textContent = '$' + fmt(Math.round(total));
    $('wcLoss').textContent = '-$' + fmt(Math.round(loss));
    $('wcNet').textContent = (net >= 0 ? '+$' : '-$') + fmt(Math.abs(Math.round(net)));
    $('wcNet').className = 'wc-value ' + (net >= 0 ? 'wc-gain' : 'wc-loss');

    const v = $('wcVerdict');
    if(net >= 0){
      v.className = 'wc-verdict wc-v-good';
      v.textContent = '✅ 數學上划算——紅利大於預期虧損，可以考慮拿';
    } else if(net > -bon){
      v.className = 'wc-verdict wc-v-warn';
      v.textContent = '⚠️ 小虧——紅利沒有全部被吃掉，但要考慮你是否本來就會打這麼多';
    } else {
      v.className = 'wc-verdict wc-v-bad';
      v.textContent = '❌ 虧損比紅利還高——拿了這筆紅利反而多虧錢，建議不要拿';
    }
  }

  ['wcDeposit','wcBonus','wcMulti'].forEach(id => {
    $(id).addEventListener('input', calc);
  });
  calc();

  // FAQ accordion
  document.querySelectorAll('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.parentElement;
      const open = item.classList.contains('open');
      document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
      if(!open) item.classList.add('open');
      btn.setAttribute('aria-expanded', !open);
    });
  });
})();
</script>

