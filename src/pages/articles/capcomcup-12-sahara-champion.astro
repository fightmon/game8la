    <div class="grid-2" style="margin:1.5rem 0">
      <div style="border-radius:12px;overflow:hidden;background:#000">
        <img src="/images/capcomcup-12/sahara-celebration-ryogoku.webp" alt="Sahara 奪冠慶祝" style="width:100%;height:auto;display:block" loading="lazy" width="1200" height="675">
      </div>
