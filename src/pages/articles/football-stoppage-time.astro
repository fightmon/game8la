import ArticleSchema from '../../components/ArticleSchema.astro';
import ManifestoBox from '../../components/ManifestoBox.astro';
import ShareButtons from '../../components/ShareButtons.astro';

const faqs = [
  { q: '足球傷停補時是什麼意思？', a: '傷停補時（Stoppage Time / Added Time）是<strong>補回上下半場「死球」浪費掉的時間</strong>。足球每半場名義上 45 分鐘，但比賽中換人、進球慶祝、球員受傷治療、VAR 確認都會讓比賽中斷，這些時間裁判會記下來，在該半場最後補回去。所以你常看到「90 分鐘」結束後還要再踢個 3～10 分鐘。' },
  { q: '補時時間是誰決定的？', a: '由<strong>主裁判</strong>決定、<strong>第四官員（場邊舉牌的那位）</strong>舉電子板公告。主裁判全場默默記錄死球時間，半場快結束時把總數告訴第四官員舉牌。要注意：<strong>那個數字是「最少」會踢的時間</strong>，如果補時內又有人受傷或拖延，還會再往上加。' },
  { q: '為什麼現代足球補時越來越長，動不動補 7、8 分鐘？', a: '因為 FIFA 從 2022 卡達世界盃開始<strong>要求裁判「精算」所有實際浪費的時間</strong>，把進球慶祝、換人、治療、VAR、慶祝跑動全部算進去，不再像以前隨便抓個 3 分鐘。所以 2022 世界盃常出現 +7、+8 甚至 +10 分鐘的補時，這是規則執行變嚴格，不是裁判心情問題。' },
  { q: '補時的時間裡，還會再補時嗎？', a: '會。<strong>補時是「至少」的概念</strong>。假設第四官員舉「+5」，但補時的第 3 分鐘有人受傷躺了 2 分鐘，主裁判可以再往上加。所以你會看到舉牌 +5、結果踢到 +7 才吹哨。比賽什麼時候真正結束，是<strong>主裁判說了算</strong>，球員和球迷只能等那一聲長哨。' },
  { q: '哪些情況會被算進傷停補時？', a: '主要有：<strong>進球後的慶祝、換人、球員受傷與治療、VAR 影像確認、球員拖延時間（換人慢吞吞、門將抱球太久）、罰球準備</strong>，以及任何讓比賽長時間中斷的狀況。簡單說：只要「球是死的、時間在流」，原則上都該被補回來。' },
  { q: '故意拖延時間（拖時間）有用嗎？會被罰嗎？', a: '短期有用、長期沒用，還可能吃黃牌。領先的球隊常用換人慢慢走、門將抱球、球出界慢慢撿來消耗時間，但<strong>這些被浪費的時間都會被算進補時補回來</strong>，等於白拖。而且明顯拖延（Time-wasting）裁判可以直接出<strong>黃牌</strong>警告。芭樂子的建議：與其拖時間被補回來又吃牌，不如好好把球控住。' },
];

const URL = 'https://game8la.com/articles/football-stoppage-time/';
