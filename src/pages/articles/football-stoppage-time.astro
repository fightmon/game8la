  <!-- Lightbox 圖片放大 modal -->
  <div class="lightbox" id="pitchLightbox" role="dialog" aria-modal="true" aria-label="放大圖解">
    <button type="button" class="lightbox__close" aria-label="關閉放大檢視" onclick="window._closePitchLightbox()">×</button>
    <div class="lightbox__inner" id="pitchLightboxInner" onclick="event.stopPropagation()"></div>
    <div class="lightbox__hint">點空白處或按 ESC 關閉</div>
  </div>
  <script is:inline>
    (function () {
      var lb = document.getElementById('pitchLightbox');
      var inner = document.getElementById('pitchLightboxInner');
      if (!lb || !inner) return;
      function open(svg) {
        var clone = svg.cloneNode(true);
        clone.removeAttribute('data-zoomable');
        clone.style.cursor = 'default';
        inner.innerHTML = '';
        inner.appendChild(clone);
        lb.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }
      function close() {
        lb.classList.remove('is-open');
        document.body.style.overflow = '';
        inner.innerHTML = '';
      }
      window._closePitchLightbox = close;
      document.querySelectorAll('.pitch-svg[data-zoomable]').forEach(function (svg) {
        svg.addEventListener('click', function () { open(svg); });
      });
      lb.addEventListener('click', close);
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && lb.classList.contains('is-open')) close();
      });
    })();
  </script>

  <!-- 傷停補時計算機 -->
  <script is:inline>
    (function(){
      var root = document.querySelector('.st-calc');
      if (!root) return;
      var NORMAL = [
        { k:'goal',   e:'⚽', label:'進球慶祝',     sec:20 },
        { k:'sub',    e:'🔄', label:'換人',         sec:10 },
        { k:'injury', e:'🤕', label:'球員受傷治療', sec:30 },
        { k:'var',    e:'📺', label:'VAR 確認',     sec:60 },
        { k:'delay',  e:'🐢', label:'拖延時間',     sec:15 }
      ];
      var ALL = NORMAL;
      var count = {};
      ALL.forEach(function(ev){ count[ev.k] = 0; });

      function rowHTML(ev){
        return '<div class="st-calc-row" data-k="' + ev.k + '">' +
          '<span class="st-ev">' + ev.e + ' ' + ev.label + ' <small>（' + ev.sec + ' 秒/次）</small></span>' +
          '<span class="st-calc-step">' +
            '<button type="button" data-act="minus" aria-label="減少">−</button>' +
            '<span class="st-cnt" id="cnt-' + ev.k + '">0</span>' +
            '<button type="button" data-act="plus" aria-label="增加">＋</button>' +
          '</span></div>';
      }
      document.getElementById('stCalcNormal').innerHTML = NORMAL.map(rowHTML).join('');

      function totalSec(){
        var s = 0;
        ALL.forEach(function(ev){ s += count[ev.k] * ev.sec; });
        return s;
      }
      function verdict(sec, min){
        if (sec === 0) return '還沒有事件發生，這場乾乾淨淨，補時先 0 分鐘——這種比賽裁判最愛，準時下班。';
        if (min <= 2) return '補 ' + min + ' 分鐘，標準場次，沒什麼好吵的，吹哨收工。';
        if (min <= 5) return '補 ' + min + ' 分鐘，有點長度了，領先的隊開始坐立難安、落後的隊眼睛發亮。';
        if (min <= 8) return '補 ' + min + ' 分鐘！這場拖很大，落後的隊還有救、領先的隊剉著等，血壓全場最高點。';
        return '補 ' + min + ' 分鐘？！這已經是另一場小比賽了。觀眾賺到、球員想哭、芭樂子血壓直接破表。';
      }
      function render(flash){
        var sec = totalSec();
        var min = Math.ceil(sec / 60);
        var numEl = document.getElementById('stCalcMin');
        numEl.textContent = '+' + min;
        document.getElementById('stCalcSec').textContent = '累積 ' + sec + ' 秒';
        document.getElementById('stCalcMsg').innerHTML = '<b>芭樂子裁判：</b>' + verdict(sec, min);
        ALL.forEach(function(ev){ document.getElementById('cnt-' + ev.k).textContent = count[ev.k]; });
        if (flash) { numEl.classList.remove('flash'); void numEl.offsetWidth; numEl.classList.add('flash'); }
      }
      root.addEventListener('click', function(e){
        var btn = e.target.closest('button[data-act]');
        if (!btn) return;
        var row = btn.closest('.st-calc-row');
        var k = row.getAttribute('data-k');
        if (btn.getAttribute('data-act') === 'plus') count[k]++;
        else count[k] = Math.max(0, count[k] - 1);
        render(true);
      });
      document.getElementById('stCalcReset').addEventListener('click', function(){
        ALL.forEach(function(ev){ count[ev.k] = 0; });
        render(false);
      });
    })();
  </script>
</BaseLayout>

