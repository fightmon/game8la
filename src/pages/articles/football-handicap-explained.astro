const faqs = [
  { q: '讓分盤到底為什麼要「讓分」？', a: '因為兩隊實力差太多時，「猜誰贏」根本沒得玩——大家都知道強隊會贏，全押強隊，盤口賠率低到像撿零錢、買弱隊又沒人要。<strong>讓分就是給強隊先「扣」幾球當門檻</strong>（例如讓 1.5 球），逼它不只要贏、還要「贏夠多」才算過關；弱隊則先「加」幾球。這樣兩邊都變成接近 50/50 的選擇，賠率也拉回兩邊都差不多 1.9 上下，這場才有得賭、才好看。' },
  { q: '讓分 -1.5 和 +1.5 是什麼意思？', a: '<strong>負號（-）是「讓分方」＝被看好的強隊</strong>，數字代表它要先扣掉幾球；<strong>正號（+）是「受讓方」＝比較弱的一隊</strong>，先加上幾球。例如「西班牙 -1.5」就是西班牙終場比數要先減 1.5 球再比；對手「+1.5」就是先加 1.5 球。記法：<strong>負號扛責任（要贏多），正號收禮物（先送你球）。</strong>' },
  { q: '讓分盤怎麼結算（怎麼算過不過關）？', a: '把<strong>讓分數套到比數上</strong>再比大小就好。買「讓分方（強隊）」：拿強隊終場比數<strong>減掉</strong>讓分數，比對手高就過關。例：西班牙 -1.5、終場 2:0 → 2−1.5＝0.5＞0，買西班牙讓分<strong>過關</strong>；但如果只贏 1:0 → 1−1.5＝−0.5＜0，<strong>不過</strong>（贏球卻輸盤，這就是讓分的陷阱）。買「受讓方（弱隊）」就是反過來：弱隊比數加上讓分數再比。' },
  { q: '為什麼讓分常常是「點五」（.5）結尾？', a: '因為<strong>有 .5 就不可能打平、不會走盤</strong>——0.5 球這種東西現實中不存在，套上去之後一定分出輸贏，盤口乾脆俐落。如果讓的是<strong>整數</strong>（讓 1 球、讓 2 球），就可能剛好「讓完打平」，這時候叫<strong>走盤</strong>，本金全額退還、不賠不賺。所以看到 .5 你就知道：這把沒有退錢這回事，要嘛過、要嘛不過。' },
  { q: '半球、一球、球半…還有 0.25、0.75 是什麼鬼？', a: '這是<strong>亞洲盤（讓球盤）</strong>的講法：半球＝0.5、一球＝1、球半＝1.5、兩球＝2。最坑的是<strong>0.25（平半）和 0.75（半一）這種「四分之一盤」</strong>——它會把你的注金<strong>自動拆成兩半</strong>，一半放在前一個整/半數、一半放後一個。例如讓 0.75＝一半當讓 0.5、一半當讓 1，結果可能是「贏一半」或「輸一半」。聽起來複雜，用本文的計算器輸入比數，它會直接幫你算出全贏／贏一半／走盤／輸一半／全輸。' },
  { q: '看懂讓分盤之後，可以去哪練手又不傷荷包？', a: '芭樂子最推的：<strong>用「世足8LA」的免費點數玩預測</strong>，天天領、輸光也不心疼，把看盤、押讓分的手感練起來，零風險。<strong>真金白銀的部分，台灣只有「運動彩券」是合法的，限 18 歲以上</strong>；網路上那些喊「穩贏報牌、體驗金、保證出金」的境外賭盤幾乎都是詐騙黑網，贏了也不出金。下注前先看芭樂子的世足博弈詐騙拆解，別把學費繳給騙子。' },
];

const URL = 'https://game8la.com/articles/football-handicap-explained/';
