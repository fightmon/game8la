  <script is:inline>
    (function () {
      var lb = document.getElementById('pitchLightbox');
      var inner = document.getElementById('pitchLightboxInner');
      if (!lb || !inner) return;
      function open(svg) {
        var clone = svg.cloneNode(true);
        clone.removeAttribute('data-zoomable');
        clone.style.cursor = 'default';
        inner.innerHTML = '';
        inner.appendChild(clone);
        lb.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }
      function close() {
        lb.classList.remove('is-open');
        document.body.style.overflow = '';
        inner.innerHTML = '';
      }
      window._closePitchLightbox = close;
      document.querySelectorAll('.pitch-svg[data-zoomable]').forEach(function (svg) {
        svg.addEventListener('click', function () { open(svg); });
      });
      lb.addEventListener('click', close);
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && lb.classList.contains('is-open')) close();
      });
    })();
  </script>

  <!-- 讓分結算計算器 -->
  <script is:inline>
    (function () {
      var root = document.getElementById('hdcCalc');
      if (!root) return;
      var $fav = document.getElementById('hdcFav'), $und = document.getElementById('hdcUnd'),
          $hcp = document.getElementById('hdcHcp'), $go = document.getElementById('hdcGo'),
          $res = document.getElementById('hdcResult'), $head = document.getElementById('hdcHeadline'),
          $favCalc = document.getElementById('hdcFavCalc'), $favV = document.getElementById('hdcFavVerdict'),
          $undCalc = document.getElementById('hdcUndCalc'), $undV = document.getElementById('hdcUndVerdict'),
          $cardFav = document.getElementById('hdcCardFav'), $cardUnd = document.getElementById('hdcCardUnd'),
          $comment = document.getElementById('hdcComment');

      // 單一整/半盤結算：margin = 強隊淨勝球, line = 讓分數
      function single(margin, line) {
        var e = margin - line;
        if (e > 1e-9) return 'win';
        if (e < -1e-9) return 'lose';
        return 'push';
      }
      // 強隊（讓分方）在讓 h 之下的結果，支援 0.25/0.75 四分盤
      function favResult(margin, h) {
        var isQuarter = Math.abs((h * 100) % 50) > 1e-6; // 0.25,0.75,1.25... → 四分盤
        if (!isQuarter) return single(margin, h);
        var m = { win: 1, push: 0, lose: -1 };
        var s = m[single(margin, h - 0.25)] + m[single(margin, h + 0.25)];
        if (s === 2) return 'win';
        if (s === 1) return 'halfwin';
        if (s === 0) return 'push';
        if (s === -1) return 'halflose';
        return 'lose';
      }
      function invert(r) {
        return { win: 'lose', lose: 'win', halfwin: 'halflose', halflose: 'halfwin', push: 'push' }[r];
      }
      var LABEL = {
        win:      { t: '✅ 全贏', d: '贏全注', cls: 'win' },
        halfwin:  { t: '🟢 贏一半', d: '半注贏、半注退本金', cls: 'win' },
        push:     { t: '⚪ 走盤', d: '退回本金，不賠不賺', cls: 'push' },
        halflose: { t: '🟠 輸一半', d: '半注輸、半注退本金', cls: 'lose' },
        lose:     { t: '❌ 全輸', d: '輸全注', cls: 'lose' }
      };

      function fmt(n) { return (Math.round(n * 100) / 100).toString(); }

      function run() {
        var fav = parseInt($fav.value, 10);
        var und = parseInt($und.value, 10);
        var h = parseFloat($hcp.value);
        if (isNaN(fav) || fav < 0) fav = 0;
        if (isNaN(und) || und < 0) und = 0;
        var margin = fav - und;

        var rFav = favResult(margin, h);
        var rUnd = invert(rFav);

        // 終場文字
        var scoreTxt = '終場 ' + fav + ' : ' + und;
        var diffTxt = margin > 0 ? ('讓分方淨勝 ' + margin + ' 球') : (margin === 0 ? '兩隊踢平' : ('讓分方淨輸 ' + (-margin) + ' 球'));
        $head.textContent = scoreTxt + '（' + diffTxt + '），讓分方讓 ' + fmt(h) + ' 球';

        // 讓分方卡
        $favCalc.textContent = '讓分後：' + fav + ' − ' + fmt(h) + ' = ' + fmt(fav - h) + '　vs　對手 ' + und;
        var lf = LABEL[rFav];
        $favV.textContent = lf.t + '（' + lf.d + '）';
        $cardFav.className = 'hdc-card ' + lf.cls;

        // 受讓方卡
        $undCalc.textContent = '受讓後：' + und + ' + ' + fmt(h) + ' = ' + fmt(und + h) + '　vs　強隊 ' + fav;
        var lu = LABEL[rUnd];
        $undV.textContent = lu.t + '（' + lu.d + '）';
        $cardUnd.className = 'hdc-card ' + lu.cls;

        // 芭樂子點評
        var c = '';
        if (margin > 0 && rFav === 'lose') {
          c = '⚠️ 經典陷阱：讓分方「贏球卻輸盤」——贏了 ' + margin + ' 球還不夠跨過 ' + fmt(h) + ' 的門檻。買它的人空歡喜一場。';
        } else if (rFav === 'push' || rFav === 'halfwin' || rFav === 'halflose') {
          c = '這就是整數盤／四分盤的眉角：不是非贏即輸，還有走盤、贏一半、輸一半。難怪有人贏球還一臉問號。';
        } else if (rFav === 'win') {
          c = '讓分方乾淨過關，淨勝 ' + margin + ' 球穩穩跨過 ' + fmt(h) + ' 門檻，買它的人爽領。';
        } else {
          c = '讓分方沒贏夠（甚至沒贏），受讓方收禮物過關。看好弱隊受讓的這把賺到。';
        }
        $comment.textContent = '芭樂子：' + c;

        $res.hidden = false;
      }

      $go.addEventListener('click', run);
      [$fav, $und].forEach(function (el) {
        el.addEventListener('keydown', function (e) { if (e.key === 'Enter') run(); });
      });
      $hcp.addEventListener('change', function () { if (!$res.hidden) run(); });
    })();
  </script>

