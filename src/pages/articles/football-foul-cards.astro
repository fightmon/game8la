  .fq-btn-free { background: linear-gradient(135deg, #2563eb, #3b82f6); color: #fff; border-color: #3b82f6; }
  .fq-btn-free:hover { box-shadow: 0 4px 15px rgba(59,130,246,0.4); }
  .fq-btn-yellow { background: linear-gradient(135deg, #ca8a04, #eab308); color: #1a1a1a; border-color: #eab308; }
  .fq-btn-yellow:hover { box-shadow: 0 4px 15px rgba(234,179,8,0.4); }
  .fq-btn-red { background: linear-gradient(135deg, #dc2626, #ef4444); color: #fff; border-color: #ef4444; }
  .fq-btn-red:hover { box-shadow: 0 4px 15px rgba(239,68,68,0.4); }

  .fq-btn.fq-correct { box-shadow: 0 0 20px rgba(34,197,94,0.6); border-color: #22c55e; }
  .fq-btn.fq-wrong { animation: fqShake 0.5s ease; border-color: #666; opacity: 0.5; }
  @keyframes fqShake { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-6px)} 40%{transform:translateX(6px)} 60%{transform:translateX(-4px)} 80%{transform:translateX(4px)} }

  .fq-explanation { margin-top: 1.2rem; animation: fqFadeIn 0.35s ease-out; }
  @keyframes fqFadeIn { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }
  .fq-result-badge { text-align: center; font-size: 1.4rem; font-weight: 800; margin-bottom: 0.5rem; white-space: pre-line; }
  .fq-result-badge.fq-badge-correct { color: #22c55e; }
  .fq-result-badge.fq-badge-wrong { color: #ef4444; }
  .fq-explain-text { background: rgba(57,255,20,0.05); border-left: 3px solid var(--guava-green, #39FF14); border-radius: 0 10px 10px 0; padding: 14px 18px; font-size: 1.05rem; line-height: 1.8; color: #ddd; margin-bottom: 0.5rem; }
  .fq-rule-ref { font-size: 0.9rem; color: var(--text-muted); margin-bottom: 1rem; padding-left: 18px; }
  .fq-next-btn { display: block; margin: 0 auto; background: transparent; border: 1.5px solid #555; color: #ccc; font-size: 1.05rem; padding: 10px 36px; border-radius: 10px; cursor: pointer; transition: all 0.2s; }
  .fq-next-btn:hover { border-color: var(--guava-green, #39FF14); color: #fff; }

  .fq-final { text-align: center; animation: fqFadeIn 0.5s ease-out; }
  .fq-final-score { font-size: 3rem; font-weight: 900; color: var(--guava-green, #39FF14); margin-bottom: 0.3rem; }
  .fq-final-title { font-size: 1.4rem; font-weight: 700; color: #fbbf24; margin-bottom: 0.5rem; }
  .fq-final-msg { font-size: 1rem; color: #bbb; margin-bottom: 1.2rem; line-height: 1.7; }
  .fq-replay-btn { background: linear-gradient(135deg, #b8860b, #d4a056); border: 2px solid #c9983a; color: #1a1a1a; font-size: 1.15rem; font-weight: 800; padding: 14px 40px; border-radius: 12px; cursor: pointer; transition: all 0.3s; letter-spacing: 2px; }
  .fq-replay-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(184,134,11,0.4); }
  .fq-share-prompt { margin-top: 1rem; font-size: 0.95rem; color: #888; }

  .fq-stats-card { max-width: 600px; margin: 2rem auto; padding: 1.2rem 1.5rem; background: var(--bg-card, rgba(255,255,255,0.03)); border: 1px solid #333; border-radius: 14px; }
  .fq-stats-title { font-size: 1.05rem; font-weight: 700; color: #eee; margin-bottom: 0.8rem; }
  .fq-stats-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .fq-stat { background: rgba(255,255,255,0.04); border-radius: 8px; padding: 8px 16px; font-size: 0.95rem; color: #bbb; }
  .fq-stat strong { font-size: 1.2rem; margin-left: 4px; color: var(--guava-green, #39FF14); }

  @media (max-width: 768px) {
    .fq-quiz-area { padding: 1rem; }
    .fq-btn { font-size: 0.98rem; padding: 12px 8px; }
    .fq-question { font-size: 1.02rem; }
    .fq-final-score { font-size: 2.5rem; }
    .fq-final-title { font-size: 1.2rem; }
  }
  @media (max-width: 480px) {
    .fq-buttons { grid-template-columns: 1fr 1fr; gap: 8px; }
    .fq-btn { font-size: 0.95rem; padding: 10px 6px; }
    .fq-explain-text { font-size: 0.95rem; padding: 10px 14px; }
    .fq-stat { padding: 6px 12px; font-size: 0.9rem; }
  }

  @media (max-width: 600px) {
    .article-content h1 { font-size: 1.55rem; }
    .article-content h2 { font-size: 1.25rem; }
  }
</style>

<script is:inline>
(function(){
  var FOUL_SCENARIOS = [
    { id:1, img:'foul-q1', desc:'芭樂子從後方飛鏟對方球員，把人家整個鏟飛起來', answer:'yellow', explain:'從後方鏟球屬於「魯莽犯規」，不管有沒有碰到球，只要動作過大危及對方安全就是黃牌。如果腳底朝上或雙腳離地，直接升級紅牌。', rule:'FIFA 規則第 12 條：魯莽犯規' },
    { id:2, img:'foul-q2', desc:'芭樂子在禁區邊緣誇張倒地翻滾，但對方根本沒碰到他', answer:'yellow', explain:'假摔（Simulation）是企圖欺騙裁判的行為，直接黃牌警告。2026 世足有 VAR，假摔被抓到的機率更高了。芭樂子奉勸：演技再好也騙不過慢動作回放。', rule:'FIFA 規則第 12 條：企圖欺騙裁判' },
    { id:3, img:'foul-q3', desc:'芭樂子跳起來腳底朝對方的腿飛踢過去，動作極度危險', answer:'red', explain:'腳底朝上的飛踢屬於「嚴重犯規」（Serious Foul Play），有極高的受傷風險，不管有沒有碰到對方都是直接紅牌。這種動作在職業比賽可能還會被追加禁賽。', rule:'FIFA 規則第 12 條：嚴重犯規' },
    { id:4, img:'foul-q4', desc:'芭樂子是守門員，跑出禁區外用手接住了球，表情超得意', answer:'free', explain:'守門員在禁區外用手觸球 = 手球犯規，判給對方直接自由球。注意：這不是紅牌！很多人以為守門員禁區外手球是紅牌，但除非是故意手球阻擋明顯進球機會，否則只是普通犯規。', rule:'FIFA 規則第 12 條：手球犯規' },
    { id:5, img:'foul-q5', desc:'芭樂子跟對方球員肩並肩互相推擠搶球，雙方都很用力', answer:'none', explain:'肩對肩的合理衝撞（Fair Charge）在足球裡是完全合法的！只要雙方都在搶球範圍內、用肩膀而不是手肘、力道沒有過大，裁判會讓比賽繼續。這就是足球的身體對抗。', rule:'FIFA 規則第 12 條：合理衝撞' },
    { id:6, img:'foul-q6', desc:'芭樂子用力拉住前面球員的球衣，球衣都快被撕破了', answer:'yellow', explain:'拉球衣是最經典的犯規動作之一。如果只是輕微拉扯，判自由球就好；但像芭樂子這樣用力到球衣快撕破、明顯阻止對方進攻，就是黃牌。如果對方有明顯得分機會被你拉住，可能升級紅牌。', rule:'FIFA 規則第 12 條：以犯規阻止有希望的進攻' },
    { id:7, img:'foul-q7', desc:'芭樂子不是守門員，但在球門前用雙手撲出去擋住射門', answer:'red', explain:'非守門員在禁區內故意用手擋住射門，而且那球幾乎確定會進 = 紅牌 + 罰球（PK）。這叫「阻止明顯的進球機會」（DOGSO），是紅牌中的紅牌。經典案例：2010 世界盃蘇亞雷斯用手擋球。', rule:'FIFA 規則第 12 條：DOGSO（阻止明顯進球機會）' },
    { id:8, img:'foul-q8', desc:'芭樂子不小心踩到對方球員的腳，被踩的人痛到跳起來', answer:'free', explain:'無意的踩腳通常判直接自由球，不一定給牌。裁判會看動作是「粗心」還是「魯莽」——如果只是跑動中不小心踩到，給自由球就好；如果是在搶球時用力踩下去，可能升級黃牌。', rule:'FIFA 規則第 12 條：粗心犯規' },
    { id:9, img:'foul-q9', desc:'芭樂子進球後把球衣脫掉甩在空中，開心到不行', answer:'yellow', explain:'進球後脫衣慶祝 = 自動黃牌，沒有例外。FIFA 規定：脫掉球衣或用球衣蓋住頭部都會被警告。所以你會看到球員進球後把球衣拉起來露出裡面的訊息，但不會脫掉——因為脫了就是黃牌。', rule:'FIFA 規則第 12 條：脫衣慶祝' },
    { id:10, img:'foul-q10', desc:'芭樂子對著裁判大吼大叫、用手指著裁判的臉，隊友怎麼拉都拉不住', answer:'red', explain:'對裁判使用攻擊性、侮辱性或辱罵性的語言和/或動作 = 直接紅牌驅逐出場。不管你覺得判決多離譜，對裁判飆髒話就是紅牌，沒有例外。很多球員就是控制不住情緒，結果讓全隊少一個人踢。', rule:'FIFA 規則第 12 條：攻擊性語言或動作' }
  ];

  var ANSWER_LABELS = { none: '沒犯規', free: '自由球', yellow: '黃牌', red: '紅牌' };
  var ANSWER_CLASSES = { none: 'fq-btn-none', free: 'fq-btn-free', yellow: 'fq-btn-yellow', red: 'fq-btn-red' };
  var LS_KEY = 'fq_stats';
  var TOTAL = FOUL_SCENARIOS.length;
  var state = { current: 0, score: 0, streak: 0, answered: false, done: false };

  function loadStats() {
    try { var s = JSON.parse(localStorage.getItem(LS_KEY)); return s || { attempts: 0, scores: [] }; } catch(e) { return { attempts: 0, scores: [] }; }
  }
  function saveStats(score) {
    var s = loadStats();
    s.attempts++;
    s.scores.push(score);
    try { localStorage.setItem(LS_KEY, JSON.stringify(s)); } catch(e) {}
    renderStats();
  }
  function renderStats() {
    var s = loadStats();
    document.getElementById('fqStatAttempts').textContent = s.attempts;
    if (s.scores.length > 0) {
      document.getElementById('fqStatBest').textContent = Math.max.apply(null, s.scores) + '/' + TOTAL;
      var sum = 0; for (var i = 0; i < s.scores.length; i++) sum += s.scores[i];
      document.getElementById('fqStatAvg').textContent = (sum / s.scores.length).toFixed(1) + '/' + TOTAL;
    } else {
      document.getElementById('fqStatBest').textContent = '-';
      document.getElementById('fqStatAvg').textContent = '-';
    }
  }

  function renderQuestion() {
    if (state.current >= TOTAL) { showFinal(); return; }
    var sc = FOUL_SCENARIOS[state.current];
    state.answered = false;

    document.getElementById('fqProgressText').textContent = '第 ' + (state.current + 1) + '/' + TOTAL + ' 題';
    document.getElementById('fqProgressFill').style.width = ((state.current + 1) / TOTAL * 100) + '%';
    document.getElementById('fqQuestionText').textContent = sc.desc;

    // Update image
    var img = document.getElementById('fqImage');
    img.src = '/images/articles/foul-quiz/' + sc.img + '.webp';
    img.srcset = '/images/articles/foul-quiz/' + sc.img + '-768w.webp 768w, /images/articles/foul-quiz/' + sc.img + '.webp 1376w';
    img.alt = '犯規情境：' + sc.desc;

    document.getElementById('fqAnswerBtns').style.display = 'grid';
    document.getElementById('fqExplanation').style.display = 'none';
    document.getElementById('fqFinalPanel').style.display = 'none';
    document.getElementById('fqProgressBar').style.display = 'block';
    document.getElementById('fqImgWrap').style.display = 'block';

    // Reset buttons
    var btns = document.getElementById('fqAnswerBtns').querySelectorAll('button');
    for (var i = 0; i < btns.length; i++) {
      btns[i].disabled = false;
      var keys = ['none','free','yellow','red'];
      btns[i].className = 'fq-btn ' + ANSWER_CLASSES[keys[i]];
    }
  }

  window._fqAnswer = function(userAnswer) {
    if (state.answered || state.done) return;
    state.answered = true;
    var sc = FOUL_SCENARIOS[state.current];
    var correct = (userAnswer === sc.answer);
    if (correct) { state.score++; state.streak++; } else { state.streak = 0; }

    // Disable all buttons and highlight
    var btns = document.getElementById('fqAnswerBtns').querySelectorAll('button');
    var keys = ['none','free','yellow','red'];
    for (var i = 0; i < btns.length; i++) {
      btns[i].disabled = true;
      if (keys[i] === userAnswer) {
        btns[i].className = 'fq-btn ' + ANSWER_CLASSES[keys[i]] + ' ' + (correct ? 'fq-correct' : 'fq-wrong');
      }
      // Highlight the correct answer if user was wrong
      if (!correct && keys[i] === sc.answer) {
        btns[i].className = 'fq-btn ' + ANSWER_CLASSES[keys[i]] + ' fq-correct';
      }
    }

    var badge = document.getElementById('fqResultBadge');
    var streakMsg = '';
    if (correct && state.streak >= 2) {
      var streakMsgs = {
        2: '連對2題！有裁判天分',
        3: '3連對！比亞洲區裁判還準',
        4: '4連對！可以去吹台灣企甲了',
        5: '5連對！英超裁判看了都想學',
        6: '6連對！VAR可以下班了',
        7: '7連對！FIFA來電了',
        8: '8連對！比99%球迷還懂',
        9: '9連對！全場起立鼓掌中',
        10: '10題全對！你不去當世足裁判真的太可惜了'
      };
      streakMsg = streakMsgs[state.streak] || '連續 ' + state.streak + ' 題全對！';
    }
    var badgeText = correct ? '答對了！正確答案：' + ANSWER_LABELS[sc.answer] : '❌答錯了！連續紀錄歸零\n正確答案：' + ANSWER_LABELS[sc.answer];
    if (streakMsg) badgeText += '\n' + streakMsg;
    badge.textContent = badgeText;
    badge.className = 'fq-result-badge ' + (correct ? 'fq-badge-correct' : 'fq-badge-wrong');
    document.getElementById('fqExplainText').textContent = sc.explain;
    document.getElementById('fqRuleRef').textContent = sc.rule;
    document.getElementById('fqExplanation').style.display = 'block';

    if (state.current >= TOTAL - 1) {
      document.getElementById('fqNextBtn').textContent = '看結果 →';
    } else {
      document.getElementById('fqNextBtn').textContent = '下一題 →';
    }
  };

  window._fqNext = function() {
    state.current++;
    if (state.current >= TOTAL) {
      showFinal();
    } else {
      renderQuestion();
      document.getElementById('fqQuizArea').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  };

  function showFinal() {
    state.done = true;
    document.getElementById('fqAnswerBtns').style.display = 'none';
    document.getElementById('fqExplanation').style.display = 'none';
    document.getElementById('fqProgressBar').style.display = 'none';
    document.getElementById('fqQuestionText').textContent = '';
    document.getElementById('fqImgWrap').style.display = 'none';

    var s = state.score;
    document.getElementById('fqFinalScore').textContent = s + ' / ' + TOTAL;
    var title = '', msg = '';
    if (s === 10) { title = '🏆FIFA認證主審！裁判界的GOAT'; msg = '滿分！芭樂子認證你是犯規判定大師。你對足球規則的理解已經超越了 99% 的球迷，2026 世足考慮讓你去現場吹哨吧。'; }
    else if (s >= 8) { title = '⭐資深裁判！球員看到你都怕'; msg = '非常厲害！你對犯規和紅黃牌的判斷已經是專業等級了。朋友圈裡應該沒人敢跟你爭論判決。'; }
    else if (s >= 6) { title = '👍不錯，可以去當第四裁判'; msg = '基本功有了，但一些細節判定還需要加強。多看幾場 VAR 回放，你很快就能更上一層樓。'; }
    else if (s >= 3) { title = '😅建議重看一次規則'; msg = '嗯⋯芭樂子建議你把上面的文章再讀一遍。犯規規則不算太難，但魔鬼在細節裡。再挑戰一次？'; }
    else { title = '💀你可能需要重新學足球'; msg = '芭樂子有點擔心你看球的品質⋯不過沒關係，犯規規則真的沒那麼簡單。把文章重新看一遍，再來挑戰一次！'; }

    document.getElementById('fqFinalTitle').textContent = title;
    document.getElementById('fqFinalMsg').textContent = msg;
    document.getElementById('fqFinalPanel').style.display = 'block';

    saveStats(s);
    document.getElementById('fqQuizArea').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  window._fqReplay = function() {
    state.current = 0;
    state.score = 0;
    state.streak = 0;
    state.answered = false;
    state.done = false;
    document.getElementById('fqImgWrap').style.display = 'block';
    document.getElementById('fqFinalPanel').style.display = 'none';
    renderQuestion();
    document.getElementById('fqQuizArea').scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  // Init
  renderStats();
  renderQuestion();
})();
</script>
