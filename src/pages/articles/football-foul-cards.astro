               srcset="/images/articles/foul-quiz/foul-q1-768w.webp 768w, /images/articles/foul-quiz/foul-q1.webp 1376w"
               sizes="(max-width: 640px) 100vw, 600px"
               loading="lazy" alt="犯規情境圖" style="width:100%;border-radius:10px;margin-bottom:0.8rem" />
        </div>

        <!-- Question -->
        <p class="fq-question" id="fqQuestionText">情境描述載入中...</p>

        <!-- Answer Buttons -->
