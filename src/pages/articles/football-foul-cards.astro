          <button type="button" class="fq-replay-btn" id="fqReplayBtn" onclick="window._fqReplay()">再玩一次</button>
          <div class="fq-share-prompt">覺得自己判得比裁判準？分享給朋友挑戰看看</div>
        </div>
      </div>

      <!-- Stats -->
      <div class="fq-stats-card" id="fqStatsCard">
        <div class="fq-stats-title">你的裁判紀錄</div>
        <div class="fq-stats-row">
