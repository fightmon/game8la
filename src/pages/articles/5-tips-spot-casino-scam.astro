              <th style="padding:0.6rem 0.8rem;text-align:left;border-bottom:2px solid var(--border)">✅ 正規平台</th>
              <th style="padding:0.6rem 0.8rem;text-align:left;border-bottom:2px solid var(--border)">❌ 黑網</th>
            </tr>
