    </article>
  </div>

  <style is:global>
    .hero-banner{ width:100%; height:4px; border-radius:8px; margin-bottom:1.5rem; }
    .content-img{ display:block; width:100%; max-width:840px; height:auto; margin:1rem auto 0; border-radius:12px; border:1px solid var(--border); }
    .article-img-caption{ text-align:center; font-size:.9rem; line-height:1.7; color:var(--text-muted); margin:.5rem auto 1.4rem; max-width:680px; }
    .wc-bait{ background:linear-gradient(135deg,rgba(244,67,54,.12),rgba(30,30,30,.55)); border:1px dashed rgba(244,67,54,.55); border-radius:16px; padding:1.5rem 1.3rem; margin:1.8rem 0; text-align:center; }
    .wc-bait-lead{ margin:.4rem 0; color:var(--text-secondary); line-height:1.75; }
    .wc-bait-btn{ display:inline-block; margin:1rem auto 0; padding:1rem 1.5rem; font-size:1.12rem; font-weight:900; color:#fff; background:linear-gradient(135deg,#ff1f1f,#c00000); border:none; border-radius:12px; cursor:pointer; animation:wcPulse 1.6s infinite; max-width:100%; }
    .wc-bait-btn:hover{ filter:brightness(1.12); }
    .wc-bait-btn:disabled{ opacity:.85; cursor:progress; animation:none; }
    @keyframes wcPulse{ 0%{box-shadow:0 0 0 0 rgba(255,31,31,.55)} 70%{box-shadow:0 0 0 14px rgba(255,31,31,0)} 100%{box-shadow:0 0 0 0 rgba(255,31,31,0)} }
    .wc-bait-reveal{ margin-top:1.5rem; animation:wcShake .5s; }
    .wc-bait-reveal img{ width:200px; max-width:62%; height:auto; border-radius:50%; border:3px solid var(--guava-green); box-shadow:0 0 24px rgba(57,255,20,.25); }
    .wc-bait-reveal h3{ color:var(--guava-pink); margin:.9rem 0 .5rem; font-size:1.3rem; }
    .wc-bait-reveal p{ color:var(--text-secondary); line-height:1.75; max-width:560px; margin:0 auto 1.1rem; }
    .wc-bait-cta{ display:flex; gap:.8rem; flex-wrap:wrap; justify-content:center; }
    @keyframes wcShake{ 0%,100%{transform:translateX(0)} 20%{transform:translateX(-8px)} 40%{transform:translateX(8px)} 60%{transform:translateX(-5px)} 80%{transform:translateX(5px)} }
    @media (prefers-reduced-motion:reduce){ .wc-bait-btn{ animation:none } .wc-bait-reveal{ animation:none } }
  </style>

  <script is:inline>
    (function(){
      var btn=document.getElementById('wcBaitBtn');
      if(!btn) return;
      var reveal=document.getElementById('wcBaitReveal'),
          title=document.getElementById('wcBaitTitle'),
          msg=document.getElementById('wcBaitMsg');
      var label='🔴 免費高清世足直播・點我看（不用錢！）';
      btn.addEventListener('click',function(){
        var n=1;
        try{ n=parseInt(localStorage.getItem('wcBaitN')||'0',10)+1; localStorage.setItem('wcBaitN',String(n)); }catch(e){}
        btn.textContent='連線中…尋找免費訊號…'; btn.disabled=true;
        setTimeout(function(){
          btn.textContent=label; btn.disabled=false;
          if(n>=3){ title.textContent='😤 第 '+n+' 次了!你是不是真的不信邪'; msg.innerHTML='芭樂子認真說:真實世界你按到第三次,個資大概已經在暗網被拍賣了。求你,<strong>看正版</strong>。'; }
          else if(n===2){ title.textContent='😮‍💨 又按?!是不是不信邪'; msg.innerHTML='第二次囉…還好還是假的。真的那種你已經中兩次木馬了。乖,<strong>看正版</strong>。'; }
          reveal.hidden=false;
          reveal.scrollIntoView({behavior:'smooth',block:'center'});
        },800);
      });
    })();
  </script>
</BaseLayout>
