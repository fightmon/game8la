---
import Icon from '../../components/Icon.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import ManifestoBox from '../../components/ManifestoBox.astro';
import ShareButtons from '../../components/ShareButtons.astro';

const weekLabel = '2026 第 17 週（4/9–4/15）';
const publishDate = '2026-04-22';

/* ── 本週新增/更新品牌 ── */
const newBrands = [
  { name: '通博娛樂城', url: 'tb657.com', isNew: true, note: '「通博」為台灣地下博弈老牌名稱，本站以 tb657.com 網域運作，典型短命域名模式' },
  { name: 'T8娛樂城', url: 't8super8.com', isNew: true, note: '使用「super8」品牌包裝，以 T8 作為簡稱吸引玩家，網域註冊時間極短' },
  { name: '卡利系統（CaliBet）', url: 'www.cali9999.net', isNew: true, note: '卡利（Cali）為知名博弈系統商名稱，本站為冒用品牌的詐騙平台，以 9999 數字營造高端感' },
];

const newCount = newBrands.filter(b => b.isNew).length;
const updatedCount = newBrands.filter(b => !b.isNew).length;
---

<ArticleSchema
  url="https://game8la.com/articles/165-weekly-2026-w17/"
  title={`【165 週報】${weekLabel}：新增 ${newCount} 個詐騙娛樂城品牌`}
  description={`內政部警政署 165 全民防騙網 ${weekLabel} 詐騙通報週報。本週新增通博娛樂城、T8娛樂城、卡利系統（CaliBet）等 ${newCount} 個全新詐騙品牌。165 公告總計約 130 個詐騙網站，假投資與博弈詐騙持續猖獗。GAME8LA 165 監測站即時追蹤更新。`}
  image="https://game8la.com/images/articles/165-weekly-default-cover.webp"
  datePublished={publishDate}
  dateModified={publishDate}
  breadcrumbs={[
    { name: '首頁', url: 'https://game8la.com/' },
    { name: '芭樂攻略', url: 'https://game8la.com/articles/' },
    { name: '165 週報', url: 'https://game8la.com/articles/165-weekly-2026-w17/' },
  ]}
/>
<BaseLayout
  currentPage="articles"
  title={`【165 週報】${weekLabel}新增 ${newCount} 個詐騙娛樂城｜GAME8LA 165 監測站`}
  description={`165 全民防騙網 ${weekLabel} 通報彙整：新增 ${newCount} 個詐騙娛樂城品牌。通博、T8、卡利系統全部上榜。芭樂子每週追蹤整理，保護你的錢包。`}
>
  <div class="container">
    <div class="breadcrumb"><a href="/">首頁</a> &gt; <a href="/articles/">芭樂攻略</a> &gt; 165 週報</div>
    <div style="color:var(--text-muted);font-size:0.8rem;margin-bottom:0.5rem">
      <Icon name="clock" /> 發佈日：{publishDate} ｜
      <Icon name="user-pen" /> 作者：芭樂子｜
      <Icon name="book-open" /> 預估閱讀 3 分鐘 ｜
      <span style="color:#f5b800;font-weight:700">🔍 165 監測站週報</span>
    </div>
    <a href="/articles/" class="back-link"><Icon name="arrow-left" /> 回攻略列表</a>
    <div class="hero-banner" style="background:linear-gradient(135deg,#0a0a1a,#1a1a3a,#ef4444)"></div>

    <article class="article-content" style="max-width:820px;margin:0 auto">
      <h1 style="font-size:1.8rem;line-height:1.3">🔍 165 監測站週報｜{weekLabel}<br /><em>新增 {newCount} 個詐騙娛樂城，老牌冒用手法再現</em></h1>

      <p style="color:var(--text-muted);font-size:0.95rem">各位 8LA 鄉民好，我是芭樂子。每週我會從<strong>內政部警政署 165 全民防騙網</strong>的最新通報中，篩選出跟娛樂城、博弈相關的詐騙品牌，整理成這份週報。目的很簡單——<strong>讓你在入金之前，多一道防線</strong>。</p>

      <!-- === 本週摘要 === -->
      <div class="card" style="border-left:4px solid #ef4444;margin:1.5rem 0">
        <h3 style="margin-top:0;color:#ef4444">⚠️ 本週摘要</h3>
        <p style="margin:0">165 全民防騙網本週公布了約 <strong>130 筆</strong>假投資／博弈詐騙網站通報（含 Nest Markets 13 件居首、Bastion X 及 P2P 各 10 件）。芭樂子從中篩選出 <strong>{newBrands.length} 個</strong>與娛樂城相關的品牌，全部為<strong>首次出現在我們的黑名單中的全新品牌</strong>。本週沒有既有品牌新增網址的情況。</p>
      </div>

      <!-- === 165 總覽數據 === -->
      <div class="card" style="border-left:4px solid #44aaff;margin:1.5rem 0">
        <h3 style="margin-top:0;color:#44aaff">📈 本週 165 通報總覽</h3>
        <p>本週 165 公告共列出約 <strong>130 個</strong>詐騙網站品牌，通報量前三名分別為：</p>
        <ul style="margin:0.5rem 0;line-height:2">
          <li><strong>Nest Markets</strong>（假投資）— 13 件</li>
          <li><strong>Bastion X</strong>（假投資）— 10 件</li>
          <li><strong>P2P</strong>（假投資）— 10 件</li>
        </ul>
        <p style="margin-bottom:0">整體趨勢上，<strong>假投資平台</strong>仍占通報大宗，假購物網站（如冒用 SHEIN、Walmart、POYA 等品牌）也明顯增加。娛樂城類型本週通報件數相對較低，但<strong>不代表風險下降</strong>——詐騙集團可能只是在轉換戰場。</p>
      </div>

      <!-- === 全新品牌 === -->
      <h2 id="new-brands" style="color:#ef4444">🆕 本週新增詐騙品牌（{newCount} 個）</h2>
      <p>以下品牌是<strong>首次</strong>被 165 通報、並由芭樂子確認為娛樂城／博弈類型的詐騙網站：</p>

      <div class="weekly-brand-list">
        {newBrands.filter(b => b.isNew).map(brand => (
          <div class="weekly-brand-card new-brand">
            <div class="brand-header">
              <span class="brand-badge new">🆕 新增</span>
              <strong>{brand.name}</strong>
            </div>
            <div class="brand-url">🌐 <code>{brand.url}</code></div>
            <p class="brand-note">💡 {brand.note}</p>
          </div>
        ))}
      </div>

      <!-- === 趨勢觀察 === -->
      <h2 id="trend">📊 本週趨勢觀察</h2>
      <div class="card" style="border-left:4px solid #f5b800;margin:1.5rem 0">
        <h3 style="margin-top:0;color:#f5b800">芭樂子觀察筆記</h3>
        <p><strong>1. 「冒用老牌博弈品牌」手法不退流行</strong>——本週的「通博」和「卡利」都是台灣玩家耳熟能詳的博弈品牌名稱。詐騙集團看準玩家對這些名字有信任感，直接拿來開假站。提醒大家：<strong>聽過的名字不等於安全</strong>，請務必用<a href="/casino-check/">娛樂城體檢工具</a>查網域。</p>
        <p><strong>2. 假投資詐騙持續壓過博弈類型</strong>——本週 130 個通報品牌中，假投資平台（如 Nest Markets、Bastion X、Robo Advisor Fund 等）占了絕大多數，娛樂城類僅 3 個。這顯示詐騙集團正把資源轉向假投資，因為假投資的單筆詐騙金額通常遠高於博弈。</p>
        <p style="margin-bottom:0"><strong>3. 假購物網站冒用國際品牌激增</strong>——SHEIN、Walmart、POYA、Lazada、TikTok 等知名品牌都被冒用建立假購物網站。這類詐騙看似跟娛樂城無關，但背後的詐騙集團往往是同一批人，只是在不同「產品線」之間切換。</p>
      </div>

      <!-- === CTA === -->
      <div class="casino-check-cta" style="background:linear-gradient(135deg,#0a1a2e,#1a2a4a);border:2px solid #f5b800;border-radius:12px;padding:2rem;text-align:center;margin:2rem 0">
        <h3 style="color:#f5b800;margin-top:0;font-size:1.3rem">🔍 擔心你玩的娛樂城在黑名單上？</h3>
        <p style="color:#ccc;margin-bottom:1.2rem">使用「娛樂城體檢」工具，一秒比對 165 詐騙黑名單 + WHOIS 網域資訊</p>
        <a href="/casino-check/" class="cta-button" style="display:inline-block;background:#f5b800;color:#000;padding:0.8rem 2rem;border-radius:8px;font-weight:700;text-decoration:none;font-size:1.1rem">立即查詢 →</a>
      </div>

      <!-- === 資料來源 === -->
      <div style="margin-top:2rem;padding:1rem;background:rgba(255,255,255,0.05);border-radius:8px;font-size:0.85rem;color:var(--text-muted)">
        <p style="margin:0"><strong>📋 資料來源</strong>：<a href="https://165.npa.gov.tw/#/article/9/1758" target="_blank" rel="noopener noreferrer">內政部警政署 165 全民防騙網 — 115/4/9-115/4/15 民眾通報假投資(博弈)詐騙網站</a></p>
        <p style="margin:0.5rem 0 0">本站僅整理娛樂城／博弈相關通報，完整名單請參考 165 官方公告。資料更新時間：{publishDate}</p>
      </div>

      <!-- === 延伸閱讀 === -->
      <h2>📚 延伸閱讀</h2>
      <ul style="line-height:2">
        <li><a href="/casino-check/">🔍 娛樂城體檢工具 — 一鍵查詢 165 黑名單 + WHOIS</a></li>
        <li><a href="/articles/165-weekly-2026-w16/">🔍 上週週報：2026 第 16 週（4/2–4/8）</a></li>
        <li><a href="/articles/5-tips-spot-casino-scam/">🛡️ 5 招識破娛樂城詐騙套路</a></li>
        <li><a href="/articles/domain-hopping-scam-truth/">🔗 娛樂城網址一直換？金蟬脫殼詐騙真相</a></li>
        <li><a href="/articles/anti-scam-8la-guide/">🚨 防詐騙 8LA 指南：8 大手法完整解析</a></li>
      </ul>

      <ShareButtons />
      <ManifestoBox />
    </article>
  </div>
</BaseLayout>

<style>
  .weekly-brand-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 1rem 0;
  }
  .weekly-brand-card {
    background: rgba(255,255,255,0.04);
    border-radius: 10px;
    padding: 1.2rem;
    border-left: 4px solid;
  }
  .weekly-brand-card.new-brand {
    border-left-color: #ef4444;
  }
  .weekly-brand-card.updated-brand {
    border-left-color: #f5b800;
  }
  .brand-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
  }
  .brand-badge {
    font-size: 0.75rem;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-weight: 700;
    white-space: nowrap;
  }
  .brand-badge.new {
    background: rgba(239,68,68,0.2);
    color: #ef4444;
  }
  .brand-badge.updated {
    background: rgba(245,184,0,0.2);
    color: #f5b800;
  }
  .brand-url {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.4rem;
  }
  .brand-url code {
    background: rgba(255,255,255,0.08);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.85rem;
    color: #ff9999;
  }
  .brand-note {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }
  @media (max-width: 768px) {
    .weekly-brand-card { padding: 1rem; }
    .brand-header { font-size: 1rem; }
  }
</style>
