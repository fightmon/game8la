import ManifestoBox from '../../components/ManifestoBox.astro';
import ShareButtons from '../../components/ShareButtons.astro';

const faqs = [
  { q: '足球場上一隊有幾個位置？', a: '一隊上場 11 人，傳統分成四條線：<strong>1 個門將、3～5 個後衛、2～5 個中場、1～3 個前鋒</strong>。實際人數要看陣型，例如 4-4-2 是 4 後衛 4 中場 2 前鋒，4-3-3 是 4 後衛 3 中場 3 前鋒。門將永遠只有 1 個，其餘 10 個外場球員怎麼分配就是教練的戰術選擇。' },
  { q: '足球背號有固定意義嗎？', a: '有傳統但不強制。經典對照是：1 號門將、2～5 號後衛、6～8 號中場、9 號中鋒、10 號核心前腰、11 號邊鋒。其中 <strong>10 號通常是球隊的靈魂人物</strong>（像梅西、馬拉度納、托蒂），9 號是主力射手。現代球員可以挑自己喜歡的號碼，所以背號只能參考，不能 100% 對應位置。' },
  { q: '中後衛和邊後衛差在哪？', a: '<strong>中後衛（CB）站中間，負責正面擋下對方前鋒、爭頂高空球</strong>，要又高又壯又會讀球；<strong>邊後衛（FB／LB／RB）站兩側，除了防守邊路，現代足球還要常常衝上去助攻、傳中</strong>，所以要能跑、體能好。簡單說中後衛是「牆」，邊後衛是「會跑的牆」。' },
  { q: '前腰、後腰是什麼意思？', a: '都是中場。<strong>後腰（防守中場 DM）站中場最後面，負責攔截、保護後防、第一時間出球</strong>，像球隊的濾網；<strong>前腰（攻擊中場 AM）站中場最前面、靠近前鋒，負責組織進攻、傳關鍵球、自己也會射門</strong>，就是 10 號那種角色。一個防守、一個進攻，剛好相反。' },
  { q: '邊鋒和中鋒哪個比較會進球？', a: '不一定，看球隊打法。<strong>中鋒（ST／CF）站最前面中央，是禁區裡的終結者，主要任務就是進球</strong>；<strong>邊鋒（LW／RW）站兩側，靠速度和盤帶內切，可以自己射也可以傳中給中鋒</strong>。現代足球邊鋒進球越來越多（像當年的 C 羅、現在很多球隊靠邊鋒得分），所以「9 號才會進球」已經是舊觀念。' },
  { q: '不懂位置也能看球嗎？', a: '當然可以！但懂了位置，看球會多一層樂趣——你會看懂「為什麼這個後衛要衝上去」「為什麼前腰要回來接球」這些跑動背後的邏輯，而不只是看誰進球。芭樂子建議：先記住「門將、後衛、中場、前鋒」四條線，再慢慢認識細項，看個幾場就上手了。' },
];

const URL = 'https://game8la.com/articles/football-positions-guide/';
