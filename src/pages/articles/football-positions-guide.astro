  <!-- Lightbox 圖片放大 modal -->
  <div class="lightbox" id="pitchLightbox" role="dialog" aria-modal="true" aria-label="放大圖解">
    <button type="button" class="lightbox__close" aria-label="關閉放大檢視" onclick="window._closePitchLightbox()">×</button>
    <div class="lightbox__inner" id="pitchLightboxInner" onclick="event.stopPropagation()"></div>
    <div class="lightbox__hint">點空白處或按 ESC 關閉</div>
  </div>
  <script is:inline>
    (function () {
      var lb = document.getElementById('pitchLightbox');
      var inner = document.getElementById('pitchLightboxInner');
      if (!lb || !inner) return;
      function open(svg) {
        var clone = svg.cloneNode(true);
        clone.removeAttribute('data-zoomable');
        clone.style.cursor = 'default';
        inner.innerHTML = '';
        inner.appendChild(clone);
        lb.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }
      function close() {
        lb.classList.remove('is-open');
        document.body.style.overflow = '';
        inner.innerHTML = '';
      }
      window._closePitchLightbox = close;
      document.querySelectorAll('.pitch-svg[data-zoomable]').forEach(function (svg) {
        svg.addEventListener('click', function () { open(svg); });
      });
      lb.addEventListener('click', close);
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && lb.classList.contains('is-open')) close();
      });
    })();
  </script>

  <!-- 陣型切換互動 -->
  <script is:inline>
    (function(){
      var grid = document.querySelector('.fp-players');
      if (!grid) return;
      var COLORS = { d: '#2196f3', m: '#4caf50', f: '#f44336' };
      var F = {
        '4-4-2':   [[180,70,'d'],[180,170,'d'],[180,290,'d'],[180,390,'d'],[360,70,'m'],[360,170,'m'],[360,290,'m'],[360,390,'m'],[560,150,'f'],[560,310,'f']],
        '4-3-3':   [[175,70,'d'],[175,175,'d'],[175,285,'d'],[175,390,'d'],[350,130,'m'],[350,230,'m'],[350,330,'m'],[560,90,'f'],[560,230,'f'],[560,370,'f']],
        '4-2-3-1': [[170,70,'d'],[170,175,'d'],[170,285,'d'],[170,390,'d'],[300,175,'m'],[300,285,'m'],[470,100,'m'],[470,230,'m'],[470,360,'m'],[580,230,'f']],
        '3-5-2':   [[185,120,'d'],[185,230,'d'],[185,340,'d'],[330,60,'m'],[330,150,'m'],[330,230,'m'],[330,310,'m'],[330,400,'m'],[565,165,'f'],[565,295,'f']]
      };
      var DESC = {
        '4-4-2': '最經典的平衡陣型，四後衛、四中場、兩前鋒，攻守均衡、好上手。',
        '4-3-3': '強調邊路與壓迫，三前鋒火力足，現代強隊最愛（西班牙、巴薩那套）。',
        '4-2-3-1': '雙後腰超穩，一個前腰串聯、一個中鋒頂在最前，攻守兼顧的主流陣型。',
        '3-5-2': '三中衛＋兩翼衛狂跑，中場人多、控球強，但邊路防守很吃體能。'
      };
      var players = [];
      for (var i = 0; i < 10; i++) players.push(document.getElementById('fp' + i));
      function apply(name){
        var arr = F[name]; if (!arr) return;
        for (var i = 0; i < 10; i++){
          if (!players[i]) continue;
          var p = arr[i];
          players[i].style.transform = 'translate(' + p[0] + 'px,' + p[1] + 'px)';
          var dot = players[i].querySelector('.fp-dot');
          if (dot) dot.setAttribute('fill', COLORS[p[2]]);
        }
        var desc = document.getElementById('fpDesc');
        if (desc) desc.innerHTML = '<b>' + name + '</b>：' + DESC[name];
        var bs = document.querySelectorAll('.fp-btn');
        for (var k = 0; k < bs.length; k++) bs[k].classList.toggle('fp-btn-on', bs[k].getAttribute('data-f') === name);
      }
      var btns = document.querySelectorAll('.fp-btn');
      for (var b = 0; b < btns.length; b++){
        btns[b].addEventListener('click', function(){ apply(this.getAttribute('data-f')); });
      }
    })();
  </script>
