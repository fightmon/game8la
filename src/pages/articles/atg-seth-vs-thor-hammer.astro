---
import Icon from '../../components/Icon.astro';
import ManifestoBox from '../../components/ManifestoBox.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqSchema from '../../components/FaqSchema.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import ToolBox from '../../components/ToolBox.astro';

const faqs = [
  { q: '戰神賽特2 跟雷神之錘2 哪台比較好贏？', a: '沒有哪台「比較好贏」。雷神 RTP 97.6% 看起來比賽特 96.89% 高，但差距只有 0.71%——每轉 100 元大約差 0.71 元。兩台都是高波動率老虎機，長期都是虧的，差別在短期誰先爆。追穩健倍數選雷神，追極限天花板選賽特。' },
  { q: '兩台的免費遊戲觸發難度一樣嗎？', a: '差不多。賽特要集 4 個 SCATTER，雷神要集 4 個 Bonus 符號，都是「等老天爺賞臉」。賽特進免遊後隨機進一般或覺醒模式，運氣好直接跳進分裂+鎖定的強化版。雷神則看有沒有出 Super Bonus 符號，有出就進超級免遊，高倍數球出現率大幅提高。' },
  { q: '買免遊該買哪台的？', a: '賽特只有一個 x100 價位，按下去聽天由命。雷神有三段式：100x（一般）、500x（超級）、4000x（神運一擊全場 1000x 倍數球）。如果你喜歡「花一筆固定成本、不想選太多」就買賽特；喜歡「依預算分段押注」就買雷神。不管買哪台，買免遊都不會改變 RTP，只是省掉等 Scatter 的時間。' },
  { q: '新手先玩哪台？', a: '芭樂子推薦先玩雷神之錘2。RTP 97.6% 比賽特高 0.71%，理論上虧得比較慢；倍數球就是五種顏色加在一起乘分數，很好懂；也沒有賽特那種「覺醒之力裡面還要再觸發分裂跟鎖定」的多層機制。等雷神的節奏摸熟了，再跳賽特2 體驗分裂跟鎖定不遲。' },
  { q: '倍數符號最高值 1000x vs x500，到底差在哪？', a: '雷神單顆倍數球最高 1000x（彩虹球），賽特單顆最高 x500。但這不代表雷神一定爆更多——因為賽特的分裂技能可以把一顆倍數球拆成 6 顆，鎖定技能又能把它們釘在盤面 6 回合。一顆 x500 分裂成 6 顆 = 3000x，再鎖 6 轉反覆乘……理論上限反而更高，這就是為什麼賽特最大倍率 x81,000 而雷神只有 x25,000。' },
  { q: '兩台都有 Jackpot 嗎？', a: '都有，而且都是四段式：MINI、MINOR、MAJOR、GRAND。但賽特1代沒有 JP（只有2代有），雷神兩代都有。JP 彩金算是額外的驚喜獎，觸發條件跟主遊戲的消除和倍數系統獨立。' },
];
---
<FaqSchema faqs={faqs} />
<ArticleSchema
