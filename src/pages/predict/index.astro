---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  currentPage="predict"
  title="世足神準預測｜猜單場、猜冠軍，比眼光衝排行榜 - GAME8LA"
  description="免費世足預測遊戲：猜世足單場勝平負、猜冠軍，用眼光點押注，跟全站鄉民比準度、衝排行榜。加入送 1000 點、每天補滿。純預測娛樂、無真實輸贏。"
>
  <div class="container">
    <div class="page-hero">
      <a href="/member/" class="pp-back">← 回會員中心</a>
      <h1>⚽ 世足神準預測</h1>
      <p class="hero-sub">猜對賺眼光點 · 比準度衝排行榜</p>
    </div>

    <!-- 未登入 -->
    <div id="ppGuest" class="pp-card" style="display:none">
      <h2>先登入會員,才能開始預測 🎯</h2>
      <p>加入即送 1,000 眼光點,每天免費補滿。到會員中心一鍵 Google 登入就能開始猜。</p>
      <a href="/member/" class="pp-loginbtn">前往會員中心登入 →</a>
    </div>

    <!-- 已登入：遊戲 -->
    <div id="ppGame" style="display:none">
      <div class="pp-walletbar">
        <span>🪙 眼光點 <strong id="ppPoints">0</strong></span>
        <a href="/member/" class="pp-wallet-link">我的後台 →</a>
      </div>
      <div id="evList" class="ev-list"><p class="muted">載入賽事中…</p></div>
    </div>

    <div id="ppLoading" class="pp-card pp-loading">載入中…</div>
  </div>

  <script is:inline>
    var VIG = 0.08;
    function showState(s) {
      document.getElementById('ppLoading').style.display = s === 'loading' ? '' : 'none';
      document.getElementById('ppGuest').style.display = s === 'guest' ? '' : 'none';
      document.getElementById('ppGame').style.display = s === 'game' ? '' : 'none';
    }
    function setPoints(p) { var el = document.getElementById('ppPoints'); if (el) el.textContent = (p || 0).toLocaleString(); }

    function fmtTime(iso) {
      var d = new Date(iso), mm = d.getMonth() + 1, dd = d.getDate(), hh = ('0' + d.getHours()).slice(-2), mi = ('0' + d.getMinutes()).slice(-2);
      return mm + '/' + dd + ' ' + hh + ':' + mi;
    }
    function loadEvents() {
      fetch('/api/events').then(function (r) { return r.json(); }).then(function (j) {
        if (j.points != null) setPoints(j.points);
        var list = document.getElementById('evList');
        if (!j.events || !j.events.length) { list.innerHTML = '<p class="muted">目前沒有可預測的賽事。</p>'; return; }
        list.innerHTML = j.events.map(renderEvent).join('');
      });
    }
    function renderEvent(e) {
      var optMap = {}; e.options.forEach(function (o) { optMap[o.key] = o; });
      if (e.status === 'settled') {
        var resLabel = optMap[e.result] ? optMap[e.result].label : e.result;
        var mine = e.myPrediction;
        var mineHtml = mine ? (mine.status === 'won' ? '<span class="ev-won">✅ 你猜中了,+' + mine.payout + ' 點</span>' : '<span class="ev-lost">❌ 沒中,−' + mine.stake + ' 點</span>') : '<span class="muted">你沒押這場</span>';
        return '<div class="ev-card settled"><div class="ev-title">' + e.title + '</div><div class="ev-res">結果：<b>' + resLabel + '</b>　' + mineHtml + '</div></div>';
      }
      if (e.myPrediction) {
        var mp = e.myPrediction, ol = optMap[mp.choice] ? optMap[mp.choice].label : mp.choice;
        return '<div class="ev-card mine"><div class="ev-title">' + e.title + '</div><div class="ev-time">' + fmtTime(e.starts_at) + ' 開賽</div><div class="ev-mybet">🎯 你押了 <b>' + mp.stake + '</b> 點在「<b>' + ol + '</b>」· 猜中可得 <b>' + mp.potential_payout + '</b> 點 · 等待結算</div></div>';
      }
      if (e.locked) {
        return '<div class="ev-card locked"><div class="ev-title">' + e.title + '</div><div class="muted">⏰ 已鎖單(開賽了),這場你沒押到。</div></div>';
      }
      var opts = e.options.map(function (o) {
        return '<button class="ev-opt" data-ev="' + e.id + '" data-key="' + o.key + '" data-prob="' + o.prob + '">' + o.label + ' <small>' + Math.round(o.prob * 100) + '%</small></button>';
      }).join('');
      return '<div class="ev-card" data-ev="' + e.id + '"><div class="ev-title">' + e.title + '</div><div class="ev-time">' + fmtTime(e.starts_at) + ' 截止</div><div class="ev-opts">' + opts + '</div>' +
        '<div class="ev-stake" id="stk' + e.id + '" hidden><div class="ev-stake-row">押 <input type="number" class="ev-stake-input" id="stkin' + e.id + '" value="100" min="1"> 點 <button class="ev-submit" data-ev="' + e.id + '">確認預測</button></div><div class="ev-preview" id="prev' + e.id + '"></div></div></div>';
    }

    var pickState = {};
    function updatePreview(evId) {
      var p = pickState[evId]; if (!p) return;
      var stake = parseInt(document.getElementById('stkin' + evId).value, 10) || 0;
      var odds = 1 / p.prob, payout = Math.max(stake, Math.round(stake * odds * (1 - VIG)));
      document.getElementById('prev' + evId).innerHTML = '猜中可得 <b>' + payout + '</b> 點　<span class="prev-meta">隱含勝率 ' + Math.round(p.prob * 100) + '% · 賠率 ' + odds.toFixed(2) + ' · <b>莊家抽水 ' + (VIG * 100) + '%</b></span>';
    }
    function deselect(evId) {
      delete pickState[evId];
      var card = document.querySelector('.ev-card[data-ev="' + evId + '"]');
      if (card) card.querySelectorAll('.ev-opt').forEach(function (b) { b.classList.remove('sel'); });
      var stk = document.getElementById('stk' + evId); if (stk) stk.hidden = true;
    }
    document.getElementById('evList').addEventListener('click', function (ev) {
      var opt = ev.target.closest('.ev-opt');
      if (opt) {
        var evId = opt.getAttribute('data-ev');
        // 再按一次同一隊 → 取消
        if (opt.classList.contains('sel')) { deselect(evId); return; }
        pickState[evId] = { key: opt.getAttribute('data-key'), prob: parseFloat(opt.getAttribute('data-prob')) };
        var card = opt.closest('.ev-card');
        card.querySelectorAll('.ev-opt').forEach(function (b) { b.classList.remove('sel'); });
        opt.classList.add('sel');
        document.getElementById('stk' + evId).hidden = false;
        updatePreview(evId);
        return;
      }
      var sub = ev.target.closest('.ev-submit');
      if (sub) {
        var id = sub.getAttribute('data-ev'), p = pickState[id];
        if (!p) { alert('先選一個結果'); return; }
        var stake = parseInt(document.getElementById('stkin' + id).value, 10) || 0;
        if (stake < 1) { alert('至少押 1 點'); return; }
        sub.disabled = true; sub.textContent = '送出中…';
        fetch('/api/predict', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ eventId: parseInt(id, 10), choice: p.key, stake: stake }) })
          .then(function (r) { return r.json(); })
          .then(function (j) {
            if (j.ok) { setPoints(j.points); loadEvents(); }
            else { alert('預測失敗：' + ({ 'not-enough-points': '點數不足', 'locked': '已鎖單', 'already-predicted': '你已經押過這場了' }[j.error] || j.error)); sub.disabled = false; sub.textContent = '確認預測'; }
          }).catch(function (e) { alert('錯誤：' + e); sub.disabled = false; sub.textContent = '確認預測'; });
      }
    });
    document.getElementById('evList').addEventListener('input', function (ev) {
      if (ev.target.classList.contains('ev-stake-input')) updatePreview(ev.target.id.replace('stkin', ''));
    });

    fetch('/api/me').then(function (r) { return r.json(); }).then(function (j) {
      if (j.member) { showState('game'); loadEvents(); } else showState('guest');
    }).catch(function () { showState('guest'); });
  </script>

  <style is:global>
    .page-hero { text-align: center; padding: 1.5rem 1rem 0.8rem; max-width: 720px; margin: 0 auto; position: relative; }
    .pp-back { position: absolute; left: 1rem; top: 1.5rem; font-size: 0.85rem; color: var(--text-muted); text-decoration: none; }
    .pp-back:hover { color: #FFD700; }
    .page-hero h1 { font-size: clamp(1.6rem, 6vw, 2.1rem); font-weight: 900; margin: 0 0 0.4rem; background: linear-gradient(135deg, #FFD700, #ff8800); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .hero-sub { font-size: 1.05rem; color: var(--text-secondary); font-weight: 700; margin: 0; }
    .muted { color: var(--text-muted); }

    .pp-card { max-width: 560px; margin: 1.2rem auto; background: var(--bg-secondary); border: 1px solid rgba(255,255,255,0.06); border-radius: 16px; padding: 1.8rem 1.6rem; text-align: center; }
    .pp-loading { color: var(--text-muted); }
    .pp-card h2 { font-size: 1.3rem; margin: 0 0 0.6rem; }
    .pp-card p { color: var(--text-secondary); line-height: 1.8; }
    .pp-loginbtn { display: inline-block; margin-top: 1rem; padding: 0.8rem 1.8rem; border-radius: 12px; background: linear-gradient(135deg, #FFD700, #ff8800); color: #000; font-weight: 800; text-decoration: none; }

    .pp-walletbar { max-width: 640px; margin: 0 auto 1rem; display: flex; align-items: center; justify-content: space-between; background: linear-gradient(135deg, rgba(255,215,0,0.08), rgba(255,136,0,0.04)); border: 1px solid rgba(255,215,0,0.25); border-radius: 12px; padding: 0.8rem 1.1rem; }
    .pp-walletbar strong { color: #FFD700; font-size: 1.2rem; }
    .pp-wallet-link { font-size: 0.85rem; color: var(--text-muted); text-decoration: none; }
    .pp-wallet-link:hover { color: #FFD700; }

    .ev-list { max-width: 640px; margin: 0 auto; }
    .ev-card { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 14px; padding: 1.1rem 1.2rem; margin-bottom: 0.9rem; }
    .ev-card.mine { border-color: rgba(255,215,0,0.4); }
    .ev-card.settled { opacity: 0.85; }
    .ev-title { font-weight: 800; font-size: 1.05rem; margin-bottom: 0.25rem; }
    .ev-time { font-size: 0.82rem; color: var(--text-muted); margin-bottom: 0.7rem; }
    .ev-opts { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .ev-opt { flex: 1; min-width: 90px; padding: 0.7rem 0.5rem; border-radius: 10px; border: 1.5px solid var(--border); background: rgba(255,255,255,0.02); color: var(--text-primary); font-weight: 700; cursor: pointer; font-size: 0.95rem; transition: border-color 0.15s, background 0.15s; }
    .ev-opt small { display: block; font-size: 0.72rem; color: var(--text-muted); font-weight: 400; margin-top: 0.15rem; }
    .ev-opt:hover { border-color: #FFD700; }
    .ev-opt.sel { border-color: #FFD700; background: rgba(255,215,0,0.12); }
    .ev-stake { margin-top: 0.9rem; }
    .ev-stake-row { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    .ev-stake-input { width: 90px; padding: 0.5rem 0.6rem; border-radius: 8px; border: 1.5px solid var(--guava-green); background: var(--bg-card, #111); color: var(--guava-green); font-weight: 800; text-align: center; outline: none; }
    .ev-submit { padding: 0.55rem 1.2rem; border: none; border-radius: 8px; background: linear-gradient(135deg, #FFD700, #ff8800); color: #000; font-weight: 800; cursor: pointer; }
    .ev-submit:disabled { opacity: 0.6; cursor: progress; }
    .ev-preview { margin-top: 0.6rem; font-size: 0.9rem; color: var(--text-secondary); }
    .ev-preview b { color: #FFD700; }
    .prev-meta { display: block; font-size: 0.78rem; color: var(--text-muted); margin-top: 0.2rem; }
    .ev-mybet { font-size: 0.92rem; color: var(--text-secondary); line-height: 1.6; }
    .ev-mybet b { color: #FFD700; }
    .ev-res { font-size: 0.92rem; }
    .ev-won { color: #22c55e; font-weight: 700; }
    .ev-lost { color: #ef4444; font-weight: 700; }

    @media (max-width: 520px) {
      .pp-back { position: static; display: block; margin-bottom: 0.5rem; }
      .ev-opt { min-width: 70px; font-size: 0.88rem; }
    }
  </style>
</BaseLayout>
