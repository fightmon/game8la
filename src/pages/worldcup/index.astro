---
import Icon from '../../components/Icon.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqSchema from '../../components/FaqSchema.astro';
import TodayMatches from '../../components/TodayMatches.astro';
import { articles } from '../../data/articles.js';

// 自動收錄所有「體育/世足」文章，依發佈日期由新到舊（新文章自動排前面，與首頁一致）
const sports = articles
  .filter((a) => a.category === 'sports')
  .sort((a, b) => b.date.localeCompare(a.date));

const faqs = [
  { q: '2026 世界盃台灣時間幾號開踢？', a: '台灣時間 2026 年 6 月 12 日（五）凌晨 3:00 開踢，由地主墨西哥對南非；冠軍決賽在台灣時間 7 月 20 日（一）凌晨 3:00。完整賽程看本專區的「世足賽程表」。' },
  { q: '2026 世足台灣在哪裡看？', a: '愛爾達（ELTA）拿下台灣轉播總代理，完整轉播 104 場（MOD 愛爾達體育台／ELTA.tv／Hami Video，付費）；華視免費轉播開幕、四強、冠軍等重點場。詳見本專區的「世足轉播哪裡看」。' },
  { q: '2026 世界盃有幾隊？怎麼打？', a: '史上首次擴編到 48 隊，分 A～L 共 12 組、每組 4 隊、共 104 場。每組前 2 名加 8 個最佳第 3 名共 32 隊晉級淘汰賽。賽制細節看「世足賽制懶人包」。' },
  { q: '看世足跟賭博有關嗎？這個專區會推我下注嗎？', a: '不會。GAME8LA 零業配、不放任何娛樂城連結。這個專區是純看球資訊（賽程、轉播、規則、預測），還會教你避開「免費直播」釣魚詐騙站。看球娛樂就好，量力而為。' },
];
---
<FaqSchema faqs={faqs} />
<BaseLayout
  currentPage="worldcup"
  title="世足8LA專區 | 2026 世界盃賽程、轉播、規則、冠軍預測一站看 - GAME8LA"
  description="世足8LA專區：2026 世界盃賽程表（台灣時間）、台灣轉播哪裡看、48隊賽制、越位犯規規則、冠軍預測工具一站搞懂。芭樂子帶你看球，零業配、防詐騙。"
  ogImage="https://game8la.com/images/og-image.webp"
>
  <div class="container">
    <div class="breadcrumb"><a href="/">首頁</a> &gt; 世足8LA專區</div>
    <a href="/" class="back-link"><Icon name="arrow-left" /> 回首頁</a>
    <div class="hero-banner" style="background:linear-gradient(135deg,#1a472a,#004d98,#f5b800)"></div>

    <div class="page-hero">
      <h1>⚽ <em>世足8LA專區</em></h1>
      <p>2026 世界盃 — 賽程、轉播、規則、冠軍預測，芭樂子帶你看球一站搞懂</p>
    </div>

    <TodayMatches />

    <!-- 賽事快速資訊卡 -->
    <section style="background:var(--bg-card);border:1px solid var(--border);border-radius:16px;padding:1.5rem;margin:2rem 0">
      <h2 style="margin-top:0">⏱️ 2026 世界盃 — 30 秒快速看（台灣時間）</h2>
      <div class="info-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:0.8rem 1.5rem;margin-top:1rem">
        <div><strong style="color:var(--text-muted)">開幕戰：</strong><span style="color:var(--guava-green)">6/12（五）03:00</span> 墨西哥vs南非</div>
        <div><strong style="color:var(--text-muted)">冠軍決賽：</strong><span style="color:var(--gold-light)">7/20（一）03:00</span></div>
        <div><strong style="color:var(--text-muted)">規模：</strong>48 隊 / 12 組 / 104 場</div>
        <div><strong style="color:var(--text-muted)">主辦：</strong>美國、加拿大、墨西哥</div>
        <div><strong style="color:var(--text-muted)">完整轉播：</strong>愛爾達（付費）</div>
        <div><strong style="color:var(--text-muted)">免費重點場：</strong>華視</div>
      </div>
      <div style="margin-top:1.2rem;display:flex;gap:1rem;flex-wrap:wrap">
        <a href="/articles/worldcup-2026-schedule/" class="btn-primary">🗓️ 完整賽程表</a>
        <a href="/articles/worldcup-2026-live-broadcast/" class="btn-outline">📺 轉播哪裡看</a>
        <a href="/tools/worldcup-2026/" class="btn-outline">🏆 冠軍預測</a>
      </div>
    </section>

    <!-- 文章網格（自動收錄體育/世足文章） -->
    <h2 class="section-title" style="margin-top:3rem">📚 世足看球文章</h2>
    <div class="wc-grid">
      {sports.map((a) => (
        <a href={a.href || `/articles/${a.slug}/`} class="wc-card">
          <div class="wc-card-img">
            <img src={a.thumbnail} alt={a.title} loading="lazy" width="600" height="338" />
            <span class="wc-badge">{a.categoryLabel}</span>
          </div>
          <div class="wc-card-body">
            <h3>{a.title}</h3>
            <p>{a.excerpt}</p>
          </div>
        </a>
      ))}
    </div>

    <!-- 常見問題 -->
    <h2 class="section-title" style="margin-top:3rem">❓ 世足看球常見問題</h2>
    <div style="margin-top:1rem">
      {faqs.map(f => (
        <details style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:1rem 1.2rem;margin-bottom:0.8rem">
          <summary style="cursor:pointer;font-weight:700;font-size:1.05rem">{f.q}</summary>
          <p style="margin:0.8rem 0 0;color:var(--text-secondary)" set:html={f.a} />
        </details>
      ))}
    </div>
  </div>

  <style>
    .wc-grid{ display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:1.5rem; margin-top:1.5rem; }
    .wc-card{ background:var(--bg-card); border:1px solid var(--border); border-radius:16px; overflow:hidden; text-decoration:none; color:inherit; transition:transform .2s, border-color .2s; display:flex; flex-direction:column; }
    .wc-card:hover{ transform:translateY(-4px); border-color:var(--guava-green); }
    .wc-card-img{ position:relative; aspect-ratio:16/9; overflow:hidden; }
    .wc-card-img img{ width:100%; height:100%; object-fit:cover; display:block; }
    .wc-badge{ position:absolute; top:10px; left:10px; background:var(--guava-green); color:#0a2810; font-weight:900; font-size:.75rem; padding:.2rem .8rem; border-radius:20px; }
    .wc-card-body{ padding:1.1rem 1.2rem; flex:1; display:flex; flex-direction:column; }
    .wc-card-body h3{ font-size:1.05rem; line-height:1.45; margin:0 0 .5rem; }
    .wc-card-body p{ font-size:.85rem; color:var(--text-muted); line-height:1.6; margin:0; }
  </style>
</BaseLayout>
