  <!-- ═══════════════════════════════════════════
       SCRIPTS
       ═══════════════════════════════════════════ -->
  <!-- 將 scamList 注入到客戶端 -->
  <script is:inline define:vars={{ scamListJSON: JSON.stringify(scamList.map(s => ({ n: s.name, u: s.urls, r: s.totalReports, d: s.latestDate }))) }}>
    const _scamDB = JSON.parse(scamListJSON);

    /* ── HTML escape 防 XSS ── */
    function escHtml(s) {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    /* ── 黑名單比對 ── */
    function checkBlacklist(domain) {
      const module = document.getElementById('blacklist-module');
      const resultEl = document.getElementById('blacklistResult');
      const domainLower = domain.toLowerCase();

      // 比對：輸入的網域是否在任何品牌的 urls 清單中（完全匹配或包含）
      const hits = [];
      for (const brand of _scamDB) {
        for (const u of brand.u) {
          // 完全匹配或輸入網域包含黑名單網址
          if (u === domainLower || domainLower.endsWith('.' + u) || u.endsWith('.' + domainLower)) {
            hits.push(brand);
            break;
          }
        }
      }

      // 也做品牌名模糊匹配（如果使用者輸入的是品牌名而非網址）
      if (hits.length === 0) {
        for (const brand of _scamDB) {
          for (const u of brand.u) {
            // 檢查主域名是否部分匹配
            const mainDomain = u.replace(/^(www|m|app|h5|t|tx|vip\d*|ag\d*|seo\d*)\./i, '');
            if (domainLower === mainDomain || domainLower.includes(mainDomain.split('.')[0])) {
              hits.push(brand);
              break;
            }
          }
        }
      }

      module.style.display = 'block';

      if (hits.length > 0) {
        let html = '';
        for (const h of hits) {
          const urlTags = h.u.map(u => `<span>${u}</span>`).join('');
          html += `
            <div class="blacklist-hit">
              <div class="blacklist-hit-title">🚨 命中黑名單：${h.n}</div>
              <div class="blacklist-hit-meta">
                <strong>通報件數：</strong>${h.r} 件 · <strong>最近通報：</strong>${h.d}<br>
                <strong>已知使用網址：</strong>
              </div>
              <div class="blacklist-hit-urls">${urlTags}</div>
            </div>
          `;
        }
        html += `<p style="margin:0.8rem 0 0;font-size:0.85rem;color:var(--text-muted)">⚠️ 以上資料來自內政部警政署 165 反詐騙通報。如已受害，請立即撥打 165 或 110 報案。</p>`;
        resultEl.innerHTML = html;
        // 滾動到黑名單結果
        module.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return true; // 有命中
      } else {
        resultEl.innerHTML = `
          <div class="blacklist-safe">
            <p>✅ 未在 165 詐騙黑名單中找到「${escHtml(domain)}」</p>
            <p class="sub">未被通報不代表 100% 安全，請繼續查看下方 WHOIS 年齡檢測。</p>
          </div>
        `;
        return false; // 沒命中
      }
    }

    /* ── 鄉民回報訊號（公開 /api/report-count，只回已列管確認數） ── */
    async function checkReports(domain) {
      const el = document.getElementById('reportsResult');
      if (!el) return;
      el.innerHTML = '';
      let count = 0;
      try {
        const r = await fetch('/api/report-count?domain=' + encodeURIComponent(domain));
        if (r.ok) { const j = await r.json(); count = j.count || 0; }
      } catch (_) { /* 端點不可用就靜默 */ }

      if (count > 0) {
        el.innerHTML = `
          <div class="rpt-hit">
            <div class="rpt-hit-title">🚨 芭樂子情報網：這站已被 <b>${count}</b> 位鄉民回報「不出金」！</div>
            <p class="rpt-hit-sub">大大，這支芭樂子手上已經 ${count} 筆災情了，<strong>錢還沒進去的快收手</strong>；已經卡關的，下面回報一筆、加 LINE 我陪你一起追。別再餵它了。</p>
          </div>`;
      } else {
        el.innerHTML = `
          <div class="rpt-zero">
            <div class="rpt-zero-title">🍈 芭樂子提醒：目前 0 筆鄉民回報——但「查不到 ≠ 安全」喔！</div>
            <p class="rpt-zero-sub">先別急著放心，大大。新詐騙站天天生，芭樂子的名單一定有來不及更新的。<strong>沒人回報，只代表「還沒人來得及哭」</strong>，不代表它乖乖的。覺得怪怪的，先過下面自助 5 關，順手回報一筆，造福後面的鄉民~</p>
            <a href="#report-intake" class="rpt-zero-cta" onclick="var t=document.getElementById('report-intake');if(t){t.scrollIntoView({behavior:'smooth'});}return false;">→ 帶我去自助檢測 + 回報</a>
          </div>`;
      }
    }

    /* ── 清理網域 ── */
    function cleanDomain(raw) {
      return raw.replace(/^https?:\/\//, '').replace(/^www\./, '').split('/')[0].split('?')[0].toLowerCase();
    }

    /* ── 計算網域年齡與風險 ── */
    function calcAge(regDateStr) {
      if (!regDateStr) return { ageMonths: null, ageLabel: '未知', riskLevel: 'unknown' };
      const regDate = new Date(regDateStr);
      const now = new Date();
      const ageMonths = Math.floor((now - regDate) / (1000 * 60 * 60 * 24 * 30.44));
      if (ageMonths < 6) return { ageMonths, ageLabel: `${ageMonths} 個月（⚠️ 高風險）`, riskLevel: 'danger' };
      if (ageMonths < 24) return { ageMonths, ageLabel: `${ageMonths} 個月（⚡ 需警覺）`, riskLevel: 'warning' };
      const y = Math.floor(ageMonths / 12), m = ageMonths % 12;
      return { ageMonths, ageLabel: `${y} 年 ${m} 個月（✅ 相對安全）`, riskLevel: 'safe' };
    }

    /* ── 根據 TLD 選擇 RDAP 端點 ── */
    function getRdapUrl(domain) {
      // .tw 網域走 TWNIC 的 RDAP
      if (domain.endsWith('.tw')) return `https://ccrdap.twnic.tw/tw/domain/${domain}`;
      // .cn 網域走 CNNIC
      if (domain.endsWith('.cn')) return `https://rdap.cnnic.cn/rdap/domain/${domain}`;
      // .jp 網域走 JPRS
      if (domain.endsWith('.jp')) return `https://rdap.jprs.jp/rdap/domain/${domain}`;
      // .kr 網域走 KISA
      if (domain.endsWith('.kr')) return `https://rdap.kisa.or.kr/rdap/domain/${domain}`;
      // 其他走國際 RDAP bootstrap
      return `https://rdap.org/domain/${domain}`;
    }

    /* ── 直接呼叫 RDAP（fallback / 本機開發用） ── */
    async function queryRdapDirect(domain) {
      const url = getRdapUrl(domain);
      const res = await fetch(url, {
        headers: { Accept: 'application/rdap+json' }
      });
      if (!res.ok) throw new Error('not found');
      const data = await res.json();
      const events = data.events || [];
      const regEvent = events.find(e => e.eventAction === 'registration');
      const expEvent = events.find(e => e.eventAction === 'expiration');
      const registrarEntity = (data.entities || []).find(e => (e.roles || []).includes('registrar'));
      const registrar = registrarEntity?.vcardArray?.[1]?.find(v => v[0] === 'fn')?.[3]
                     || registrarEntity?.handle || '未知';
      const nameServer = (data.nameservers || []).map(ns => ns.ldhName).filter(Boolean).slice(0, 4);
      const age = calcAge(regEvent?.eventDate);
      return {
        domain,
        registrationDate: regEvent?.eventDate || null,
        expirationDate: expEvent?.eventDate || null,
        registrar,
        nameServer,
        ...age
      };
    }

    /* ── DNS 存在性檢查（透過 Cloudflare DoH） ── */
    async function checkDnsExists(domain) {
      try {
        const res = await fetch(`https://cloudflare-dns.com/dns-query?name=${encodeURIComponent(domain)}&type=A`, {
          headers: { Accept: 'application/dns-json' }
        });
        if (!res.ok) return false;
        const data = await res.json();
        // Status 0 = NOERROR (域名存在), 3 = NXDOMAIN (不存在)
        return data.Status === 0 && data.Answer && data.Answer.length > 0;
      } catch (_) { return false; }
    }

    /* ── WHOIS 檢測主函式（掛到 window 以便 onclick 調用） ── */
    window.runWhois = async function() {
      const input = document.getElementById('whoisInput');
      const btn = document.getElementById('whoisBtn');
      const resultEl = document.getElementById('whoisResult');
      const raw = (input.value || '').trim();
      if (!raw) { input.focus(); return; }
      const domain = cleanDomain(raw);

      // 第一步：先比對黑名單（即時，不需等 RDAP）
      checkBlacklist(domain);
      checkReports(domain); // 鄉民回報訊號（非同步，不擋）

      // 第二步：WHOIS 查詢
      btn.disabled = true;
      btn.textContent = '查詢中…';
      resultEl.style.display = 'block';
      resultEl.className = 'result-area result-neutral';
      resultEl.innerHTML = '<p style="text-align:center;color:var(--text-muted)">⏳ 正在查詢 RDAP 資料庫…</p>';

      let data = null;
      try {
        // 優先走 Cloudflare Pages Function proxy
        const res = await fetch(`/api/whois?domain=${encodeURIComponent(domain)}`);
        if (res.ok) {
          data = await res.json();
          if (data.error) data = null; // proxy 回傳錯誤，走 fallback
        }
      } catch (_) { /* proxy 不可用，走 fallback */ }

      // Fallback：直接從瀏覽器呼叫 RDAP
      if (!data) {
        try {
          data = await queryRdapDirect(domain);
        } catch (_) {
          // RDAP 查不到 → 用 DNS 確認網域是否真的存在
          const dnsExists = await checkDnsExists(domain);
          if (dnsExists) {
            // 網域存在但 RDAP 沒有收錄（常見於部分 .tw 註冊商）
            resultEl.className = 'result-area result-warning';
            resultEl.innerHTML = `
              <div style="font-size:1.2rem;font-weight:900;margin-bottom:0.8rem">⚠️ 網域存在，但 RDAP 資料庫未收錄</div>
              <div class="result-row">
                <span class="result-label">查詢網域</span>
                <span class="result-value">${escHtml(domain)}</span>
              </div>
              <div class="result-row">
                <span class="result-label">DNS 狀態</span>
                <span class="result-value" style="color:#22c55e">✅ 網域有解析（網站存在）</span>
              </div>
              <div class="result-row">
                <span class="result-label">RDAP 狀態</span>
                <span class="result-value" style="color:#f5b800">⚠️ 未收錄註冊資料</span>
              </div>
              <div style="margin-top:1rem;padding:0.8rem;background:rgba(245,184,0,0.1);border-radius:8px">
                <p style="margin:0;font-size:0.88rem;color:var(--text-secondary)">
                  <strong style="color:#f5b800">為什麼查不到？</strong><br>
                  部分 .tw 等地區網域的註冊商尚未完整同步資料到 RDAP 資料庫。這不代表網站一定有問題，但也無法透過 RDAP 驗證其歷史。<br><br>
                  <strong>建議：</strong>請搭配下方 165 反詐騙查詢 + Google 搜尋「${escHtml(domain)} 評價」「${escHtml(domain)} 詐騙」做交叉比對。
                </p>
              </div>
              <p style="margin:1rem 0 0;font-size:0.85rem;color:var(--text-muted)">
                💡 你也可以到 <a href="https://whois.twnic.net.tw/" target="_blank" rel="noopener" style="color:#f5b800">TWNIC WHOIS</a> 手動查詢 .tw 網域的完整資訊。
              </p>
            `;
          } else {
            // DNS 也查不到 → 網域真的不存在
            resultEl.className = 'result-area result-danger';
            resultEl.innerHTML = `<p style="color:#ef4444;font-weight:700">❌ 查無此網域：${escHtml(domain)}</p><p style="font-size:0.85rem;color:var(--text-muted);margin-top:0.5rem">DNS 查詢無結果，此網域可能不存在或已停用。請確認網址是否正確。</p>`;
          }
          btn.disabled = false;
          btn.innerHTML = '🔎 立即檢測';
          return;
        }
      }

      // 如果 proxy 回傳 rdapMissing，顯示「網域存在但 RDAP 未收錄」
      if (data.rdapMissing) {
        resultEl.className = 'result-area result-warning';
        resultEl.innerHTML = `
          <div style="font-size:1.2rem;font-weight:900;margin-bottom:0.8rem">⚠️ 網域存在，但 RDAP 資料庫未收錄</div>
          <div class="result-row">
            <span class="result-label">查詢網域</span>
            <span class="result-value">${data.domain}</span>
          </div>
          <div class="result-row">
            <span class="result-label">DNS 狀態</span>
            <span class="result-value" style="color:#22c55e">✅ 網域有解析（網站存在）</span>
          </div>
          <div class="result-row">
            <span class="result-label">RDAP 狀態</span>
            <span class="result-value" style="color:#f5b800">⚠️ 未收錄註冊資料</span>
          </div>
          <div style="margin-top:1rem;padding:0.8rem;background:rgba(245,184,0,0.1);border-radius:8px">
            <p style="margin:0;font-size:0.88rem;color:var(--text-secondary)">
              <strong style="color:#f5b800">為什麼查不到？</strong><br>
              部分 .tw 等地區網域的註冊商尚未完整同步資料到 RDAP 資料庫。這不代表網站一定有問題，但也無法透過 RDAP 驗證其歷史。<br><br>
              <strong>建議：</strong>請搭配下方 165 反詐騙查詢 + Google 搜尋「${data.domain} 評價」「${data.domain} 詐騙」做交叉比對。
            </p>
          </div>
          <p style="margin:1rem 0 0;font-size:0.85rem;color:var(--text-muted)">
            💡 你也可以到 <a href="https://whois.twnic.net.tw/" target="_blank" rel="noopener" style="color:#f5b800">TWNIC WHOIS</a> 手動查詢 .tw 網域的完整資訊。
          </p>
        `;
        btn.disabled = false;
        btn.innerHTML = '🔎 立即檢測';
        return;
      }

      const riskClass = data.riskLevel === 'safe' ? 'result-safe'
                      : data.riskLevel === 'warning' ? 'result-warning'
                      : data.riskLevel === 'danger' ? 'result-danger'
                      : 'result-neutral';

      const regDate = data.registrationDate ? new Date(data.registrationDate).toLocaleDateString('zh-TW') : '未知';
      const expDate = data.expirationDate ? new Date(data.expirationDate).toLocaleDateString('zh-TW') : '未知';

      const riskIcon = data.riskLevel === 'safe' ? '✅'
                     : data.riskLevel === 'warning' ? '⚡'
                     : data.riskLevel === 'danger' ? '🔴' : '❓';

      resultEl.className = `result-area ${riskClass}`;
      resultEl.innerHTML = `
        <div style="font-size:1.3rem;font-weight:900;margin-bottom:0.8rem">${riskIcon} ${data.ageLabel}</div>
        <div class="result-row">
          <span class="result-label">查詢網域</span>
          <span class="result-value">${data.domain}</span>
        </div>
        <div class="result-row">
          <span class="result-label">註冊日期</span>
          <span class="result-value">${regDate}</span>
        </div>
        <div class="result-row">
          <span class="result-label">到期日期</span>
          <span class="result-value">${expDate}</span>
        </div>
        <div class="result-row">
          <span class="result-label">註冊商</span>
          <span class="result-value" style="font-size:0.9rem">${data.registrar}</span>
        </div>
        ${(data.nameServer || []).length ? `
        <div class="result-row">
          <span class="result-label">DNS 伺服器</span>
          <span class="result-value" style="font-size:0.85rem">${data.nameServer.join(', ')}</span>
        </div>` : ''}
        <p style="margin:1rem 0 0;font-size:0.85rem;color:var(--text-muted)">
          💡 芭樂子提醒：網域年齡只是第一關。請搭配下方流水計算器和 165 查詢做完整體檢。
        </p>
      `;

      btn.disabled = false;
      btn.innerHTML = '🔎 立即檢測';
    };

    // Enter key to trigger WHOIS
    document.getElementById('whoisInput')?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') window.runWhois();
    });

    /* ── Hero 搜尋框即時連動模組 4 ── */
    window.heroLiveFilter = function(value) {
      const kw = value.toLowerCase().trim();
      if (!kw) return; // 空值不動作，避免干擾
      // 同步模組 4 的文字篩選
      const filterInput = document.getElementById('listFilter');
      if (filterInput) filterInput.value = value;
      window.filterList(value);
      // 重置快速篩選按鈕
      document.querySelectorAll('.qf-btn').forEach(b => b.classList.remove('qf-active'));
    };


    /* ── 流水計算器（掛到 window 以便 onclick 調用） ── */
    window.runCalc = function() {
      const deposit = parseFloat(document.getElementById('depositAmt').value) || 0;
      const bonus = parseFloat(document.getElementById('bonusAmt').value) || 0;
      const turnover = parseFloat(document.getElementById('turnoverX').value) || 0;
      const edge = parseFloat(document.getElementById('houseEdge').value) || 0;
      const resultEl = document.getElementById('calcResult');

      if (deposit <= 0 || turnover <= 0) {
        resultEl.style.display = 'block';
        resultEl.className = 'result-area result-danger';
        resultEl.innerHTML = '<p style="color:#ef4444;font-weight:700">請填入存款金額和流水倍數。</p>';
        return;
      }

      const base = deposit + bonus;
      const requiredWager = base * turnover;
      const expectedLoss = requiredWager * (edge / 100);
      const remaining = base - expectedLoss;
      const lossPercent = base > 0 ? ((expectedLoss / base) * 100).toFixed(1) : 0;

      // Per-hand stats (assume 1000/hand)
      const betPerHand = 1000;
      const handsNeeded = Math.ceil(requiredWager / betPerHand);
      const minutesNeeded = Math.ceil(handsNeeded * 0.5); // ~30sec per hand

      // Risk level
      let riskClass, riskIcon, riskLabel;
      if (turnover <= 25) {
        riskClass = 'result-safe';
        riskIcon = '✅';
        riskLabel = '流水倍數在合理範圍內';
      } else if (turnover <= 35) {
        riskClass = 'result-warning';
        riskIcon = '⚡';
        riskLabel = '流水偏高，優惠的甜頭大部分會蒸發';
      } else {
        riskClass = 'result-danger';
        riskIcon = '🔴';
        riskLabel = '數學陷阱！幾乎不可能帶錢走';
      }

      resultEl.style.display = 'block';
      resultEl.className = `result-area ${riskClass}`;
      resultEl.innerHTML = `
        <div style="font-size:1.3rem;font-weight:900;margin-bottom:0.8rem">${riskIcon} ${riskLabel}</div>
        <div class="result-row">
          <span class="result-label">本金 + 優惠</span>
          <span class="result-value">NT$ ${base.toLocaleString()}</span>
        </div>
        <div class="result-row">
          <span class="result-label">需完成投注額</span>
          <span class="result-value" style="color:#f5b800">NT$ ${requiredWager.toLocaleString()}</span>
        </div>
        <div class="result-row">
          <span class="result-label">預期損失（莊家優勢 ${edge}%）</span>
          <span class="result-value" style="color:#ef4444">- NT$ ${Math.round(expectedLoss).toLocaleString()}（${lossPercent}%）</span>
        </div>
        <div class="result-row">
          <span class="result-label">理論剩餘金額</span>
          <span class="result-value" style="color:${remaining > 0 ? '#22c55e' : '#ef4444'}">NT$ ${Math.round(remaining).toLocaleString()}</span>
        </div>
        <div class="result-row">
          <span class="result-label">預估需要玩</span>
          <span class="result-value">${handsNeeded.toLocaleString()} 手（約 ${minutesNeeded > 60 ? (minutesNeeded / 60).toFixed(1) + ' 小時' : minutesNeeded + ' 分鐘'}）</span>
        </div>
        ${remaining <= 0 ? `
        <div style="margin-top:1rem;padding:0.8rem;background:rgba(239,68,68,0.15);border-radius:8px">
          <p style="margin:0;color:#ef4444;font-weight:700">⚠️ 以此流水倍數和莊家優勢計算，你的本金＋優惠在完成流水之前就會<strong>全部輸光</strong>。這不是優惠，是陷阱。</p>
        </div>` : ''}
        ${remaining > 0 && remaining < deposit ? `
        <div style="margin-top:1rem;padding:0.8rem;background:rgba(245,184,0,0.15);border-radius:8px">
          <p style="margin:0;color:#f5b800;font-weight:700">⚠️ 即使跑完流水，你拿回的錢比你原本存入的還少。這個「優惠」實際上讓你<strong>倒虧 NT$ ${Math.round(deposit - remaining).toLocaleString()}</strong>。</p>
        </div>` : ''}
        <p style="margin:1rem 0 0;font-size:0.85rem;color:var(--text-muted)">
          💡 以上為數學期望值計算。實際結果會因運氣波動而不同，但長期而言數學不會騙人。
        </p>
      `;
    };

    /* ── 名單篩選（掛到 window 以便 oninput 調用） ── */
    window.filterList = function(keyword) {
      const kw = keyword.toLowerCase().trim();
      const cards = document.querySelectorAll('.scam-card');
      let visibleCount = 0;
      cards.forEach(card => {
        const name = card.dataset.name || '';
        const urls = card.dataset.urls || '';
        const match = !kw || name.includes(kw) || urls.includes(kw);
        card.style.display = match ? '' : 'none';
        if (match) visibleCount++;
      });
      // 無結果提示
      const hint = document.getElementById('noResultHint');
      const kwEl = document.getElementById('noResultKeyword');
      if (hint) {
        if (kw && visibleCount === 0) {
          hint.style.display = 'block';
          if (kwEl) kwEl.textContent = keyword.trim();
        } else {
          hint.style.display = 'none';
        }
      }
      // 重置快速篩選按鈕狀態
      if (kw) {
        document.querySelectorAll('.qf-btn').forEach(b => b.classList.remove('qf-active'));
      }
    };

    /* ── Sticky 警示浮條 ── */
    (function() {
      const sticky = document.getElementById('stickyWarning');
      const heroSearch = document.querySelector('.hero-search');
      if (!sticky || !heroSearch) return;
      let ticking = false;
      window.addEventListener('scroll', function() {
        if (!ticking) {
          requestAnimationFrame(function() {
            const heroBottom = heroSearch.getBoundingClientRect().bottom;
            if (heroBottom < -100) {
              sticky.classList.add('visible');
            } else {
              sticky.classList.remove('visible');
            }
            ticking = false;
          });
          ticking = true;
        }
      });
    })();

    /* ── 快速篩選（依 tag） ── */
    window.quickFilter = function(tag, btnEl) {
      // 清空文字輸入
      const filterInput = document.getElementById('listFilter');
      if (filterInput) filterInput.value = '';
      // 隱藏無結果提示
      const hint = document.getElementById('noResultHint');
      if (hint) hint.style.display = 'none';
      // 切換按鈕 active 狀態
      document.querySelectorAll('.qf-btn').forEach(b => b.classList.remove('qf-active'));
      if (btnEl) btnEl.classList.add('qf-active');
      // 篩選卡片
      const cards = document.querySelectorAll('.scam-card');
      cards.forEach(card => {
        if (tag === 'all') {
          card.style.display = '';
        } else {
          const tags = (card.dataset.tags || '').split(',');
          card.style.display = tags.includes(tag) ? '' : 'none';
        }
      });
    };
  </script>

  <script is:inline>
    /* ── 回報收件口 ──
       同源 Cloudflare Worker 路由，直接寫進 D1 資料庫（src/worker.js handleReport）。 */
    var REPORT_ENDPOINT = '/api/report';

    window.submitReport = function () {
      var urlEl = document.getElementById('rpUrl');
      var url = (urlEl.value || '').trim();
      if (!url) { alert('至少填一下平台網址或名稱，芭樂子才記得住啦 🍈'); urlEl.focus(); return; }
      var amount = document.getElementById('rpAmount').value || '';
      var methods = Array.prototype.slice
        .call(document.querySelectorAll('#rpMethods input:checked'))
        .map(function (c) { return c.value; }).join('、');
      var note = (document.getElementById('rpNote').value || '').trim();
      var domain = url.replace(/^https?:\/\//, '').replace(/^www\./, '').split('/')[0].split('?')[0].toLowerCase();
      var payload = { url: url, domain: domain, amount: amount, methods: methods, note: note, ref: 'casino-check' };

      var btn = document.getElementById('rpSubmit');
      btn.disabled = true; btn.textContent = '送出中…';
      var done = function () {
        document.getElementById('reportForm').style.display = 'none';
        var t = document.getElementById('reportThanks');
        t.style.display = 'block';
        t.scrollIntoView({ behavior: 'smooth', block: 'center' });
      };
      fetch(REPORT_ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      }).then(done).catch(done);
    };
  </script>
</BaseLayout>
