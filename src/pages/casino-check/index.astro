---
import Icon from '../../components/Icon.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { scamList, lastUpdated } from '../../data/scam-list.js';

const totalBrands = scamList.length;
const totalUrls = scamList.reduce((sum, s) => sum + s.urls.length, 0);
const totalReports = scamList.reduce((sum, s) => sum + s.totalReports, 0);

// 最近 30 天內被通報的品牌
const now = new Date();
const thirtyDaysAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
const recentBrands = scamList.filter(s => s.latestDate >= thirtyDaysAgo).length;
// 通報超過 10 次的高危品牌
const highRiskBrands = scamList.filter(s => s.totalReports >= 10).length;

// 為每個品牌計算風險標籤
const enrichedList = scamList.map(s => {
  const tags: string[] = [];
  if (s.latestDate >= thirtyDaysAgo) tags.push('最新通報');
  if (s.totalReports >= 10) tags.push('高風險');
  if (s.urls.length >= 5) tags.push('疑似換殼');
  return { ...s, tags };
});
---
<BaseLayout currentPage="casino-check" title="娛樂城體檢｜入金前 3 分鐘安全檢測 + 詐騙黑名單 - GAME8LA" description="免費線上娛樂城安全檢測工具：165 詐騙黑名單即時比對、WHOIS 網域年齡查詢、流水計算器。收錄 90 個詐騙品牌、369 個網址。入金前花 3 分鐘，避開黑網。">
  <div class="container">
    <div class="breadcrumb"><a href="/">首頁</a> &gt; 娛樂城體檢</div>
    <a href="/" class="back-link"><Icon name="arrow-left" /> 回首頁</a>
    <div class="hero-banner" style="background:linear-gradient(135deg,#0a1a2e,#1a3a5c,#f5b800)"></div>

    <div class="page-hero" style="text-align:center;margin-bottom:0">
      <h1 style="font-size:2.2rem;line-height:1.3">🛡️ <em>娛樂城體檢</em></h1>
      <p style="color:var(--text-secondary);max-width:600px;margin:0.5rem auto 0">入金之前花 3 分鐘，讓芭樂子幫你檢查——這間娛樂城能不能信？</p>
      <p class="last-sync">📡 數據最後同步時間：<strong>{lastUpdated}</strong> · 資料來源：內政部警政署 165</p>
    </div>

    <!-- ═══════════════════════════════════════════
         Hero 搜尋框：最醒目的入口
         ═══════════════════════════════════════════ -->
    <div class="hero-search">
      <p class="hero-search-label">輸入網址或品牌名稱，1 秒診斷安全性</p>
      <div class="hero-input-wrap">
        <input type="text" id="whoisInput" placeholder="例如 bet888.com 或 金沙娛樂城" autocomplete="off" spellcheck="false" oninput="heroLiveFilter(this.value)" />
        <button type="button" id="whoisBtn" onclick="runWhois()">
          <Icon name="search" /> 立即檢測
        </button>
      </div>
      <p class="hero-search-hint">按下檢測 → 自動比對 165 詐騙黑名單 + 查詢網域年齡，3 秒出結果</p>
      <!-- 數據亮點 -->
      <div class="hero-stats-row">
        <div class="hero-stat">
          <span class="hero-stat-num">{totalBrands}</span>
          <span class="hero-stat-label">詐騙品牌</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num">{totalUrls}</span>
          <span class="hero-stat-label">詐騙網址</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num">{totalReports}</span>
          <span class="hero-stat-label">通報件數</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num" style="color:#ef4444">{recentBrands}</span>
          <span class="hero-stat-label">近期活躍</span>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════
         模組 0：165 黑名單比對結果
         ═══════════════════════════════════════════ -->
    <section class="check-module" id="blacklist-module" style="display:none">
      <div class="module-header">
        <span class="module-number" style="background:linear-gradient(135deg,#ef4444,#dc2626)">!</span>
        <div>
          <h2 style="margin:0">🚨 165 詐騙黑名單比對</h2>
          <p class="module-desc">比對內政部警政署 165 反詐騙通報資料庫</p>
        </div>
      </div>
      <div id="blacklistResult"></div>
      <div id="reportsResult"></div>
    </section>

    <!-- ═══════════════════════════════════════════
         模組 1：WHOIS 網域年齡檢測
         ═══════════════════════════════════════════ -->
    <section class="check-module" id="whois-module">
      <div class="module-header">
        <span class="module-number">1</span>
        <div>
          <h2 style="margin:0">🔎 網域年齡檢測結果</h2>
          <p class="module-desc">剛開幾個月就狂灑優惠？高機率是黑網。</p>
        </div>
      </div>

      <div id="whoisResult" class="result-area" style="display:none"></div>

      <div class="module-tip">
        <strong>判讀標準：</strong>
        <span class="dot dot-green"></span> 超過 2 年 = 相對安全 ·
        <span class="dot dot-yellow"></span> 6 月–2 年 = 需警覺 ·
        <span class="dot dot-red"></span> 不到 6 個月 = 高風險
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         模組 2：流水倍數計算器
         ═══════════════════════════════════════════ -->
    <section class="check-module" id="turnover-module">
      <div class="module-header">
        <span class="module-number">2</span>
        <div>
          <h2 style="margin:0">🧮 流水倍數計算器</h2>
          <p class="module-desc">輸入存款金額、優惠金額、流水倍數，幫你算出要投注多少才能提款——以及你的錢有多大機率蒸發。</p>
        </div>
      </div>

      <div class="calc-grid">
        <div class="calc-field">
          <label for="depositAmt">💰 你的存款金額（NTD）</label>
          <input type="number" id="depositAmt" placeholder="例如 10000" min="0" />
        </div>
        <div class="calc-field">
          <label for="bonusAmt">🎁 優惠/彩金金額（NTD）</label>
          <input type="number" id="bonusAmt" placeholder="例如 10000" min="0" />
        </div>
        <div class="calc-field">
          <label for="turnoverX">🔄 流水倍數</label>
          <input type="number" id="turnoverX" placeholder="例如 30" min="1" step="1" />
        </div>
        <div class="calc-field">
          <label for="houseEdge">🏦 莊家優勢 %（可選）</label>
          <select id="houseEdge">
            <option value="1.06">百家樂 莊閒（1.06%）</option>
            <option value="2.7">輪盤 歐式（2.7%）</option>
            <option value="5.0" selected>老虎機 平均（5%）</option>
            <option value="8.0">老虎機 高抽（8%）</option>
            <option value="0">我自己算（0%）</option>
          </select>
        </div>
      </div>

      <button type="button" class="calc-btn" onclick="runCalc()">📊 計算結果</button>

      <div id="calcResult" class="result-area" style="display:none"></div>

      <div class="module-tip">
        <strong>判讀標準：</strong>
        <span class="dot dot-green"></span> 15–25 倍 = 合理 ·
        <span class="dot dot-yellow"></span> 25–35 倍 = 偏高 ·
        <span class="dot dot-red"></span> 40 倍以上 = 陷阱
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         模組 3：165 警示帳戶快查
         ═══════════════════════════════════════════ -->
    <section class="check-module" id="report-module">
      <div class="module-header">
        <span class="module-number">3</span>
        <div>
          <h2 style="margin:0">🚨 165 反詐騙快查</h2>
          <p class="module-desc">直接連到內政部警政署 165 反詐騙官網，查詢你要入金的平台是否已經被通報。</p>
        </div>
      </div>

      <div style="display:flex;flex-wrap:wrap;gap:1rem;margin-top:1rem">
        <a href="https://165.npa.gov.tw/#/articles/subjectlist/2" target="_blank" rel="noopener" class="external-btn">
          🔍 查詢詐騙網站公告
        </a>
        <a href="https://165.npa.gov.tw/#/report/report" target="_blank" rel="noopener" class="external-btn external-btn-outline">
          📝 我要檢舉通報
        </a>
      </div>

      <div class="module-tip" style="margin-top:1.2rem">
        <strong>提醒：</strong>165 是官方反詐騙專線。如果你已經被騙，<strong style="color:#ef4444">請立即撥打 165 或 110 報案</strong>，並保留所有交易紀錄、對話截圖。
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         模組 4：完整詐騙名單瀏覽
         ═══════════════════════════════════════════ -->
    <section class="check-module" id="full-list-module">
      <div class="module-header">
        <span class="module-number">4</span>
        <div>
          <h2 style="margin:0">📋 165 詐騙娛樂城完整名單</h2>
          <p class="module-desc">內政部警政署 165 通報資料彙整，共 {totalBrands} 個品牌。輸入關鍵字即時篩選。</p>
        </div>
      </div>

      <!-- 快速篩選按鈕 -->
      <div class="quick-filters">
        <button type="button" class="qf-btn qf-active" onclick="quickFilter('all', this)">全部 ({totalBrands})</button>
        <button type="button" class="qf-btn" onclick="quickFilter('最新通報', this)">🔴 最新通報 ({recentBrands})</button>
        <button type="button" class="qf-btn" onclick="quickFilter('高風險', this)">⚠️ 高風險 ({highRiskBrands})</button>
        <button type="button" class="qf-btn" onclick="quickFilter('疑似換殼', this)">🔄 疑似換殼</button>
      </div>

      <input type="text" id="listFilter" placeholder="搜尋品牌名稱或網址…" oninput="filterList(this.value)" style="width:100%;padding:0.75rem 1rem;background:var(--bg-secondary);border:1px solid var(--border);border-radius:10px;color:var(--text-primary);font-size:0.95rem;font-family:inherit;outline:none;margin-bottom:1rem" />

      <!-- 搜尋無結果提示 -->
      <div id="noResultHint" class="no-result-hint" style="display:none">
        <p>🔍 找不到符合「<strong id="noResultKeyword"></strong>」的品牌</p>
        <p class="no-result-sub">這不代表該網站安全！請使用上方搜尋框輸入網址，進行 WHOIS 年齡檢測 + 165 黑名單比對。</p>
        <button type="button" class="no-result-btn" onclick="document.getElementById('whoisInput').value=document.getElementById('listFilter').value;document.getElementById('whoisInput').scrollIntoView({behavior:'smooth',block:'center'});setTimeout(()=>window.runWhois(),400)">🔎 立即檢測這個網址</button>
      </div>

      <div id="scamListContainer" class="scam-list-grid">
        {enrichedList.map(s => (
          <div class="scam-card" data-name={s.name.toLowerCase()} data-urls={s.urls.join(' ')} data-tags={s.tags.join(',')}>
            {s.tags.length > 0 && (
              <div class="scam-card-tags">
                {s.tags.map(t => (
                  <span class={`risk-tag ${t === '最新通報' ? 'tag-recent' : t === '高風險' ? 'tag-danger' : 'tag-shell'}`}>{t}</span>
                ))}
              </div>
            )}
            <div class="scam-card-head">
              <strong>{s.name}</strong>
              <span class={`scam-reports ${s.totalReports >= 50 ? 'reports-critical' : s.totalReports >= 10 ? 'reports-high' : ''}`}>{s.totalReports} 件通報</span>
            </div>
            <div class="scam-card-date">最近通報：{s.latestDate}</div>
            <div class="scam-card-urls">
              {s.urls.slice(0, 3).map(u => <span>{u}</span>)}
              {s.urls.length > 3 && <span class="more">+{s.urls.length - 3} 個網址</span>}
            </div>
          </div>
        ))}
      </div>

      <div class="module-tip" style="margin-top:1rem">
        <strong>資料來源：</strong>內政部警政署 165 全民防騙網 · 搜尋關鍵字「娛樂城」 · 類別「假投資（博弈）網站」 · 最後更新：{lastUpdated}<br>
        <strong>注意：</strong>查詢結果僅限 165 近 2 年通報資料。未被通報不代表安全，請搭配上方工具做完整體檢。
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         模組 5：你也被坑了？站內回報 + 加 LINE 等通知
         ═══════════════════════════════════════════ -->
    <section class="check-module" id="report-intake">
      <div class="module-header">
        <span class="module-number" style="background:linear-gradient(135deg,#39ff14,#0a8a3c)">5</span>
        <div>
          <h2 style="margin:0">🙋 你也被「不出金」坑了嗎？</h2>
          <p class="module-desc">查不到不代表安全——你的一筆回報，可能擋下下一個受害者。芭樂子幫你記，黑名單更新第一個通知你。</p>
        </div>
      </div>

      <!-- 自助 5 關 -->
      <div class="selfcheck-box">
        <p class="selfcheck-title">⚡ 查不到？先自己過這 5 關，中 1 條就快逃：</p>
        <ul class="selfcheck-list">
          <li><span class="sc-n">1</span> 域名開不到 3 個月就狂灑優惠？→ 超可疑</li>
          <li><span class="sc-n">2</span> 出金前叫你「先繳稅／保證金／解凍金」？→ <strong style="color:#ef4444">100% 詐騙話術</strong></li>
          <li><span class="sc-n">3</span> 找不到實體公司／執照，客服只有 TG？</li>
          <li><span class="sc-n">4</span> 是有人「帶你玩、報明牌、拉你進群」才認識的？</li>
          <li><span class="sc-n">5</span> 入金是打到「個人帳戶／USDT／人頭戶」？</li>
        </ul>
        <p class="selfcheck-foot">芭樂子：中 1 條我就皺眉，中 2 條快跑，中 3 條……R.I.P 錢包，趕快截圖報警。</p>
      </div>

      <!-- 回報表單 -->
      <div id="reportForm" class="report-form">
        <p class="report-form-title">📝 回報一筆（全部選填、不綁身分，30 秒）：</p>
        <div class="calc-grid">
          <div class="calc-field" style="grid-column:1/-1">
            <label for="rpUrl">🔗 平台網址 / 名稱</label>
            <input type="text" id="rpUrl" placeholder="例如 bet888.com 或 金沙娛樂城" autocomplete="off" spellcheck="false" />
          </div>
          <div class="calc-field">
            <label for="rpAmount">💸 卡關金額</label>
            <select id="rpAmount">
              <option value="">不方便說</option>
              <option value="1萬內">1 萬內</option>
              <option value="1-10萬">1～10 萬</option>
              <option value="10-50萬">10～50 萬</option>
              <option value="50萬以上">50 萬以上</option>
            </select>
          </div>
        </div>
        <p class="rp-tags-label">🕳 遇到的手法（可複選）：</p>
        <div class="rp-tags" id="rpMethods">
          <label><input type="checkbox" value="出金前要繳稅/保證金" /> 出金前要繳稅／保證金</label>
          <label><input type="checkbox" value="客服已讀不回/消失" /> 客服已讀不回／消失</label>
          <label><input type="checkbox" value="平台直接關站" /> 平台直接關站</label>
          <label><input type="checkbox" value="一直加流水卡提款" /> 一直加流水／卡提款</label>
          <label><input type="checkbox" value="帳號無故被凍結" /> 帳號無故被凍結</label>
          <label><input type="checkbox" value="有人帶單拉LINE群" /> 有人帶單／拉 LINE 群</label>
        </div>
        <div class="calc-field" style="margin-top:0.8rem">
          <label for="rpNote">🗒 補充（選填）</label>
          <textarea id="rpNote" rows="2" placeholder="發生經過、被卡多久…幫後面的人多寫幾句"></textarea>
        </div>
        <button type="button" class="calc-btn" id="rpSubmit" onclick="submitReport()">📨 送出回報，造福鄉民</button>
        <p class="rp-privacy">🔒 不會留你的姓名／電話，只收平台資訊。送出即同意作為避雷公開資料（去識別處理）。</p>
      </div>

      <!-- 送出後的感謝 + LINE -->
      <div id="reportThanks" class="report-thanks" style="display:none">
        <div class="rt-icon">🍈</div>
        <p class="rt-title">收到了！芭樂子幫你記下這筆了 🙏</p>
        <p class="rt-sub">我會排進查證佇列。<strong>想在這個平台有新進度、或黑名單更新時第一個收到通知？</strong>加我 LINE，我廣播——你加我、我推你，不用留個資。</p>
        <a href="https://line.me/R/ti/p/@531ivqvs" target="_blank" rel="noopener" class="rt-line-btn">💬 加入芭樂子避雷 LINE</a>
      </div>

      <!-- 常駐 LINE 入口（沒回報也能加） -->
      <div class="report-line-always">
        <span>只想收避雷更新、不想填表？</span>
        <a href="https://line.me/R/ti/p/@531ivqvs" target="_blank" rel="noopener">→ 直接加 LINE 收黑名單更新</a>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         底部提示
         ═══════════════════════════════════════════ -->
    <div class="bottom-cta">
      <p>💡 <strong>想了解更多防詐知識？</strong></p>
      <div style="display:flex;flex-wrap:wrap;gap:0.8rem;margin-top:0.8rem">
        <a href="/articles/5-tips-spot-casino-scam/" class="cta-link">5 招識破娛樂城詐騙套路</a>
        <a href="/articles/casino-not-recommended-by-casinos/" class="cta-link">連娛樂城都怕的黑名單</a>
        <a href="/articles/domain-hopping-scam-truth/" class="cta-link">換網址詐騙真相</a>
      </div>
    </div>

  </div>

  <!-- 支持芭樂子 -->
  <div class="donate-banner">
    <div class="donate-banner-inner">
      <div class="donate-banner-icon">🍈</div>
      <div class="donate-banner-body">
        <p><strong>芭樂子幫你擋掉一個坑了嗎？</strong></p>
        <p>娛樂城體檢工具免費用、沒有業配、沒有導流。165 名單比對、WHOIS 查詢、流水計算全部自己扛伺服器費用在做。覺得有幫到你，用 30 秒支持芭樂子繼續做下去：</p>
        <p style="margin-top:0.6rem;font-size:0.95rem"><strong>分享這個工具給朋友</strong> ｜ <strong>加入書籤下次再來</strong> ｜ 📧 有問題歡迎寫信 <a href="mailto:hello@game8la.tw" style="color:var(--gold-light)">hello@game8la.tw</a></p>
      </div>
    </div>
  </div>

  <!-- Sticky 安全警示浮條 -->
  <div class="sticky-warning" id="stickyWarning">
    <span class="sticky-warning-text">⚠️ 入金前先檢查！任何要你先存錢的「客服」都是詐騙高風險</span>
    <button type="button" class="sticky-warning-btn" onclick="document.getElementById('whoisInput').scrollIntoView({behavior:'smooth',block:'center'});document.getElementById('whoisInput').focus()">🔎 立即檢測</button>
  </div>

  <!-- ═══════════════════════════════════════════
       STYLES
       ═══════════════════════════════════════════ -->
  <style is:global>
    /* === Hero Search === */
    .hero-search {
      text-align: center;
      margin: 1.5rem 0 2.5rem;
      padding: 2rem 1.5rem;
      background: linear-gradient(135deg, rgba(245,184,0,0.06), rgba(245,184,0,0.02));
      border: 2px solid rgba(245,184,0,0.35);
      border-radius: 20px;
      position: relative;
      animation: heroGlow 3s ease-in-out infinite;
    }
    @keyframes heroGlow {
      0%, 100% { box-shadow: 0 0 20px rgba(245,184,0,0.08), 0 0 60px rgba(245,184,0,0.04); }
      50% { box-shadow: 0 0 30px rgba(245,184,0,0.15), 0 0 80px rgba(245,184,0,0.08); }
    }
    .hero-search-label {
      font-size: 1.15rem;
      font-weight: 800;
      color: #f5b800;
      margin: 0 0 1rem;
      letter-spacing: 0.02em;
    }
    .hero-input-wrap {
      display: flex;
      gap: 0.6rem;
      max-width: 560px;
      margin: 0 auto;
    }
    .hero-input-wrap input {
      flex: 1;
      padding: 1rem 1.2rem;
      background: rgba(0,0,0,0.5);
      border: 2px solid rgba(245,184,0,0.5);
      border-radius: 14px;
      color: #fff;
      font-size: 1.15rem;
      font-weight: 600;
      font-family: inherit;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .hero-input-wrap input::placeholder {
      color: rgba(245,184,0,0.5);
      font-weight: 500;
    }
    .hero-input-wrap input:focus {
      border-color: #f5b800;
      box-shadow: 0 0 0 3px rgba(245,184,0,0.2);
    }
    .hero-input-wrap button {
      padding: 1rem 1.8rem;
      background: linear-gradient(135deg, #f5b800, #e09900);
      border: none;
      border-radius: 14px;
      color: #000;
      font-weight: 800;
      font-size: 1.05rem;
      cursor: pointer;
      white-space: nowrap;
      transition: all 0.2s;
      font-family: inherit;
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    .hero-input-wrap button:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 24px rgba(245,184,0,0.35);
    }
    .hero-input-wrap button:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
    }
    .hero-search-hint {
      margin: 0.8rem 0 0;
      font-size: 0.82rem;
      color: var(--text-muted);
    }

    .hero-search-stats {
      margin: 0.5rem 0 0;
      font-size: 0.78rem;
      color: var(--text-muted);
    }
    .hero-search-stats strong {
      color: #f5b800;
    }

    /* === Hero Stats Row === */
    .hero-stats-row {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 1.2rem;
      margin-top: 1.5rem;
      padding-top: 1.2rem;
      border-top: 1px solid rgba(245,184,0,0.15);
    }
    .hero-stat {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.15rem;
    }
    .hero-stat-num {
      font-size: 1.6rem;
      font-weight: 900;
      color: #f5b800;
      line-height: 1;
      font-variant-numeric: tabular-nums;
    }
    .hero-stat-label {
      font-size: 0.75rem;
      color: var(--text-muted);
      font-weight: 600;
      letter-spacing: 0.03em;
    }
    .hero-stat-divider {
      width: 1px;
      height: 32px;
      background: rgba(245,184,0,0.2);
    }

    /* === Last Sync === */
    .last-sync {
      font-size: 0.78rem;
      color: var(--text-muted);
      margin: 0.6rem auto 0;
      max-width: 600px;
    }
    .last-sync strong {
      color: #f5b800;
    }

    /* === Blacklist result === */
    .blacklist-hit {
      padding: 1.2rem;
      background: rgba(239,68,68,0.1);
      border: 2px solid rgba(239,68,68,0.4);
      border-radius: 12px;
      margin-bottom: 0.8rem;
    }
    .blacklist-hit-title {
      font-size: 1.2rem;
      font-weight: 900;
      color: #ef4444;
      margin-bottom: 0.6rem;
    }
    .blacklist-hit-meta {
      font-size: 0.88rem;
      color: var(--text-secondary);
      line-height: 1.8;
    }
    .blacklist-hit-meta strong {
      color: var(--text-primary);
    }
    .blacklist-hit-urls {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-top: 0.5rem;
    }
    .blacklist-hit-urls span {
      padding: 0.2rem 0.6rem;
      background: rgba(239,68,68,0.15);
      border-radius: 6px;
      font-size: 0.78rem;
      color: #fca5a5;
      font-family: monospace;
    }
    .blacklist-safe {
      padding: 1rem;
      background: rgba(34,197,94,0.08);
      border: 1px solid rgba(34,197,94,0.3);
      border-radius: 12px;
      text-align: center;
    }
    .blacklist-safe p {
      margin: 0;
      font-weight: 700;
      color: #22c55e;
    }
    .blacklist-safe .sub {
      font-weight: 400;
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-top: 0.3rem;
    }

    /* === Scam list grid === */
    .scam-list-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 0.8rem;
      max-height: 600px;
      overflow-y: auto;
      padding-right: 0.3rem;
    }
    .scam-list-grid::-webkit-scrollbar { width: 6px; }
    .scam-list-grid::-webkit-scrollbar-thumb { background: rgba(245,184,0,0.3); border-radius: 3px; }
    .scam-card {
      padding: 0.8rem 1rem;
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 10px;
      transition: border-color 0.2s;
    }
    .scam-card:hover { border-color: #ef4444; }
    .scam-card-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 0.5rem;
    }
    .scam-card-head strong {
      font-size: 0.95rem;
      color: var(--text-primary);
    }
    .scam-reports {
      font-size: 0.72rem;
      padding: 0.15rem 0.5rem;
      background: rgba(239,68,68,0.15);
      color: #fca5a5;
      border-radius: 4px;
      white-space: nowrap;
    }
    .scam-card-date {
      font-size: 0.78rem;
      color: var(--text-muted);
      margin: 0.3rem 0;
    }
    .scam-card-urls {
      display: flex;
      flex-wrap: wrap;
      gap: 0.3rem;
    }
    .scam-card-urls span {
      font-size: 0.72rem;
      padding: 0.1rem 0.4rem;
      background: rgba(255,255,255,0.05);
      border-radius: 4px;
      color: var(--text-muted);
      font-family: monospace;
    }
    .scam-card-urls .more {
      color: #f5b800;
      font-family: inherit;
    }

    /* === Risk Tags === */
    .scam-card-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.3rem;
      margin-bottom: 0.5rem;
    }
    .risk-tag {
      font-size: 0.65rem;
      font-weight: 700;
      padding: 0.12rem 0.5rem;
      border-radius: 4px;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }
    .tag-recent {
      background: rgba(245,184,0,0.2);
      color: #f5b800;
      border: 1px solid rgba(245,184,0,0.4);
    }
    .tag-danger {
      background: rgba(239,68,68,0.2);
      color: #fca5a5;
      border: 1px solid rgba(239,68,68,0.4);
    }
    .tag-shell {
      background: rgba(168,85,247,0.15);
      color: #c4b5fd;
      border: 1px solid rgba(168,85,247,0.35);
    }
    .scam-reports.reports-high {
      background: rgba(239,68,68,0.25);
      color: #fca5a5;
      font-weight: 700;
    }
    .scam-reports.reports-critical {
      background: rgba(239,68,68,0.4);
      color: #fff;
      font-weight: 900;
      animation: reportPulse 2s ease-in-out infinite;
    }
    @keyframes reportPulse {
      0%, 100% { box-shadow: none; }
      50% { box-shadow: 0 0 8px rgba(239,68,68,0.4); }
    }

    /* === Quick Filters === */
    .quick-filters {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }
    .qf-btn {
      padding: 0.45rem 0.9rem;
      border-radius: 20px;
      border: 1px solid var(--border);
      background: var(--bg-secondary);
      color: var(--text-secondary);
      font-size: 0.82rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      font-family: inherit;
    }
    .qf-btn:hover {
      border-color: #f5b800;
      color: #f5b800;
    }
    .qf-btn.qf-active {
      background: rgba(245,184,0,0.15);
      border-color: #f5b800;
      color: #f5b800;
    }

    /* === No Result Hint === */
    .no-result-hint {
      text-align: center;
      padding: 2rem 1.5rem;
      background: rgba(245,184,0,0.05);
      border: 1px dashed rgba(245,184,0,0.3);
      border-radius: 12px;
      margin-bottom: 1rem;
    }
    .no-result-hint p {
      margin: 0;
      color: var(--text-secondary);
      font-size: 0.95rem;
    }
    .no-result-hint strong {
      color: #f5b800;
    }
    .no-result-sub {
      font-size: 0.82rem !important;
      color: var(--text-muted) !important;
      margin-top: 0.5rem !important;
    }
    .no-result-btn {
      margin-top: 1rem;
      padding: 0.7rem 1.5rem;
      background: linear-gradient(135deg, #f5b800, #e09900);
      border: none;
      border-radius: 10px;
      color: #000;
      font-weight: 700;
      font-size: 0.9rem;
      cursor: pointer;
      font-family: inherit;
      transition: all 0.2s;
    }
    .no-result-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(245,184,0,0.3);
    }

    /* === Module card === */
    .check-module {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 1.8rem;
      margin-bottom: 2rem;
    }
    .module-header {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 1.2rem;
    }
    .module-number {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px; height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, #f5b800, #e09900);
      color: #000;
      font-weight: 900;
      font-size: 1.2rem;
      flex-shrink: 0;
    }
    .module-desc {
      color: var(--text-secondary);
      font-size: 0.9rem;
      margin: 0.3rem 0 0;
      line-height: 1.6;
    }

    /* === Input group (WHOIS) === */
    .input-group {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }
    .input-group input {
      flex: 1;
      padding: 0.85rem 1rem;
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 10px;
      color: var(--text-primary);
      font-size: 1rem;
      font-family: inherit;
      outline: none;
      transition: border-color 0.2s;
    }
    .input-group input:focus {
      border-color: #f5b800;
    }
    .input-group button,
    .calc-btn {
      padding: 0.85rem 1.5rem;
      background: linear-gradient(135deg, #f5b800, #e09900);
      border: none;
      border-radius: 10px;
      color: #000;
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
      white-space: nowrap;
      transition: all 0.2s;
      font-family: inherit;
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    .input-group button:hover,
    .calc-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(245, 184, 0, 0.3);
    }
    .input-group button:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
    }
    .calc-btn {
      margin-top: 1rem;
    }

    /* === Calc grid === */
    .calc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
    }
    .calc-field label {
      display: block;
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-bottom: 0.4rem;
      font-weight: 600;
    }
    .calc-field input,
    .calc-field select {
      width: 100%;
      padding: 0.75rem 0.8rem;
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 10px;
      color: var(--text-primary);
      font-size: 1rem;
      font-family: inherit;
      outline: none;
      transition: border-color 0.2s;
    }
    .calc-field input:focus,
    .calc-field select:focus {
      border-color: #f5b800;
    }

    /* === Result area === */
    .result-area {
      margin-top: 1rem;
      padding: 1.2rem;
      border-radius: 12px;
      border: 1px solid var(--border);
      line-height: 1.8;
    }
    .result-safe   { background: rgba(34,197,94,0.08);  border-color: rgba(34,197,94,0.3); }
    .result-warning { background: rgba(245,184,0,0.08); border-color: rgba(245,184,0,0.3); }
    .result-danger  { background: rgba(239,68,68,0.08); border-color: rgba(239,68,68,0.3); }
    .result-neutral { background: var(--bg-secondary); }

    .result-label {
      font-size: 0.82rem;
      color: var(--text-muted);
      margin-bottom: 0.15rem;
    }
    .result-value {
      font-weight: 700;
      font-size: 1.05rem;
    }
    .result-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 0.4rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .result-row:last-child { border-bottom: none; }

    /* === Dots === */
    .module-tip {
      margin-top: 1rem;
      font-size: 0.85rem;
      color: var(--text-muted);
      line-height: 1.8;
    }
    .dot {
      display: inline-block;
      width: 10px; height: 10px;
      border-radius: 50%;
      margin-right: 2px;
      vertical-align: middle;
    }
    .dot-green  { background: #22c55e; }
    .dot-yellow { background: #f5b800; }
    .dot-red    { background: #ef4444; }

    /* === External buttons === */
    .external-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.85rem 1.5rem;
      background: linear-gradient(135deg, #ef4444, #dc2626);
      border: none;
      border-radius: 10px;
      color: #fff;
      font-weight: 700;
      font-size: 0.95rem;
      text-decoration: none;
      transition: all 0.2s;
    }
    .external-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(239,68,68,0.3);
    }
    .external-btn-outline {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text-primary);
    }
    .external-btn-outline:hover {
      border-color: #ef4444;
      color: #ef4444;
      box-shadow: 0 4px 16px rgba(239,68,68,0.1);
    }

    /* === Bottom CTA === */
    .bottom-cta {
      text-align: center;
      padding: 2rem;
      margin-bottom: 2rem;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 16px;
    }
    .cta-link {
      display: inline-block;
      padding: 0.6rem 1.2rem;
      background: rgba(245,184,0,0.1);
      border: 1px solid rgba(245,184,0,0.3);
      border-radius: 8px;
      color: var(--gold-light);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 600;
      transition: all 0.2s;
    }
    .cta-link:hover {
      background: rgba(245,184,0,0.2);
      border-color: #f5b800;
      transform: translateY(-1px);
    }

    /* === Sticky Warning === */
    .sticky-warning {
      position: fixed;
      bottom: -80px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 900;
      display: flex;
      align-items: center;
      gap: 0.8rem;
      padding: 0.7rem 1.2rem;
      background: rgba(18, 18, 18, 0.95);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(239,68,68,0.4);
      border-radius: 14px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 20px rgba(239,68,68,0.1);
      transition: bottom 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      max-width: 680px;
      width: calc(100% - 2rem);
    }
    .sticky-warning.visible {
      bottom: 1.2rem;
    }
    .sticky-warning-text {
      font-size: 0.82rem;
      color: var(--text-secondary);
      font-weight: 600;
      flex: 1;
    }
    .sticky-warning-btn {
      padding: 0.5rem 1rem;
      background: linear-gradient(135deg, #f5b800, #e09900);
      border: none;
      border-radius: 8px;
      color: #000;
      font-weight: 800;
      font-size: 0.8rem;
      cursor: pointer;
      white-space: nowrap;
      font-family: inherit;
      transition: all 0.2s;
    }
    .sticky-warning-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(245,184,0,0.3);
    }

    /* === Responsive === */
    @media (max-width: 768px) {
      /* Page hero */
      .page-hero h1 { font-size: 1.6rem !important; }
      .page-hero p { font-size: 0.88rem !important; }

      /* Hero search — even more prominent on mobile */
      .hero-search {
        margin: 1rem -0.5rem 1.5rem;
        padding: 1.5rem 1rem;
        border-radius: 16px;
      }
      .hero-search-label { font-size: 1.1rem; }
      .hero-input-wrap {
        flex-direction: column;
        gap: 0.6rem;
      }
      .hero-input-wrap input {
        padding: 1rem;
        font-size: 1.1rem;
        text-align: center;
        border-radius: 12px;
      }
      .hero-input-wrap button {
        width: 100%;
        justify-content: center;
        padding: 1rem;
        font-size: 1.05rem;
        border-radius: 12px;
      }

      /* Hero stats row */
      .hero-stats-row {
        gap: 0.6rem;
        margin-top: 1rem;
        padding-top: 1rem;
        flex-wrap: wrap;
      }
      .hero-stat-num { font-size: 1.3rem; }
      .hero-stat-label { font-size: 0.7rem; }
      .hero-stat-divider { height: 24px; }
      .last-sync { font-size: 0.72rem; }

      /* Module cards */
      .check-module {
        padding: 1rem;
        border-radius: 12px;
        margin-bottom: 1.2rem;
      }

      /* Module header — tighter */
      .module-header {
        gap: 0.7rem;
        margin-bottom: 0.8rem;
      }
      .module-number {
        width: 32px; height: 32px;
        font-size: 1rem;
      }
      .module-header h2 { font-size: 1.15rem !important; }
      .module-desc { font-size: 0.82rem; }

      /* Calc grid — single column */
      .calc-grid {
        grid-template-columns: 1fr;
        gap: 0.8rem;
      }
      .calc-field label { font-size: 0.82rem; }
      .calc-field input,
      .calc-field select {
        padding: 0.8rem;
        font-size: 0.95rem;
      }
      .calc-btn {
        width: 100%;
        justify-content: center;
        padding: 0.9rem;
        font-size: 1rem;
        border-radius: 10px;
      }

      /* Result area — tighter */
      .result-area {
        padding: 1rem;
        border-radius: 10px;
      }
      .result-area > div:first-child {
        font-size: 1.1rem !important;
      }
      .result-row {
        flex-direction: column;
        gap: 0.1rem;
        padding: 0.5rem 0;
      }
      .result-value {
        font-size: 0.95rem;
      }

      /* 165 buttons — full width stack */
      #report-module > div {
        flex-direction: column;
      }
      .external-btn {
        width: 100%;
        justify-content: center;
        padding: 0.9rem;
        border-radius: 10px;
        font-size: 0.95rem;
      }

      /* Module tips */
      .module-tip { font-size: 0.78rem; line-height: 1.7; }

      /* Bottom CTA */
      .bottom-cta {
        padding: 1.2rem;
        margin-bottom: 1.5rem;
        border-radius: 12px;
      }
      .bottom-cta p { font-size: 0.95rem; }
      .cta-link {
        display: block;
        text-align: center;
        font-size: 0.85rem;
        padding: 0.7rem 1rem;
      }

      /* Hero banner — shorter */
      .hero-banner { min-height: 80px !important; }

      /* Quick filters — scroll horizontal */
      .quick-filters { gap: 0.35rem; }
      .qf-btn { font-size: 0.75rem; padding: 0.4rem 0.7rem; }

      /* Sticky warning — hide on mobile */
      .sticky-warning { display: none !important; }
    }

    /* Extra small phones */
    @media (max-width: 380px) {
      .check-module { padding: 0.8rem; }
      .module-header h2 { font-size: 1.05rem !important; }
      .page-hero h1 { font-size: 1.35rem !important; }
      .hero-search { padding: 1.2rem 0.8rem; }
      .hero-search-label { font-size: 1rem; }
      .hero-input-wrap input { font-size: 1rem; padding: 0.9rem; }
    }

    /* Donate banner (medium) */
    .donate-banner { max-width: 900px; margin: 2rem auto; }
    .donate-banner-inner {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.2rem 1.5rem;
      background: linear-gradient(135deg, rgba(57,255,20,0.06), rgba(245,184,0,0.04));
      border: 1px solid rgba(57,255,20,0.25);
      border-radius: 14px;
      font-size: 0.9rem;
      line-height: 1.7;
    }
    .donate-banner-icon { font-size: 2rem; flex-shrink: 0; margin-top: 0.2rem; }
    .donate-banner-body p { margin: 0 0 0.4rem; color: var(--text-secondary); }
    .donate-banner-body p strong { color: var(--text-primary); }
    .donate-banner-bank {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      margin-top: 0.4rem;
      padding: 0.4rem 0.8rem;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 8px;
      font-family: 'SF Mono','Fira Code',monospace;
      font-size: 0.88rem;
    }
    .donate-banner-bank strong { color: var(--guava-green); letter-spacing: 0.5px; }
    .donate-banner-copy { background: var(--guava-green); color: #000; border: none; border-radius: 6px; padding: 2px 10px; font-size: 0.76rem; font-weight: 700; cursor: pointer; transition: opacity 0.15s; }
    .donate-banner-copy:hover { opacity: 0.8; }
    @media (max-width: 600px) {
