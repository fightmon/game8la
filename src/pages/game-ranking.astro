<script>
document.querySelectorAll('.gr-filter-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.gr-filter-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    const f=btn.dataset.filter;
    document.querySelectorAll('.game-item').forEach(el=>{
      if(f==='all'){el.style.display='grid';return}
      const tags=(el.dataset.tags||'').split(',');
      el.style.display=tags.includes(f)?'grid':'none';
    });
  });
});
</script>
</BaseLayout>


