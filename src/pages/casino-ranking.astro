<script>
function filterCasinos(cat) {
  document.querySelectorAll('.casino-item').forEach(el => {
    if(cat === 'all') { el.style.display = 'grid'; return; }
    el.style.display = el.dataset.cat === cat ? 'grid' : 'none';
  });
  // highlight active filter button
  document.querySelectorAll('.tag[onclick]').forEach(btn => {
    btn.style.background = btn.getAttribute('onclick').includes("'"+cat+"'") ? 'rgba(57,255,20,0.4)' : '';
  });
}
</script>
