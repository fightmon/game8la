body{font-family:'Noto Sans TC',sans-serif;background:radial-gradient(ellipse 80% 50% at 20% 10%,rgba(57,255,20,0.06) 0%,transparent 50%),radial-gradient(ellipse 60% 40% at 80% 30%,rgba(255,16,240,0.05) 0%,transparent 50%),radial-gradient(ellipse 70% 50% at 50% 70%,rgba(57,255,20,0.04) 0%,transparent 50%),radial-gradient(ellipse 50% 35% at 10% 90%,rgba(255,16,240,0.04) 0%,transparent 50%),linear-gradient(180deg,#0a0a0a 0%,#121212 15%,#0e120e 40%,#12101a 65%,#121212 85%,#0a0a0a 100%);color:var(--text-primary);line-height:1.8}
a{color:var(--gold-light);text-decoration:none}a:hover{text-decoration:underline}
