.hero-title-inner::after {
  content: ''; position: absolute; width: 30px; height: 30px;
  border-color: rgba(255,255,255,0.6); border-style: solid;
}
.hero-title-inner::before {
  top: 0; right: 0;
  border-width: 2px 2px 0 0;
  animation: bracketTR 4s ease-in-out infinite;
}
.hero-title-inner::after {
  bottom: 0; left: 0;
  border-width: 0 0 2px 2px;
  animation: bracketBL 4s ease-in-out infinite;
}
@keyframes bracketTL {
  0%,100% { width: 30px; height: 30px; opacity: 0.6; }
  50% { width: 50px; height: 40px; opacity: 1; }
}
@keyframes bracketBR {
  0%,100% { width: 30px; height: 30px; opacity: 0.6; }
  50% { width: 50px; height: 40px; opacity: 1; }
}
@keyframes bracketTR {
  0%,100% { width: 30px; height: 30px; opacity: 0.6; }
  50% { width: 50px; height: 40px; opacity: 1; }
}
@keyframes bracketBL {
  0%,100% { width: 30px; height: 30px; opacity: 0.6; }
  50% { width: 50px; height: 40px; opacity: 1; }
}

.hero-content p {
  color: #bbb; font-size: 1.05rem; margin-bottom: 2rem;
  letter-spacing: 0.5px;
}

/* Buttons — neon style */
.hero-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.btn-primary {
  padding: 0.8rem 2rem;
  background: #39FF14; color: #000; font-weight: 700;
  border: none; border-radius: 10px;
  cursor: pointer; font-size: 1rem; transition: all 0.3s;
  box-shadow: 0 0 15px rgba(57,255,20,0.4), 0 0 30px rgba(57,255,20,0.15);
  text-shadow: none; text-decoration: none;
}
.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 0 25px rgba(57,255,20,0.6), 0 0 50px rgba(57,255,20,0.3);
  filter: brightness(1.1);
}
.btn-outline {
  padding: 0.8rem 2rem; background: transparent;
  border: 2px solid #FF10F0; color: #FF10F0;
  border-radius: 10px; cursor: pointer; font-size: 1rem; font-weight: 600;
  transition: all 0.3s; text-decoration: none;
  text-shadow: 0 0 8px rgba(255,16,240,0.4);
  box-shadow: 0 0 10px rgba(255,16,240,0.15);
}
.btn-outline:hover {
  background: rgba(255,16,240,0.1);
  box-shadow: 0 0 20px rgba(255,16,240,0.3);
  text-decoration: none;
}

/* Slide arrows */
.hero-arrows {
  position: absolute; top: 50%; width: 100%;
  display: flex; justify-content: space-between; padding: 0 1.5rem;
  transform: translateY(-50%); z-index: 6;
}
.hero-arrows button {
  width: 50px; height: 50px; border-radius: 50%;
  background: rgba(0,0,0,0.6); border: 1px solid rgba(57,255,20,0.3);
  color: #39FF14; font-size: 1.2rem; cursor: pointer;
  transition: all 0.3s;
}
.hero-arrows button:hover { background: #39FF14; color: #000; box-shadow: 0 0 20px rgba(57,255,20,0.5); }
.hero-dots {
  position: absolute; bottom: 20px; left: 50%;
  transform: translateX(-50%); display: flex; gap: 0.5rem; z-index: 6;
}
.hero-dots span {
  width: 12px; height: 12px; border-radius: 50%;
  background: rgba(255,255,255,0.2); cursor: pointer; transition: all 0.3s;
}
.hero-dots span.active {
  background: #39FF14; width: 30px; border-radius: 6px;
  box-shadow: 0 0 10px rgba(57,255,20,0.5);
}

/* === Cyberpunk decorations (from video) === */

/* Four-pointed twinkling stars */
.cyber-star, .cyber-globe, .cyber-wave { pointer-events: none !important; }
.hero::before, .hero::after { pointer-events: none !important; }
.hero-slides { pointer-events: none; }
.hero-slide, .hero-content, .hero-btns, .hero-btns * { pointer-events: auto; }
/* Hero button text bulletproof visibility */
.hero-btns .btn-primary,
.hero-btns .btn-primary:hover,
.hero-btns .btn-primary:focus,
.hero-btns .btn-primary:active {
  color: #000 !important;
  text-shadow: none !important;
  filter: none !important;
  -webkit-text-fill-color: #000 !important;
  background: #39FF14 !important;
}
.hero-btns .btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 0 25px rgba(57,255,20,0.6), 0 0 50px rgba(57,255,20,0.3);
  background: #4aff2a !important;
}
.hero-btns .btn-outline,
.hero-btns .btn-outline:hover {
  color: #FF10F0 !important;
  -webkit-text-fill-color: #FF10F0 !important;
}
.hero-title-frame, .hero-title-inner, .hero-content :is(h1, h2.hero-h), .hero-content :is(h1, h2.hero-h) em, .hero-content .tag, .hero-content p { pointer-events: none; }
.hero-content { pointer-events: none; }
.hero-btns, .hero-btns * { pointer-events: auto !important; }
.hero-btns a, .hero-btns button { cursor: pointer !important; position: relative; z-index: 20; }
.cyber-star {
  position: absolute; z-index: 3; width: 24px; height: 24px;
  color: #39FF14; filter: drop-shadow(0 0 8px currentColor);
}
.cyber-star.s1 { top: 18%; left: 12%; animation: starTwinkle 2s ease-in-out infinite; }
.cyber-star.s2 { top: 55%; right: 10%; width: 18px; height: 18px; animation: starTwinkle 2.5s ease-in-out 0.8s infinite; }
.cyber-star.s3 { bottom: 22%; left: 8%; width: 14px; height: 14px; animation: starTwinkle 3s ease-in-out 1.5s infinite; color: #FF10F0; filter: drop-shadow(0 0 6px #FF10F0); }
.cyber-star.s4 { top: 25%; right: 18%; width: 20px; height: 20px; animation: starTwinkle 2.2s ease-in-out 0.4s infinite; }
@keyframes starTwinkle {
  0%,100% { transform: scale(1) rotate(0deg); opacity: 0.7; }
  50% { transform: scale(1.4) rotate(30deg); opacity: 1; }
}

/* Wireframe globe (CSS only) */
.cyber-globe {
  position: absolute; z-index: 2;
  width: 80px; height: 80px;
  border: 1.5px solid rgba(255,255,255,0.25);
  border-radius: 50%;
  animation: globeSpin 8s linear infinite;
}
.cyber-globe::before {
  content: ''; position: absolute; inset: -1px;
  border: 1.5px solid rgba(255,255,255,0.25);
  border-radius: 50%;
  transform: rotateY(60deg);
}
.cyber-globe::after {
  content: ''; position: absolute;
  top: 50%; left: -1px; right: -1px; height: 0;
  border-top: 1.5px solid rgba(255,255,255,0.2);
}
.cyber-globe .globe-ring {
  position: absolute; inset: -1px;
  border: 1.5px solid rgba(255,255,255,0.15);
  border-radius: 50%;
}
.cyber-globe .globe-ring:nth-child(1) { transform: rotateY(30deg); }
.cyber-globe .globe-ring:nth-child(2) { transform: rotateY(90deg); }
.cyber-globe .globe-ring:nth-child(3) { transform: rotateX(90deg) scale(0.5); top: 25%; bottom: 25%; }

.globe-1 { top: 60%; left: 5%; animation-direction: reverse; }
.globe-2 { top: 10%; right: 5%; width: 60px; height: 60px; }
@keyframes globeSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* Wavy line animation */
.cyber-wave {
  position: absolute; bottom: 18%; left: 50%; transform: translateX(-50%);
  z-index: 3; width: 140px; height: 20px;
}
.cyber-wave svg { width: 100%; height: 100%; }
.cyber-wave path {
  fill: none; stroke: #39FF14; stroke-width: 2.5;
  stroke-dasharray: 200; stroke-dashoffset: 200;
  animation: waveDraw 2s ease-in-out infinite alternate;
  filter: drop-shadow(0 0 4px #39FF14);
}
@keyframes waveDraw {
  to { stroke-dashoffset: 0; }
}

/* Scan line overlay */
.hero .scanline {
  position: absolute; inset: 0; z-index: 4; pointer-events: none;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0,0,0,0.06) 2px,
    rgba(0,0,0,0.06) 4px
  );
}

/* Guava SVG inline icon */
.guava-icon { display: inline-block; vertical-align: middle; }

/* === SECTIONS === */
.section { padding: 4rem 2rem; max-width: 1300px; margin: 0 auto; }
.section-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 2rem;
}
.section-header h2 {
  font-size: 1.8rem; font-weight: 900;
  display: flex; align-items: center; gap: 0.5rem;
}
.section-header h2::before {
  content: ''; width: 4px; height: 30px;
  background: linear-gradient(to bottom, var(--gold-light), var(--guava-green));
  border-radius: 2px;
}
.section-header .more-link {
  color: var(--gold); text-decoration: none; font-size: 0.95rem;
  display: flex; align-items: center; gap: 0.3rem;
}
.section-header .more-link:hover { text-decoration: underline; color: var(--gold-light); }

/* === STATS BAR === */
.stats-bar {
  display: flex; justify-content: center; gap: 3rem; padding: 2.5rem 2rem;
  background: linear-gradient(135deg, var(--bg-secondary), rgba(42,51,32,0.5));
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}
.stat-item { text-align: center; }
.stat-item .stat-num {
  font-size: 2.2rem; font-weight: 900;
  background: linear-gradient(135deg, var(--gold-light), var(--gold));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.stat-item .stat-label { color: var(--text-muted); font-size: 0.9rem; }

/* === RANKING === */
.ranking-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem;
}
.rank-card {
  background: var(--bg-card); border-radius: 16px; overflow: hidden;
  border: 1px solid var(--border); transition: all 0.3s; cursor: pointer;
  position: relative;
}
.rank-card:hover {
  transform: translateY(-5px);
  border-color: var(--gold);
  box-shadow: 0 10px 30px rgba(0,0,0,0.4), 0 0 20px var(--gold-glow);
}
.rank-badge {
  position: absolute; top: 12px; left: 12px; z-index: 2;
  width: 36px; height: 36px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-weight: 900; font-size: 0.9rem;
}
.rank-badge.gold { background: linear-gradient(135deg, var(--gold-light), var(--gold)); color: #000000; box-shadow: 0 0 12px var(--gold-glow); }
.rank-badge.silver { background: linear-gradient(135deg, #c0c0c0, #909090); color: #000000; }
.rank-badge.bronze { background: linear-gradient(135deg, #b45309, #92400e); color: #fff; }
.rank-badge.normal { background: var(--bg-secondary); color: var(--text-muted); border: 1px solid var(--border); }
.rank-img {
  width: 100%; height: 160px;
  display: flex; align-items: center; justify-content: center;
  font-size: 3rem;
}
.rank-info { padding: 1.2rem; }
.rank-info h3 { font-size: 1.1rem; margin-bottom: 0.3rem; }
.rank-info .rank-score {
  display: flex; align-items: center; gap: 0.5rem;
  margin-bottom: 0.5rem;
}
.rank-info .rank-score .score {
  font-size: 1.3rem; font-weight: 900; color: var(--gold-light);
}
.stars { color: var(--gold-light); font-size: 0.85rem; }
.stars .empty { color: var(--text-muted); }
.rank-info .rank-tags { display: flex; gap: 0.3rem; flex-wrap: wrap; }
.rank-info .rank-tags span {
  font-size: 0.75rem; padding: 0.2rem 0.6rem;
  background: rgba(57,255,20,0.15); color: var(--guava-green);
  border-radius: 4px;
}

/* === GAME CARDS === */
.game-tabs {
  display: flex; gap: 0.5rem; margin-bottom: 2rem;
  border-bottom: 2px solid var(--border); padding-bottom: 0;
}
.game-tab {
  padding: 0.7rem 1.5rem; background: none; border: none;
  color: var(--text-muted); font-size: 0.95rem; cursor: pointer;
  border-bottom: 2px solid transparent; margin-bottom: -2px;
  transition: all 0.3s; font-family: inherit;
}
.game-tab:hover { color: var(--text-primary); }
.game-tab.active {
  color: var(--gold-light); border-bottom-color: var(--gold);
  font-weight: 700;
}
.game-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;
}
.game-card {
  background: var(--bg-card); border-radius: 16px; overflow: hidden;
  border: 1px solid var(--border); transition: all 0.3s; cursor: pointer;
}
.game-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.4);
  border-color: rgba(57,255,20,0.3);
}
.game-card-img {
  width: 100%; height: 180px;
  display: flex; align-items: center; justify-content: center;
  font-size: 4rem; position: relative;
}
.game-card-img .hot-badge {
  position: absolute; top: 10px; right: 10px;
  background: linear-gradient(135deg, var(--guava-pink), var(--guava-flesh));
  color: white; padding: 0.2rem 0.7rem; border-radius: 20px;
  font-size: 0.75rem; font-weight: 700;
}
.game-card-img .new-badge {
  position: absolute; top: 10px; right: 10px;
  background: var(--guava-green); color: #0a2810;
  padding: 0.2rem 0.7rem; border-radius: 20px;
  font-size: 0.75rem; font-weight: 900;
}
.game-card-body { padding: 1.2rem 1.4rem 1.4rem; }
.game-card-body h3 { font-size: 1.05rem; margin-bottom: 0.5rem; }
.game-card-body .game-meta {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 0.8rem;
}
.game-card-body .game-meta .rating {
  display: flex; align-items: center; gap: 0.3rem;
  font-weight: 700; color: var(--gold-light);
}
.game-card-body .game-meta .views {
  color: var(--text-muted); font-size: 0.85rem;
}
.game-card-body .game-desc {
  color: var(--text-secondary); font-size: 0.85rem;
  display: -webkit-box; -webkit-line-clamp: 2;
  -webkit-box-orient: vertical; overflow: hidden;
  margin-bottom: 1rem;
}
.game-card-body .game-actions { display: flex; gap: 0.6rem; margin-top: 0.2rem; }
.game-card-body .game-actions a, .game-card-body .game-actions button {
  flex: 1; padding: 0.6rem 0.5rem; border-radius: 8px;
  font-size: 0.85rem; cursor: pointer; font-weight: 600;
  font-family: inherit; transition: all 0.3s;
}
.btn-play {
  background: linear-gradient(135deg, var(--guava-green), var(--guava-green-dark));
  border: none; color: white;
}
.btn-play:hover { filter: brightness(1.15); }
.btn-info {
  background: transparent; border: 1px solid var(--gold);
  color: var(--gold-light);
}
.btn-info:hover { background: rgba(57,255,20,0.1); }

/* === ARTICLES === */
.article-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem;
}
.article-card {
  background: var(--bg-card); border-radius: 16px;
  overflow: hidden; border: 1px solid var(--border);
  transition: all 0.3s; cursor: pointer;
}
.article-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.4);
}
.article-img {
  width: 100%; height: 160px;
  display: flex; align-items: center; justify-content: center;
  font-size: 3rem; position: relative; overflow: hidden;
}
.article-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.article-img .cat-badge {
  position: absolute; top: 10px; left: 10px;
  padding: 0.2rem 0.8rem; border-radius: 20px;
  font-size: 0.75rem; font-weight: 700;
}
.cat-attack { background: var(--guava-pink); color: #2a0014; font-weight: 900; }
.cat-review { background: var(--guava-green); color: #0a2810; font-weight: 900; }
.cat-news { background: var(--gold); color: #000000; }
.cat-tip { background: #b32418; color: #ffffff; font-weight: 900; }
/* 以「文章類別」決定顏色，每個類別固定一色 */
.cat-slots     { background: #f5b800; color: #1a0f00; font-weight: 900; }
.cat-baccarat  { background: #4facfe; color: #001a2e; font-weight: 900; }
.cat-live      { background: #fa709a; color: #2a0014; font-weight: 900; }
.cat-lottery   { background: #1a8c3a; color: #ffffff; font-weight: 900; }
.cat-anti-scam { background: #b32418; color: #ffffff; font-weight: 900; }
.cat-finance   { background: #00c896; color: #002a1e; font-weight: 900; }
.cat-sports    { background: #ff6b35; color: #2a0a00; font-weight: 900; }
.cat-fishing   { background: #00d4ff; color: #001a2e; font-weight: 900; }
.cat-poker     { background: #9b59b6; color: #ffffff; font-weight: 900; }
.cat-other     { background: #888888; color: #ffffff; font-weight: 900; }
.article-body { padding: 1.2rem; }
.article-body h3 {
  font-size: 1rem; margin-bottom: 0.5rem;
  display: -webkit-box; -webkit-line-clamp: 2;
  -webkit-box-orient: vertical; overflow: hidden;
}
.article-body .article-meta {
  display: flex; align-items: center; gap: 1rem;
  color: var(--text-muted); font-size: 0.8rem;
  margin-bottom: 0.5rem;
}
.article-body .article-excerpt {
  color: var(--text-secondary); font-size: 0.85rem;
  display: -webkit-box; -webkit-line-clamp: 2;
  -webkit-box-orient: vertical; overflow: hidden;
}

/* === USER RATING WIDGET === */
.rating-section {
  background: linear-gradient(135deg, var(--bg-secondary), rgba(42,51,32,0.5));
  border-radius: 20px;
  padding: 3rem; text-align: center;
  border: 1px solid var(--border);
  margin: 2rem auto; max-width: 700px;
  position: relative; overflow: hidden;
}
.rating-section::before {
  content: ''; position: absolute; top: -50%; right: -20%;
  width: 300px; height: 300px; border-radius: 50%;
  background: radial-gradient(circle, rgba(57,255,20,0.08), transparent);
}
.rating-section h3 { font-size: 1.5rem; margin-bottom: 0.5rem; position: relative; }
.rating-section > p { color: var(--text-secondary); margin-bottom: 1.5rem; position: relative; }
.user-stars { display: flex; justify-content: center; gap: 0.5rem; margin-bottom: 1.5rem; position: relative; }
.user-stars i {
  font-size: 2.5rem; color: var(--text-muted); cursor: pointer;
  transition: all 0.2s;
}
.user-stars i:hover, .user-stars i.active { color: var(--gold-light); transform: scale(1.15); filter: drop-shadow(0 0 6px var(--gold-glow)); }
.rating-input {
  display: flex; gap: 0.5rem; max-width: 500px; margin: 0 auto; position: relative;
}
.rating-input input {
  flex: 1; padding: 0.8rem 1.2rem;
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: 10px; color: var(--text-primary);
  font-size: 0.95rem; outline: none; font-family: inherit;
}
.rating-input input:focus { border-color: var(--gold); }
.rating-input button {
  padding: 0.8rem 1.5rem;
  background: linear-gradient(135deg, var(--gold-light), var(--gold));
  border: none; border-radius: 10px; color: #000000;
  font-weight: 700; cursor: pointer; font-family: inherit;
  transition: all 0.3s;
}
.rating-input button:hover { filter: brightness(1.1); box-shadow: 0 4px 15px var(--gold-glow); }
.rating-input button { white-space: nowrap; flex-shrink: 0; }
@media (max-width: 600px) {
  .rating-input { flex-direction: column; gap: 0.6rem; }
  .rating-input input { width: 100%; }
  .rating-input button { width: 100%; padding: 0.9rem 1rem; }
  .review-item { flex-wrap: nowrap; }
  .review-content { min-width: 0; }
  .review-content .review-header { flex-wrap: wrap; gap: 0.3rem 0.6rem; }
  .review-content .review-text { word-break: break-word; }
}

/* === REVIEW COMMENTS === */
.reviews-list { margin-top: 2rem; position: relative; }
.review-item {
  background: var(--bg-card); border-radius: 12px;
  padding: 1.2rem; margin-bottom: 1rem;
  border: 1px solid var(--border);
  display: flex; gap: 1rem;
}
.review-avatar {
  width: 44px; height: 44px; border-radius: 50%;
  background: linear-gradient(135deg, var(--guava-green), var(--gold));
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; flex-shrink: 0; color: #000000;
}
.review-content { flex: 1; }
.review-content .review-header {
  display: flex; align-items: center; gap: 0.8rem; margin-bottom: 0.3rem;
}
.review-content .review-header .name { font-weight: 700; font-size: 0.95rem; }
.review-content .review-header .date { color: var(--text-muted); font-size: 0.8rem; }
.review-content .review-text { color: var(--text-secondary); font-size: 0.9rem; }

/* === SIDEBAR HOT LIST === */
.hot-list {
  background: var(--bg-card); border-radius: 16px;
  padding: 1.5rem; border: 1px solid var(--border);
}
.hot-list h3 {
  font-size: 1.1rem; margin-bottom: 1rem;
  padding-bottom: 0.8rem; border-bottom: 1px solid var(--border);
}
.hot-item {
  display: flex; align-items: center; gap: 0.8rem;
  padding: 0.7rem 0; border-bottom: 1px solid rgba(42,51,32,0.5);
  cursor: pointer; transition: all 0.2s;
}
.hot-item:last-child { border-bottom: none; }
.hot-item:hover { padding-left: 0.5rem; }
.hot-item .hot-num {
  width: 26px; height: 26px; border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-weight: 900; font-size: 0.8rem; flex-shrink: 0;
}
.hot-num.top1 { background: linear-gradient(135deg, var(--gold-light), var(--gold)); color: #000000; }
.hot-num.top2 { background: #c0c0c0; color: #000000; }
.hot-num.top3 { background: #b45309; color: #fff; }
.hot-num.rest { background: var(--bg-secondary); color: var(--text-muted); }
.hot-item .hot-title { font-size: 0.9rem; }
.hot-item .hot-views { color: var(--text-muted); font-size: 0.8rem; margin-left: auto; white-space: nowrap; }

/* === CATEGORY FILTER === */
.category-filters {
  display: flex; gap: 0.8rem; flex-wrap: wrap; margin-bottom: 2rem;
}
.cat-filter {
  padding: 0.6rem 1.2rem; background: var(--bg-card);
