}
function setRating(n) { userRating = n; resetRating(); }

function submitReview() {
  const text = document.getElementById('reviewText').value.trim();
  if (!text || userRating === 0) { alert('先選星星再丟8LA！'); return; }
  const list = document.getElementById('reviewsList');
  const starSvg = '<svg viewBox="0 0 24 24" width="1em" height="1em" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--gold)"><polygon points="12 2 15.09 10.26 24 10.27 17.18 16.70 20.27 24.97 12 18.54 3.73 24.98 6.82 16.71 0 10.27 8.91 10.26 12 2"></polygon></svg>';
  const emptySvg = '<svg viewBox="0 0 24 24" width="1em" height="1em" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--text-muted)"><polygon points="12 2 15.09 10.26 24 10.27 17.18 16.70 20.27 24.97 12 18.54 3.73 24.98 6.82 16.71 0 10.27 8.91 10.26 12 2"></polygon></svg>';
  const stars = Array(5).fill(0).map((_, i) =>
    i < userRating ? starSvg : emptySvg
  ).join('');
  const today = new Date().toISOString().split('T')[0];
  const html = `<div class="review-item animate-in">
    <div class="review-avatar">你</div>
    <div class="review-content">
      <div class="review-header">
        <span class="name">8LA玩家</span>
        <span class="stars" style="font-size:0.75rem">${stars}</span>
        <span class="date">${today}</span>
      </div>
      <div class="review-text">${text}</div>
    </div>
  </div>`;
  list.insertAdjacentHTML('afterbegin', html);
  document.getElementById('reviewText').value = '';
  userRating = 0; resetRating();
}

// === SEARCH ===
const searchData = [
  ...games.map(g => ({ name: g.name, type: '遊戲', icon: 'gamepad-2' })),
  { name: '百家樂牌路攻略', type: '文章', icon: 'book' },
  { name: '2026 遊戲平台排行', type: '文章', icon: 'book' },
  { name: '老虎機 RTP 排行', type: '文章', icon: 'book' },
  { name: '防詐騙指南', type: '文章', icon: 'shield' },
  { name: '皇家遊戲平台', type: '遊戲平台', icon: 'crown' },
  { name: '鑽石俱樂部', type: '遊戲平台', icon: 'gem' },
  { name: '金沙國際', type: '遊戲平台', icon: 'dice-5' },
];
function openSearch() {
  document.getElementById('searchModal').classList.add('open');
  setTimeout(() => document.getElementById('searchInput').focus(), 100);
}
function closeSearch(e) {
  if (e.target === document.getElementById('searchModal')) {
    document.getElementById('searchModal').classList.remove('open');
  }
}
function handleSearch(q) {
  const results = document.getElementById('searchResults');
  if (!q.trim()) { results.innerHTML = ''; return; }
  const filtered = searchData.filter(d => d.name.toLowerCase().includes(q.toLowerCase()));
  results.innerHTML = filtered.length ? filtered.map(d =>
    `<div class="search-result-item" onclick="document.getElementById('searchModal').classList.remove('open')">
      ${getSVGIcon(d.icon)}
      <div><strong>${d.name}</strong><br><small style="color:var(--text-muted)">${d.type}</small></div>
    </div>`
  ).join('') : '<div style="padding:1rem 1.5rem;color:var(--text-muted)">找不到相關8LA ⚡</div>';
}
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') document.getElementById('searchModal').classList.remove('open');
});

// === SCROLL TO TOP ===
function scrollToTop() { window.scrollTo({ top: 0, behavior: 'smooth' }); }
window.addEventListener('scroll', () => {
  document.getElementById('scrollTop').classList.toggle('visible', window.scrollY > 500);
});

// === SMOOTH NAV ===
document.querySelectorAll('.nav-links a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    e.preventDefault();
    const target = document.querySelector(a.getAttribute('href'));
    if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    document.querySelectorAll('.nav-links a').forEach(l => l.classList.remove('active'));
    a.classList.add('active');
  });
});
</script>
