      <tr><td><img src="/images/mahjong-ways2/symbols/mahjong-ways2_l_bamboo2.webp" alt="二條符號" width="40" height="48" style="vertical-align:middle;margin-right:6px" loading="lazy">二條</td><td>1</td><td>3</td><td>6</td></tr>
