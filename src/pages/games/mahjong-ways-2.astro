      <tr><td><img src="/images/mahjong-ways2/symbols/mahjong-ways2_l_ball3.webp" alt="三筒符號" width="40" height="48" style="vertical-align:middle;margin-right:6px" loading="lazy">三筒</td><td>2</td><td>4</td><td>10</td></tr>
      <tr><td><img src="/images/mahjong-ways2/symbols/mahjong-ways2_l_ball2.webp" alt="二筒符號" width="40" height="48" style="vertical-align:middle;margin-right:6px" loading="lazy">二筒</td><td>1</td><td>3</td><td>6</td></tr>
