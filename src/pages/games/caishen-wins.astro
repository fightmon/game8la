---
import Icon from '../../components/Icon.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqSchema from '../../components/FaqSchema.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';

const faqs = [
  { q: '贏財神的 RTP 是多少？', a: '根據 PG Soft 官方規格，贏財神（Caishen Wins）的預設 RTP 為 96.92%，屬於業界中上水準。不過 PG Soft 提供多個 RTP 版本讓平台選用，實際 RTP 請在遊戲內規則頁面確認。' },
  { q: '贏財神的最大倍率是多少？', a: 'PG Soft 官方公布的最大贏獎倍率為 x100,000。根據 10 億次模擬旋轉，實測最高達到 4,936x。x100,000 是理論天花板，實際達成率極低。' },
  { q: '贏財神的 Free Spin 怎麼觸發？', a: '盤面上出現 4 個以上奪寶符號（Scatter）即可觸發免費旋轉。基礎 8 轉，每多 1 個 Scatter 額外 +2 轉。觸發後可以選擇直接開始（x8 獎金倍數），或搏一搏挑戰更多轉數和更高倍數。' },
  { q: '搏一搏機制是什麼？', a: '觸發免費旋轉後，玩家可以選擇「搏一搏」來賭更多免費轉數或更高的獎金倍數。成功的話：搏轉數 +2 轉、搏倍數 +2 倍。失敗的話直接結束免費旋轉（搏轉數）或停止加倍（搏倍數）。最高可以搏到 x20 獎金倍數，風險與回報並存。' },
  { q: '多路連消百搭是什麼？', a: '在任何旋轉期間，第 2~5 軸上佔據 2~4 個位置的符號（不含百搭）可能被銀框包圍。上一輪贏獎中的銀框符號會變成金框，金框符號會變成 2~4 個百搭符號。這個連鎖機制讓中獎路數從 2,025 路最高膨脹到 32,400 路。' },
  { q: '贏財神適合新手嗎？', a: '非常適合。中波動不會太極端，整體中獎率 35.46% 代表大約每 3 轉就有 1 次回饋。6 軸盤面雖然看起來複雜，但中獎路數多、連消機制直覺好懂。搏一搏機制增加趣味但不影響基本玩法，新手可以先選保守的 8 轉 x8 起步。' },
];
---
