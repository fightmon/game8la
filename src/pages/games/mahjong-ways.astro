      <tr><td><img src="/images/mahjong-ways/symbols/mahjong-ways_l_ball-2.webp" alt="二筒符號" width="40" height="48" style="vertical-align:middle;margin-right:6px" loading="lazy">二筒</td><td>1</td><td>3</td><td>6</td></tr>
