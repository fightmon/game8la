---
import Icon from '../../components/Icon.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="芭樂好彩 - 台灣彩券最新開獎結果｜大樂透、威力彩、今彩539" description="GAME8LA 芭樂好彩：每期自動更新台灣彩券最新開獎結果，包含威力彩、大樂透、今彩539、3星彩、4星彩、BINGO BINGO 賓果，附前 5 期歷史紀錄。" currentPage="lottery">
    <div class="container">
      <div class="breadcrumb"><a href="/">首頁</a> &gt; 芭樂好彩</div>
      <a href="/" class="back-link"><Icon name="arrow-left" /> 回首頁</a>
      <div style="width:100%;height:220px;background:linear-gradient(135deg,#0a2e1a,#1b5032,#0a2e1a);border-radius:16px;margin-bottom:1.5rem"></div>
      <div class="page-hero">
        <h1>🍈 <em>芭樂好彩</em></h1>
        <p>台灣彩券最新開獎結果，每期開獎後自動更新</p>
        <p class="updated">最後更新：<span id="updateTime">載入中…</span></p>
      </div>

    <section class="lottery-grid">
      <!-- 威力彩 -->
      <div class="lottery-card" data-lottery="super_lotto">
        <div class="card-head"><Icon name="zap" /><h2>威力彩</h2><span class="period" id="super-period">--</span></div>
        <div class="card-body">
          <div class="draw-label">第一區</div>
          <div class="numbers main" id="super-main">
            <span class="num loading">--</span><span class="num loading">--</span><span class="num loading">--</span>
            <span class="num loading">--</span><span class="num loading">--</span><span class="num loading">--</span>
          </div>
          <div class="draw-label">第二區</div>
          <div class="numbers special"><span class="num special-num" id="super-special">--</span></div>
          <div class="draw-date">開獎日：<span id="super-date">--</span></div>
        </div>
      </div>

      <!-- 大樂透 -->
      <div class="lottery-card" data-lottery="lotto649">
        <div class="card-head"><Icon name="star" /><h2>大樂透</h2><span class="period" id="lotto649-period">--</span></div>
        <div class="card-body">
          <div class="draw-label">本期開獎號碼</div>
          <div class="numbers main" id="lotto649-main">
            <span class="num loading">--</span><span class="num loading">--</span><span class="num loading">--</span>
            <span class="num loading">--</span><span class="num loading">--</span><span class="num loading">--</span>
          </div>
          <div class="draw-label">特別號</div>
          <div class="numbers special"><span class="num special-num" id="lotto649-special">--</span></div>
          <div class="draw-date">開獎日：<span id="lotto649-date">--</span></div>
        </div>
      </div>

      <!-- 今彩539 -->
      <div class="lottery-card" data-lottery="daily_cash">
        <div class="card-head"><Icon name="coins" /><h2>今彩 539</h2><span class="period" id="daily-period">--</span></div>
        <div class="card-body">
          <div class="draw-label">本期開獎號碼</div>
          <div class="numbers main" id="daily-main">
            <span class="num loading">--</span><span class="num loading">--</span><span class="num loading">--</span>
            <span class="num loading">--</span><span class="num loading">--</span>
          </div>
          <div class="draw-date">開獎日：<span id="daily-date">--</span></div>
        </div>
      </div>

      <!-- 3 星彩 -->
      <div class="lottery-card" data-lottery="lotto3d">
        <div class="card-head"><Icon name="dice-3" /><h2>3 星彩</h2><span class="period" id="lotto3d-period">--</span></div>
        <div class="card-body">
          <div class="draw-label">本期開獎號碼</div>
          <div class="numbers main" id="lotto3d-main">
            <span class="num loading">--</span><span class="num loading">--</span><span class="num loading">--</span>
          </div>
          <div class="draw-date">開獎日：<span id="lotto3d-date">--</span></div>
        </div>
      </div>

      <!-- 4 星彩 -->
      <div class="lottery-card" data-lottery="lotto4d">
        <div class="card-head"><Icon name="dice-4" /><h2>4 星彩</h2><span class="period" id="lotto4d-period">--</span></div>
        <div class="card-body">
          <div class="draw-label">本期開獎號碼</div>
          <div class="numbers main" id="lotto4d-main">
            <span class="num loading">--</span><span class="num loading">--</span><span class="num loading">--</span><span class="num loading">--</span>
          </div>
          <div class="draw-date">開獎日：<span id="lotto4d-date">--</span></div>
        </div>
      </div>

      <!-- BINGO BINGO 賓果賓果 -->
      <div class="lottery-card" data-lottery="bingo">
        <div class="card-head"><Icon name="target" /><h2>BINGO BINGO 賓果</h2><span class="period" id="bingo-period">--</span></div>
        <div class="card-body">
          <div class="draw-label">開出 20 號</div>
          <div class="numbers main wide" id="bingo-main">
            <span class="num loading">--</span><span class="num loading">--</span><span class="num loading">--</span><span class="num loading">--</span>
            <span class="num loading">--</span><span class="num loading">--</span><span class="num loading">--</span><span class="num loading">--</span>
            <span class="num loading">--</span><span class="num loading">--</span><span class="num loading">--</span><span class="num loading">--</span>
            <span class="num loading">--</span><span class="num loading">--</span><span class="num loading">--</span><span class="num loading">--</span>
            <span class="num loading">--</span><span class="num loading">--</span><span class="num loading">--</span><span class="num loading">--</span>
          </div>
          <div class="draw-label">超級獎號</div>
          <div class="numbers special"><span class="num special-num" id="bingo-special">--</span></div>
          <div class="draw-date">開獎日：<span id="bingo-date">--</span></div>
        </div>
      </div>

    </section>

    <section class="info-box">
      <h3>📅 開獎時間</h3>
      <ul>
        <li><strong>大樂透</strong>：每週二、五晚間 20:30 開獎</li>
        <li><strong>威力彩</strong>：每週一、四晚間 20:30 開獎</li>
        <li><strong>今彩 539</strong>：每日晚間 20:30 開獎（週日除外）</li>
        <li><strong>3 星彩 / 4 星彩</strong>：每日晚間 20:30 開獎（週日除外）</li>
        <li><strong>BINGO BINGO 賓果賓果</strong>：每日 12:05 起每 5 分鐘開獎一場至 23:55</li>
      </ul>
      <p class="disclaimer">⚠️ 本頁資料僅供參考，實際中獎號碼請以 <a href="https://www.taiwanlottery.com/" target="_blank" rel="noopener">台灣彩券官方網站</a> 公告為準。</p>
    </section>

    <section class="lottery-read-more">
      <div class="rm-head">
        <h3>📚 樂透延伸閱讀</h3>
        <p>對完號碼沒中？先別撕單！芭樂子整理的機率、包牌、RTP 實測攻略，看完再戰下一期。</p>
      </div>
      <div class="rm-grid">
        <a class="rm-card gold" href="/lottery/guide/">
          <span class="rm-tag">📘 新手必看</span>
          <h4>彩票投注完整指南：大樂透、威力彩、539 玩法機率一本通</h4>
          <p>4 大官方彩種全比較、中獎機率數學、包牌教學、快開彩玩法、稅務須知一次看完。</p>
          <span class="rm-cta">閱讀完整攻略 <Icon name="arrow-right" /></span>
        </a>
        <a class="rm-card green" href="/articles/lottery-odds-comparison/">
          <span class="rm-tag">🔥 熱門實測</span>
          <h4>【2026 實測】威力彩 vs 大樂透機率大揭秘：頭獎差 4 倍？</h4>
          <p>芭樂子拆解 1/2,208 萬 vs 1/1,398 萬的真相，附 RTP 與期望值對照表。</p>
          <span class="rm-cta">看機率實測 <Icon name="arrow-right" /></span>
        </a>
        <a class="rm-card pink" href="/articles/daily-cash-539-wheel-guide/">
          <span class="rm-tag">🎯 包牌攻略</span>
          <h4>【539 包牌攻略】最強系統號玩法：中獎率提升 10 倍？</h4>
          <p>系統號包牌、養牌紀律、膽拖公式，包 7 碼任一獎項命中率飆到 91%，附避雷清單。</p>
          <span class="rm-cta">解鎖包牌公式 <Icon name="arrow-right" /></span>
        </a>
        <a class="rm-card purple" href="/articles/lottery-vs-slots-comparison/">
          <span class="rm-tag">⚔️ 勝率對決</span>
          <h4>【2026 實測】威力彩 vs 老虎機勝率大對決：差了 100 倍？</h4>
          <p>威力彩 RTP 55% vs 老虎機 97%，用國際認證數據拆解「哪個比較好贏」的數學真相。</p>
          <span class="rm-cta">看勝率比較 <Icon name="arrow-right" /></span>
        </a>
      </div>
    </section>
    </div>

  <style is:global>
    .page-hero .updated { font-size: 0.85rem; color: var(--text-muted); margin-top: 0.5rem; }

    .lottery-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 1.5rem; margin: 2rem auto; }
    .lottery-card {
      background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px;
      overflow: hidden; transition: all 0.3s;
    }
    .lottery-card:hover { border-color: var(--gold); box-shadow: 0 10px 30px rgba(57,255,20,0.1); }

    .card-head {
      background: linear-gradient(135deg, rgba(57,255,20,0.15), rgba(255,16,240,0.08));
      padding: 1rem 1.5rem; display: flex; align-items: center; gap: 0.8rem;
      border-bottom: 1px solid var(--border);
    }
    .card-head i { font-size: 1.5rem; color: var(--gold-light); }
    .card-head h2 { font-size: 1.3rem; color: var(--text-primary); margin: 0; flex: 1; }
    .card-head .period { font-size: 0.8rem; color: var(--text-muted); background: rgba(0,0,0,0.3); padding: 0.3rem 0.7rem; border-radius: 12px; }

    .card-body { padding: 1.5rem; }
    .draw-label { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.7rem; }
    .numbers { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 1.2rem; }
    .numbers.wide .num { width: 44px; height: 44px; font-size: 1.1rem; }
    .num {
      width: 52px; height: 52px; border-radius: 50%;
      background: linear-gradient(135deg, #39FF14, #2bcc10);
      color: #000; font-weight: 900; font-size: 1.3rem;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 4px 12px rgba(57,255,20,0.3);
    }
    .num.loading { background: var(--bg-secondary); color: var(--text-muted); box-shadow: none; }
    .num.special-num { background: linear-gradient(135deg, #FF10F0, #c80dc0); box-shadow: 0 4px 12px rgba(255,16,240,0.3); }
    .num.mini { width: 32px; height: 32px; font-size: 0.85rem; box-shadow: 0 2px 6px rgba(57,255,20,0.25); }
    .num.mini.special-num { box-shadow: 0 2px 6px rgba(255,16,240,0.25); }
    .draw-date { font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.5rem; }

    .history-toggle {
      display: flex; align-items: center; justify-content: center; gap: 0.4rem;
      margin-top: 1rem; padding: 0.6rem; cursor: pointer;
      background: rgba(57,255,20,0.06); border: 1px dashed var(--border); border-radius: 8px;
      color: var(--gold-light); font-size: 0.85rem; font-weight: 600;
      transition: all 0.2s; user-select: none;
    }
    .history-toggle:hover { background: rgba(57,255,20,0.12); border-color: var(--gold); }
    .history-toggle .arrow { transition: transform 0.3s; }
    .lottery-card.expanded .history-toggle .arrow { transform: rotate(180deg); }
    .history-list { display: none; margin-top: 1rem; padding-top: 1rem; border-top: 1px dashed var(--border); }
    .lottery-card.expanded .history-list { display: block; }
    .history-row { padding: 0.7rem 0; border-bottom: 1px solid var(--border); }
    .history-row:last-child { border-bottom: none; }
    .history-meta { font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.4rem; display: flex; gap: 0.8rem; }
    .history-meta strong { color: var(--gold-light); }
    .history-nums { display: flex; flex-wrap: wrap; gap: 0.35rem; align-items: center; }
    .history-sep { color: var(--text-muted); margin: 0 0.2rem; }

    .info-box {
      background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px;
      padding: 1.5rem 2rem; margin: 2rem auto 4rem; max-width: 1168px;
    }
    .info-box h3 { color: var(--gold-light); margin-bottom: 1rem; }
    .info-box ul { list-style: none; padding: 0; }
    .info-box li { padding: 0.5rem 0; color: var(--text-secondary); border-bottom: 1px dashed var(--border); }
    .info-box li:last-child { border: none; }
    .info-box li strong { color: var(--gold-light); margin-right: 0.5rem; }
    .disclaimer { margin-top: 1rem; font-size: 0.85rem; color: var(--text-muted); }

    /* 樂透延伸閱讀 */
    .lottery-read-more {
      max-width: 1168px; margin: 3rem auto 4rem;
    }
    .lottery-read-more .rm-head { text-align: center; margin-bottom: 1.8rem; }
    .lottery-read-more .rm-head h3 {
      font-size: 1.8rem; margin: 0 0 0.5rem;
      background: linear-gradient(135deg, #FFD700, #39FF14);
      -webkit-background-clip: text; background-clip: text; color: transparent;
    }
    .lottery-read-more .rm-head p { color: var(--text-secondary); font-size: 0.95rem; margin: 0; }
    .rm-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.2rem;
    }
    .rm-card {
      position: relative; display: flex; flex-direction: column;
      padding: 1.4rem 1.3rem 1.2rem;
      background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px;
      text-decoration: none; color: var(--text-primary);
      transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
      overflow: hidden;
    }
    .rm-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: var(--gold); transition: height 0.25s;
    }
    .rm-card:hover { transform: translateY(-4px); }
    .rm-card:hover::before { height: 5px; }
    .rm-card.gold::before { background: linear-gradient(90deg, #FFD700, #FFA500); }
    .rm-card.gold:hover { border-color: #FFD700; box-shadow: 0 10px 30px rgba(255,215,0,0.18); }
    .rm-card.green::before { background: linear-gradient(90deg, #39FF14, #2bcc10); }
    .rm-card.green:hover { border-color: #39FF14; box-shadow: 0 10px 30px rgba(57,255,20,0.18); }
    .rm-card.pink::before { background: linear-gradient(90deg, #FF10F0, #c80dc0); }
    .rm-card.pink:hover { border-color: #FF10F0; box-shadow: 0 10px 30px rgba(255,16,240,0.18); }
    .rm-card.purple::before { background: linear-gradient(90deg, #a855f7, #ec4899); }
    .rm-card.purple:hover { border-color: #a855f7; box-shadow: 0 10px 30px rgba(168,85,247,0.2); }
    .rm-tag {
      display: inline-block; align-self: flex-start;
      padding: 0.25rem 0.7rem; border-radius: 999px;
      background: rgba(57,255,20,0.1); color: var(--gold-light);
      font-size: 0.75rem; font-weight: 700; margin-bottom: 0.7rem;
    }
    .rm-card.gold .rm-tag { background: rgba(255,215,0,0.12); color: #FFD700; }
    .rm-card.pink .rm-tag { background: rgba(255,16,240,0.12); color: #FF10F0; }
    .rm-card.purple .rm-tag { background: rgba(168,85,247,0.14); color: #c084fc; }
    .rm-card h4 {
      font-size: 1.05rem; line-height: 1.45; margin: 0 0 0.6rem;
      color: var(--text-primary); font-weight: 800;
    }
    .rm-card p {
      font-size: 0.88rem; color: var(--text-secondary);
      line-height: 1.6; margin: 0 0 1rem; flex: 1;
    }
    .rm-cta {
      display: inline-flex; align-items: center; gap: 0.35rem;
      font-size: 0.85rem; font-weight: 700; color: var(--gold-light);
    }
    .rm-card.gold .rm-cta { color: #FFD700; }
    .rm-card.pink .rm-cta { color: #FF10F0; }
    .rm-card.purple .rm-cta { color: #c084fc; }
    .rm-card:hover .rm-cta i { transform: translateX(3px); transition: transform 0.2s; }

    @media (max-width: 768px) {
      .page-header h1 { font-size: 1.8rem; }
      .num { width: 44px; height: 44px; font-size: 1.1rem; }
      .numbers.wide .num { width: 36px; height: 36px; font-size: 0.95rem; }
      .lottery-read-more .rm-head h3 { font-size: 1.4rem; }
      .rm-grid { grid-template-columns: 1fr; }
    }
  </style>

  <script is:inline>
    (async function(){
      const updateEl = document.getElementById('updateTime');
      updateEl.textContent = '載入中…';

      function setNums(containerId, nums) {
        const el = document.getElementById(containerId);
        if (!el || !nums || !nums.length) return;
        const spans = el.querySelectorAll('.num');
        spans.forEach((sp, i) => {
          if (nums[i] != null) {
            sp.textContent = String(nums[i]).padStart(2, '0');
            sp.classList.remove('loading');
          }
        });
      }
      function setText(id, val) {
        const el = document.getElementById(id);
        if (el && val != null) el.textContent = val;
      }
      function setSpecial(id, val) {
        const el = document.getElementById(id);
        if (el && val != null) {
          el.textContent = String(val).padStart(2, '0');
          el.classList.remove('loading');
        }
      }
      function pad(n) { return String(n).padStart(2, '0'); }
      function buildHistoryRow(rec, opts) {
        const mainCount = opts.mainCount;
        const specialKey = opts.specialKey; // 'special' | 'area2' | null
        const specialLabel = opts.specialLabel || '';
        const main = (rec.numbers || []).slice(0, mainCount);
        const sp = specialKey ? rec[specialKey] : null;
        const numsHtml = main.map(n => `<span class="num mini">${pad(n)}</span>`).join('') +
          (sp != null ? `<span class="history-sep">${specialLabel}</span><span class="num mini special-num">${pad(sp)}</span>` : '');
        return `<div class="history-row">
          <div class="history-meta"><strong>第 ${rec.period || '--'} 期</strong><span>${rec.date || ''}</span></div>
          <div class="history-nums">${numsHtml}</div>
        </div>`;
      }
      function renderHistory(cardSelector, history, opts) {
        if (!history || history.length === 0) return;
        const card = document.querySelector(cardSelector);
        if (!card) return;
        const body = card.querySelector('.card-body');
        if (!body) return;
        const rowsHtml = history.map(r => buildHistoryRow(r, opts)).join('');
        const html = `
          <div class="history-toggle">
            <span class="label">查看前 ${history.length} 期</span>
            <Icon name="chevron-down" />
          </div>
          <div class="history-list">${rowsHtml}</div>
        `;
        body.insertAdjacentHTML('beforeend', html);
        const toggle = body.querySelector('.history-toggle');
        toggle.addEventListener('click', () => {
          const expanded = card.classList.toggle('expanded');
          toggle.querySelector('.label').textContent = expanded ? '收起' : `查看前 ${history.length} 期`;
        });
      }

      try {
        const res = await fetch('/api/lottery', { cache: 'no-store' });
        if (!res.ok) throw new Error('api error');
        const json = await res.json();
        const d = json.data || {};

        // 大樂透
        if (d.lotto649) {
          setNums('lotto649-main', d.lotto649.numbers);
          setSpecial('lotto649-special', d.lotto649.special);
          setText('lotto649-period', d.lotto649.period ? '第 ' + d.lotto649.period + ' 期' : '--');
          setText('lotto649-date', d.lotto649.date || '--');
          renderHistory('[data-lottery="lotto649"]', d.lotto649.history, { mainCount: 6, specialKey: 'special', specialLabel: '+' });
        }
        // 威力彩
        if (d.super_lotto) {
          setNums('super-main', d.super_lotto.numbers);
          setSpecial('super-special', d.super_lotto.area2 ?? d.super_lotto.special);
          setText('super-period', d.super_lotto.period ? '第 ' + d.super_lotto.period + ' 期' : '--');
          setText('super-date', d.super_lotto.date || '--');
          renderHistory('[data-lottery="super_lotto"]', d.super_lotto.history, { mainCount: 6, specialKey: 'area2', specialLabel: '+' });
        }
        // 今彩 539
        if (d.daily_cash) {
          setNums('daily-main', d.daily_cash.numbers);
          setText('daily-period', d.daily_cash.period ? '第 ' + d.daily_cash.period + ' 期' : '--');
          setText('daily-date', d.daily_cash.date || '--');
          renderHistory('[data-lottery="daily_cash"]', d.daily_cash.history, { mainCount: 5, specialKey: null });
        }
        // 3 星彩
        if (d.lotto3d) {
          setNums('lotto3d-main', d.lotto3d.numbers);
          setText('lotto3d-period', d.lotto3d.period ? '第 ' + d.lotto3d.period + ' 期' : '--');
          setText('lotto3d-date', d.lotto3d.date || '--');
          renderHistory('[data-lottery="lotto3d"]', d.lotto3d.history, { mainCount: 3, specialKey: null });
        }
        // 4 星彩
        if (d.lotto4d) {
          setNums('lotto4d-main', d.lotto4d.numbers);
          setText('lotto4d-period', d.lotto4d.period ? '第 ' + d.lotto4d.period + ' 期' : '--');
          setText('lotto4d-date', d.lotto4d.date || '--');
          renderHistory('[data-lottery="lotto4d"]', d.lotto4d.history, { mainCount: 4, specialKey: null });
        }
        // BINGO BINGO
        if (d.bingo) {
          setNums('bingo-main', d.bingo.numbers);
          setSpecial('bingo-special', d.bingo.special);
          setText('bingo-period', d.bingo.period ? '第 ' + d.bingo.period + ' 期' : '--');
          setText('bingo-date', d.bingo.date || '--');
        }

        const ts = json.updatedAt ? new Date(json.updatedAt) : new Date();
        updateEl.textContent = ts.toLocaleString('zh-TW', { timeZone: 'Asia/Taipei' });
      } catch (e) {
        console.warn('lottery api failed', e);
        updateEl.textContent = '無法取得即時資料，請前往台灣彩券官網查詢';
      }
    })();
  </script>
</BaseLayout>
