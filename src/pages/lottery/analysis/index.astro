// Generate all C(n,k) combinations from an array
function combinations(arr, k) {
  if (k === 0) return [[]];
  if (arr.length < k) return [];
  const result = [];
  function helper(start, combo) {
    if (combo.length === k) { result.push([...combo]); return; }
    for (let i = start; i <= arr.length - (k - combo.length); i++) {
      combo.push(arr[i]);
      helper(i + 1, combo);
      combo.pop();
    }
  }
  helper(0, []);
  return result;
}

// Determine pool size to keep combos manageable
function getPoolSize(maxBets, pickCount) {
  // Find the largest pool where C(pool, pick) is reasonable
  // but pick at least pickCount+2
  const minPool = pickCount + 2;
  let pool = minPool;
  for (let n = minPool; n <= 20; n++) {
    let c = 1;
    for (let i = 0; i < pickCount; i++) c = c * (n - i) / (i + 1);
    if (c > maxBets * 3) break; // pool too large, stop
    pool = n;
  }
  return pool;
}

function generateWheel(draws, allDraws, cfg, forceAuto) {
  const betCost = BET_COST[currentLottery];
  const maxBets = Math.floor(currentBudget / betCost);
  if (maxBets < 1) return { pool: [], combos: [], maxBets: 0, betCost, poolSize: 0, isCustom: false };

  const { allScores } = calcSuggestions(draws, allDraws, cfg);
  const useCustom = !forceAuto && wheelSource === 'custom' && customPoolNums.length > cfg.count;

  let pool, poolNums, poolSize;

  if (useCustom) {
    // Custom mode: use user-selected numbers, attach scores from allScores
    poolNums = [...customPoolNums];
    poolSize = poolNums.length;
    pool = poolNums.map(n => {
      const found = allScores.find(s => s.num === n);
      return found || { num: n, total: 0, freqScore: 0, missScore: 0, inLastDraw: false };
    });
  } else {
    // Auto mode: use top-scored numbers
    poolSize = getPoolSize(maxBets, cfg.count);
    pool = allScores.slice(0, poolSize);
    poolNums = pool.map(s => s.num);
  }

  // Compute total combos count (without generating)
  const totalCombosCount = C(poolSize, cfg.count);

  // Safety: cap combos generation to prevent browser crash
  // Full enum up to 5000; above that, sample smartly
  const MAX_ENUM = 5000;
  let allCombos;

  // Build a score lookup map for O(1) access
  const scoreMap = new Map();
  pool.forEach(p => scoreMap.set(p.num, p));

  function scoreCombo(combo) {
    let score = 0, hotCount = 0, missCount = 0;
    for (const n of combo) {
      const s = scoreMap.get(n);
      if (s) {
        score += s.total;
        if (s.freqScore >= 70) hotCount++;
        if (s.missScore >= 70) missCount++;
      }
    }
    return { nums: combo, score: Math.round(score * 10) / 10, hotCount, missCount };
  }

  // Cap how many combos we actually need: maxBets or MAX_ENUM, whichever is smaller
  const needCombos = Math.min(maxBets, MAX_ENUM);

  if (totalCombosCount <= MAX_ENUM) {
    // Full enumeration — safe, pool is small enough
    allCombos = combinations(poolNums, cfg.count).map(scoreCombo);
  } else {
    // Pool too large for full enum — sample from top-scored numbers + random
    const sampleTarget = Math.min(needCombos * 3, MAX_ENUM);
    const seen = new Set();
    const sampled = [];
    const sorted = [...poolNums].sort((a, b) => {
      return (scoreMap.get(b)?.total || 0) - (scoreMap.get(a)?.total || 0);
    });
    // Greedy: combos from top-scored numbers first
    const topN = Math.min(sorted.length, 12);
    const topCombos = combinations(sorted.slice(0, topN), cfg.count);
    for (const c of topCombos) {
      const key = c.join(',');
      if (!seen.has(key)) { seen.add(key); sampled.push(scoreCombo(c)); }
      if (sampled.length >= sampleTarget) break;
    }
    // Fill remaining with random combos
    let attempts = 0;
    while (sampled.length < sampleTarget && attempts < sampleTarget * 10) {
      attempts++;
      const combo = [];
      const used = new Set();
      while (combo.length < cfg.count) {
        const idx = Math.floor(Math.random() * poolNums.length);
        if (!used.has(idx)) { used.add(idx); combo.push(poolNums[idx]); }
      }
      combo.sort((a, b) => a - b);
      const key = combo.join(',');
      if (!seen.has(key)) { seen.add(key); sampled.push(scoreCombo(combo)); }
    }
    allCombos = sampled;
  }

  // Sort by score, take top needed
  allCombos.sort((a, b) => b.score - a.score);
  const combos = allCombos.slice(0, needCombos);

  return { pool, combos, maxBets, betCost, poolSize, totalCombos: totalCombosCount, isCustom: useCustom };
}

function renderWheel() {
  const cfg = LOTTERY_CONFIG[currentLottery];
  const data = lotteryData[currentLottery];
  if (!data) return;

  const draws = getDraws();
  const allDraws = data.draws;
  const betCost = BET_COST[currentLottery];
  const { pool, combos, maxBets, poolSize, totalCombos, isCustom } = generateWheel(draws, allDraws, cfg);

  // Custom mode: show hint if not enough numbers selected
  if (wheelSource === 'custom' && customPoolNums.length <= cfg.count) {
    document.getElementById('wheelSummary').innerHTML = '';
