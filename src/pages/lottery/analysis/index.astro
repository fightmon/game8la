// === SUGGESTION ENGINE ===
function calcSuggestions(draws, allDraws, cfg) {
  const { maxNum, count } = cfg;
  const freq = calcFrequency(draws, maxNum);
  const missing = calcMissing(allDraws, maxNum);
  const repeatStats = calcRepeat(draws, maxNum);
  const lastDraw = allDraws.length > 0 ? allDraws[0].numbers : [];

  // Normalize helpers
  const vals = arr => arr.length ? arr : [0];
  const minMax = (arr) => {
    const mn = Math.min(...vals(arr)), mx = Math.max(...vals(arr));
    return { min: mn, max: mx, range: mx - mn || 1 };
  };

  const freqVals = Object.values(freq);
  const missVals = Object.values(missing);
  const fNorm = minMax(freqVals);
  const mNorm = minMax(missVals);

  // Score each number
  const scores = [];
  for (let n = 1; n <= maxNum; n++) {
    // 1) Frequency score (0~100): higher freq = higher score (hot bias)
    const freqScore = ((freq[n] - fNorm.min) / fNorm.range) * 100;

    // 2) Missing score (0~100): higher missing = higher score (overdue)
    const missScore = ((missing[n] - mNorm.min) / mNorm.range) * 100;

    // 3) Repeat score (0~100): if number was in last draw, use its repeat rate
    let repeatScore = 0;
    if (lastDraw.includes(n) && repeatStats[n]) {
      const s = repeatStats[n];
      repeatScore = s.appeared > 0 ? (s.repeated / s.appeared) * 100 : 0;
      // Boost: multiply by 2 for "recent momentum" but cap at 100
      repeatScore = Math.min(repeatScore * 2, 100);
    }

    // Weighted combination:
    // - Frequency 40%: hot numbers appear more
    // - Missing 35%: overdue numbers due for return
    // - Repeat 25%: last draw momentum (only applies to numbers in last draw)
    const total = freqScore * 0.40 + missScore * 0.35 + repeatScore * 0.25;

    scores.push({
      num: n,
      total: Math.round(total * 10) / 10,
      freqScore: Math.round(freqScore),
      missScore: Math.round(missScore),
      repeatScore: Math.round(repeatScore),
      freq: freq[n],
      missing: missing[n],
      inLastDraw: lastDraw.includes(n)
    });
  }

  // Sort by total score descending
  scores.sort((a, b) => b.total - a.total);

  // Pick top `count` numbers for the main suggestion
  const mainPicks = scores.slice(0, count);

  // Also return a "balanced" set: top 3 hot + top (count-3) overdue (or split evenly for 5-pick)
  const hotSorted = [...scores].sort((a, b) => b.freqScore - a.freqScore);
  const missSorted = [...scores].sort((a, b) => b.missScore - a.missScore);
  const hotCount = Math.ceil(count / 2);
  const coldCount = count - hotCount;
  const balancedSet = new Set();
  for (const s of hotSorted) { if (balancedSet.size < hotCount) balancedSet.add(s.num); }
  for (const s of missSorted) { if (balancedSet.size < count && !balancedSet.has(s.num)) balancedSet.add(s.num); }
  // Fill remaining if needed
  for (const s of scores) { if (balancedSet.size < count && !balancedSet.has(s.num)) balancedSet.add(s.num); }
  const balancedPicks = scores.filter(s => balancedSet.has(s.num)).sort((a, b) => a.num - b.num);

  return { mainPicks, balancedPicks, allScores: scores };
}

function renderSuggestions() {
  const cfg = LOTTERY_CONFIG[currentLottery];
  const data = lotteryData[currentLottery];
  if (!data) return;

  const draws = getDraws();
  const allDraws = data.draws;
  const { mainPicks, balancedPicks, allScores } = calcSuggestions(draws, allDraws, cfg);

  // Update range display
  const rangeLabel = currentRange === 0 ? '全部' : currentRange;
  document.getElementById('suggestRange').textContent = rangeLabel;

  const el = document.getElementById('suggestionResult');
  const maxScore = mainPicks.length > 0 ? mainPicks[0].total : 1;

  // Special number suggestion (for 威力彩/大樂透)
  let specialHtml = '';
  if (cfg.hasSpecial) {
    const specFreq = calcSpecialFrequency(draws, cfg.specialMax);
    const specMissing = {};
    for (let i = 1; i <= cfg.specialMax; i++) {
      specMissing[i] = 0;
      for (let j = 0; j < allDraws.length; j++) {
        if (allDraws[j].special === i) break;
        specMissing[i]++;
      }
    }
    // Score special numbers
    const specScores = [];
    const sfVals = Object.values(specFreq);
    const smVals = Object.values(specMissing);
    const sfN = { min: Math.min(...sfVals), max: Math.max(...sfVals), range: Math.max(...sfVals) - Math.min(...sfVals) || 1 };
    const smN = { min: Math.min(...smVals), max: Math.max(...smVals), range: Math.max(...smVals) - Math.min(...smVals) || 1 };
    for (let i = 1; i <= cfg.specialMax; i++) {
      const fs = ((specFreq[i] - sfN.min) / sfN.range) * 100;
      const ms = ((specMissing[i] - smN.min) / smN.range) * 100;
      specScores.push({ num: i, total: Math.round((fs * 0.5 + ms * 0.5) * 10) / 10 });
    }
    specScores.sort((a, b) => b.total - a.total);
    const topSpec = specScores[0];
    specialHtml = `
      <div class="suggest-special">
        <span class="suggest-special-label">${cfg.specialLabel}推薦</span>
        <span class="num-ball special-ball suggest-special-ball">${topSpec.num}</span>
        <span class="suggest-special-score">評分 ${topSpec.total}</span>
      </div>`;
  }

  el.innerHTML = `
    <div class="suggest-tabs">
      <button class="sg-tab active" onclick="switchSuggestMode(this,'weighted')">📊 綜合評分</button>
      <button class="sg-tab" onclick="switchSuggestMode(this,'balanced')">⚖️ 冷熱平衡</button>
    </div>

    <div class="suggest-set" id="suggestWeighted" style="display:block">
      <div class="suggest-balls">
        ${mainPicks.map(s => `
          <div class="suggest-ball-wrap">
            <div class="suggest-ball">${s.num}</div>
            <div class="suggest-score">${s.total}</div>
            <div class="suggest-tags">
              ${s.freqScore >= 70 ? '<span class="sg-tag hot">熱</span>' : ''}
              ${s.missScore >= 70 ? '<span class="sg-tag miss">遺</span>' : ''}
              ${s.inLastDraw ? '<span class="sg-tag repeat">連</span>' : ''}
            </div>
          </div>`).join('')}
      </div>
      ${specialHtml}
      <div class="suggest-detail">
        <table class="suggest-table">
          <thead>
            <tr><th>號碼</th><th>出現次數</th><th>遺漏期數</th><th>熱度</th><th>遺漏</th><th>連開</th><th>總分</th></tr>
          </thead>
          <tbody>
            ${mainPicks.map(s => `
              <tr>
                <td><span class="num-ball sg-ball">${s.num}</span></td>
                <td>${s.freq} 次</td>
                <td>${s.missing} 期</td>
                <td><div class="sg-bar-mini"><div class="sg-bar-fill hot" style="width:${s.freqScore}%"></div></div></td>
                <td><div class="sg-bar-mini"><div class="sg-bar-fill miss" style="width:${s.missScore}%"></div></div></td>
                <td><div class="sg-bar-mini"><div class="sg-bar-fill repeat" style="width:${s.repeatScore}%"></div></div></td>
                <td><strong>${s.total}</strong></td>
              </tr>`).join('')}
          </tbody>
        </table>
      </div>
    </div>

    <div class="suggest-set" id="suggestBalanced" style="display:none">
      <div class="suggest-balls">
        ${balancedPicks.map(s => `
          <div class="suggest-ball-wrap">
            <div class="suggest-ball">${s.num}</div>
            <div class="suggest-score">${s.total}</div>
            <div class="suggest-tags">
              ${s.freqScore >= 70 ? '<span class="sg-tag hot">熱</span>' : ''}
              ${s.missScore >= 70 ? '<span class="sg-tag miss">遺</span>' : ''}
              ${s.inLastDraw ? '<span class="sg-tag repeat">連</span>' : ''}
            </div>
          </div>`).join('')}
      </div>
      ${specialHtml}
      <p class="suggest-explain">⚖️ 冷熱平衡模式：取 ${Math.ceil(cfg.count/2)} 個最熱號 + ${cfg.count - Math.ceil(cfg.count/2)} 個最久未開號，兼顧趨勢與回歸。</p>
    </div>

    <div class="suggest-algo-note">
      <details>
        <summary>📐 評分公式說明</summary>
        <p>每個號碼的綜合評分 = <strong>熱度 × 40%</strong> + <strong>遺漏值 × 35%</strong> + <strong>連開動能 × 25%</strong></p>
        <p>熱度：該號碼在選定範圍內的出現頻率歸一化(0~100)。遺漏值：距離上次開出的期數歸一化。連開動能：若該號碼出現在最近一期，則依其歷史連開率加權。</p>
      </details>
    </div>`;
}

