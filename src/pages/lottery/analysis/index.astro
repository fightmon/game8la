      </div>`;
    document.getElementById('wheelCombos').innerHTML = '';
    document.getElementById('wheelReview').innerHTML = '';
    document.getElementById('wheelSim').innerHTML = '';
    return;
  }

  // Summary
  const actualCost = combos.length * betCost;
  document.getElementById('wheelSummary').innerHTML = `
    <div class="whl-summary-grid">
      <div class="whl-stat">
        <span class="whl-stat-val">$${currentBudget.toLocaleString()}</span>
        <span class="whl-stat-label">投注預算</span>
      </div>
      <div class="whl-stat">
        <span class="whl-stat-val">${combos.length} 注</span>
        <span class="whl-stat-label">包牌組合（每注 $${betCost}）</span>
      </div>
      <div class="whl-stat">
        <span class="whl-stat-val">${poolSize} 碼</span>
        <span class="whl-stat-label">${isCustom ? '自選號碼' : '候選號碼池'}</span>
      </div>
      <div class="whl-stat">
        <span class="whl-stat-val">$${actualCost.toLocaleString()}</span>
        <span class="whl-stat-label">實際花費</span>
      </div>
    </div>`;

  // Custom mode: budget overflow notice
  if (isCustom && totalCombos > combos.length) {
    const fullCost = totalCombos * betCost;
    document.getElementById('wheelSummary').innerHTML += `
      <div class="whl-budget-overflow">
        <div class="whl-bo-icon">⚠️</div>
        <div class="whl-bo-text">
          <strong>預算不足以包完所有組合</strong>
          <p>你選了 <strong>${poolSize} 碼</strong>，共可產生 <strong>${totalCombos} 種組合</strong>，全包需要 <strong>$${fullCost.toLocaleString()}</strong>。</p>
          <p>目前預算 $${currentBudget.toLocaleString()} 只能買 <strong>${combos.length} 注</strong>（已按強度排序取最強組合）。</p>
        </div>
        <button class="whl-bo-btn" onclick="adjustBudgetForCustom(${fullCost})">
          💰 調整預算為 $${fullCost.toLocaleString()}（全包 ${totalCombos} 注）
        </button>
      </div>`;
  }

  // Pool display
  const poolTitle = isCustom
    ? `✋ 你的自選號碼（${poolSize} 碼）`
    : `🎯 候選號碼池（TOP ${poolSize} 高分號碼）`;
  document.getElementById('wheelPool').innerHTML = `
    <h4>${poolTitle}</h4>
    <div class="whl-pool-balls">
      ${pool.map((s, i) => `
        <div class="whl-pool-item">
          <div class="whl-pool-ball">${s.num}</div>
          <div class="whl-pool-score">${s.total}</div>
          <div class="suggest-tags">
            ${s.freqScore >= 70 ? '<span class="sg-tag hot">熱</span>' : ''}
            ${s.missScore >= 70 ? '<span class="sg-tag miss">遺</span>' : ''}
            ${s.inLastDraw ? '<span class="sg-tag repeat">連</span>' : ''}
          </div>
        </div>`).join('')}
    </div>`;

  // Combos table
  if (combos.length === 0) {
    document.getElementById('wheelCombos').innerHTML = '<p class="whl-empty">預算不足，至少需要 $' + betCost + ' 才能買一注。</p>';
  } else {
    // Show first 5, expand up to 200 max to protect DOM performance
    const showFirst = 5;
    const MAX_DISPLAY = 100;
    const displayCombos = combos.slice(0, MAX_DISPLAY);
    const hasMore = displayCombos.length > showFirst;
    const truncated = combos.length > MAX_DISPLAY;

    // Special number for 威力彩/大樂透
    let specialCol = '';
    let specialHeader = '';
    if (cfg.hasSpecial) {
      const specFreq = calcSpecialFrequency(draws, cfg.specialMax);
      const specScores = [];
      for (let i = 1; i <= cfg.specialMax; i++) specScores.push({ num: i, freq: specFreq[i] });
      specScores.sort((a, b) => b.freq - a.freq);
      const topSpec = specScores[0].num;
      specialHeader = `<th>${cfg.specialLabel}</th>`;
      specialCol = `<td><span class="num-mini hit">${topSpec}</span></td>`;
    }

    const comboRow = (c, i) => `
      <tr>
        <td class="whl-idx">${i + 1}</td>
        <td class="td-nums">${c.nums.map(n => `<span class="num-mini">${n}</span>`).join('')}</td>
        ${specialCol}
        <td><span class="whl-strength">${c.score}</span></td>
        <td class="whl-composition">
          ${c.hotCount > 0 ? `<span class="sg-tag hot">${c.hotCount}熱</span>` : ''}
          ${c.missCount > 0 ? `<span class="sg-tag miss">${c.missCount}遺</span>` : ''}
        </td>
      </tr>`;

    document.getElementById('wheelCombos').innerHTML = `
      <h4>📋 包牌組合表${totalCombos > combos.length ? `（從 ${totalCombos.toLocaleString()} 種組合中選出最強 ${combos.length.toLocaleString()} 注）` : ''}</h4>
      <div class="whl-table-wrap">
        <table class="whl-table">
          <thead>
            <tr>
              <th>#</th>
              <th>號碼組合</th>
              ${specialHeader}
              <th>強度</th>
              <th>組成</th>
            </tr>
          </thead>
          <tbody>
            ${displayCombos.slice(0, showFirst).map((c, i) => comboRow(c, i)).join('')}
          </tbody>
          ${hasMore ? `<tbody id="wheelHiddenRows" style="display:none">
            ${displayCombos.slice(showFirst).map((c, i) => comboRow(c, i + showFirst)).join('')}
          </tbody>` : ''}
        </table>
      </div>
      ${hasMore ? `<button class="whl-show-more" id="wheelToggle" onclick="toggleWheelCombos()">顯示前 ${displayCombos.length} 注</button>` : ''}
      ${truncated ? `<p class="whl-trunc-note">⚠️ 共 ${combos.length.toLocaleString()} 注，為保持頁面流暢僅顯示前 ${MAX_DISPLAY} 注（已按強度排序）</p>` : ''}`;
  }

  // Last draw review
  renderWheelReview(draws, allDraws, cfg);

  // Probability simulation (539 only)
  renderWheelSim(poolSize, combos, BET_COST[currentLottery]);
}

