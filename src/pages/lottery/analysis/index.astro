        }
      },
      {
        "@type": "Question",
        "name": "大樂透冷熱門號碼真的有用嗎？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "冷熱門號碼是根據歷史數據的統計結果，反映的是「過去」而非「未來」。GAME8LA 的回測模擬顯示，不管用熱號還是冷號策略，長期命中率都會趨近隨機選號。數據可以當參考，但不應該當作投注依據。"
        }
      },
      {
        "@type": "Question",
        "name": "539 遺漏值很高的號碼是不是快要開了？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "這是常見的「賭徒謬誤」。每顆球被抽中的機率永遠相同，不會因為某個號碼很久沒開就「該出現了」。遺漏值只是歷史紀錄，不具有預測能力。"
        }
      },
      {
        "@type": "Question",
        "name": "GAME8LA 的選號參考是怎麼算的？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "選號參考綜合三項指標加權評分：熱度（出現頻率）佔 40%、遺漏值佔 35%、同號連開動能佔 25%。所有計算完全基於歷史數據，沒有任何主觀預測成分。評分公式公開透明，僅供娛樂參考。"
        }
      },
      {
        "@type": "Question",
        "name": "包牌真的能提高中獎率嗎？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "包牌能提高「號碼覆蓋率」，也就是你買的組合涵蓋更多號碼。但彩券的數學期望值永遠是負的，買越多注只是覆蓋越廣，不代表期望報酬會變正。請量力而為。"
        }
      }
    ]
  }
  </script>

  <!-- 總免責 -->
  <div class="analysis-disclaimer">
    <p>⚠️ <strong>免責聲明：</strong>以上統計僅為歷史數據呈現，每次開獎皆為獨立事件，過去的號碼分布不代表未來的開獎結果。請理性購買彩券，量力而為。實際開獎結果請以 <a href="https://www.taiwanlottery.com/" target="_blank" rel="noopener">台灣彩券官方網站</a> 公告為準。</p>
  </div>

  <!-- 跨區導流 -->
  <section class="cross-sell">
    <h3>🎯 對機率遊戲有興趣？</h3>
    <div class="cross-grid">
      <a class="cross-card" href="/articles/slots-guide/">
        <span class="cross-icon">🎰</span>
        <div>
          <strong>老虎機 RTP 科學分析</strong>
          <p>彩券 RTP 約 55%，老虎機可達 96%+。用數據看懂兩者差距。</p>
        </div>
        <span class="cross-arrow">→</span>
      </a>
      <a class="cross-card" href="/casino-check/">
        <span class="cross-icon">🛡️</span>
        <div>
          <strong>娛樂城安全體檢</strong>
          <p>準備投注前，先查一下平台安不安全，保護你的個資和資金。</p>
        </div>
        <span class="cross-arrow">→</span>
      </a>
      <a class="cross-card" href="/articles/anti-scam-8la-guide/">
        <span class="cross-icon">🚨</span>
        <div>
          <strong>防詐騙 8LA 指南</strong>
          <p>號碼分析群組 99% 是詐騙。學會辨識，別讓你的血汗錢飛了。</p>
        </div>
        <span class="cross-arrow">→</span>
      </a>
    </div>
  </section>

  <!-- 延伸閱讀 -->
  <section class="lottery-read-more" style="max-width:1168px;margin:2rem auto 3rem">
    <div class="rm-head">
      <h3>📚 延伸閱讀</h3>
    </div>
    <div class="rm-grid">
      <a class="rm-card gold" href="/lottery/">
        <span class="rm-tag">🍈 芭樂好彩</span>
        <h4>最新開獎結果</h4>
        <p>威力彩、大樂透、539 各期開獎號碼即時更新</p>
        <span class="rm-cta">查看開獎 →</span>
      </a>
      <a class="rm-card green" href="/articles/lottery-odds-comparison/">
        <span class="rm-tag">🔥 機率實測</span>
        <h4>威力彩 vs 大樂透機率大揭秘</h4>
        <p>頭獎差 4 倍？RTP 與期望值完整對照</p>
        <span class="rm-cta">看機率分析 →</span>
      </a>
      <a class="rm-card pink" href="/articles/daily-cash-539-wheel-guide/">
        <span class="rm-tag">🎯 包牌攻略</span>
        <h4>539 包牌攻略：系統號玩法</h4>
        <p>包 7 碼任一獎項命中率 91%</p>
        <span class="rm-cta">解鎖包牌公式 →</span>
      </a>
    </div>
  </section>
</div>

<script is:inline>
// === CONFIG ===
const LOTTERY_CONFIG = {
  daily_cash_539: { file: '/data/daily-cash-539.json', label: '今彩 539', maxNum: 39, count: 5, hasSpecial: false, specialLabel: '' },
  super_lotto:    { file: '/data/super-lotto.json',    label: '威力彩',   maxNum: 38, count: 6, hasSpecial: true,  specialLabel: '第二區', specialMax: 8 },
  lotto649:       { file: '/data/lotto649.json',       label: '大樂透',   maxNum: 49, count: 6, hasSpecial: true,  specialLabel: '特別號', specialMax: 49 },
};

let currentLottery = 'daily_cash_539';
let currentRange = 50;
let lotteryData = {};

// === INIT ===
async function init() {
  await loadData(currentLottery);
  render();
}

async function loadData(key) {
  if (lotteryData[key]) return;
  try {
    const res = await fetch(LOTTERY_CONFIG[key].file);
    lotteryData[key] = await res.json();
  } catch (e) {
    console.error('Failed to load lottery data:', e);
  }
}

function switchLottery(btn) {
  document.querySelectorAll('.lot-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  currentLottery = btn.dataset.lottery;
  loadData(currentLottery).then(() => render());
}

function setRange(btn) {
  document.querySelectorAll('.range-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  currentRange = parseInt(btn.dataset.range);
  render();
}

// === CORE ANALYSIS ===
function getDraws() {
  const data = lotteryData[currentLottery];
  if (!data) return [];
  const draws = data.draws;
  return currentRange === 0 ? draws : draws.slice(0, currentRange);
}

function calcFrequency(draws, maxNum) {
  const freq = {};
  for (let i = 1; i <= maxNum; i++) freq[i] = 0;
  draws.forEach(d => d.numbers.forEach(n => freq[n]++));
  return freq;
}

function calcSpecialFrequency(draws, maxNum) {
  const freq = {};
  for (let i = 1; i <= maxNum; i++) freq[i] = 0;
  draws.forEach(d => { if (d.special) freq[d.special]++; });
  return freq;
}

function calcMissing(allDraws, maxNum) {
  // Calculate from ALL draws (not range-limited) for accuracy
  const missing = {};
  for (let i = 1; i <= maxNum; i++) {
    missing[i] = 0;
    for (let j = 0; j < allDraws.length; j++) {
      if (allDraws[j].numbers.includes(i)) break;
      missing[i]++;
    }
  }
  return missing;
}

function calcRepeat(allDraws, maxNum) {
  // For each number: how many times it appeared in draw[i] AND draw[i+1] consecutively
  const stats = {};
  for (let n = 1; n <= maxNum; n++) {
    stats[n] = { appeared: 0, repeated: 0 };
  }
  for (let i = 0; i < allDraws.length - 1; i++) {
    const curr = allDraws[i].numbers;
    const next = allDraws[i + 1].numbers;
    curr.forEach(n => {
      stats[n].appeared++;
      if (next.includes(n)) stats[n].repeated++;
    });
  }
  return stats;
}

function calcCombos(draws) {
  const combos = {};
  draws.forEach(d => {
    const nums = d.numbers;
    for (let i = 0; i < nums.length; i++) {
      for (let j = i + 1; j < nums.length; j++) {
        const key = `${nums[i]}-${nums[j]}`;
        combos[key] = (combos[key] || 0) + 1;
      }
    }
  });
  return Object.entries(combos)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 15);
}

// === RENDER ===
function render() {
  const cfg = LOTTERY_CONFIG[currentLottery];
  const data = lotteryData[currentLottery];
  if (!data) return;

  const draws = getDraws();
  const allDraws = data.draws;
  const freq = calcFrequency(draws, cfg.maxNum);
  const missing = calcMissing(allDraws, cfg.maxNum);
  const combos = calcCombos(draws);

  // Update meta
  document.getElementById('updateTime').textContent = data.lastUpdated;
  document.getElementById('totalDraws').textContent = draws.length;

  // Suggestions & Wheel (first sections)
  renderSuggestions();
  renderWheel();

  // Theory note
  const theory = (1 / cfg.maxNum * 100).toFixed(2);
  document.getElementById('theoryNote').textContent = `1/${cfg.maxNum} ≈ ${theory}%`;

  // Repeat analysis (use filtered draws, not allDraws)
  const repeatStats = calcRepeat(draws, cfg.maxNum);
  renderRepeat(repeatStats, cfg.maxNum);

  // Hot/Cold
  const sorted = Object.entries(freq).sort((a, b) => b[1] - a[1]);
  const hot = sorted.slice(0, 10);
  const cold = sorted.slice(-10).reverse();

  renderHotCold('hotNumbers', hot, draws.length, 'hot');
  renderHotCold('coldNumbers', cold, draws.length, 'cold');

  // Special numbers
  const specialEl = document.getElementById('specialStats');
  if (cfg.hasSpecial) {
    specialEl.style.display = 'block';
    document.getElementById('specialTitle').textContent = `🎯 ${cfg.specialLabel}統計`;
    const specFreq = calcSpecialFrequency(draws, cfg.specialMax);
    const specSorted = Object.entries(specFreq).sort((a, b) => b[1] - a[1]);
    renderHotCold('specialNumbers', specSorted, draws.length, 'special');
  } else {
    specialEl.style.display = 'none';
  }

  // Frequency chart
  renderFreqChart(freq, cfg.maxNum, draws.length);

  // Missing values
  renderMissing(missing, cfg.maxNum);

  // Update missing disclaimer dynamically
  const missingSorted = Object.entries(missing).sort((a, b) => b[1] - a[1]);
  if (missingSorted.length > 0 && missingSorted[0][1] > 0) {
    document.getElementById('topMissNote').textContent =
      `${missingSorted[0][0]} 號已經 ${missingSorted[0][1]} 期沒開`;
  }

  // Combos
  renderCombos(combos, draws.length);

  // Backtest
  renderBacktest();

  // Recent draws
  renderRecentDraws(draws.slice(0, 10), cfg);

  // Countdown & Picker
  updateCountdown();
  renderPicker();
}

function renderRepeat(stats, maxNum) {
  const cfg = LOTTERY_CONFIG[currentLottery];
  const theory = (1 / maxNum * 100).toFixed(2);
  const entries = Object.entries(stats)
    .filter(([_, s]) => s.appeared >= 3) // only show numbers with enough data
    .map(([num, s]) => {
      const rate = s.appeared > 0 ? (s.repeated / s.appeared * 100) : 0;
      return { num: parseInt(num), appeared: s.appeared, repeated: s.repeated, rate };
    })
    .sort((a, b) => b.rate - a.rate);

  // Summary
  const totalAppeared = entries.reduce((a, e) => a + e.appeared, 0);
  const totalRepeated = entries.reduce((a, e) => a + e.repeated, 0);
  const avgRate = totalAppeared > 0 ? (totalRepeated / totalAppeared * 100).toFixed(2) : 0;

  document.getElementById('repeatSummary').innerHTML = `
    <div class="repeat-summary-inner">
      <div class="rs-item">
        <span class="rs-val">${avgRate}%</span>
        <span class="rs-label">整體同號連開率</span>
      </div>
      <div class="rs-item">
        <span class="rs-val">${theory}%</span>
        <span class="rs-label">理論機率 (1/${maxNum})</span>
      </div>
      <div class="rs-item">
        <span class="rs-val ${Math.abs(parseFloat(avgRate) - parseFloat(theory)) < 1 ? 'match' : 'diff'}">${Math.abs(parseFloat(avgRate) - parseFloat(theory)).toFixed(2)}%</span>
        <span class="rs-label">與理論值差距</span>
      </div>
    </div>`;

  // Top repeat + bottom repeat
  const top5 = entries.slice(0, 8);
  const bottom5 = entries.slice(-8).reverse();

  document.getElementById('repeatGrid').innerHTML = `
    <div class="repeat-cols">
      <div class="repeat-col">
        <h4>📈 同號連開率最高</h4>
        ${top5.map(e => `
          <div class="repeat-row">
            <span class="num-ball">${e.num}</span>
            <div class="repeat-bar-wrap">
              <div class="repeat-bar" style="width:${Math.min(e.rate * 2, 100)}%"></div>
              <div class="repeat-theory" style="left:${Math.min(parseFloat(theory) * 2, 100)}%"></div>
            </div>
            <span class="repeat-rate">${e.rate.toFixed(1)}%</span>
            <span class="repeat-detail">${e.repeated}/${e.appeared}</span>
          </div>`).join('')}
      </div>
      <div class="repeat-col">
        <h4>📉 同號連開率最低</h4>
        ${bottom5.map(e => `
          <div class="repeat-row">
            <span class="num-ball">${e.num}</span>
            <div class="repeat-bar-wrap">
              <div class="repeat-bar low" style="width:${Math.min(e.rate * 2, 100)}%"></div>
              <div class="repeat-theory" style="left:${Math.min(parseFloat(theory) * 2, 100)}%"></div>
            </div>
            <span class="repeat-rate">${e.rate.toFixed(1)}%</span>
            <span class="repeat-detail">${e.repeated}/${e.appeared}</span>
          </div>`).join('')}
      </div>
    </div>`;
}

// === BACKTEST ===
let currentStrategy = 'hot';
function switchStrategy(btn) {
  document.querySelectorAll('.bt-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  currentStrategy = btn.dataset.strategy;
  renderBacktest();
}

function runBacktest(allDraws, numCount, maxNum, strategy) {
  // For each draw i (from index 0 = newest), use draws i+1..i+lookback to determine hot/cold
  // Then check how many of those picks appeared in draw i
  const lookback = 20; // use past 20 draws to calc hot/cold
  const results = [];

  for (let i = 0; i < allDraws.length - lookback; i++) {
    const pastDraws = allDraws.slice(i + 1, i + 1 + lookback);
    const freq = {};
    for (let n = 1; n <= maxNum; n++) freq[n] = 0;
    pastDraws.forEach(d => d.numbers.forEach(n => freq[n]++));

    const sorted = Object.entries(freq).sort((a, b) => b[1] - a[1]);
    let picks;
    if (strategy === 'hot') {
      picks = sorted.slice(0, numCount).map(e => parseInt(e[0]));
    } else {
      picks = sorted.slice(-numCount).map(e => parseInt(e[0]));
    }

    const actual = allDraws[i].numbers;
    const hits = picks.filter(n => actual.includes(n));

    results.push({
      period: allDraws[i].period,
      date: allDraws[i].date,
      picks: picks.sort((a, b) => a - b),
      actual: actual,
      hits: hits,
      hitCount: hits.length
    });
  }
  return results;
}

function renderBacktest() {
  const cfg = LOTTERY_CONFIG[currentLottery];
  const data = lotteryData[currentLottery];
  if (!data) return;

  const results = runBacktest(data.draws, cfg.count, cfg.maxNum, currentStrategy);
  if (results.length === 0) return;

  // Summary stats
  const totalHits = results.reduce((a, r) => a + r.hitCount, 0);
  const totalPicks = results.length * cfg.count;
  const avgHit = (totalHits / results.length).toFixed(2);
  const hitRate = (totalHits / totalPicks * 100).toFixed(2);
  const expectedHit = (cfg.count * cfg.count / cfg.maxNum).toFixed(2);
  const expectedRate = (cfg.count / cfg.maxNum * 100).toFixed(2);
  const anyHitDraws = results.filter(r => r.hitCount > 0).length;
  const anyHitPct = (anyHitDraws / results.length * 100).toFixed(1);
  const bestDraw = results.reduce((a, r) => r.hitCount > a.hitCount ? r : a, results[0]);
  const label = currentStrategy === 'hot' ? '熱號' : '冷號';

  document.getElementById('backtestSummary').innerHTML = `
    <div class="bt-summary">
      <div class="bt-stat">
        <span class="bt-val">${avgHit}</span>
        <span class="bt-label">每期平均命中</span>
      </div>
      <div class="bt-stat">
        <span class="bt-val">${expectedHit}</span>
        <span class="bt-label">隨機期望值</span>
      </div>
      <div class="bt-stat">
        <span class="bt-val ${parseFloat(avgHit) > parseFloat(expectedHit) ? 'win' : 'lose'}">${avgHit > expectedHit ? '+' : ''}${(avgHit - expectedHit).toFixed(2)}</span>
        <span class="bt-label">${label}策略 vs 隨機</span>
      </div>
      <div class="bt-stat">
        <span class="bt-val">${anyHitPct}%</span>
        <span class="bt-label">有命中的期數</span>
      </div>
    </div>
    <p class="bt-verdict">${parseFloat(avgHit) > parseFloat(expectedHit)
      ? `📊 在這 ${results.length} 期回測中，買${label}平均每期多中 ${(avgHit - expectedHit).toFixed(2)} 個——但這只是隨機波動，不代表策略有效。`
      : `📊 在這 ${results.length} 期回測中，買${label}甚至不如隨機選號。最佳一期是第 ${bestDraw.period} 期命中 ${bestDraw.hitCount} 個。`
    }</p>`;

  // Table: show top results (most hits first)
  const sorted = [...results].sort((a, b) => b.hitCount - a.hitCount);
  const show = sorted.slice(0, 15);

  document.getElementById('backtestTable').innerHTML = `
    <thead>
      <tr>
        <th>期別</th>
        <th>日期</th>
        <th>${label}選號</th>
        <th>實際開獎</th>
        <th>命中</th>
      </tr>
    </thead>
    <tbody>
      ${show.map(r => `
        <tr class="${r.hitCount >= 3 ? 'highlight' : ''}">
          <td>${r.period}</td>
          <td>${r.date}</td>
          <td class="td-nums">${r.picks.map(n =>
            `<span class="num-mini ${r.hits.includes(n) ? 'hit' : ''}">${n}</span>`
          ).join('')}</td>
          <td class="td-nums">${r.actual.map(n =>
            `<span class="num-mini ${r.hits.includes(n) ? 'hit' : ''}">${n}</span>`
          ).join('')}</td>
          <td><span class="hit-badge h${r.hitCount}">${r.hitCount}</span></td>
        </tr>`).join('')}
    </tbody>`;
}

function renderHotCold(elId, items, total, type) {
  const el = document.getElementById(elId);
  el.innerHTML = items.map(([num, count], i) => {
    const pct = total > 0 ? ((count / total) * 100).toFixed(1) : 0;
    const barWidth = total > 0 ? Math.max(5, (count / total) * 100 * (type === 'special' ? 3 : 1.5)) : 0;
    const numClass = type === 'special' ? 'num-ball special-ball' : 'num-ball';
    return `
      <div class="hc-row">
        <span class="hc-rank">${i + 1}</span>
        <span class="${numClass}">${num}</span>
        <div class="hc-bar-wrap">
          <div class="hc-bar ${type}" style="width:${Math.min(barWidth, 100)}%"></div>
        </div>
        <span class="hc-count">${count} 次</span>
        <span class="hc-pct">${pct}%</span>
      </div>`;
  }).join('');
}

function renderFreqChart(freq, maxNum, total) {
  const el = document.getElementById('freqChart');
  const maxFreq = Math.max(...Object.values(freq), 1);
  const avg = total > 0 ? (Object.values(freq).reduce((a, b) => a + b, 0) / maxNum) : 0;
  const maxBarPx = 160; // max bar height in pixels

  el.innerHTML = Object.entries(freq).map(([num, count]) => {
    const heightPx = maxFreq > 0 ? Math.max((count / maxFreq) * maxBarPx, 4) : 4;
    const isHot = count > avg * 1.3;
    const isCold = count < avg * 0.7;
    const cls = isHot ? 'bar hot' : isCold ? 'bar cold' : 'bar';
    return `
      <div class="freq-col">
        <div class="freq-value">${count}</div>
        <div class="${cls}" style="height:${heightPx}px"></div>
        <div class="freq-num">${num}</div>
      </div>`;
  }).join('') + `<div class="avg-line" style="bottom:${20 + (avg / maxFreq) * maxBarPx}px"><span>平均 ${avg.toFixed(1)}</span></div>`;
}

function renderMissing(missing, maxNum) {
  const el = document.getElementById('missingGrid');
  const sorted = Object.entries(missing).sort((a, b) => b[1] - a[1]);

  el.innerHTML = sorted.map(([num, count]) => {
    const level = count === 0 ? 'just' : count <= 3 ? 'low' : count <= 8 ? 'mid' : count <= 15 ? 'high' : 'extreme';
    return `
      <div class="miss-item ${level}">
        <span class="miss-num">${num}</span>
        <span class="miss-val">${count}</span>
        <span class="miss-label">${count === 0 ? '剛開' : count + ' 期'}</span>
      </div>`;
  }).join('');
}

function renderCombos(combos, total) {
  const el = document.getElementById('comboList');
  el.innerHTML = combos.map(([key, count], i) => {
    const [a, b] = key.split('-');
    const pct = total > 0 ? ((count / total) * 100).toFixed(1) : 0;
    return `
      <div class="combo-row">
        <span class="combo-rank">#${i + 1}</span>
        <span class="num-ball">${a}</span>
        <span class="combo-plus">+</span>
        <span class="num-ball">${b}</span>
        <span class="combo-count">${count} 次 (${pct}%)</span>
      </div>`;
  }).join('');
}

function renderRecentDraws(draws, cfg) {
  const el = document.getElementById('recentDraws');
  const showFirst = 5;
  const rowHtml = (d) => `
    <div class="recent-row">
      <div class="recent-meta">
        <span class="recent-period">第 ${d.period} 期</span>
        <span class="recent-date">${d.date}</span>
      </div>
      <div class="recent-nums">
        ${d.numbers.map(n => `<span class="num mini">${n}</span>`).join('')}
        ${cfg.hasSpecial && d.special != null ? `<span class="num mini special-num">${d.special}</span>` : ''}
      </div>
    </div>`;
  const visible = draws.slice(0, showFirst).map(rowHtml).join('');
  const hidden = draws.length > showFirst
    ? `<div class="recent-hidden" id="recentHidden" style="display:none">${draws.slice(showFirst).map(rowHtml).join('')}</div>
       <button class="whl-show-more" id="recentToggle" onclick="toggleRecentDraws()">顯示更多（共 ${draws.length} 期）</button>`
    : '';
  el.innerHTML = visible + hidden;
}

function toggleRecentDraws() {
  const el = document.getElementById('recentHidden');
  const btn = document.getElementById('recentToggle');
  if (el.style.display === 'none') {
    el.style.display = 'block';
    btn.textContent = '收合';
  } else {
    el.style.display = 'none';
    btn.textContent = '顯示更多';
  }
}

// === SUGGESTION ENGINE ===
function calcSuggestions(draws, allDraws, cfg) {
  const { maxNum, count } = cfg;
  const freq = calcFrequency(draws, maxNum);
  const missing = calcMissing(allDraws, maxNum);
  const repeatStats = calcRepeat(draws, maxNum);
  const lastDraw = allDraws.length > 0 ? allDraws[0].numbers : [];

  // Normalize helpers
  const vals = arr => arr.length ? arr : [0];
  const minMax = (arr) => {
    const mn = Math.min(...vals(arr)), mx = Math.max(...vals(arr));
    return { min: mn, max: mx, range: mx - mn || 1 };
  };

  const freqVals = Object.values(freq);
  const missVals = Object.values(missing);
  const fNorm = minMax(freqVals);
  const mNorm = minMax(missVals);

  // Score each number
  const scores = [];
  for (let n = 1; n <= maxNum; n++) {
    // 1) Frequency score (0~100): higher freq = higher score (hot bias)
    const freqScore = ((freq[n] - fNorm.min) / fNorm.range) * 100;

    // 2) Missing score (0~100): higher missing = higher score (overdue)
    const missScore = ((missing[n] - mNorm.min) / mNorm.range) * 100;

    // 3) Repeat score (0~100): if number was in last draw, use its repeat rate
    let repeatScore = 0;
    if (lastDraw.includes(n) && repeatStats[n]) {
      const s = repeatStats[n];
      repeatScore = s.appeared > 0 ? (s.repeated / s.appeared) * 100 : 0;
      // Boost: multiply by 2 for "recent momentum" but cap at 100
      repeatScore = Math.min(repeatScore * 2, 100);
    }

    // Weighted combination:
    // - Frequency 40%: hot numbers appear more
    // - Missing 35%: overdue numbers due for return
    // - Repeat 25%: last draw momentum (only applies to numbers in last draw)
    const total = freqScore * 0.40 + missScore * 0.35 + repeatScore * 0.25;

    scores.push({
      num: n,
      total: Math.round(total * 10) / 10,
      freqScore: Math.round(freqScore),
      missScore: Math.round(missScore),
      repeatScore: Math.round(repeatScore),
      freq: freq[n],
      missing: missing[n],
      inLastDraw: lastDraw.includes(n)
    });
  }

  // Sort by total score descending
  scores.sort((a, b) => b.total - a.total);

  // Pick top `count` numbers for the main suggestion
  const mainPicks = scores.slice(0, count);

  // Also return a "balanced" set: top 3 hot + top (count-3) overdue (or split evenly for 5-pick)
  const hotSorted = [...scores].sort((a, b) => b.freqScore - a.freqScore);
  const missSorted = [...scores].sort((a, b) => b.missScore - a.missScore);
  const hotCount = Math.ceil(count / 2);
  const coldCount = count - hotCount;
  const balancedSet = new Set();
  for (const s of hotSorted) { if (balancedSet.size < hotCount) balancedSet.add(s.num); }
  for (const s of missSorted) { if (balancedSet.size < count && !balancedSet.has(s.num)) balancedSet.add(s.num); }
  // Fill remaining if needed
  for (const s of scores) { if (balancedSet.size < count && !balancedSet.has(s.num)) balancedSet.add(s.num); }
  const balancedPicks = scores.filter(s => balancedSet.has(s.num)).sort((a, b) => a.num - b.num);

  return { mainPicks, balancedPicks, allScores: scores };
}

function renderSuggestions() {
  const cfg = LOTTERY_CONFIG[currentLottery];
  const data = lotteryData[currentLottery];
  if (!data) return;

  const draws = getDraws();
  const allDraws = data.draws;
  const { mainPicks, balancedPicks, allScores } = calcSuggestions(draws, allDraws, cfg);

  // Update range display
  const rangeLabel = currentRange === 0 ? '全部' : currentRange;
  document.getElementById('suggestRange').textContent = rangeLabel;

  const el = document.getElementById('suggestionResult');
  const maxScore = mainPicks.length > 0 ? mainPicks[0].total : 1;

  // Special number suggestion (for 威力彩/大樂透)
  let specialHtml = '';
  if (cfg.hasSpecial) {
    const specFreq = calcSpecialFrequency(draws, cfg.specialMax);
    const specMissing = {};
    for (let i = 1; i <= cfg.specialMax; i++) {
      specMissing[i] = 0;
      for (let j = 0; j < allDraws.length; j++) {
        if (allDraws[j].special === i) break;
        specMissing[i]++;
      }
    }
    // Score special numbers
    const specScores = [];
    const sfVals = Object.values(specFreq);
    const smVals = Object.values(specMissing);
    const sfN = { min: Math.min(...sfVals), max: Math.max(...sfVals), range: Math.max(...sfVals) - Math.min(...sfVals) || 1 };
    const smN = { min: Math.min(...smVals), max: Math.max(...smVals), range: Math.max(...smVals) - Math.min(...smVals) || 1 };
    for (let i = 1; i <= cfg.specialMax; i++) {
      const fs = ((specFreq[i] - sfN.min) / sfN.range) * 100;
      const ms = ((specMissing[i] - smN.min) / smN.range) * 100;
      specScores.push({ num: i, total: Math.round((fs * 0.5 + ms * 0.5) * 10) / 10 });
    }
    specScores.sort((a, b) => b.total - a.total);
    const topSpec = specScores[0];
    specialHtml = `
      <div class="suggest-special">
        <span class="suggest-special-label">${cfg.specialLabel}推薦</span>
        <span class="num-ball special-ball suggest-special-ball">${topSpec.num}</span>
        <span class="suggest-special-score">評分 ${topSpec.total}</span>
      </div>`;
  }

  el.innerHTML = `
    <div class="suggest-tabs">
      <button class="sg-tab active" onclick="switchSuggestMode(this,'weighted')">📊 綜合評分</button>
      <button class="sg-tab" onclick="switchSuggestMode(this,'balanced')">⚖️ 冷熱平衡</button>
    </div>

    <div class="suggest-set" id="suggestWeighted" style="display:block">
      <div class="suggest-balls">
        ${mainPicks.map(s => `
          <div class="suggest-ball-wrap">
            <div class="suggest-ball">${s.num}</div>
            <div class="suggest-score">${s.total}</div>
            <div class="suggest-tags">
              ${s.freqScore >= 70 ? '<span class="sg-tag hot">熱</span>' : ''}
              ${s.missScore >= 70 ? '<span class="sg-tag miss">遺</span>' : ''}
              ${s.inLastDraw ? '<span class="sg-tag repeat">連</span>' : ''}
            </div>
          </div>`).join('')}
      </div>
      ${specialHtml}
      <div class="suggest-detail">
        <table class="suggest-table">
          <thead>
            <tr><th>號碼</th><th>出現次數</th><th>遺漏期數</th><th>熱度</th><th>遺漏</th><th>連開</th><th>總分</th></tr>
          </thead>
          <tbody>
            ${mainPicks.map(s => `
              <tr>
                <td><span class="num-ball sg-ball">${s.num}</span></td>
                <td>${s.freq} 次</td>
                <td>${s.missing} 期</td>
                <td><div class="sg-bar-mini"><div class="sg-bar-fill hot" style="width:${s.freqScore}%"></div></div></td>
                <td><div class="sg-bar-mini"><div class="sg-bar-fill miss" style="width:${s.missScore}%"></div></div></td>
                <td><div class="sg-bar-mini"><div class="sg-bar-fill repeat" style="width:${s.repeatScore}%"></div></div></td>
                <td><strong>${s.total}</strong></td>
              </tr>`).join('')}
          </tbody>
        </table>
      </div>
    </div>

    <div class="suggest-set" id="suggestBalanced" style="display:none">
      <div class="suggest-balls">
        ${balancedPicks.map(s => `
          <div class="suggest-ball-wrap">
            <div class="suggest-ball">${s.num}</div>
            <div class="suggest-score">${s.total}</div>
            <div class="suggest-tags">
              ${s.freqScore >= 70 ? '<span class="sg-tag hot">熱</span>' : ''}
              ${s.missScore >= 70 ? '<span class="sg-tag miss">遺</span>' : ''}
              ${s.inLastDraw ? '<span class="sg-tag repeat">連</span>' : ''}
            </div>
          </div>`).join('')}
      </div>
      ${specialHtml}
      <p class="suggest-explain">⚖️ 冷熱平衡模式：取 ${Math.ceil(cfg.count/2)} 個最熱號 + ${cfg.count - Math.ceil(cfg.count/2)} 個最久未開號，兼顧趨勢與回歸。</p>
    </div>

    <div class="suggest-algo-note">
      <details>
        <summary>📐 評分公式說明</summary>
        <p>每個號碼的綜合評分 = <strong>熱度 × 40%</strong> + <strong>遺漏值 × 35%</strong> + <strong>連開動能 × 25%</strong></p>
        <p>熱度：該號碼在選定範圍內的出現頻率歸一化(0~100)。遺漏值：距離上次開出的期數歸一化。連開動能：若該號碼出現在最近一期，則依其歷史連開率加權。</p>
      </details>
    </div>`;
}

function switchSuggestMode(btn, mode) {
  document.querySelectorAll('.sg-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('suggestWeighted').style.display = mode === 'weighted' ? 'block' : 'none';
  document.getElementById('suggestBalanced').style.display = mode === 'balanced' ? 'block' : 'none';
}

// === WHEEL GENERATOR ===
let currentBudget = 1000;

const BET_COST = {
  daily_cash_539: 50,
  super_lotto: 50,
  lotto649: 50,
};

function setBudget(btn) {
  document.querySelectorAll('.whl-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  currentBudget = parseInt(btn.dataset.budget);
  document.getElementById('customBudget').value = '';
  renderWheel();
}

function setCustomBudget() {
  const input = document.getElementById('customBudget');
  const val = parseInt(input.value);
  if (!val || val < 100) { input.focus(); return; }
  document.querySelectorAll('.whl-btn[data-budget]').forEach(b => b.classList.remove('active'));
  currentBudget = val;
  renderWheel();
}

// Generate all C(n,k) combinations from an array
function combinations(arr, k) {
  if (k === 0) return [[]];
  if (arr.length < k) return [];
  const result = [];
  function helper(start, combo) {
    if (combo.length === k) { result.push([...combo]); return; }
    for (let i = start; i <= arr.length - (k - combo.length); i++) {
      combo.push(arr[i]);
      helper(i + 1, combo);
      combo.pop();
    }
  }
  helper(0, []);
  return result;
}

// Determine pool size to keep combos manageable
function getPoolSize(maxBets, pickCount) {
  // Find the largest pool where C(pool, pick) is reasonable
  // but pick at least pickCount+2
  const minPool = pickCount + 2;
  let pool = minPool;
  for (let n = minPool; n <= 20; n++) {
    let c = 1;
    for (let i = 0; i < pickCount; i++) c = c * (n - i) / (i + 1);
    if (c > maxBets * 3) break; // pool too large, stop
    pool = n;
  }
  return pool;
}

function generateWheel(draws, allDraws, cfg) {
  const betCost = BET_COST[currentLottery];
  const maxBets = Math.floor(currentBudget / betCost);
  if (maxBets < 1) return { pool: [], combos: [], maxBets: 0, betCost, poolSize: 0 };

  // Get scored numbers
  const { allScores } = calcSuggestions(draws, allDraws, cfg);
  const poolSize = getPoolSize(maxBets, cfg.count);
  const pool = allScores.slice(0, poolSize);
  const poolNums = pool.map(s => s.num);

  // Generate all combos from pool
  let allCombos = combinations(poolNums, cfg.count);

  // Score each combo: sum of individual scores
  allCombos = allCombos.map(combo => {
    const score = combo.reduce((sum, n) => {
      const s = pool.find(p => p.num === n);
      return sum + (s ? s.total : 0);
    }, 0);
    // Count tags
    const hotCount = combo.filter(n => { const s = pool.find(p => p.num === n); return s && s.freqScore >= 70; }).length;
    const missCount = combo.filter(n => { const s = pool.find(p => p.num === n); return s && s.missScore >= 70; }).length;
    return { nums: combo, score: Math.round(score * 10) / 10, hotCount, missCount };
  });

  // Sort by score, take top maxBets
  allCombos.sort((a, b) => b.score - a.score);
  const combos = allCombos.slice(0, maxBets);

  return { pool, combos, maxBets, betCost, poolSize, totalCombos: allCombos.length };
}

function renderWheel() {
  const cfg = LOTTERY_CONFIG[currentLottery];
  const data = lotteryData[currentLottery];
  if (!data) return;

  const draws = getDraws();
  const allDraws = data.draws;
  const betCost = BET_COST[currentLottery];
  const { pool, combos, maxBets, poolSize, totalCombos } = generateWheel(draws, allDraws, cfg);

  // Summary
  const actualCost = combos.length * betCost;
  document.getElementById('wheelSummary').innerHTML = `
    <div class="whl-summary-grid">
      <div class="whl-stat">
        <span class="whl-stat-val">$${currentBudget.toLocaleString()}</span>
        <span class="whl-stat-label">投注預算</span>
      </div>
      <div class="whl-stat">
        <span class="whl-stat-val">${combos.length} 注</span>
        <span class="whl-stat-label">包牌組合（每注 $${betCost}）</span>
      </div>
      <div class="whl-stat">
        <span class="whl-stat-val">${poolSize} 碼</span>
        <span class="whl-stat-label">候選號碼池</span>
      </div>
      <div class="whl-stat">
        <span class="whl-stat-val">$${actualCost.toLocaleString()}</span>
        <span class="whl-stat-label">實際花費</span>
      </div>
    </div>`;

  // Pool display
  document.getElementById('wheelPool').innerHTML = `
    <h4>🎯 候選號碼池（TOP ${poolSize} 高分號碼）</h4>
    <div class="whl-pool-balls">
      ${pool.map((s, i) => `
        <div class="whl-pool-item">
          <div class="whl-pool-ball">${s.num}</div>
          <div class="whl-pool-score">${s.total}</div>
          <div class="suggest-tags">
            ${s.freqScore >= 70 ? '<span class="sg-tag hot">熱</span>' : ''}
            ${s.missScore >= 70 ? '<span class="sg-tag miss">遺</span>' : ''}
            ${s.inLastDraw ? '<span class="sg-tag repeat">連</span>' : ''}
          </div>
        </div>`).join('')}
    </div>`;

  // Combos table
  if (combos.length === 0) {
    document.getElementById('wheelCombos').innerHTML = '<p class="whl-empty">預算不足，至少需要 $' + betCost + ' 才能買一注。</p>';
  } else {
    // Show first 50 combos, with "show more" if needed
    const showFirst = 5;
    const hasMore = combos.length > showFirst;

    // Special number for 威力彩/大樂透
    let specialCol = '';
    let specialHeader = '';
    if (cfg.hasSpecial) {
      const specFreq = calcSpecialFrequency(draws, cfg.specialMax);
      const specScores = [];
      for (let i = 1; i <= cfg.specialMax; i++) specScores.push({ num: i, freq: specFreq[i] });
      specScores.sort((a, b) => b.freq - a.freq);
      const topSpec = specScores[0].num;
      specialHeader = `<th>${cfg.specialLabel}</th>`;
      specialCol = `<td><span class="num-mini hit">${topSpec}</span></td>`;
    }

    const comboRow = (c, i) => `
      <tr>
        <td class="whl-idx">${i + 1}</td>
        <td class="td-nums">${c.nums.map(n => `<span class="num-mini">${n}</span>`).join('')}</td>
        ${specialCol}
        <td><span class="whl-strength">${c.score}</span></td>
        <td class="whl-composition">
          ${c.hotCount > 0 ? `<span class="sg-tag hot">${c.hotCount}熱</span>` : ''}
          ${c.missCount > 0 ? `<span class="sg-tag miss">${c.missCount}遺</span>` : ''}
        </td>
      </tr>`;

    document.getElementById('wheelCombos').innerHTML = `
      <h4>📋 包牌組合表${totalCombos > combos.length ? `（從 ${totalCombos} 種組合中選出最強 ${combos.length} 注）` : ''}</h4>
      <div class="whl-table-wrap">
        <table class="whl-table">
          <thead>
            <tr>
              <th>#</th>
              <th>號碼組合</th>
              ${specialHeader}
              <th>強度</th>
              <th>組成</th>
            </tr>
          </thead>
          <tbody>
            ${combos.slice(0, showFirst).map((c, i) => comboRow(c, i)).join('')}
          </tbody>
          ${hasMore ? `<tbody id="wheelHiddenRows" style="display:none">
            ${combos.slice(showFirst).map((c, i) => comboRow(c, i + showFirst)).join('')}
          </tbody>` : ''}
        </table>
      </div>
      ${hasMore ? `<button class="whl-show-more" id="wheelToggle" onclick="toggleWheelCombos()">顯示全部 ${combos.length} 注</button>` : ''}`;
  }

  // Last draw review
  renderWheelReview(draws, allDraws, cfg);
}

function toggleWheelCombos() {
  const el = document.getElementById('wheelHiddenRows');
  const btn = document.getElementById('wheelToggle');
  if (!el || !btn) return;
  if (el.style.display === 'none') {
    el.style.display = '';
    btn.textContent = '收合';
  } else {
    el.style.display = 'none';
    const total = el.querySelectorAll('tr').length + 5;
    btn.textContent = '顯示全部 ' + total + ' 注';
  }
}

function renderWheelReview(draws, allDraws, cfg) {
  const el = document.getElementById('wheelReview');
  if (allDraws.length < 2) { el.innerHTML = ''; return; }

  // Simulate: what if we had used this system for the LAST draw?
  // Use draws[1..] (excluding latest) to generate wheel, then check against draws[0]
  const pastDraws = draws.length > 1 ? draws.slice(1) : allDraws.slice(1);
  const pastAllDraws = allDraws.slice(1);
  if (pastDraws.length < 5) { el.innerHTML = ''; return; }

  const lastDraw = allDraws[0];
  const { pool: simPool, combos: simCombos } = generateWheel(pastDraws, pastAllDraws, cfg);

  if (simCombos.length === 0) { el.innerHTML = ''; return; }

  // Check hits
  const actual = lastDraw.numbers;
  let bestHit = 0;
  let bestCombo = null;
  const hitCombos = simCombos.map(c => {
    const hits = c.nums.filter(n => actual.includes(n));
    if (hits.length > bestHit) { bestHit = hits.length; bestCombo = c; }
    return { ...c, hits, hitCount: hits.length };
  });

  const anyHit = hitCombos.filter(c => c.hitCount > 0).length;
  const poolHits = simPool.filter(s => actual.includes(s.num));

  // Special number check
  let specialHit = '';
  if (cfg.hasSpecial && lastDraw.special != null) {
    const specFreq = calcSpecialFrequency(pastDraws, cfg.specialMax);
    const specScores = [];
    for (let i = 1; i <= cfg.specialMax; i++) specScores.push({ num: i, freq: specFreq[i] });
    specScores.sort((a, b) => b.freq - a.freq);
    const suggestedSpec = specScores[0].num;
    specialHit = lastDraw.special === suggestedSpec
      ? `<span class="whl-review-hit">✅ ${cfg.specialLabel} ${suggestedSpec} 命中！</span>`
      : `<span class="whl-review-miss">❌ ${cfg.specialLabel}推薦 ${suggestedSpec}，實際開 ${lastDraw.special}</span>`;
  }

  el.innerHTML = `
    <h4>📋 上期回顧 — 第 ${lastDraw.period} 期 (${lastDraw.date})</h4>
    <div class="whl-review-grid">
      <div class="whl-review-item">
        <span class="whl-review-label">實際開獎</span>
        <div class="td-nums">${actual.map(n => `<span class="num-mini ${simPool.some(s => s.num === n) ? 'hit' : ''}">${n}</span>`).join('')}
        ${cfg.hasSpecial && lastDraw.special != null ? `<span class="num-mini special-num">${lastDraw.special}</span>` : ''}</div>
      </div>
      <div class="whl-review-item">
        <span class="whl-review-label">號碼池命中</span>
        <span class="whl-review-val">${poolHits.length} / ${simPool.length} 個號碼在池中</span>
      </div>
      <div class="whl-review-item">
        <span class="whl-review-label">最佳單注</span>
        <span class="whl-review-val">${bestCombo ? `命中 ${bestHit} 個：${bestCombo.nums.map(n => actual.includes(n) ? `<span class="num-mini hit">${n}</span>` : `<span class="num-mini">${n}</span>`).join('')}` : '—'}</span>
      </div>
      <div class="whl-review-item">
        <span class="whl-review-label">有命中的注數</span>
        <span class="whl-review-val">${anyHit} / ${simCombos.length} 注</span>
      </div>
      ${specialHit ? `<div class="whl-review-item"><span class="whl-review-label">${cfg.specialLabel}</span>${specialHit}</div>` : ''}
    </div>
    <p class="whl-review-note">💡 以上是假設用同樣的演算法和預算 $${currentBudget.toLocaleString()} 回測上一期的結果。</p>`;
}

// === COLLAPSIBLE SECTIONS ===
function toggleSection(headEl) {
  const section = headEl.closest('.collapsible');
  if (!section) return;
  const body = section.querySelector('.section-body');
  const chevron = section.querySelector('.section-chevron');
  if (!body) return;
  const isCollapsed = body.style.display === 'none';
  body.style.display = isCollapsed ? '' : 'none';
  section.classList.toggle('collapsed', !isCollapsed);
  if (chevron) chevron.textContent = isCollapsed ? '▾' : '▸';
}

// === COUNTDOWN TIMER ===
let countdownInterval = null;
function updateCountdown() {
  const cfg = LOTTERY_CONFIG[currentLottery];
  document.getElementById('countdownLottery').textContent = cfg.label;
  if (countdownInterval) clearInterval(countdownInterval);
  countdownInterval = setInterval(tickCountdown, 1000);
  tickCountdown();
}

function getNextDrawTime() {
  const now = new Date();
  const drawHour = 20, drawMin = 30;
  // 539: daily, 威力彩: Mon(1)/Thu(4), 大樂透: Tue(2)/Fri(5)
  let drawDays;
  if (currentLottery === 'daily_cash_539') {
    drawDays = [0,1,2,3,4,5,6]; // every day
  } else if (currentLottery === 'super_lotto') {
    drawDays = [1, 4]; // Mon, Thu
  } else {
    drawDays = [2, 5]; // Tue, Fri
  }

  let target = new Date(now);
  target.setHours(drawHour, drawMin, 0, 0);

  // If today is a draw day and we haven't passed draw time, use today
  if (drawDays.includes(target.getDay()) && target > now) {
    return target;
  }

  // Otherwise find the next draw day
  for (let i = 1; i <= 7; i++) {
    let next = new Date(now);
    next.setDate(now.getDate() + i);
    next.setHours(drawHour, drawMin, 0, 0);
    if (drawDays.includes(next.getDay())) {
      return next;
    }
  }
  return target;
}

function tickCountdown() {
  const next = getNextDrawTime();
  const now = new Date();
  const diff = next - now;
  if (diff <= 0) {
    document.getElementById('countdownTimer').textContent = '開獎中！';
    return;
  }
  const h = Math.floor(diff / 3600000);
  const m = Math.floor((diff % 3600000) / 60000);
  const s = Math.floor((diff % 60000) / 1000);
  document.getElementById('countdownTimer').textContent =
    `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
}

// === PICKER (心水號碼) ===
let pickerSelected = [];

function renderPicker() {
  const cfg = LOTTERY_CONFIG[currentLottery];
  pickerSelected = [];
  document.getElementById('pickerMax').textContent = cfg.count;
  document.getElementById('pickerCount').textContent = '0';
  document.getElementById('pickerBalls').innerHTML = '';
  document.getElementById('pickerResult').innerHTML = '';
  document.getElementById('pickerCheckBtn').disabled = true;

  let html = '';
  for (let i = 1; i <= cfg.maxNum; i++) {
    html += `<button class="pk-num" data-num="${i}" onclick="togglePickerNum(${i})">${i}</button>`;
  }
  document.getElementById('pickerGrid').innerHTML = html;
}

function togglePickerNum(num) {
  const cfg = LOTTERY_CONFIG[currentLottery];
  const idx = pickerSelected.indexOf(num);
  if (idx > -1) {
    pickerSelected.splice(idx, 1);
  } else {
    if (pickerSelected.length >= cfg.count) return; // max reached
    pickerSelected.push(num);
  }
  pickerSelected.sort((a, b) => a - b);

  // Update grid highlights
  document.querySelectorAll('#pickerGrid .pk-num').forEach(btn => {
    btn.classList.toggle('selected', pickerSelected.includes(parseInt(btn.dataset.num)));
  });

  // Update selected balls display
  document.getElementById('pickerCount').textContent = pickerSelected.length;
  document.getElementById('pickerBalls').innerHTML = pickerSelected.map(n =>
    `<span class="num-mini pk-ball">${n}</span>`
  ).join('');

  // Enable/disable check button
  document.getElementById('pickerCheckBtn').disabled = pickerSelected.length < cfg.count;
}

function clearPicker() {
  pickerSelected = [];
  renderPicker();
}

function checkMyNumbers() {
  const cfg = LOTTERY_CONFIG[currentLottery];
  const data = lotteryData[currentLottery];
  if (!data || pickerSelected.length < cfg.count) return;

  const allDraws = data.draws;
  let hits = [];

  allDraws.forEach(draw => {
    const matched = pickerSelected.filter(n => draw.numbers.includes(n));
    if (matched.length >= 2) {
      hits.push({ date: draw.date, period: draw.period, numbers: draw.numbers, matched, count: matched.length });
    }
  });

  hits.sort((a, b) => b.count - a.count || b.date.localeCompare(a.date));

  let html = `<div class="picker-result-box">`;
  html += `<h4>歷史命中結果（共 ${allDraws.length} 期）</h4>`;

  if (hits.length === 0) {
    html += `<p class="picker-no-hit">這組號碼在歷史開獎中命中不到 2 個號碼 😅 換一組試試？</p>`;
  } else {
    const maxShow = 10;
    const display = hits.slice(0, maxShow);
    html += `<p class="picker-hit-summary">命中 2+ 個號碼的期數：<strong>${hits.length}</strong> 期</p>`;
    html += `<div class="picker-hit-list">`;
    display.forEach(h => {
      html += `<div class="picker-hit-row">
        <span class="picker-hit-date">${h.date}</span>
        <span class="picker-hit-nums">${h.numbers.map(n =>
          `<span class="num-mini ${h.matched.includes(n) ? 'hit' : ''}">${n}</span>`
        ).join('')}</span>
        <span class="picker-hit-count">中 ${h.count} 個</span>
      </div>`;
    });
    html += `</div>`;
    if (hits.length > maxShow) {
      html += `<p class="picker-more">… 還有 ${hits.length - maxShow} 期有命中</p>`;
    }
  }
  html += `</div>`;
  document.getElementById('pickerResult').innerHTML = html;
}

// GO
init();
</script>

