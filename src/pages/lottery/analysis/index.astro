function renderWheelReview(draws, allDraws, cfg) {
  const el = document.getElementById('wheelReview');
  if (allDraws.length < 2) { el.innerHTML = ''; return; }

  // Simulate: what if we had used this system for the LAST draw?
  // Use draws[1..] (excluding latest) to generate wheel, then check against draws[0]
  const pastDraws = draws.length > 1 ? draws.slice(1) : allDraws.slice(1);
  const pastAllDraws = allDraws.slice(1);
  if (pastDraws.length < 5) { el.innerHTML = ''; return; }

  const lastDraw = allDraws[0];
  const isCustomReview = wheelSource === 'custom' && customPoolNums.length > cfg.count;
  const { pool: simPool, combos: simCombos } = generateWheel(pastDraws, pastAllDraws, cfg, !isCustomReview);

  if (simCombos.length === 0) { el.innerHTML = ''; return; }

  // Check hits
  const actual = lastDraw.numbers;
  let bestHit = 0;
  let bestCombo = null;
  const hitCombos = simCombos.map(c => {
    const hits = c.nums.filter(n => actual.includes(n));
    if (hits.length > bestHit) { bestHit = hits.length; bestCombo = c; }
    return { ...c, hits, hitCount: hits.length };
  });

  const anyHit = hitCombos.filter(c => c.hitCount > 0).length;
  const poolHits = simPool.filter(s => actual.includes(s.num));

  // Special number check
  let specialHit = '';
  if (cfg.hasSpecial && lastDraw.special != null) {
    const specFreq = calcSpecialFrequency(pastDraws, cfg.specialMax);
    const specScores = [];
    for (let i = 1; i <= cfg.specialMax; i++) specScores.push({ num: i, freq: specFreq[i] });
    specScores.sort((a, b) => b.freq - a.freq);
    const suggestedSpec = specScores[0].num;
    specialHit = lastDraw.special === suggestedSpec
      ? `<span class="whl-review-hit">✅ ${cfg.specialLabel} ${suggestedSpec} 命中！</span>`
      : `<span class="whl-review-miss">❌ ${cfg.specialLabel}推薦 ${suggestedSpec}，實際開 ${lastDraw.special}</span>`;
  }

  el.innerHTML = `
    <h4>📋 上期回顧 — 第 ${lastDraw.period} 期 (${lastDraw.date})</h4>
    <div class="whl-review-grid">
      <div class="whl-review-item">
        <span class="whl-review-label">實際開獎</span>
        <div class="td-nums">${actual.map(n => `<span class="num-mini ${simPool.some(s => s.num === n) ? 'hit' : ''}">${n}</span>`).join('')}
        ${cfg.hasSpecial && lastDraw.special != null ? `<span class="num-mini special-num">${lastDraw.special}</span>` : ''}</div>
      </div>
      <div class="whl-review-item">
        <span class="whl-review-label">號碼池命中</span>
        <span class="whl-review-val">${poolHits.length} / ${simPool.length} 個號碼在池中</span>
      </div>
      <div class="whl-review-item">
        <span class="whl-review-label">最佳單注</span>
        <span class="whl-review-val">${bestCombo ? `命中 ${bestHit} 個：${bestCombo.nums.map(n => actual.includes(n) ? `<span class="num-mini hit">${n}</span>` : `<span class="num-mini">${n}</span>`).join('')}` : '—'}</span>
      </div>
      <div class="whl-review-item">
        <span class="whl-review-label">有命中的注數</span>
        <span class="whl-review-val">${anyHit} / ${simCombos.length} 注</span>
      </div>
      ${specialHit ? `<div class="whl-review-item"><span class="whl-review-label">${cfg.specialLabel}</span>${specialHit}</div>` : ''}
    </div>
    <p class="whl-review-note">💡 以上是假設用${isCustomReview ? '你的自選號碼池' : '同樣的演算法'}和預算 $${currentBudget.toLocaleString()} 回測上一期的結果。</p>`;
}

// === WHEEL PROBABILITY SIMULATION (包牌機率模擬) ===

// 539 prize structure: { match: N, prize: $, label }
const PRIZE_539 = [
  { match: 5, prize: 8000000, label: '頭獎（5 中 5）' },
  { match: 4, prize: 20000,   label: '貳獎（5 中 4）' },
  { match: 3, prize: 300,     label: '參獎（5 中 3）' },
  { match: 2, prize: 50,      label: '肆獎（5 中 2）' },
];

// C(n,k) with memoization
const _cMemo = {};
function C(n, k) {
  if (k < 0 || k > n) return 0;
  if (k === 0 || k === n) return 1;
  const key = n + ',' + k;
  if (_cMemo[key]) return _cMemo[key];
  _cMemo[key] = C(n - 1, k - 1) + C(n - 1, k);
  return _cMemo[key];
}

// Exact probability: given poolSize numbers covering the draw space,
// with numBets = C(poolSize, pickCount) bets, what's P(at least one bet hits exactly matchK)?
// For a single bet: P(match exactly k) = C(5,k)*C(34,5-k) / C(39,5) for 539
// For poolSize-covered wheel: P(at least one bet hits k+) uses inclusion-exclusion
// Simpler approach: for a wheel of poolSize numbers, P(exactly m of them are in the draw)
// = C(poolSize, m) * C(39-poolSize, 5-m) / C(39, 5)
// Then, given m numbers hit in pool, how many bets have >= k matches?
function calcWheelProbabilities(poolSize, pickCount, maxNum) {
  const totalC = C(maxNum, pickCount); // C(39,5)
  const results = [];

  // For each prize tier (match 5,4,3,2)
  for (const tier of PRIZE_539) {
    const k = tier.match;
    if (k > pickCount || k > poolSize) {
      results.push({ ...tier, probSingle: 0, probWheel: 0 });
      continue;
    }

    // P(single bet matches exactly k) = C(pickCount,k) * C(maxNum-pickCount, pickCount-k) / C(maxNum, pickCount)
    const pSingle = C(pickCount, k) * C(maxNum - pickCount, pickCount - k) / totalC;

    // For the wheel: P(at least one bet matches >= k numbers)
    // We sum over m = k..min(poolSize, pickCount):
    // P(exactly m pool numbers are drawn) * (1 if m >= k, since at least one C(m,k) bet will have those k)
    // P(exactly m from pool) = C(poolSize, m) * C(maxNum - poolSize, pickCount - m) / C(maxNum, pickCount)
    let probAtLeastK = 0;
    for (let m = k; m <= Math.min(poolSize, pickCount); m++) {
      probAtLeastK += C(poolSize, m) * C(maxNum - poolSize, pickCount - m) / totalC;
    }

    results.push({ ...tier, probSingle: pSingle, probWheel: probAtLeastK });
  }
  return results;
}

// Expected Value calculation
function calcWheelEV(poolSize, numBets, betCost, pickCount, maxNum) {
  const totalC = C(maxNum, pickCount);
  let expectedReturn = 0;

  // For each prize tier, expected count of winning bets
  for (const tier of PRIZE_539) {
    const k = tier.match;
    if (k > pickCount || k > poolSize) continue;

    // Expected winning bets = numBets * P(single bet matches exactly k)
    // But bets share pool numbers, so we need a smarter approach:
    // For each possible "m numbers from pool hit", compute how many bets match >= k
    for (let m = k; m <= Math.min(poolSize, pickCount); m++) {
      const pM = C(poolSize, m) * C(maxNum - poolSize, pickCount - m) / totalC;
      // Given m pool numbers are drawn: bets with exactly k of those m =
      // C(m, k) * C(poolSize - m, pickCount - k) / C(poolSize, pickCount) * numBets
      // But this counts "exactly k from the m winners", we want exactly tier.match matched
      const betsWithExactK = C(m, k) * C(poolSize - m, pickCount - k) / C(poolSize, pickCount) * numBets;
      if (m === k && m === pickCount) {
        // head prize: only bets that are exactly the winning numbers
        expectedReturn += pM * (m === pickCount ? 1 : 0) * tier.prize;
      }
    }
  }

  // Simplified EV: use Monte Carlo for accuracy, exact formula for display
  // Let's use the simpler per-bet EV * numBets
  let evPerBet = 0;
  for (const tier of PRIZE_539) {
    const k = tier.match;
    const pSingle = C(pickCount, k) * C(maxNum - pickCount, pickCount - k) / totalC;
    evPerBet += pSingle * tier.prize;
  }
  const totalEV = evPerBet * numBets;
  const totalCost = numBets * betCost;
  const roi = ((totalEV - totalCost) / totalCost * 100);

  return { evPerBet: Math.round(evPerBet * 100) / 100, totalEV: Math.round(totalEV), totalCost, roi: Math.round(roi * 10) / 10 };
}

// Monte Carlo simulation
function monteCarloSim(poolNums, combosList, maxNum, pickCount, iterations) {
  // Count distribution: how many iterations result in best-bet hitting 0,1,2,3,4,5 numbers
  const dist = new Array(pickCount + 1).fill(0);
  let totalPrize = 0;

  for (let i = 0; i < iterations; i++) {
    // Random draw: pick `pickCount` unique numbers from 1..maxNum
    const draw = [];
    const used = new Set();
    while (draw.length < pickCount) {
      const n = Math.floor(Math.random() * maxNum) + 1;
      if (!used.has(n)) { used.add(n); draw.push(n); }
    }

    // Check all combos, find best match
    let bestMatch = 0;
    let iterPrize = 0;
    for (const combo of combosList) {
      const hits = combo.nums.filter(n => draw.includes(n)).length;
      if (hits > bestMatch) bestMatch = hits;
      // Sum prizes for ALL winning bets this draw
      for (const tier of PRIZE_539) {
        if (hits === tier.match) { iterPrize += tier.prize; break; }
      }
    }
    dist[bestMatch]++;
    totalPrize += iterPrize;
  }

  // Convert to percentages
  const pct = dist.map(d => Math.round(d / iterations * 10000) / 100);
  const avgReturn = Math.round(totalPrize / iterations);
  return { dist, pct, avgReturn, iterations };
}

function renderWheelSim(poolSize, combos, betCost) {
  const el = document.getElementById('wheelSim');
  if (!el) return;
  if (currentLottery !== 'daily_cash_539' || combos.length === 0) {
    el.innerHTML = currentLottery !== 'daily_cash_539'
      ? '<div class="sim-coming-soon"><span class="sim-icon">🔮</span><p>包牌機率模擬目前僅支援 <strong>今彩 539</strong>，威力彩與大樂透版本開發中。</p></div>'
      : '';
    return;
  }

  const maxNum = 39, pickCount = 5;
  const numBets = combos.length;
  const totalCost = numBets * betCost;

  // 1. Exact probabilities
  const probs = calcWheelProbabilities(poolSize, pickCount, maxNum);

  // 2. EV calculation
  const ev = calcWheelEV(poolSize, numBets, betCost, pickCount, maxNum);

  // 3. Monte Carlo (10,000 iterations)
  const mc = monteCarloSim([], combos, maxNum, pickCount, 10000);

  // Build HTML
  let html = `
    <div class="sim-panel">
      <h4>🔮 包牌機率模擬 <span class="sim-badge">539 專屬</span></h4>
      <p class="sim-subtitle">用 ${poolSize} 碼包 ${numBets} 注（$${totalCost.toLocaleString()}），到底有多少機會中獎？</p>

      <!-- Tab buttons -->
      <div class="sim-tabs">
        <button class="sim-tab active" onclick="switchSimTab(this,'simProb')">精算機率</button>
        <button class="sim-tab" onclick="switchSimTab(this,'simEV')">期望值</button>
        <button class="sim-tab" onclick="switchSimTab(this,'simMC')">萬次模擬</button>
      </div>

      <!-- Tab 1: Exact Probability -->
      <div class="sim-content" id="simProb">
        <table class="sim-table">
          <thead>
            <tr>
              <th>獎項</th>
              <th>單注機率</th>
              <th>${numBets} 注至少中一次</th>
              <th>獎金</th>
            </tr>
          </thead>
          <tbody>
            ${probs.map(p => `
              <tr>
                <td class="sim-tier">${p.label}</td>
                <td>${p.probSingle > 0 ? formatProb(p.probSingle) : '—'}</td>
                <td class="sim-highlight">${p.probWheel > 0 ? formatProb(p.probWheel) : '—'}</td>
                <td>$${p.prize.toLocaleString()}</td>
              </tr>`).join('')}
            <tr class="sim-total-row">
              <td class="sim-tier">任一獎項</td>
              <td>—</td>
              <td class="sim-highlight">${formatProb(probs[probs.length - 1].probWheel)}</td>
              <td>—</td>
            </tr>
          </tbody>
        </table>
        <p class="sim-note">※ 「至少中一次」是指 ${numBets} 注中任一注達到該獎項的機率（考慮號碼池覆蓋）</p>
      </div>

      <!-- Tab 2: Expected Value -->
      <div class="sim-content" id="simEV" style="display:none">
        <div class="sim-ev-grid">
          <div class="sim-ev-card">
            <span class="sim-ev-label">投注成本</span>
            <span class="sim-ev-val cost">-$${totalCost.toLocaleString()}</span>
          </div>
          <div class="sim-ev-card">
            <span class="sim-ev-label">單注期望回收</span>
            <span class="sim-ev-val">$${ev.evPerBet.toFixed(1)}</span>
          </div>
          <div class="sim-ev-card">
            <span class="sim-ev-label">${numBets} 注期望回收</span>
            <span class="sim-ev-val">$${ev.totalEV.toLocaleString()}</span>
          </div>
          <div class="sim-ev-card ${ev.roi >= 0 ? 'positive' : 'negative'}">
            <span class="sim-ev-label">期望報酬率</span>
            <span class="sim-ev-val">${ev.roi > 0 ? '+' : ''}${ev.roi}%</span>
          </div>
        </div>
        <div class="sim-ev-bar-wrap">
          <div class="sim-ev-bar-label">
            <span>投入 $${totalCost.toLocaleString()}</span>
            <span>期望回收 $${ev.totalEV.toLocaleString()}</span>
          </div>
          <div class="sim-ev-bar-track">
            <div class="sim-ev-bar-fill" style="width:${Math.min(100, ev.totalEV / totalCost * 100)}%"></div>
          </div>
          <p class="sim-ev-verdict">每花 $100，平均拿回 $${Math.round(ev.totalEV / totalCost * 100)}<br>
          <strong style="color:var(--text-muted);font-weight:400">（期望值為負 = 長期一定虧，這是數學事實，跟運氣無關）</strong></p>
        </div>
      </div>

      <!-- Tab 3: Monte Carlo -->
      <div class="sim-content" id="simMC" style="display:none">
        <p class="sim-mc-title">🎲 模擬 ${mc.iterations.toLocaleString()} 次開獎結果</p>
        <div class="sim-mc-chart">
          ${mc.pct.map((p, i) => {
            const barH = Math.max(2, p / Math.max(...mc.pct) * 100);
            const tierLabel = i === 0 ? '槓龜' : i === 1 ? '中1' : i === 2 ? '肆獎' : i === 3 ? '參獎' : i === 4 ? '貳獎' : '頭獎';
            const tierColor = i === 0 ? '#555' : i <= 1 ? '#666' : i === 2 ? '#f5b800' : i === 3 ? '#ff8800' : i === 4 ? '#39FF14' : '#ec4899';
            return `<div class="sim-mc-col">
              <span class="sim-mc-pct">${p > 0 ? p + '%' : '0%'}</span>
              <div class="sim-mc-bar" style="height:${barH}%;background:${tierColor}"></div>
              <span class="sim-mc-label">${tierLabel}</span>
            </div>`;
          }).join('')}
        </div>
        <div class="sim-mc-summary">
          <div class="sim-mc-stat">
            <span class="sim-mc-stat-label">每次開獎平均回收</span>
            <span class="sim-mc-stat-val">$${mc.avgReturn.toLocaleString()}</span>
          </div>
          <div class="sim-mc-stat">
            <span class="sim-mc-stat-label">每次開獎投入</span>
            <span class="sim-mc-stat-val cost">$${totalCost.toLocaleString()}</span>
          </div>
          <div class="sim-mc-stat">
            <span class="sim-mc-stat-label">模擬淨損益</span>
            <span class="sim-mc-stat-val ${mc.avgReturn >= totalCost ? 'positive' : 'negative'}">
              ${mc.avgReturn >= totalCost ? '+' : '-'}$${Math.abs(mc.avgReturn - totalCost).toLocaleString()}
            </span>
          </div>
        </div>
        <button class="sim-rerun" onclick="rerunMonteCarlo()">🔄 重跑一次模擬</button>
        <p class="sim-note">※ 每次模擬結果略有不同（隨機性），但趨勢一致：長期期望值為負</p>
      </div>
    </div>`;

  el.innerHTML = html;
}

function formatProb(p) {
  if (p >= 0.01) return (p * 100).toFixed(2) + '%';
  if (p >= 0.0001) return '1/' + Math.round(1 / p).toLocaleString();
  if (p > 0) return '1/' + Math.round(1 / p).toLocaleString();
  return '0';
}

function switchSimTab(btn, tabId) {
  btn.parentElement.querySelectorAll('.sim-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  btn.closest('.sim-panel').querySelectorAll('.sim-content').forEach(c => c.style.display = 'none');
  document.getElementById(tabId).style.display = '';
}

function rerunMonteCarlo() {
  const cfg = LOTTERY_CONFIG[currentLottery];
  const data = lotteryData[currentLottery];
  if (!data || currentLottery !== 'daily_cash_539') return;
  const draws = getDraws();
  const allDraws = data.draws;
  const { pool, combos, poolSize } = generateWheel(draws, allDraws, cfg);
  const betCost = BET_COST[currentLottery];
  renderWheelSim(poolSize, combos, betCost);
  // Auto-switch to MC tab
  const mcBtn = document.querySelector('.sim-tab:last-child');
  if (mcBtn) switchSimTab(mcBtn, 'simMC');
}

// === COLLAPSIBLE SECTIONS ===
function toggleSection(headEl) {
  const section = headEl.closest('.collapsible');
  if (!section) return;
  const body = section.querySelector('.section-body');
  const chevron = section.querySelector('.section-chevron');
  if (!body) return;
  const isCollapsed = body.style.display === 'none';
  body.style.display = isCollapsed ? '' : 'none';
  section.classList.toggle('collapsed', !isCollapsed);
  if (chevron) chevron.textContent = isCollapsed ? '▾' : '▸';
}

// === COUNTDOWN TIMER ===
let countdownInterval = null;
function updateCountdown() {
  const cfg = LOTTERY_CONFIG[currentLottery];
  document.getElementById('countdownLottery').textContent = cfg.label;
  if (countdownInterval) clearInterval(countdownInterval);
  countdownInterval = setInterval(tickCountdown, 1000);
  tickCountdown();
}

function getNextDrawTime() {
  const now = new Date();
  const drawHour = 20, drawMin = 30;
  // 539: daily, 威力彩: Mon(1)/Thu(4), 大樂透: Tue(2)/Fri(5)
  let drawDays;
  if (currentLottery === 'daily_cash_539') {
    drawDays = [0,1,2,3,4,5,6]; // every day
  } else if (currentLottery === 'super_lotto') {
    drawDays = [1, 4]; // Mon, Thu
  } else {
    drawDays = [2, 5]; // Tue, Fri
  }

  let target = new Date(now);
  target.setHours(drawHour, drawMin, 0, 0);

  // If today is a draw day and we haven't passed draw time, use today
  if (drawDays.includes(target.getDay()) && target > now) {
    return target;
  }

  // Otherwise find the next draw day
  for (let i = 1; i <= 7; i++) {
    let next = new Date(now);
    next.setDate(now.getDate() + i);
    next.setHours(drawHour, drawMin, 0, 0);
    if (drawDays.includes(next.getDay())) {
      return next;
    }
  }
  return target;
}

function tickCountdown() {
  const next = getNextDrawTime();
  const now = new Date();
  const diff = next - now;
  if (diff <= 0) {
    document.getElementById('countdownTimer').textContent = '開獎中！';
    return;
  }
  const h = Math.floor(diff / 3600000);
  const m = Math.floor((diff % 3600000) / 60000);
  const s = Math.floor((diff % 60000) / 1000);
  document.getElementById('countdownTimer').textContent =
    `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
}

// === PICKER (自選號碼) ===
let pickerSelected = [];

function renderPicker() {
  const cfg = LOTTERY_CONFIG[currentLottery];
  pickerSelected = [];
  document.getElementById('pickerMax').textContent = cfg.count;
  document.getElementById('pickerCount').textContent = '0';
  document.getElementById('pickerBalls').innerHTML = '';
  document.getElementById('pickerResult').innerHTML = '';
  document.getElementById('pickerCheckBtn').disabled = true;

  let html = '';
  for (let i = 1; i <= cfg.maxNum; i++) {
    html += `<button class="pk-num" data-num="${i}" onclick="togglePickerNum(${i})">${i}</button>`;
  }
  document.getElementById('pickerGrid').innerHTML = html;
}

function togglePickerNum(num) {
  const cfg = LOTTERY_CONFIG[currentLottery];
  const idx = pickerSelected.indexOf(num);
  if (idx > -1) {
    pickerSelected.splice(idx, 1);
  } else {
    if (pickerSelected.length >= cfg.count) return; // max reached
    pickerSelected.push(num);
  }
  pickerSelected.sort((a, b) => a - b);

  // Update grid highlights
  document.querySelectorAll('#pickerGrid .pk-num').forEach(btn => {
    btn.classList.toggle('selected', pickerSelected.includes(parseInt(btn.dataset.num)));
  });

  // Update selected balls display
  document.getElementById('pickerCount').textContent = pickerSelected.length;
  document.getElementById('pickerBalls').innerHTML = pickerSelected.map(n =>
    `<span class="num-mini pk-ball">${n}</span>`
  ).join('');

  // Enable/disable check button
  document.getElementById('pickerCheckBtn').disabled = pickerSelected.length < cfg.count;
}

function clearPicker() {
  pickerSelected = [];
  renderPicker();
}

function checkMyNumbers() {
  const cfg = LOTTERY_CONFIG[currentLottery];
  const data = lotteryData[currentLottery];
  if (!data || pickerSelected.length < cfg.count) return;

  const allDraws = data.draws;
  let hits = [];

  allDraws.forEach(draw => {
    const matched = pickerSelected.filter(n => draw.numbers.includes(n));
    if (matched.length >= 2) {
      hits.push({ date: draw.date, period: draw.period, numbers: draw.numbers, matched, count: matched.length });
    }
  });

  hits.sort((a, b) => b.count - a.count || b.date.localeCompare(a.date));

  let html = `<div class="picker-result-box">`;
  html += `<h4>歷史命中結果（共 ${allDraws.length} 期）</h4>`;

  if (hits.length === 0) {
    html += `<p class="picker-no-hit">這組號碼在歷史開獎中命中不到 2 個號碼 😅 換一組試試？</p>`;
  } else {
    const maxShow = 10;
    const display = hits.slice(0, maxShow);
    html += `<p class="picker-hit-summary">命中 2+ 個號碼的期數：<strong>${hits.length}</strong> 期</p>`;
    html += `<div class="picker-hit-list">`;
    display.forEach(h => {
      html += `<div class="picker-hit-row">
        <span class="picker-hit-date">${h.date}</span>
        <span class="picker-hit-nums">${h.numbers.map(n =>
          `<span class="num-mini ${h.matched.includes(n) ? 'hit' : ''}">${n}</span>`
        ).join('')}</span>
        <span class="picker-hit-count">中 ${h.count} 個</span>
      </div>`;
    });
    html += `</div>`;
    if (hits.length > maxShow) {
      html += `<p class="picker-more">… 還有 ${hits.length - maxShow} 期有命中</p>`;
    }
  }
  html += `</div>`;
  // Contextual CTA — 號碼選好了，平台選對了嗎？
  html += `<div class="picker-cta" style="margin-top:1.2rem;padding:1rem 1.2rem;background:linear-gradient(135deg,rgba(245,184,0,0.06),rgba(245,184,0,0.02));border:2px solid rgba(245,184,0,0.25);border-radius:12px;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap">
    <div>
      <strong style="color:#f5b800">🛡️ 號碼選好了，平台選對了嗎？</strong>
      <p style="margin:0.3rem 0 0;font-size:0.85rem;color:var(--text-muted)">入金前先查一下——有沒有被 165 通報？網域才幾個月？</p>
    </div>
    <a href="/casino-check/" style="text-decoration:none">
      <div style="background:linear-gradient(135deg,#f5b800,#e09900);color:#000;font-weight:900;padding:0.6rem 1rem;border-radius:10px;white-space:nowrap;font-size:0.88rem">一鍵體檢 →</div>
    </a>
  </div>`;
  document.getElementById('pickerResult').innerHTML = html;
}

// GO
init();
</script>

