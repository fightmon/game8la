.lot-tab.active {
  background: linear-gradient(135deg, rgba(57,255,20,0.15), rgba(255,215,0,0.1));
  border-color: var(--gold); color: var(--gold-light);
  box-shadow: 0 4px 15px rgba(57,255,20,0.15);
}

/* Range selector */
.range-selector {
  display: flex; align-items: center; justify-content: center;
  gap: 0.5rem; margin-bottom: 2rem; flex-wrap: wrap;
}
.range-label { color: var(--text-muted); font-size: 0.9rem; }
.range-btn {
  padding: 0.4rem 1rem; border-radius: 8px;
  background: var(--bg-card); border: 1px solid var(--border);
  color: var(--text-secondary); font-size: 0.85rem;
  cursor: pointer; transition: all 0.2s;
}
.range-btn:hover { border-color: var(--gold); }
.range-btn.active {
  background: var(--gold); color: #000; font-weight: 700;
  border-color: var(--gold);
}

/* Section */
.analysis-section {
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: 16px; padding: 1.8rem; margin-bottom: 1.5rem;
}
.section-head { margin-bottom: 1.2rem; }
.section-head h2 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.3rem; }
.section-head p { color: var(--text-muted); font-size: 0.9rem; }

/* Collapsible */
.collapsible > .section-head {
  cursor: pointer; user-select: none; transition: opacity 0.2s;
}
.collapsible > .section-head:hover { opacity: 0.8; }
.collapsible.collapsed > .section-head { margin-bottom: 0; }
.section-chevron {
  font-size: 0.85rem; color: var(--text-muted); margin-left: 0.3rem;
  display: inline-block; transition: transform 0.2s;
}
.section-body { transition: all 0.2s; }

/* Hot/Cold grid */
.hot-cold-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
.hc-card { padding: 1.2rem; border-radius: 12px; }
.hc-card.hot { background: rgba(255, 68, 68, 0.06); border: 1px solid rgba(255, 68, 68, 0.2); }
.hc-card.cold { background: rgba(68, 170, 255, 0.06); border: 1px solid rgba(68, 170, 255, 0.2); }
.hc-card h3 { font-size: 1rem; margin-bottom: 0.8rem; color: var(--text-primary); }
.hc-row {
  display: flex; align-items: center; gap: 0.5rem;
  padding: 0.35rem 0; font-size: 0.85rem;
}
.hc-rank { width: 20px; color: var(--text-muted); font-weight: 700; text-align: center; }
.num-ball {
  width: 32px; height: 32px; border-radius: 50%;
  background: linear-gradient(135deg, #39FF14, #2bcc10);
  color: #000; font-weight: 900; font-size: 0.85rem;
  display: inline-flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.num-ball.special-ball {
  background: linear-gradient(135deg, #FF10F0, #c80dc0);
}
.hc-bar-wrap { flex: 1; height: 8px; background: rgba(255,255,255,0.05); border-radius: 4px; overflow: hidden; }
.hc-bar { height: 100%; border-radius: 4px; transition: width 0.5s; }
.hc-bar.hot { background: linear-gradient(90deg, #ff4444, #ff8800); }
.hc-bar.cold { background: linear-gradient(90deg, #44aaff, #4488ff); }
.hc-bar.special { background: linear-gradient(90deg, #FF10F0, #c80dc0); }
.hc-count { color: var(--text-secondary); min-width: 40px; text-align: right; }
.hc-pct { color: var(--text-muted); min-width: 40px; text-align: right; }

/* Special stats */
.special-stats {
  margin-top: 1.2rem; padding: 1.2rem; border-radius: 12px;
  background: rgba(255, 16, 240, 0.06); border: 1px solid rgba(255, 16, 240, 0.2);
}
.special-stats h3 { font-size: 1rem; margin-bottom: 0.8rem; color: var(--text-primary); }

/* Frequency chart */
.chart-container { position: relative; overflow-x: auto; padding-bottom: 0.5rem; }
.freq-chart {
  display: flex; align-items: stretch; gap: 2px;
  height: 220px; position: relative; min-width: fit-content;
  padding: 0 0.5rem;
}
.freq-col {
  display: flex; flex-direction: column; align-items: center;
  justify-content: flex-end;
  flex: 1; min-width: 22px; position: relative;
}
.freq-value { font-size: 0.65rem; color: var(--text-muted); margin-bottom: 2px; }
.freq-col .bar {
  width: 100%; min-width: 16px; max-width: 28px; border-radius: 3px 3px 0 0;
  background: rgba(57, 255, 20, 0.4); transition: height 0.5s;
}
.freq-col .bar.hot { background: linear-gradient(to top, #ff4444, #ff8800); }
.freq-col .bar.cold { background: linear-gradient(to top, #44aaff, #2266cc); }
.freq-num { font-size: 0.7rem; color: var(--text-muted); margin-top: 4px; }
.avg-line {
  position: absolute; left: 0; right: 0;
  border-top: 2px dashed rgba(255, 215, 0, 0.5);
  pointer-events: none;
}
.avg-line span {
  position: absolute; right: 0; top: -16px;
  font-size: 0.7rem; color: var(--gold-light);
  background: var(--bg-card); padding: 0 4px;
}

/* Missing grid */
.missing-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(65px, 1fr));
  gap: 0.5rem;
}
.miss-item {
  display: flex; flex-direction: column; align-items: center;
  padding: 0.6rem 0.3rem; border-radius: 10px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  transition: all 0.2s;
}
.miss-item.just { border-color: #39FF14; background: rgba(57,255,20,0.08); }
.miss-item.low { border-color: rgba(57,255,20,0.3); }
.miss-item.mid { }
.miss-item.high { border-color: rgba(255,136,0,0.4); background: rgba(255,136,0,0.06); }
.miss-item.extreme { border-color: rgba(255,68,68,0.5); background: rgba(255,68,68,0.08); }
.miss-num { font-weight: 900; font-size: 1.1rem; color: var(--text-primary); }
.miss-val { font-size: 1.3rem; font-weight: 900; color: var(--gold-light); }
.miss-label { font-size: 0.7rem; color: var(--text-muted); }
.miss-item.just .miss-val { color: #39FF14; }
.miss-item.extreme .miss-val { color: #ff4444; }

/* Combo list */
.combo-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0.5rem; }
.combo-row {
  display: flex; align-items: center; gap: 0.5rem;
  padding: 0.6rem 0.8rem; border-radius: 10px;
  background: var(--bg-secondary); border: 1px solid var(--border);
}
.combo-rank { color: var(--gold-light); font-weight: 800; font-size: 0.85rem; min-width: 28px; }
.combo-plus { color: var(--text-muted); font-weight: 600; }
.combo-count { color: var(--text-secondary); font-size: 0.85rem; margin-left: auto; }

/* Recent draws */
.recent-draws { display: flex; flex-direction: column; gap: 0.5rem; }
.recent-row {
  display: flex; align-items: center; gap: 1rem;
  padding: 0.8rem 1rem; border-radius: 10px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  flex-wrap: wrap;
}
.recent-meta { display: flex; flex-direction: column; min-width: 120px; }
.recent-period { font-weight: 700; font-size: 0.9rem; color: var(--text-primary); }
.recent-date { font-size: 0.8rem; color: var(--text-muted); }
.recent-nums { display: flex; gap: 0.3rem; flex-wrap: wrap; }

/* Disclaimer */
/* Guava notes (inline disclaimers) */
.guava-note {
  display: flex; align-items: flex-start; gap: 0.8rem;
  margin-top: 1.2rem; padding: 1rem 1.2rem;
  background: rgba(57, 255, 20, 0.05);
  border: 1px dashed rgba(57, 255, 20, 0.25);
  border-radius: 10px; font-size: 0.85rem; color: var(--text-secondary);
  line-height: 1.6;
}
.guava-note .gn-icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 0.1rem; }
.guava-note p { margin: 0; }

/* Repeat analysis */
.repeat-summary-inner {
  display: flex; gap: 1rem; justify-content: center; margin-bottom: 1.5rem; flex-wrap: wrap;
}
.rs-item {
  display: flex; flex-direction: column; align-items: center;
  padding: 1rem 1.5rem; border-radius: 12px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  min-width: 140px;
}
.rs-val { font-size: 1.8rem; font-weight: 900; color: var(--gold-light); }
.rs-val.match { color: #39FF14; }
.rs-val.diff { color: #ffb347; }
.rs-label { font-size: 0.8rem; color: var(--text-muted); margin-top: 0.3rem; }

.repeat-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
.repeat-col h4 { font-size: 0.95rem; color: var(--text-primary); margin-bottom: 0.8rem; }
.repeat-row {
  display: flex; align-items: center; gap: 0.5rem;
  padding: 0.35rem 0; font-size: 0.85rem;
}
.repeat-bar-wrap {
  flex: 1; height: 8px; background: rgba(255,255,255,0.05);
  border-radius: 4px; overflow: visible; position: relative;
}
.repeat-bar {
  height: 100%; border-radius: 4px;
  background: linear-gradient(90deg, #39FF14, #FFD700);
  transition: width 0.5s;
}
.repeat-bar.low {
  background: linear-gradient(90deg, #44aaff, #4488ff);
}
.repeat-theory {
  position: absolute; top: -4px; width: 2px; height: 16px;
  background: #ff4444; border-radius: 1px;
}
.repeat-rate { color: var(--gold-light); font-weight: 700; min-width: 45px; text-align: right; }
.repeat-detail { color: var(--text-muted); font-size: 0.75rem; min-width: 35px; text-align: right; }

/* Backtest */
.backtest-toggle {
  display: flex; gap: 0.5rem; margin-bottom: 1.2rem;
}
.bt-btn {
  padding: 0.5rem 1.2rem; border-radius: 8px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  color: var(--text-secondary); font-size: 0.9rem; font-weight: 600;
  cursor: pointer; transition: all 0.2s;
}
.bt-btn:hover { border-color: var(--gold); }
.bt-btn.active {
  background: var(--gold); color: #000; border-color: var(--gold);
}
.bt-summary {
  display: flex; gap: 0.8rem; justify-content: center; margin-bottom: 1rem; flex-wrap: wrap;
}
.bt-stat {
  display: flex; flex-direction: column; align-items: center;
  padding: 0.8rem 1.2rem; border-radius: 12px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  min-width: 120px;
}
.bt-val { font-size: 1.5rem; font-weight: 900; color: var(--gold-light); }
.bt-val.win { color: #39FF14; }
.bt-val.lose { color: #ff4444; }
.bt-label { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.2rem; text-align: center; }
.bt-verdict {
  text-align: center; font-size: 0.9rem; color: var(--text-secondary);
  margin: 0.8rem 0 1.2rem; line-height: 1.6;
}

.backtest-table-wrap { overflow-x: auto; }
.backtest-table {
  width: 100%; border-collapse: collapse; font-size: 0.85rem;
}
.backtest-table th {
  text-align: left; padding: 0.6rem 0.5rem;
  border-bottom: 2px solid var(--border); color: var(--text-muted);
  font-size: 0.8rem; white-space: nowrap;
}
.backtest-table td {
  padding: 0.5rem; border-bottom: 1px solid var(--border);
  color: var(--text-secondary); white-space: nowrap;
}
.backtest-table tr.highlight { background: rgba(57, 255, 20, 0.06); }
.td-nums { display: flex; gap: 3px; flex-wrap: wrap; }
.num-mini {
  width: 26px; height: 26px; border-radius: 50%;
  background: var(--bg-secondary); border: 1px solid var(--border);
  color: var(--text-muted); font-weight: 700; font-size: 0.75rem;
  display: inline-flex; align-items: center; justify-content: center;
}
.num-mini.hit {
  background: linear-gradient(135deg, #39FF14, #2bcc10);
  color: #000; border-color: #39FF14;
  box-shadow: 0 0 6px rgba(57, 255, 20, 0.4);
}
.hit-badge {
  display: inline-flex; align-items: center; justify-content: center;
  width: 26px; height: 26px; border-radius: 50%;
  font-weight: 900; font-size: 0.85rem;
  background: var(--bg-secondary); color: var(--text-muted); border: 1px solid var(--border);
}
.hit-badge.h0 { opacity: 0.4; }
.hit-badge.h1 { color: var(--gold-light); border-color: var(--gold); }
.hit-badge.h2 { color: #39FF14; border-color: #39FF14; background: rgba(57,255,20,0.1); }
.hit-badge.h3, .hit-badge.h4, .hit-badge.h5, .hit-badge.h6 {
  background: linear-gradient(135deg, #39FF14, #FFD700);
  color: #000; border-color: #39FF14;
  box-shadow: 0 0 10px rgba(57,255,20,0.4);
}

/* Cross-sell */
.cross-sell {
  margin: 2rem 0; padding: 1.8rem;
  background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px;
}
.cross-sell h3 { font-size: 1.2rem; margin-bottom: 1.2rem; color: var(--text-primary); }
.cross-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem; }
.cross-card {
  display: flex; align-items: center; gap: 1rem;
  padding: 1rem 1.2rem; border-radius: 12px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  text-decoration: none; color: var(--text-primary);
  transition: all 0.25s;
}
.cross-card:hover {
  border-color: var(--gold); transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(57,255,20,0.1);
}
.cross-icon { font-size: 2rem; flex-shrink: 0; }
.cross-card div { flex: 1; }
.cross-card strong { display: block; font-size: 0.95rem; color: var(--gold-light); margin-bottom: 0.2rem; }
.cross-card p { font-size: 0.8rem; color: var(--text-muted); margin: 0; line-height: 1.4; }
.cross-arrow { color: var(--gold-light); font-size: 1.2rem; font-weight: 800; flex-shrink: 0; }

/* Disclaimer */
.analysis-disclaimer {
  padding: 1.2rem; margin: 2rem 0;
  background: rgba(255, 136, 0, 0.08); border: 1px solid rgba(255, 136, 0, 0.3);
  border-radius: 12px; font-size: 0.85rem; color: var(--text-secondary);
}
.analysis-disclaimer strong { color: #ffb347; }
.analysis-disclaimer a { color: #ffd966; text-decoration: underline; }

/* === Countdown Timer === */
.countdown-bar {
  display: flex; align-items: center; justify-content: center; gap: 0.8rem;
  margin-top: 0.8rem; padding: 0.6rem 1.2rem;
  background: linear-gradient(135deg, rgba(255,215,0,0.1), rgba(57,255,20,0.08));
  border: 1px solid rgba(255,215,0,0.25); border-radius: 10px;
}
.countdown-label { font-size: 0.9rem; color: var(--text-secondary); }
.countdown-timer {
  font-size: 1.5rem; font-weight: 900; letter-spacing: 0.08em;
  background: linear-gradient(135deg, #FFD700, #39FF14); -webkit-background-clip: text;
  background-clip: text; color: transparent;
  font-variant-numeric: tabular-nums;
}

/* === Picker (心水號碼) === */
.picker-section {
  background: linear-gradient(135deg, rgba(255,105,180,0.06), rgba(255,215,0,0.04));
  border-color: rgba(255,105,180,0.3);
}
.picker-grid {
  display: flex; flex-wrap: wrap; gap: 0.4rem; justify-content: center; margin-bottom: 1rem;
}
.pk-num {
  width: 44px; height: 44px; border-radius: 50%;
  background: var(--bg-secondary); border: 2px solid var(--border);
  color: var(--text-secondary); font-size: 1rem; font-weight: 700;
  cursor: pointer; transition: all 0.2s; display: flex;
  align-items: center; justify-content: center;
}
.pk-num:hover { border-color: #ff69b4; color: #ff69b4; }
.pk-num.selected {
  background: linear-gradient(135deg, #ff69b4, #ff1493); color: #fff;
  border-color: #ff69b4; box-shadow: 0 3px 12px rgba(255,105,180,0.4);
  transform: scale(1.08);
}
.picker-selected {
  display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap;
  padding: 0.8rem; background: var(--bg-secondary); border-radius: 10px; margin-bottom: 1rem;
}
.picker-label { font-size: 0.9rem; color: var(--text-muted); white-space: nowrap; }
.picker-balls { display: flex; gap: 0.4rem; flex-wrap: wrap; flex: 1; }
.pk-ball {
  background: linear-gradient(135deg, #ff69b4, #ff1493) !important;
  color: #fff !important; font-weight: 700;
}
.picker-clear, .picker-check {
  padding: 0.5rem 1rem; border-radius: 8px; font-size: 0.85rem; font-weight: 600;
  cursor: pointer; transition: all 0.2s; border: none;
}
.picker-clear { background: var(--bg-card); color: var(--text-secondary); border: 1px solid var(--border); }
.picker-clear:hover { border-color: var(--text-muted); }
.picker-check {
  background: linear-gradient(135deg, #ff69b4, #ff1493); color: #fff;
}
.picker-check:disabled { opacity: 0.4; cursor: not-allowed; }
.picker-check:not(:disabled):hover { box-shadow: 0 4px 15px rgba(255,105,180,0.4); }
.picker-result-box {
  padding: 1rem; background: var(--bg-secondary); border-radius: 10px;
  border: 1px solid rgba(255,105,180,0.2);
}
.picker-result-box h4 { font-size: 1rem; margin-bottom: 0.8rem; color: var(--text-primary); }
.picker-no-hit { color: var(--text-muted); font-size: 0.9rem; }
.picker-hit-summary { font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.8rem; }
.picker-hit-summary strong { color: #ff69b4; }
.picker-hit-list { display: flex; flex-direction: column; gap: 0.5rem; }
.picker-hit-row {
  display: flex; align-items: center; gap: 0.6rem; padding: 0.5rem 0.6rem;
  background: var(--bg-card); border-radius: 8px;
}
.picker-hit-date { font-size: 0.82rem; color: var(--text-muted); min-width: 90px; }
.picker-hit-nums { display: flex; gap: 0.25rem; flex-wrap: wrap; flex: 1; }
.picker-hit-nums .num-mini.hit {
  background: linear-gradient(135deg, #ff69b4, #ff1493) !important;
  color: #fff !important; font-weight: 700;
}
.picker-hit-count { font-size: 0.85rem; font-weight: 700; color: #ff69b4; white-space: nowrap; }
.picker-more { font-size: 0.82rem; color: var(--text-muted); margin-top: 0.5rem; }

/* === Safety CTA === */
.safety-cta {
  margin: 2rem 0; padding: 1.2rem 1.5rem;
  background: linear-gradient(135deg, rgba(57,255,20,0.08), rgba(255,215,0,0.06));
  border: 2px solid rgba(57,255,20,0.3); border-radius: 14px;
}
.safety-cta-inner {
  display: flex; align-items: center; gap: 1rem;
}
.safety-cta-icon { font-size: 2rem; flex-shrink: 0; }
.safety-cta-text { flex: 1; }
.safety-cta-text strong { font-size: 1rem; color: var(--text-primary); display: block; margin-bottom: 0.3rem; }
.safety-cta-text p { font-size: 0.85rem; color: var(--text-muted); margin: 0; }
.safety-cta-btn {
  display: inline-block; padding: 0.7rem 1.5rem; border-radius: 10px;
  background: linear-gradient(135deg, #39FF14, #00e676); color: #000;
  font-weight: 800; font-size: 0.95rem; text-decoration: none;
  transition: all 0.25s; white-space: nowrap; flex-shrink: 0;
}
.safety-cta-btn:hover { box-shadow: 0 4px 20px rgba(57,255,20,0.4); transform: translateY(-1px); }

/* === FAQ === */
.faq-list { display: flex; flex-direction: column; gap: 0.5rem; }
.faq-item {
  background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 10px;
  overflow: hidden;
}
.faq-item summary {
  padding: 1rem 1.2rem; font-size: 1rem; font-weight: 700; color: var(--text-primary);
  cursor: pointer; list-style: none; display: flex; align-items: center; gap: 0.5rem;
}
.faq-item summary::-webkit-details-marker { display: none; }
.faq-item summary::before { content: '▸'; color: var(--gold); transition: transform 0.2s; }
.faq-item[open] summary::before { transform: rotate(90deg); }
.faq-item p {
  padding: 0 1.2rem 1rem; font-size: 0.9rem; color: var(--text-secondary);
  line-height: 1.7; margin: 0;
}

/* Hero sub */
.hero-sub { color: var(--text-muted); font-size: 1rem; font-weight: 500; }

/* Suggestion section */
.suggestion-section {
  background: linear-gradient(135deg, rgba(255,215,0,0.06), rgba(57,255,20,0.04));
  border-color: rgba(255,215,0,0.3);
}
.suggest-tabs {
  display: flex; gap: 0.5rem; margin-bottom: 1.5rem;
}
.sg-tab {
  padding: 0.5rem 1.2rem; border-radius: 8px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  color: var(--text-secondary); font-size: 0.9rem; font-weight: 600;
  cursor: pointer; transition: all 0.2s;
}
.sg-tab:hover { border-color: var(--gold); }
.sg-tab.active {
  background: linear-gradient(135deg, #FFD700, #ff8800); color: #000;
  border-color: #FFD700; font-weight: 700;
}
.suggest-balls {
  display: flex; gap: 1rem; justify-content: center;
  flex-wrap: wrap; margin-bottom: 1.5rem;
}
.suggest-ball-wrap {
  display: flex; flex-direction: column; align-items: center; gap: 0.3rem;
}
.suggest-ball {
  width: 52px; height: 52px; border-radius: 50%;
  background: linear-gradient(135deg, #FFD700, #ff8800);
  color: #000; font-weight: 900; font-size: 1.3rem;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 15px rgba(255,215,0,0.4);
  animation: ballPulse 2s ease-in-out infinite;
}
@keyframes ballPulse {
  0%, 100% { box-shadow: 0 4px 15px rgba(255,215,0,0.4); }
  50% { box-shadow: 0 4px 25px rgba(255,215,0,0.7); }
}
.suggest-score {
  font-size: 0.75rem; font-weight: 700; color: var(--gold-light);
}
.suggest-tags {
  display: flex; gap: 0.2rem;
}
.sg-tag {
  font-size: 0.6rem; padding: 0.1rem 0.35rem; border-radius: 4px;
