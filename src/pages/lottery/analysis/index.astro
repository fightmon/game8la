<script is:inline>
// === CONFIG ===
const WORKER_URL = 'https://lottery-cron.fightmon.workers.dev';
const LOTTERY_CONFIG = {
  daily_cash_539: { file: '/data/daily-cash-539.json', label: '今彩 539', maxNum: 39, count: 5, hasSpecial: false, specialLabel: '' },
  super_lotto:    { file: '/data/super-lotto.json',    label: '威力彩',   maxNum: 38, count: 6, hasSpecial: true,  specialLabel: '第二區', specialMax: 8 },
  lotto649:       { file: '/data/lotto649.json',       label: '大樂透',   maxNum: 49, count: 6, hasSpecial: true,  specialLabel: '特別號', specialMax: 49 },
};

let currentLottery = 'daily_cash_539';
let currentRange = 50;
let lotteryData = {};
let dataSource = 'static'; // 'worker' or 'static'

// === INIT ===
async function init() {
  showSkeleton();
  await loadData(currentLottery);
  hideSkeleton();
  render();
}

function showSkeleton() {
  const containers = ['freqChart', 'missingGrid', 'hotNumbers', 'coldNumbers'];
  containers.forEach(id => {
    const el = document.getElementById(id);
    if (el) el.innerHTML = '<div class="skeleton-loader"></div>';
  });
}

function hideSkeleton() {
  document.querySelectorAll('.skeleton-loader').forEach(el => el.remove());
}

async function loadData(key) {
  if (lotteryData[key]) return;
  const fileName = LOTTERY_CONFIG[key].file.replace('/data/', '');
  let workerData = null;
  let staticData = null;

  // 先嘗試從 Worker KV 讀取即時資料
  try {
    const res = await fetch(`${WORKER_URL}/data/${fileName}`);
    if (res.ok) {
      workerData = await res.json();
      console.log(`[${key}] Worker KV 回應成功，lastUpdated: ${workerData.lastUpdated}`);
    }
  } catch (e) {
    console.warn(`[${key}] Worker 連線失敗:`, e.message);
  }

  // 也讀取靜態 JSON
  try {
    const res = await fetch(LOTTERY_CONFIG[key].file);
    if (res.ok) {
      staticData = await res.json();
      console.log(`[${key}] 靜態 JSON lastUpdated: ${staticData.lastUpdated}`);
    }
  } catch (e) {
    console.warn(`[${key}] 靜態 JSON 讀取失敗:`, e.message);
  }

  // 比較兩邊資料，取較新的
  if (workerData && staticData) {
    if (workerData.lastUpdated >= staticData.lastUpdated) {
      lotteryData[key] = workerData;
      dataSource = 'worker';
      console.log(`[${key}] 使用 Worker KV（較新或相同）`);
    } else {
      lotteryData[key] = staticData;
      dataSource = 'static';
      console.log(`[${key}] 使用靜態 JSON（比 Worker 新）`);
    }
  } else if (workerData) {
    lotteryData[key] = workerData;
    dataSource = 'worker';
  } else if (staticData) {
    lotteryData[key] = staticData;
    dataSource = 'static';
  } else {
    console.error(`[${key}] 兩個來源都讀取失敗`);
  }
}

function switchLottery(btn) {
  document.querySelectorAll('.lot-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  currentLottery = btn.dataset.lottery;
  // Reset custom pool when switching lottery type
  customPoolNums = [];
  if (wheelSource === 'custom') renderCustomPoolGrid();
  loadData(currentLottery).then(() => render());
}

function setRange(btn) {
  document.querySelectorAll('.range-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  currentRange = parseInt(btn.dataset.range);
  render();
}

// === CORE ANALYSIS ===
function getDraws() {
  const data = lotteryData[currentLottery];
  if (!data) return [];
  const draws = data.draws;
  return currentRange === 0 ? draws : draws.slice(0, currentRange);
}

function calcFrequency(draws, maxNum) {
  const freq = {};
  for (let i = 1; i <= maxNum; i++) freq[i] = 0;
  draws.forEach(d => d.numbers.forEach(n => freq[n]++));
  return freq;
}

function calcSpecialFrequency(draws, maxNum) {
  const freq = {};
  for (let i = 1; i <= maxNum; i++) freq[i] = 0;
  draws.forEach(d => { if (d.special) freq[d.special]++; });
  return freq;
}

function calcMissing(allDraws, maxNum) {
  // Calculate from ALL draws (not range-limited) for accuracy
  const missing = {};
  for (let i = 1; i <= maxNum; i++) {
    missing[i] = 0;
    for (let j = 0; j < allDraws.length; j++) {
      if (allDraws[j].numbers.includes(i)) break;
      missing[i]++;
    }
  }
  return missing;
}

function calcRepeat(allDraws, maxNum) {
  // For each number: how many times it appeared in draw[i] AND draw[i+1] consecutively
  const stats = {};
  for (let n = 1; n <= maxNum; n++) {
    stats[n] = { appeared: 0, repeated: 0 };
  }
  for (let i = 0; i < allDraws.length - 1; i++) {
    const curr = allDraws[i].numbers;
    const next = allDraws[i + 1].numbers;
    curr.forEach(n => {
      stats[n].appeared++;
      if (next.includes(n)) stats[n].repeated++;
    });
  }
  return stats;
}

function calcCombos(draws) {
  const combos = {};
  draws.forEach(d => {
    const nums = d.numbers;
    for (let i = 0; i < nums.length; i++) {
      for (let j = i + 1; j < nums.length; j++) {
        const key = `${nums[i]}-${nums[j]}`;
        combos[key] = (combos[key] || 0) + 1;
      }
    }
  });
  return Object.entries(combos)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 15);
}

// === RENDER ===
function render() {
  const cfg = LOTTERY_CONFIG[currentLottery];
  const data = lotteryData[currentLottery];
  if (!data) return;

  const draws = getDraws();
  const allDraws = data.draws;
  const freq = calcFrequency(draws, cfg.maxNum);
  const missing = calcMissing(allDraws, cfg.maxNum);
  const combos = calcCombos(draws);

  // Update meta
  const srcTag = dataSource === 'worker' ? ' (即時)' : ' (靜態)';
  document.getElementById('updateTime').textContent = data.lastUpdated + srcTag;
  document.getElementById('totalDraws').textContent = draws.length;

  // Suggestions & Wheel (first sections)
  renderSuggestions();
  renderWheel();

  // Theory note
  const theory = (1 / cfg.maxNum * 100).toFixed(2);
  document.getElementById('theoryNote').textContent = `1/${cfg.maxNum} ≈ ${theory}%`;

  // Repeat analysis (use filtered draws, not allDraws)
  const repeatStats = calcRepeat(draws, cfg.maxNum);
  renderRepeat(repeatStats, cfg.maxNum);

  // Hot/Cold
  const sorted = Object.entries(freq).sort((a, b) => b[1] - a[1]);
  const hot = sorted.slice(0, 10);
  const cold = sorted.slice(-10).reverse();

  renderHotCold('hotNumbers', hot, draws.length, 'hot');
  renderHotCold('coldNumbers', cold, draws.length, 'cold');

  // Special numbers
  const specialEl = document.getElementById('specialStats');
  if (cfg.hasSpecial) {
    specialEl.style.display = 'block';
    document.getElementById('specialTitle').textContent = `🎯 ${cfg.specialLabel}統計`;
    const specFreq = calcSpecialFrequency(draws, cfg.specialMax);
    const specSorted = Object.entries(specFreq).sort((a, b) => b[1] - a[1]);
    renderHotCold('specialNumbers', specSorted, draws.length, 'special');
  } else {
    specialEl.style.display = 'none';
  }

  // Frequency chart
  renderFreqChart(freq, cfg.maxNum, draws.length);

  // Missing values
  renderMissing(missing, cfg.maxNum);

  // Update missing disclaimer dynamically
  const missingSorted = Object.entries(missing).sort((a, b) => b[1] - a[1]);
  if (missingSorted.length > 0 && missingSorted[0][1] > 0) {
    document.getElementById('topMissNote').textContent =
      `${missingSorted[0][0]} 號已經 ${missingSorted[0][1]} 期沒開`;
  }

  // Combos
  renderCombos(combos, draws.length);

  // Backtest
  renderBacktest();

  // Recent draws
  renderRecentDraws(draws.slice(0, 10), cfg);

  // Countdown & Picker
  updateCountdown();
  renderPicker();
}

function renderRepeat(stats, maxNum) {
  const cfg = LOTTERY_CONFIG[currentLottery];
  const theory = (1 / maxNum * 100).toFixed(2);
  const entries = Object.entries(stats)
    .filter(([_, s]) => s.appeared >= 3) // only show numbers with enough data
    .map(([num, s]) => {
      const rate = s.appeared > 0 ? (s.repeated / s.appeared * 100) : 0;
      return { num: parseInt(num), appeared: s.appeared, repeated: s.repeated, rate };
    })
    .sort((a, b) => b.rate - a.rate);

  // Summary
  const totalAppeared = entries.reduce((a, e) => a + e.appeared, 0);
  const totalRepeated = entries.reduce((a, e) => a + e.repeated, 0);
  const avgRate = totalAppeared > 0 ? (totalRepeated / totalAppeared * 100).toFixed(2) : 0;

  document.getElementById('repeatSummary').innerHTML = `
    <div class="repeat-summary-inner">
      <div class="rs-item">
        <span class="rs-val">${avgRate}%</span>
        <span class="rs-label">整體同號連開率</span>
      </div>
      <div class="rs-item">
        <span class="rs-val">${theory}%</span>
        <span class="rs-label">理論機率 (1/${maxNum})</span>
      </div>
      <div class="rs-item">
        <span class="rs-val ${Math.abs(parseFloat(avgRate) - parseFloat(theory)) < 1 ? 'match' : 'diff'}">${Math.abs(parseFloat(avgRate) - parseFloat(theory)).toFixed(2)}%</span>
        <span class="rs-label">與理論值差距</span>
      </div>
    </div>`;

  // Top repeat + bottom repeat
  const top5 = entries.slice(0, 8);
  const bottom5 = entries.slice(-8).reverse();

  document.getElementById('repeatGrid').innerHTML = `
    <div class="repeat-cols">
      <div class="repeat-col">
        <h4>📈 同號連開率最高</h4>
        ${top5.map(e => `
          <div class="repeat-row">
            <span class="num-ball">${e.num}</span>
            <div class="repeat-bar-wrap">
              <div class="repeat-bar" style="width:${Math.min(e.rate * 2, 100)}%"></div>
              <div class="repeat-theory" style="left:${Math.min(parseFloat(theory) * 2, 100)}%"></div>
            </div>
            <span class="repeat-rate">${e.rate.toFixed(1)}%</span>
            <span class="repeat-detail">${e.repeated}/${e.appeared}</span>
          </div>`).join('')}
      </div>
      <div class="repeat-col">
        <h4>📉 同號連開率最低</h4>
        ${bottom5.map(e => `
          <div class="repeat-row">
            <span class="num-ball">${e.num}</span>
            <div class="repeat-bar-wrap">
              <div class="repeat-bar low" style="width:${Math.min(e.rate * 2, 100)}%"></div>
              <div class="repeat-theory" style="left:${Math.min(parseFloat(theory) * 2, 100)}%"></div>
            </div>
            <span class="repeat-rate">${e.rate.toFixed(1)}%</span>
            <span class="repeat-detail">${e.repeated}/${e.appeared}</span>
          </div>`).join('')}
      </div>
    </div>`;
}

// === BACKTEST ===
let currentStrategy = 'hot';
function switchStrategy(btn) {
  document.querySelectorAll('.bt-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  currentStrategy = btn.dataset.strategy;
  renderBacktest();
}

function runBacktest(allDraws, numCount, maxNum, strategy) {
  // For each draw i (from index 0 = newest), use draws i+1..i+lookback to determine hot/cold
  // Then check how many of those picks appeared in draw i
  const lookback = 20; // use past 20 draws to calc hot/cold
  const results = [];

  for (let i = 0; i < allDraws.length - lookback; i++) {
    const pastDraws = allDraws.slice(i + 1, i + 1 + lookback);
    const freq = {};
    for (let n = 1; n <= maxNum; n++) freq[n] = 0;
    pastDraws.forEach(d => d.numbers.forEach(n => freq[n]++));

    const sorted = Object.entries(freq).sort((a, b) => b[1] - a[1]);
    let picks;
    if (strategy === 'hot') {
      picks = sorted.slice(0, numCount).map(e => parseInt(e[0]));
    } else {
      picks = sorted.slice(-numCount).map(e => parseInt(e[0]));
    }

    const actual = allDraws[i].numbers;
    const hits = picks.filter(n => actual.includes(n));

    results.push({
      period: allDraws[i].period,
      date: allDraws[i].date,
      picks: picks.sort((a, b) => a - b),
      actual: actual,
      hits: hits,
      hitCount: hits.length
    });
  }
  return results;
}

function renderBacktest() {
  const cfg = LOTTERY_CONFIG[currentLottery];
  const data = lotteryData[currentLottery];
  if (!data) return;

  const results = runBacktest(data.draws, cfg.count, cfg.maxNum, currentStrategy);
  if (results.length === 0) return;

  // Summary stats
  const totalHits = results.reduce((a, r) => a + r.hitCount, 0);
  const totalPicks = results.length * cfg.count;
  const avgHit = (totalHits / results.length).toFixed(2);
  const hitRate = (totalHits / totalPicks * 100).toFixed(2);
  const expectedHit = (cfg.count * cfg.count / cfg.maxNum).toFixed(2);
  const expectedRate = (cfg.count / cfg.maxNum * 100).toFixed(2);
  const anyHitDraws = results.filter(r => r.hitCount > 0).length;
  const anyHitPct = (anyHitDraws / results.length * 100).toFixed(1);
  const bestDraw = results.reduce((a, r) => r.hitCount > a.hitCount ? r : a, results[0]);
  const label = currentStrategy === 'hot' ? '熱號' : '冷號';

  document.getElementById('backtestSummary').innerHTML = `
    <div class="bt-summary">
      <div class="bt-stat">
        <span class="bt-val">${avgHit}</span>
        <span class="bt-label">每期平均命中</span>
      </div>
      <div class="bt-stat">
        <span class="bt-val">${expectedHit}</span>
        <span class="bt-label">隨機期望值</span>
      </div>
      <div class="bt-stat">
        <span class="bt-val ${parseFloat(avgHit) > parseFloat(expectedHit) ? 'win' : 'lose'}">${avgHit > expectedHit ? '+' : ''}${(avgHit - expectedHit).toFixed(2)}</span>
        <span class="bt-label">${label}策略 vs 隨機</span>
      </div>
      <div class="bt-stat">
        <span class="bt-val">${anyHitPct}%</span>
        <span class="bt-label">有命中的期數</span>
      </div>
    </div>
    <p class="bt-verdict">${parseFloat(avgHit) > parseFloat(expectedHit)
      ? `📊 在這 ${results.length} 期回測中，買${label}平均每期多中 ${(avgHit - expectedHit).toFixed(2)} 個——但這只是隨機波動，不代表策略有效。`
      : `📊 在這 ${results.length} 期回測中，買${label}甚至不如隨機選號。最佳一期是第 ${bestDraw.period} 期命中 ${bestDraw.hitCount} 個。`
    }</p>`;

  // Table: show top results (most hits first)
  const sorted = [...results].sort((a, b) => b.hitCount - a.hitCount);
  const show = sorted.slice(0, 15);

  document.getElementById('backtestTable').innerHTML = `
    <thead>
      <tr>
        <th>期別</th>
        <th>日期</th>
        <th>${label}選號</th>
        <th>實際開獎</th>
        <th>命中</th>
      </tr>
    </thead>
    <tbody>
      ${show.map(r => `
        <tr class="${r.hitCount >= 3 ? 'highlight' : ''}">
          <td>${r.period}</td>
          <td>${r.date}</td>
          <td class="td-nums">${r.picks.map(n =>
            `<span class="num-mini ${r.hits.includes(n) ? 'hit' : ''}">${n}</span>`
          ).join('')}</td>
          <td class="td-nums">${r.actual.map(n =>
            `<span class="num-mini ${r.hits.includes(n) ? 'hit' : ''}">${n}</span>`
          ).join('')}</td>
          <td><span class="hit-badge h${r.hitCount}">${r.hitCount}</span></td>
        </tr>`).join('')}
    </tbody>`;
}

function renderHotCold(elId, items, total, type) {
  const el = document.getElementById(elId);
  el.innerHTML = items.map(([num, count], i) => {
    const pct = total > 0 ? ((count / total) * 100).toFixed(1) : 0;
    const barWidth = total > 0 ? Math.max(5, (count / total) * 100 * (type === 'special' ? 3 : 1.5)) : 0;
    const numClass = type === 'special' ? 'num-ball special-ball' : 'num-ball';
    return `
      <div class="hc-row">
        <span class="hc-rank">${i + 1}</span>
        <span class="${numClass}">${num}</span>
        <div class="hc-bar-wrap">
          <div class="hc-bar ${type}" style="width:${Math.min(barWidth, 100)}%"></div>
        </div>
        <span class="hc-count">${count} 次</span>
        <span class="hc-pct">${pct}%</span>
      </div>`;
  }).join('');
}

function renderFreqChart(freq, maxNum, total) {
  const el = document.getElementById('freqChart');
  const maxFreq = Math.max(...Object.values(freq), 1);
  const avg = total > 0 ? (Object.values(freq).reduce((a, b) => a + b, 0) / maxNum) : 0;
  const maxBarPx = 160; // max bar height in pixels

  el.innerHTML = Object.entries(freq).map(([num, count]) => {
    const heightPx = maxFreq > 0 ? Math.max((count / maxFreq) * maxBarPx, 4) : 4;
    const isHot = count > avg * 1.3;
    const isCold = count < avg * 0.7;
    const cls = isHot ? 'bar hot' : isCold ? 'bar cold' : 'bar';
    return `
