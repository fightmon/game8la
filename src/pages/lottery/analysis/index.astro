  document.querySelectorAll('.whl-btn[data-budget]').forEach(b => b.classList.remove('active'));
  const input = document.getElementById('customBudget');
  if (input) input.value = fullCost;
  renderWheel();
}

function toggleWheelCombos() {
  const el = document.getElementById('wheelHiddenRows');
  const btn = document.getElementById('wheelToggle');
  if (!el || !btn) return;
  if (el.style.display === 'none') {
    el.style.display = '';
    btn.textContent = '收合';
  } else {
    el.style.display = 'none';
    const total = el.querySelectorAll('tr').length + 5;
    btn.textContent = '顯示全部 ' + total + ' 注';
  }
