.cross-arrow { color: var(--gold-light); font-size: 1.2rem; font-weight: 800; flex-shrink: 0; }

/* Disclaimer */
.analysis-disclaimer {
  padding: 1.2rem; margin: 2rem 0;
  background: rgba(255, 136, 0, 0.08); border: 1px solid rgba(255, 136, 0, 0.3);
  border-radius: 12px; font-size: 0.85rem; color: var(--text-secondary);
}
.analysis-disclaimer strong { color: #ffb347; }
.analysis-disclaimer a { color: #ffd966; text-decoration: underline; }

/* === Wheel Source Toggle + Custom Pool === */
.whl-source-toggle {
  display: flex; align-items: center; gap: 0.5rem;
  flex-wrap: wrap; margin-bottom: 1rem;
}
.whl-source-label { color: var(--text-muted); font-size: 0.9rem; font-weight: 600; }
.whl-src-btn {
  padding: 0.5rem 1rem; border-radius: 8px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  color: var(--text-secondary); font-size: 0.88rem; font-weight: 600;
  cursor: pointer; transition: all 0.2s;
}
.whl-src-btn:hover { border-color: var(--gold); }
.whl-src-btn.active {
  background: linear-gradient(135deg, #ff8800, #FFD700); color: #000;
  border-color: #ff8800; font-weight: 700;
}

.whl-custom-pool {
  margin-bottom: 1.2rem; padding: 1rem;
  background: rgba(255,136,0,0.04); border: 1px dashed rgba(255,136,0,0.3);
  border-radius: 12px;
}
.whl-cp-hint { font-size: 0.88rem; color: var(--text-secondary); margin: 0 0 0.8rem; }
.whl-cp-hint strong { color: var(--gold-light); }
.whl-cp-grid {
  display: flex; flex-wrap: wrap; gap: 0.35rem; justify-content: center; margin-bottom: 0.8rem;
}
.whl-cp-num {
  width: 40px; height: 40px; border-radius: 50%;
  background: var(--bg-secondary); border: 2px solid var(--border);
  color: var(--text-secondary); font-size: 0.92rem; font-weight: 700;
  cursor: pointer; transition: all 0.2s; display: flex;
  align-items: center; justify-content: center;
}
.whl-cp-num:hover { border-color: #ff8800; color: #ff8800; }
.whl-cp-num.selected {
  background: linear-gradient(135deg, #ff8800, #FFD700); color: #000;
  border-color: #ff8800; box-shadow: 0 3px 10px rgba(255,136,0,0.35);
  transform: scale(1.08);
}
.whl-cp-status {
  display: flex; align-items: center; justify-content: center; gap: 1rem;
  font-size: 0.88rem; color: var(--text-muted);
}
.whl-cp-status strong { color: #ff8800; font-size: 1.05rem; }
.whl-cp-clear {
  padding: 0.3rem 0.8rem; border-radius: 6px;
  background: var(--bg-card); border: 1px solid var(--border);
  color: var(--text-secondary); font-size: 0.8rem; cursor: pointer;
}
.whl-cp-clear:hover { border-color: var(--text-muted); }

/* Custom pool warning */
.whl-cp-warn {
  margin-top: 0.8rem; padding: 1rem 1.2rem;
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
  border: 2px solid #ff9800; border-radius: 12px;
  display: flex; gap: 0.8rem; align-items: flex-start;
}
[data-theme="dark"] .whl-cp-warn {
  background: linear-gradient(135deg, rgba(255,152,0,0.15) 0%, rgba(255,152,0,0.06) 100%);
}
.whl-cp-warn-icon { font-size: 1.5rem; flex-shrink: 0; margin-top: 0.1rem; }
.whl-cp-warn-body { font-size: 0.85rem; line-height: 1.6; }
.whl-cp-warn-body strong { color: #e65100; display: block; margin-bottom: 0.3rem; font-size: 0.92rem; }
[data-theme="dark"] .whl-cp-warn-body strong { color: #ffab40; }
.whl-cp-warn-body p { margin: 0.25rem 0; color: #5d4037; }
[data-theme="dark"] .whl-cp-warn-body p { color: #ffcc80; }
.whl-cp-warn.shake { animation: whl-shake 0.4s ease-in-out; }
@keyframes whl-shake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-6px); }
  40% { transform: translateX(6px); }
  60% { transform: translateX(-4px); }
  80% { transform: translateX(4px); }
}

.whl-cp-not-enough {
  padding: 1rem; text-align: center; font-size: 0.92rem;
  color: var(--text-muted); background: rgba(255,136,0,0.04);
  border: 1px dashed rgba(255,136,0,0.25); border-radius: 10px;
}
.whl-cp-not-enough strong { color: #ff8800; }

/* === Wheel Probability Simulation === */
.wheel-sim { margin-top: 1.5rem; }
.sim-panel {
  background: linear-gradient(135deg, rgba(138,43,226,0.06), rgba(255,215,0,0.04));
  border: 1px solid rgba(138,43,226,0.3);
  border-radius: 14px; padding: 1.5rem;
}
.sim-panel h4 {
  font-size: 1.1rem; color: var(--text-primary); margin: 0 0 0.3rem;
  display: flex; align-items: center; gap: 0.5rem;
}
.sim-badge {
  font-size: 0.65rem; font-weight: 900; color: #fff;
  background: linear-gradient(135deg, #8b5cf6, #a855f7);
  padding: 0.15rem 0.6rem; border-radius: 999px; letter-spacing: 0.5px;
}
.sim-subtitle { font-size: 0.9rem; color: var(--text-muted); margin: 0 0 1rem; }
.sim-tabs {
  display: flex; gap: 0.4rem; margin-bottom: 1.2rem;
  border-bottom: 2px solid var(--border); padding-bottom: 0.5rem;
}
.sim-tab {
  padding: 0.5rem 1rem; border-radius: 8px 8px 0 0;
  background: transparent; border: 1px solid transparent;
  color: var(--text-muted); font-size: 0.85rem; font-weight: 600;
  cursor: pointer; transition: all 0.2s;
}
.sim-tab:hover { color: var(--text-primary); }
.sim-tab.active {
  background: rgba(138,43,226,0.12); border-color: rgba(138,43,226,0.4);
  color: #a855f7; font-weight: 700;
}

/* Probability table */
.sim-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
.sim-table th {
  text-align: left; padding: 0.5rem 0.6rem; border-bottom: 2px solid var(--border);
  color: var(--text-muted); font-size: 0.78rem; white-space: nowrap;
}
.sim-table td {
  padding: 0.5rem 0.6rem; border-bottom: 1px solid var(--border);
  color: var(--text-secondary); font-size: 0.88rem;
}
.sim-tier { font-weight: 700; color: var(--text-primary); white-space: nowrap; }
.sim-highlight { color: #a855f7; font-weight: 700; }
.sim-total-row td { border-top: 2px solid var(--border); font-weight: 700; }
.sim-total-row .sim-highlight { color: #39FF14; font-size: 1rem; }
.sim-note { font-size: 0.78rem; color: var(--text-muted); margin: 0.6rem 0 0; font-style: italic; }

/* EV cards */
.sim-ev-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 0.6rem; margin-bottom: 1.2rem;
}
.sim-ev-card {
  display: flex; flex-direction: column; align-items: center;
  padding: 0.8rem; border-radius: 10px;
  background: var(--bg-secondary); border: 1px solid var(--border);
}
.sim-ev-label { font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.3rem; }
.sim-ev-val { font-size: 1.2rem; font-weight: 900; color: var(--gold-light); }
.sim-ev-val.cost { color: #ef4444; }
.sim-ev-card.negative .sim-ev-val { color: #ef4444; }
.sim-ev-card.positive .sim-ev-val { color: #39FF14; }

/* EV bar */
.sim-ev-bar-wrap { margin: 1rem 0; }
.sim-ev-bar-label {
  display: flex; justify-content: space-between;
  font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.3rem;
}
.sim-ev-bar-track {
  height: 24px; background: rgba(239,68,68,0.15);
  border-radius: 12px; overflow: hidden; border: 1px solid rgba(239,68,68,0.3);
}
.sim-ev-bar-fill {
  height: 100%; background: linear-gradient(90deg, #ef4444, #f97316, #FFD700);
  border-radius: 12px; transition: width 0.5s;
}
.sim-ev-verdict {
  text-align: center; font-size: 0.92rem; color: var(--text-secondary);
  margin: 0.6rem 0 0; line-height: 1.6;
}

/* Monte Carlo chart */
.sim-mc-title { font-size: 0.95rem; color: var(--text-primary); font-weight: 700; margin: 0 0 1rem; }
.sim-mc-chart {
  display: flex; align-items: flex-end; justify-content: center;
  gap: 0.5rem; height: 160px; margin-bottom: 1rem;
  padding: 0.5rem; background: var(--bg-secondary); border-radius: 10px;
}
.sim-mc-col {
  display: flex; flex-direction: column; align-items: center;
  flex: 1; max-width: 60px; height: 100%;
  justify-content: flex-end;
}
.sim-mc-pct { font-size: 0.7rem; color: var(--text-secondary); font-weight: 700; margin-bottom: 0.2rem; }
.sim-mc-bar { width: 100%; border-radius: 4px 4px 0 0; min-height: 2px; transition: height 0.3s; }
.sim-mc-label { font-size: 0.72rem; color: var(--text-muted); margin-top: 0.3rem; font-weight: 600; }
.sim-mc-summary {
  display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; margin: 1rem 0;
}
.sim-mc-stat {
  display: flex; flex-direction: column; align-items: center;
  padding: 0.6rem 1rem; background: var(--bg-secondary);
  border: 1px solid var(--border); border-radius: 10px; min-width: 120px;
}
.sim-mc-stat-label { font-size: 0.72rem; color: var(--text-muted); }
.sim-mc-stat-val { font-size: 1.1rem; font-weight: 900; color: var(--gold-light); margin-top: 0.2rem; }
.sim-mc-stat-val.cost { color: #ef4444; }
.sim-mc-stat-val.negative { color: #ef4444; }
.sim-mc-stat-val.positive { color: #39FF14; }
.sim-rerun {
  display: block; margin: 0.8rem auto 0; padding: 0.6rem 1.5rem;
  background: linear-gradient(135deg, #8b5cf6, #a855f7); color: #fff;
  border: none; border-radius: 10px; font-weight: 700; font-size: 0.9rem;
  cursor: pointer; transition: all 0.2s;
}
.sim-rerun:hover { transform: translateY(-2px); box-shadow: 0 4px 16px rgba(138,43,226,0.4); }

/* Coming soon */
.sim-coming-soon {
  display: flex; align-items: center; gap: 0.8rem; padding: 1rem;
  background: rgba(138,43,226,0.06); border: 1px dashed rgba(138,43,226,0.3);
  border-radius: 10px; margin-top: 1.5rem;
}
.sim-coming-soon .sim-icon { font-size: 1.5rem; }
.sim-coming-soon p { margin: 0; font-size: 0.88rem; color: var(--text-muted); }

/* === Countdown Timer === */
.countdown-bar {
  display: flex; align-items: center; justify-content: center; gap: 0.8rem;
  margin-top: 0.8rem; padding: 0.6rem 1.2rem;
  background: linear-gradient(135deg, rgba(255,215,0,0.1), rgba(57,255,20,0.08));
  border: 1px solid rgba(255,215,0,0.25); border-radius: 10px;
}
.countdown-label { font-size: 0.9rem; color: var(--text-secondary); }
.countdown-timer {
  font-size: 1.5rem; font-weight: 900; letter-spacing: 0.08em;
  background: linear-gradient(135deg, #FFD700, #39FF14); -webkit-background-clip: text;
  background-clip: text; color: transparent;
  font-variant-numeric: tabular-nums;
}

/* === Picker (自選號碼) === */
.picker-section {
  background: linear-gradient(135deg, rgba(255,105,180,0.06), rgba(255,215,0,0.04));
  border-color: rgba(255,105,180,0.3);
}
.picker-grid {
  display: flex; flex-wrap: wrap; gap: 0.4rem; justify-content: center; margin-bottom: 1rem;
}
.pk-num {
  width: 44px; height: 44px; border-radius: 50%;
  background: var(--bg-secondary); border: 2px solid var(--border);
  color: var(--text-secondary); font-size: 1rem; font-weight: 700;
  cursor: pointer; transition: all 0.2s; display: flex;
  align-items: center; justify-content: center;
}
.pk-num:hover { border-color: #ff69b4; color: #ff69b4; }
.pk-num.selected {
  background: linear-gradient(135deg, #ff69b4, #ff1493); color: #fff;
  border-color: #ff69b4; box-shadow: 0 3px 12px rgba(255,105,180,0.4);
  transform: scale(1.08);
}
.picker-selected {
  display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap;
  padding: 0.8rem; background: var(--bg-secondary); border-radius: 10px; margin-bottom: 1rem;
}
.picker-label { font-size: 0.9rem; color: var(--text-muted); white-space: nowrap; }
.picker-balls { display: flex; gap: 0.4rem; flex-wrap: wrap; flex: 1; }
.pk-ball {
  background: linear-gradient(135deg, #ff69b4, #ff1493) !important;
  color: #fff !important; font-weight: 700;
}
.picker-clear, .picker-check {
  padding: 0.5rem 1rem; border-radius: 8px; font-size: 0.85rem; font-weight: 600;
  cursor: pointer; transition: all 0.2s; border: none;
}
.picker-clear { background: var(--bg-card); color: var(--text-secondary); border: 1px solid var(--border); }
.picker-clear:hover { border-color: var(--text-muted); }
.picker-check {
  background: linear-gradient(135deg, #ff69b4, #ff1493); color: #fff;
}
.picker-check:disabled { opacity: 0.4; cursor: not-allowed; }
.picker-check:not(:disabled):hover { box-shadow: 0 4px 15px rgba(255,105,180,0.4); }
.picker-result-box {
  padding: 1rem; background: var(--bg-secondary); border-radius: 10px;
  border: 1px solid rgba(255,105,180,0.2);
}
.picker-result-box h4 { font-size: 1rem; margin-bottom: 0.8rem; color: var(--text-primary); }
.picker-no-hit { color: var(--text-muted); font-size: 0.9rem; }
.picker-hit-summary { font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.8rem; }
.picker-hit-summary strong { color: #ff69b4; }
.picker-hit-list { display: flex; flex-direction: column; gap: 0.5rem; }
.picker-hit-row {
  display: flex; align-items: center; gap: 0.6rem; padding: 0.5rem 0.6rem;
  background: var(--bg-card); border-radius: 8px;
}
.picker-hit-date { font-size: 0.82rem; color: var(--text-muted); min-width: 90px; }
.picker-hit-nums { display: flex; gap: 0.25rem; flex-wrap: wrap; flex: 1; }
.picker-hit-nums .num-mini.hit {
  background: linear-gradient(135deg, #ff69b4, #ff1493) !important;
  color: #fff !important; font-weight: 700;
}
.picker-hit-count { font-size: 0.85rem; font-weight: 700; color: #ff69b4; white-space: nowrap; }
.picker-more { font-size: 0.82rem; color: var(--text-muted); margin-top: 0.5rem; }

/* === Safety CTA === */
.safety-cta {
  margin: 2rem 0; padding: 1.2rem 1.5rem;
  background: linear-gradient(135deg, rgba(57,255,20,0.08), rgba(255,215,0,0.06));
  border: 2px solid rgba(57,255,20,0.3); border-radius: 14px;
}
.safety-cta-inner {
  display: flex; align-items: center; gap: 1rem;
}
.safety-cta-icon { font-size: 2rem; flex-shrink: 0; }
.safety-cta-text { flex: 1; }
.safety-cta-text strong { font-size: 1rem; color: var(--text-primary); display: block; margin-bottom: 0.3rem; }
.safety-cta-text p { font-size: 0.85rem; color: var(--text-muted); margin: 0; }
.safety-cta-btn {
  display: inline-block; padding: 0.7rem 1.5rem; border-radius: 10px;
  background: linear-gradient(135deg, #39FF14, #00e676); color: #000;
  font-weight: 800; font-size: 0.95rem; text-decoration: none;
  transition: all 0.25s; white-space: nowrap; flex-shrink: 0;
}
.safety-cta-btn:hover { box-shadow: 0 4px 20px rgba(57,255,20,0.4); transform: translateY(-1px); }

/* === FAQ === */
.faq-list { display: flex; flex-direction: column; gap: 0.5rem; }
.faq-item {
  background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 10px;
  overflow: hidden;
}
.faq-item summary {
  padding: 1rem 1.2rem; font-size: 1rem; font-weight: 700; color: var(--text-primary);
  cursor: pointer; list-style: none; display: flex; align-items: center; gap: 0.5rem;
}
.faq-item summary::-webkit-details-marker { display: none; }
.faq-item summary::before { content: '▸'; color: var(--gold); transition: transform 0.2s; }
.faq-item[open] summary::before { transform: rotate(90deg); }
.faq-item p {
  padding: 0 1.2rem 1rem; font-size: 0.9rem; color: var(--text-secondary);
  line-height: 1.7; margin: 0;
}

/* Hero sub */
.hero-sub { color: var(--text-muted); font-size: 1rem; font-weight: 500; }

/* Suggestion section */
.suggestion-section {
  background: linear-gradient(135deg, rgba(255,215,0,0.06), rgba(57,255,20,0.04));
  border-color: rgba(255,215,0,0.3);
}
.suggest-tabs {
  display: flex; gap: 0.5rem; margin-bottom: 1.5rem;
}
.sg-tab {
  padding: 0.5rem 1.2rem; border-radius: 8px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  color: var(--text-secondary); font-size: 0.9rem; font-weight: 600;
  cursor: pointer; transition: all 0.2s;
}
.sg-tab:hover { border-color: var(--gold); }
.sg-tab.active {
  background: linear-gradient(135deg, #FFD700, #ff8800); color: #000;
  border-color: #FFD700; font-weight: 700;
}
.suggest-balls {
  display: flex; gap: 1rem; justify-content: center;
  flex-wrap: wrap; margin-bottom: 1.5rem;
}
.suggest-ball-wrap {
  display: flex; flex-direction: column; align-items: center; gap: 0.3rem;
}
.suggest-ball {
  width: 52px; height: 52px; border-radius: 50%;
  background: linear-gradient(135deg, #FFD700, #ff8800);
  color: #000; font-weight: 900; font-size: 1.3rem;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 15px rgba(255,215,0,0.4);
  animation: ballPulse 2s ease-in-out infinite;
}
@keyframes ballPulse {
  0%, 100% { box-shadow: 0 4px 15px rgba(255,215,0,0.4); }
  50% { box-shadow: 0 4px 25px rgba(255,215,0,0.7); }
}
.suggest-score {
  font-size: 0.75rem; font-weight: 700; color: var(--gold-light);
}
.suggest-tags {
  display: flex; gap: 0.2rem;
}
.sg-tag {
  font-size: 0.6rem; padding: 0.1rem 0.35rem; border-radius: 4px;
  font-weight: 700;
}
.sg-tag.hot { background: rgba(255,68,68,0.2); color: #ff6666; }
.sg-tag.miss { background: rgba(68,170,255,0.2); color: #66bbff; }
.sg-tag.repeat { background: rgba(57,255,20,0.2); color: #39FF14; }

/* Special suggestion */
.suggest-special {
  display: flex; align-items: center; justify-content: center;
  gap: 0.8rem; margin: 1rem 0; padding: 0.8rem;
  background: rgba(255,16,240,0.06); border: 1px solid rgba(255,16,240,0.25);
  border-radius: 10px;
}
.suggest-special-label { color: var(--text-muted); font-size: 0.9rem; font-weight: 600; }
.suggest-special-ball { width: 44px; height: 44px; font-size: 1.1rem; box-shadow: 0 4px 12px rgba(255,16,240,0.3); }
.suggest-special-score { font-size: 0.85rem; color: #FF10F0; font-weight: 700; }

/* Detail table */
.suggest-detail { overflow-x: auto; margin-top: 1rem; }
.suggest-table {
  width: 100%; border-collapse: collapse; font-size: 0.85rem;
}
.suggest-table th {
  text-align: left; padding: 0.5rem; border-bottom: 2px solid var(--border);
  color: var(--text-muted); font-size: 0.78rem; white-space: nowrap;
}
.suggest-table td {
  padding: 0.5rem; border-bottom: 1px solid var(--border);
  color: var(--text-secondary); white-space: nowrap;
}
.sg-ball { width: 28px; height: 28px; font-size: 0.78rem; }
.sg-bar-mini {
  width: 60px; height: 6px; background: rgba(255,255,255,0.08);
  border-radius: 3px; overflow: hidden;
}
.sg-bar-fill {
  height: 100%; border-radius: 3px; transition: width 0.4s;
}
.sg-bar-fill.hot { background: linear-gradient(90deg, #ff4444, #ff8800); }
.sg-bar-fill.miss { background: linear-gradient(90deg, #44aaff, #4488ff); }
.sg-bar-fill.repeat { background: linear-gradient(90deg, #39FF14, #2bcc10); }

.suggest-explain {
  text-align: center; font-size: 0.85rem; color: var(--text-muted);
  margin-top: 0.5rem; line-height: 1.5;
}

.suggest-algo-note {
  margin-top: 1rem; font-size: 0.82rem; color: var(--text-muted);
}
.suggest-algo-note summary {
  cursor: pointer; color: var(--text-secondary); font-weight: 600;
}
.suggest-algo-note p {
  margin: 0.4rem 0; line-height: 1.6;
}

/* Wheel Generator */
.wheel-section {
  background: linear-gradient(135deg, rgba(255,136,0,0.05), rgba(255,215,0,0.04));
  border-color: rgba(255,136,0,0.25);
}
.wheel-budget {
  display: flex; align-items: center; gap: 0.5rem;
  flex-wrap: wrap; margin-bottom: 1.5rem;
}
.wheel-budget-label { color: var(--text-muted); font-size: 0.9rem; font-weight: 600; }
.whl-btn {
  padding: 0.5rem 1.2rem; border-radius: 8px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  color: var(--text-secondary); font-size: 0.9rem; font-weight: 600;
  cursor: pointer; transition: all 0.2s;
}
.whl-btn:hover { border-color: var(--gold); }
.whl-btn.active {
  background: linear-gradient(135deg, #ff8800, #FFD700); color: #000;
  border-color: #ff8800; font-weight: 700;
}
.whl-custom {
  display: flex; gap: 0.3rem; align-items: center;
}
.whl-custom input {
  width: 100px; padding: 0.45rem 0.6rem; border-radius: 8px;
