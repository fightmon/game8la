---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import { tileRow } from '../../../lib/mahjong-tiles.js';

const pageTitle = 'Mahjong Pung, Chow & Kong — Free Interactive Trainer | Chow Only From Your Left';
const pageDesc = 'Learning mahjong? Confused about when to call Pung, Chow or Kong? This free 8-question interactive trainer teaches you tile by tile — one tap, instant feedback, fits one phone screen. Uses Taiwanese mahjong tiles; the calls are universal across every mahjong variant.';
const canonical = 'https://game8la.com/en/tools/mahjong-rules-trainer/';
const zhUrl = 'https://game8la.com/tools/mahjong-rules-trainer/';
const alternates = [
  { hreflang: 'en', href: canonical },
  { hreflang: 'zh-Hant', href: zhUrl },
  { hreflang: 'x-default', href: canonical },
];

const faqs = [
  { q: "What's the difference between Pung and Chow?", a: 'Pung uses two identical tiles in your hand plus a third discarded by ANY player, forming a triplet. Chow uses two same-suit tiles in sequence plus a discard from your LEFT player only, forming a run.' },
  { q: "Why can't I Chow a tile from Across or the Right?", a: 'In mahjong you may Chow only from your Left player — the one who discards right before your turn. Tiles from Across or the Right can only be Pung’d or Kong’d. This is the most common beginner mistake.' },
  { q: 'How many kinds of Kong are there?', a: 'Three: Open Kong (three in hand + a discard), Closed Kong (all four self-drawn, declared face-down), and Added Kong (adding a fourth tile to a Pung you already called). After any Kong you draw a replacement tile.' },
  { q: 'Does calling Pung break a concealed hand?', a: 'Yes. Once you Pung, Chow, or make an open Kong, your hand is no longer concealed and you lose the concealed-hand bonus. To stay concealed, win entirely by self-draw.' },
  { q: 'Can one tile be both Pung’d and Chow’d?', a: 'No — you take only one action. And when several players want the same tile, priority is: Win > Pung/Kong > Chow. A player calling Pung beats a player who only wants to Chow.' },
];
const faqSchema = { '@context':'https://schema.org','@type':'FAQPage', mainEntity: faqs.map(f=>({ '@type':'Question', name:f.q, acceptedAnswer:{ '@type':'Answer', text:f.a } })) };
const softwareSchema = { '@context':'https://schema.org','@type':'WebApplication', name:'Mahjong Pung Chow Kong Trainer', applicationCategory:'GameApplication', operatingSystem:'Web', inLanguage:'en', offers:{ '@type':'Offer', price:'0', priceCurrency:'USD' }, url:canonical };
const breadcrumbSchema = { '@context':'https://schema.org','@type':'BreadcrumbList', itemListElement:[
  { '@type':'ListItem', position:1, name:'Home', item:'https://game8la.com/' },
  { '@type':'ListItem', position:2, name:'Tools', item:'https://game8la.com/tools/' },
  { '@type':'ListItem', position:3, name:'Mahjong Pung Chow Kong Trainer', item:canonical },
]};
---

<BaseLayout title={pageTitle} description={pageDesc} ogUrl={canonical} currentPage="tools" alternates={alternates}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="container">
    <div class="page-hero">
      <div class="lang-switch"><a href={zhUrl}>中文</a><span>English</span></div>
      <h1>🀄 Mahjong Pung · Chow · Kong Trainer</h1>
      <p class="hero-sub">Someone discards a tile — can you Pung? Chow? Kong? Or just Pass? One tile at a time, fits a single phone screen.</p>
      <p class="hero-desc">Hi! I'm Bala-zi. The hardest part for new mahjong players is knowing when to call Pung, Chow and Kong — especially the rule that <strong>you can only Chow from the player on your Left</strong>. This trainer shows the <strong>same hand discarded by different players</strong> so you can see the difference with your own eyes. (The tiles are Taiwanese mahjong, but Pung / Chow / Kong work the same in every mahjong variant — Japanese Riichi, Chinese, Hong Kong, all of them.)</p>
    </div>

    <!-- ===== Interactive trainer (fits one screen) ===== -->
    <section class="rt-game" id="rtGame">
      <div class="rt-progress">
        <span class="rt-progress-text" id="rtPtext">Q 1 / 8</span>
        <div class="rt-progress-track"><div class="rt-progress-fill" id="rtPfill" style="width:12.5%"></div></div>
      </div>

      <div class="rt-card" id="rtCard">
        <!-- Table: who discarded + Left → You "can Chow" relationship -->
        <div class="rt-table" id="rtTable">
          <svg class="rt-eat-path" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
            <defs><marker id="rtAH" markerWidth="6" markerHeight="6" refX="4" refY="3" orient="auto"><path d="M0,0 L5,3 L0,6 Z" fill="#39FF14"/></marker></defs>
            <path d="M15,52 Q15,86 44,89" fill="none" stroke="#39FF14" stroke-width="1.3" stroke-dasharray="3 2.4" marker-end="url(#rtAH)" opacity="0.8"/>
          </svg>
          <span class="rt-eat-badge">Chow</span>
          <div class="rt-seat seat-top" data-seat="toi"><svg class="rt-person" viewBox="0 0 40 42"><circle cx="20" cy="12" r="9"/><path d="M4,42 Q4,24 20,24 Q36,24 36,42 Z"/></svg><span class="rt-seat-lbl">Across</span></div>
          <div class="rt-seat seat-left" data-seat="kami"><svg class="rt-person" viewBox="0 0 40 42"><circle cx="20" cy="12" r="9"/><path d="M4,42 Q4,24 20,24 Q36,24 36,42 Z"/></svg><span class="rt-seat-lbl">Left</span></div>
          <div class="rt-seat seat-right" data-seat="shimo"><svg class="rt-person" viewBox="0 0 40 42"><circle cx="20" cy="12" r="9"/><path d="M4,42 Q4,24 20,24 Q36,24 36,42 Z"/></svg><span class="rt-seat-lbl">Right</span></div>
          <div class="rt-seat seat-me"><span class="rt-seat-lbl me">You 👇</span></div>
          <div class="rt-ghost" id="rtGhost" aria-hidden="true"></div>
          <div class="rt-center" id="rtDiscard"></div>
        </div>
        <p class="rt-from" id="rtFrom">Left discards a tile</p>
        <!-- Your hand -->
        <div class="rt-hand-label">👇 Your hand</div>
        <div class="rt-felt"><div class="rt-hand" id="rtHand"></div></div>
        <!-- Question + answer buttons -->
        <div class="rt-ask" id="rtAsk">What can you do with this tile?</div>
        <div class="rt-guess" id="rtGuess">
          <button data-a="pung">Pung</button>
          <button data-a="chow">Chow</button>
          <button data-a="kong">Kong</button>
          <button data-a="pass">Pass</button>
        </div>
        <!-- Reveal -->
        <div class="rt-reveal" id="rtReveal">
          <div class="rt-verdict" id="rtVerdict"></div>
          <p class="rt-why" id="rtWhy"></p>
          <button class="rt-next" id="rtNext">Next →</button>
        </div>
      </div>

      <!-- Final -->
      <div class="rt-final" id="rtFinal" style="display:none">
        <div class="rt-final-score" id="rtFinalScore">0 / 8</div>
        <div class="rt-final-title" id="rtFinalTitle"></div>
        <div class="rt-final-msg" id="rtFinalMsg"></div>
        <button class="rt-next" id="rtReplay">🔄 Play again</button>
      </div>

      <!-- Stats -->
      <div class="rt-stats">
        <span class="rt-stat">This run <strong id="rtStreak">0</strong></span>
        <span class="rt-stat">Total correct <strong id="rtCorrect">0</strong></span>
        <span class="rt-stat">Best streak <strong id="rtBest">0</strong></span>
      </div>
    </section>

    <!-- ===== Teaching ===== -->
    <section class="rt-teach">
      <p class="rt-suit-note">📖 <strong>Reading the tiles:</strong> there are three suits — <strong>Man</strong> (萬 / characters), <strong>Pin</strong> (筒 / circles) and <strong>Sou</strong> (條 / bamboo) — plus honor tiles: the Winds (East 東, South 南, West 西, North 北) and Dragons (Red 中, Green 發, White 白).</p>

      <h2 id="pung">🟢 What is Pung? How do you call it?</h2>
      <p><strong>Pung</strong> = you already hold <strong>two identical tiles</strong>; when <strong>any player</strong> discards the third, you call "Pung" to form a <strong>triplet</strong>.</p>
      <div class="rt-eg"><div class="rt-eg-tiles" set:html={tileRow('5m5m')} /><span class="rt-eg-arrow">+ anyone discards <span set:html={tileRow('5m')} /> →</span><div class="rt-eg-tiles" set:html={tileRow('5m5m5m')} /></div>
      <ul>
        <li>✅ You can Pung a discard from <strong>any</strong> player — Left, Across, or Right.</li>
        <li>✅ Honor tiles (Winds &amp; Dragons) can be Pung'd too; a Dragon triplet even scores points.</li>
        <li>⚠️ A Pung'd set is <strong>exposed (face up)</strong>, and your hand is no longer <strong>concealed</strong>.</li>
      </ul>

      <h2 id="chow">🟡 What is Chow? Why only from the Left?</h2>
      <p><strong>Chow</strong> = you hold <strong>two tiles of the same suit in sequence</strong>, and use them with the <strong>Left player's</strong> discard to make a <strong>run</strong>.</p>
      <div class="rt-eg"><div class="rt-eg-tiles" set:html={tileRow('4m5m')} /><span class="rt-eg-arrow">+ <b>Left</b> discards <span set:html={tileRow('6m')} /> →</span><div class="rt-eg-tiles" set:html={tileRow('4m5m6m')} /></div>
      <div class="rt-keybox">
        <strong>🚨 The #1 beginner trap: Chow only from your Left</strong>
        <p>Your Left player is the one who discards <strong>right before your turn</strong>. Even if you hold the perfect tiles, you <strong>cannot Chow</strong> a discard from Across or the Right — only Pung or Kong. Questions 2 and 3 give you the same hand from different players so you feel the difference.</p>
      </div>
      <ul>
        <li>❌ <strong>Honor tiles can't be Chow'd.</strong> Winds and Dragons have no runs — only Pung.</li>
        <li>⚠️ A Chow is also exposed and breaks a concealed hand.</li>
      </ul>

      <h2 id="kong">🔵 What is Kong? The three types</h2>
      <div class="rt-eg"><div class="rt-eg-tiles" set:html={tileRow('7p7p7p')} /><span class="rt-eg-arrow">+ someone discards <span set:html={tileRow('7p')} /> →</span><div class="rt-eg-tiles" set:html={tileRow('7p7p7p7p')} /></div>
      <ul>
        <li><strong>① Open Kong</strong>: you hold three identical tiles and <strong>someone discards</strong> the fourth.</li>
        <li><strong>② Closed Kong</strong>: you draw all four <strong>yourself</strong>, declared face-down (keeps your hand concealed).</li>
        <li><strong>③ Added Kong</strong>: you already <strong>Pung'd</strong> a triplet and later <strong>draw</strong> the fourth tile to add on.</li>
        <li>🎁 After any Kong you <strong>draw a replacement tile</strong> (a chance at a Kong-draw win).</li>
      </ul>

      <h2 id="priority">⚖️ Multiple players want it? Call priority</h2>
      <p>When several players want the same discard, the order is:</p>
      <div class="rt-priority">Win <span>&gt;</span> Pung / Kong <span>&gt;</span> Chow</div>
      <p>So if you only want to Chow but another player calls Pung, the Pung wins; and anyone who can Win beats both. Remember this order and you'll never call out of turn.</p>
    </section>

    <!-- ===== FAQ ===== -->
    <section class="rt-faq">
      <h2>❓ Pung / Chow / Kong FAQ</h2>
      {faqs.map(f => (
        <details class="rt-faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </section>

    <div class="rt-cross">
      <p>Read Chinese? Try the full Chinese version with extra Taiwanese-scoring tools.</p>
      <a href={zhUrl} class="rt-cross-btn">🀄 中文版練習器 →</a>
    </div>

    <ShareButtons title={pageTitle} url={canonical} />
  </div>

<style is:global>
  /* Pung/Chow/Kong trainer (rt- prefix); is:global because tile SVGs are injected by JS */
  .container{ max-width:760px; margin:0 auto; padding:0 1rem 4rem; }
  .page-hero{ text-align:center; padding:2.2rem 0 1rem; }
  .page-hero h1{ font-size:2rem; margin:0 0 .6rem; color:var(--gold-light); }
  .hero-sub{ font-size:1.08rem; color:var(--text-primary); margin:.2rem 0 .8rem; font-weight:600; }
  .hero-desc{ font-size:.96rem; color:var(--text-secondary); line-height:1.7; max-width:620px; margin:0 auto; text-align:left; }
  .lang-switch{ display:flex; justify-content:center; gap:.4rem; margin-bottom:.8rem; font-size:.85rem; }
  .lang-switch a{ color:var(--gold-light,#ffd24a); text-decoration:none; border:1px solid var(--border,#444); border-radius:20px; padding:.2rem .8rem; }
  .lang-switch a:hover{ background:rgba(245,184,0,.12); }
  .lang-switch span{ color:#1a1a1a; background:var(--gold,#f5b800); border-radius:20px; padding:.2rem .8rem; font-weight:700; }

  /* ===== trainer ===== */
  .rt-game{ margin-top:1.6rem; }
  .rt-progress{ display:flex; align-items:center; gap:.7rem; margin-bottom:.9rem; }
  .rt-progress-text{ font-size:.9rem; color:var(--text-muted); white-space:nowrap; }
  .rt-progress-track{ flex:1; height:8px; background:rgba(255,255,255,.08); border-radius:6px; overflow:hidden; }
  .rt-progress-fill{ height:100%; background:linear-gradient(90deg,#2bd60a,#39FF14,#9bff7a,#39FF14); background-size:200% 100%; border-radius:6px; transition:width .4s ease; }

  .rt-card{ background:var(--bg-card,#1a1a1a); border:1px solid var(--border,#333); border-radius:18px; padding:1.1rem 1rem 1.2rem; }

  /* ===== top-down table ===== */
  .rt-table{ position:relative; width:100%; max-width:288px; aspect-ratio:1 / .9; margin:.2rem auto .2rem; }
  .rt-eat-path{ position:absolute; inset:0; width:100%; height:100%; pointer-events:none; z-index:1; }
  .rt-eat-badge{ position:absolute; left:13%; bottom:20%; z-index:3; background:#1e7a46; color:#fff; font-size:.6rem; font-weight:800; padding:.08rem .42rem; border-radius:8px; border:1px solid #39FF14; }
  .rt-table.from-kami .rt-eat-badge{ animation:rtEatPulse 1s ease-in-out infinite; }
  @keyframes rtEatPulse{ 0%,100%{ transform:scale(1); box-shadow:0 0 0 rgba(57,255,20,0); } 50%{ transform:scale(1.18); box-shadow:0 0 10px rgba(57,255,20,.75); } }
  .rt-seat{ position:absolute; z-index:2; display:flex; flex-direction:column; align-items:center; gap:1px; color:#7a8a99; transition:color .3s; }
  .rt-person{ width:34px; height:auto; fill:currentColor; transition:filter .3s; }
  .rt-seat-lbl{ font-size:.72rem; font-weight:700; white-space:nowrap; }
  .rt-seat-lbl.me{ color:#f5b800; font-size:.84rem; }
  .seat-top{ top:0; left:50%; transform:translateX(-50%); }
  .seat-left{ left:0; top:46%; transform:translateY(-50%); }
  .seat-right{ right:0; top:46%; transform:translateY(-50%); }
  .seat-me{ bottom:0; left:50%; transform:translateX(-50%); }
  .rt-seat.active{ color:#39FF14; }
  .rt-seat.active .rt-person{ filter:drop-shadow(0 0 7px #39FF14); }
  .rt-center{ position:absolute; top:46%; left:50%; width:56px; z-index:2; transform:translate(-50%,-50%); }
  .rt-center svg{ width:56px; height:auto; filter:drop-shadow(0 4px 10px rgba(0,0,0,.5)); }
  .rt-center.fly-toi{ animation:rtFlyToi .5s cubic-bezier(.3,.7,.3,1) both; }
  .rt-center.fly-kami{ animation:rtFlyKami .5s cubic-bezier(.3,.7,.3,1) both; }
  .rt-center.fly-shimo{ animation:rtFlyShimo .5s cubic-bezier(.3,.7,.3,1) both; }
  @keyframes rtFlyToi{ from{ transform:translate(-50%,-50%) translateY(-78px); opacity:0; } to{ transform:translate(-50%,-50%); opacity:1; } }
  @keyframes rtFlyKami{ from{ transform:translate(-50%,-50%) translateX(-96px); opacity:0; } to{ transform:translate(-50%,-50%); opacity:1; } }
  @keyframes rtFlyShimo{ from{ transform:translate(-50%,-50%) translateX(96px); opacity:0; } to{ transform:translate(-50%,-50%); opacity:1; } }
  /* ghost tile: looping discard motion (real tile stays still for reading) */
  .rt-ghost{ position:absolute; top:46%; left:50%; width:56px; z-index:1; transform:translate(-50%,-50%); opacity:0; pointer-events:none; }
  .rt-ghost svg{ width:56px; height:auto; filter:drop-shadow(0 0 5px rgba(57,255,20,.4)); }
  .rt-ghost.loop-toi{ animation:rtGhostToi 1.9s ease-in-out infinite; }
  .rt-ghost.loop-kami{ animation:rtGhostKami 1.9s ease-in-out infinite; }
  .rt-ghost.loop-shimo{ animation:rtGhostShimo 1.9s ease-in-out infinite; }
  @keyframes rtGhostToi{ 0%{ transform:translate(-50%,-50%) translateY(-78px) scale(.82); opacity:0; } 16%{ opacity:.65; } 52%{ transform:translate(-50%,-50%) scale(1); opacity:.5; } 66%,100%{ transform:translate(-50%,-50%) scale(1); opacity:0; } }
  @keyframes rtGhostKami{ 0%{ transform:translate(-50%,-50%) translateX(-96px) scale(.82); opacity:0; } 16%{ opacity:.65; } 52%{ transform:translate(-50%,-50%) scale(1); opacity:.5; } 66%,100%{ transform:translate(-50%,-50%) scale(1); opacity:0; } }
  @keyframes rtGhostShimo{ 0%{ transform:translate(-50%,-50%) translateX(96px) scale(.82); opacity:0; } 16%{ opacity:.65; } 52%{ transform:translate(-50%,-50%) scale(1); opacity:.5; } 66%,100%{ transform:translate(-50%,-50%) scale(1); opacity:0; } }
  .rt-from{ text-align:center; font-size:.92rem; font-weight:700; color:var(--text-secondary); margin:.1rem 0 .55rem; }
  .rt-from b{ color:#39FF14; }

  .rt-hand-label{ text-align:center; font-size:.86rem; color:var(--text-muted); margin:.8rem 0 .3rem; }
  .rt-felt{ background:radial-gradient(ellipse at center,#1f6b3f,#14502e); border-radius:12px; padding:.7rem .5rem; border:1px solid #0c3d22; }
  .rt-hand{ display:flex; justify-content:center; flex-wrap:wrap; gap:6px; }
  .rt-hand svg{ width:42px; height:auto; border-radius:5px; transition:transform .2s, filter .2s; }
  .rt-hand svg.hl{ filter:drop-shadow(0 0 8px #ffd700); transform:translateY(-5px); }

  .rt-ask{ text-align:center; font-size:1.18rem; font-weight:800; color:var(--text-primary); margin:.95rem 0 .7rem; }
  .rt-guess{ display:flex; justify-content:center; gap:8px; }
  .rt-guess button{ flex:1; max-width:96px; font-size:1.1rem; font-weight:800; padding:14px 0; border-radius:12px; border:2px solid var(--border,#444); background:#222; color:#fff; cursor:pointer; transition:all .15s; }
  .rt-guess button:hover{ border-color:var(--gold,#f5b800); }
  .rt-guess button[data-a="pung"]{ color:#7bffb0; }
  .rt-guess button[data-a="chow"]{ color:#ffe17b; }
  .rt-guess button[data-a="kong"]{ color:#7bc4ff; }
  .rt-guess button[data-a="pass"]{ color:#bbb; }
  .rt-guess button.right{ background:#1e7a46; border-color:#39FF14; color:#fff; animation:rtPop .4s ease; }
  .rt-guess button.wrong{ background:#7a1e1e; border-color:#ff5a5a; color:#fff; animation:rtShake .4s ease; }
  .rt-guess button.dim{ opacity:.4; }
  @keyframes rtPop{ 0%{transform:scale(1);} 50%{transform:scale(1.12);} 100%{transform:scale(1);} }
  @keyframes rtShake{ 0%,100%{transform:translateX(0);} 25%{transform:translateX(-6px);} 75%{transform:translateX(6px);} }

  .rt-reveal{ display:none; margin-top:.9rem; text-align:center; }
  .rt-reveal.show{ display:block; }
  .rt-verdict{ font-size:1.3rem; font-weight:800; margin-bottom:.4rem; }
  .rt-verdict.ok{ color:#39FF14; }
  .rt-verdict.no{ color:#ff6b6b; }
  .rt-verdict.half{ color:#ffd24a; }
  .rt-why{ font-size:.96rem; color:var(--text-secondary); line-height:1.65; margin:.3rem auto .9rem; max-width:560px; }
  .rt-next{ background:linear-gradient(135deg,#f5b800,#ffd24a); color:#1a1a1a; font-weight:800; font-size:1.05rem; padding:12px 30px; border:none; border-radius:12px; cursor:pointer; }
  .rt-next:hover{ filter:brightness(1.06); }

  .rt-final{ text-align:center; background:var(--bg-card,#1a1a1a); border:1px solid var(--gold,#f5b800); border-radius:18px; padding:1.8rem 1.2rem; margin-top:1rem; }
  .rt-final-score{ font-size:2.2rem; font-weight:900; color:var(--gold-light,#ffd24a); }
  .rt-final-title{ font-size:1.3rem; font-weight:800; margin:.4rem 0; color:var(--text-primary); }
  .rt-final-msg{ font-size:1rem; color:var(--text-secondary); margin-bottom:1.1rem; line-height:1.6; }

  .rt-stats{ display:flex; justify-content:center; flex-wrap:wrap; gap:.6rem; margin-top:1.1rem; }
  .rt-stat{ background:rgba(255,255,255,.05); border:1px solid var(--border,#333); border-radius:10px; padding:.55rem .9rem; font-size:.92rem; color:var(--text-secondary); }
  .rt-stat strong{ color:var(--gold-light,#ffd24a); font-size:1.25rem; }

  /* ===== teaching ===== */
  .rt-teach{ margin-top:3rem; }
  .rt-suit-note{ background:rgba(255,255,255,.04); border:1px solid var(--border,#333); border-radius:10px; padding:.8rem 1rem; font-size:.92rem; color:var(--text-secondary); line-height:1.7; }
  .rt-teach h2{ font-size:1.4rem; margin:2rem 0 .8rem; color:var(--gold-light,#ffd24a); border-bottom:2px solid var(--border,#333); padding-bottom:.4rem; }
  .rt-teach p{ line-height:1.8; color:var(--text-secondary); margin:.6rem 0; }
  .rt-teach ul{ line-height:1.9; color:var(--text-secondary); padding-left:1.2rem; }
  .rt-teach strong{ color:var(--text-primary); }
  .rt-eg{ display:flex; align-items:center; justify-content:center; flex-wrap:wrap; gap:.5rem; background:rgba(30,122,70,.12); border:1px solid rgba(57,255,20,.2); border-radius:12px; padding:.9rem; margin:.9rem 0; }
  .rt-eg-tiles{ display:flex; gap:3px; }
  .rt-eg svg{ width:38px; height:auto; }
  .rt-eg-arrow{ font-size:.92rem; color:var(--text-secondary); display:flex; align-items:center; gap:4px; }
  .rt-eg-arrow svg{ width:30px; vertical-align:middle; }
  .rt-keybox{ background:rgba(192,40,45,.12); border:1.5px solid #c0282d; border-radius:12px; padding:1rem 1.1rem; margin:1rem 0; }
  .rt-keybox strong{ color:#ff8080; font-size:1.05rem; display:block; margin-bottom:.4rem; }
  .rt-keybox p{ margin:0; }
  .rt-priority{ display:flex; align-items:center; justify-content:center; gap:.7rem; font-size:1.3rem; font-weight:800; color:var(--gold-light,#ffd24a); background:rgba(245,184,0,.1); border-radius:12px; padding:1rem; margin:.8rem 0; }
  .rt-priority span{ color:var(--text-muted); font-size:1rem; }

  .rt-faq{ margin-top:2.5rem; }
  .rt-faq h2{ font-size:1.4rem; color:var(--gold-light,#ffd24a); margin-bottom:1rem; }
  .rt-faq-item{ background:var(--bg-card,#1a1a1a); border:1px solid var(--border,#333); border-radius:10px; margin-bottom:.6rem; padding:.2rem .4rem; }
  .rt-faq-item summary{ cursor:pointer; padding:.85rem .8rem; font-weight:700; color:var(--text-primary); }
  .rt-faq-item p{ padding:0 .8rem .9rem; color:var(--text-secondary); line-height:1.7; margin:0; }

  .rt-cross{ text-align:center; margin-top:2.5rem; padding:1.4rem; background:rgba(245,184,0,.08); border-radius:14px; }
  .rt-cross p{ color:var(--text-secondary); margin:0 0 .8rem; }
  .rt-cross-btn{ display:inline-block; background:linear-gradient(135deg,#f5b800,#ffd24a); color:#1a1a1a; font-weight:800; padding:.8rem 1.5rem; border-radius:12px; text-decoration:none; }

  @media (prefers-reduced-motion: reduce){
    .rt-center,.rt-ghost,.rt-eat-badge,.rt-guess button.right,.rt-guess button.wrong,.rt-progress-fill{ animation:none !important; }
  }
  /* ===== mobile compact: whole loop on one screen ===== */
  @media (max-width:600px){
    .page-hero{ padding:1.4rem 0 .6rem; }
    .page-hero h1{ font-size:1.5rem; }
    .hero-sub{ font-size:.96rem; }
    .hero-desc{ font-size:.88rem; }
    .rt-game{ margin-top:1rem; }
    .rt-card{ padding:.85rem .7rem 1rem; border-radius:14px; }
    .rt-from{ font-size:.86rem; margin:.1rem 0 .4rem; }
    .rt-table{ max-width:238px; }
    .rt-person{ width:28px; }
    .rt-seat-lbl{ font-size:.66rem; }
    .rt-seat-lbl.me{ font-size:.76rem; }
    .rt-center{ width:48px; } .rt-center svg{ width:48px; }
    .rt-ghost{ width:48px; } .rt-ghost svg{ width:48px; }
    .rt-eat-badge{ font-size:.55rem; }
    .rt-hand-label{ margin:.55rem 0 .25rem; font-size:.8rem; }
    .rt-felt{ padding:.5rem .4rem; }
    .rt-hand{ gap:4px; }
    .rt-hand svg{ width:36px; }
    .rt-ask{ font-size:1.02rem; margin:.7rem 0 .55rem; }
    .rt-guess{ gap:6px; }
    .rt-guess button{ font-size:1rem; padding:12px 0; max-width:none; }
    .rt-reveal{ margin-top:.7rem; }
    .rt-verdict{ font-size:1.12rem; }
    .rt-why{ font-size:.88rem; }
    .rt-next{ padding:11px 26px; font-size:1rem; }
    .rt-stats{ margin-top:.9rem; gap:.45rem; }
    .rt-stat{ padding:.45rem .7rem; font-size:.8rem; }
  }
  @media (max-width:380px){
    .rt-hand svg{ width:31px; }
    .rt-hand{ gap:3px; }
    .rt-guess button{ font-size:.92rem; padding:11px 0; }
    .rt-table{ max-width:212px; }
    .rt-center{ width:42px; } .rt-center svg{ width:42px; }
    .rt-ghost{ width:42px; } .rt-ghost svg{ width:42px; }
    .rt-person{ width:25px; }
  }
</style>

<script is:inline>
(function(){
  /* ===== tile SVG (same as mahjong-tiles, inlined) ===== */
  var CN=["","一","二","三","四","五","六","七","八","九"];
  var HCH={1:"東",2:"南",3:"西",4:"北",5:"中",6:"發",7:"白"};
  var HCOL={1:"#1d4ee8",2:"#1d4ee8",3:"#1d4ee8",4:"#1d4ee8",5:"#c0282d",6:"#1e7a46",7:"#2b7bb0"};
  function grid(n){var L=24,C=36,R=48;return ({1:[[C,50]],2:[[C,30],[C,70]],3:[[L,28],[C,50],[R,72]],4:[[L,30],[R,30],[L,70],[R,70]],5:[[L,30],[R,30],[C,50],[L,70],[R,70]],6:[[L,28],[R,28],[L,50],[R,50],[L,72],[R,72]],7:[[L,26],[R,26],[L,50],[C,50],[R,50],[L,74],[R,74]],8:[[L,24],[R,24],[L,42],[R,42],[L,60],[R,60],[L,78],[R,78]],9:[[L,26],[C,26],[R,26],[L,50],[C,50],[R,50],[L,74],[C,74],[R,74]]})[n];}
  function pin(n){var cols=["#1e7a46","#c0282d","#1d4ee8"];return grid(n).map(function(p,i){var x=p[0],y=p[1],col=n===1?"#c0282d":cols[i%3],r=n===1?16:7.5;return '<circle cx="'+x+'" cy="'+y+'" r="'+r+'" fill="#fff" stroke="'+col+'" stroke-width="'+(n===1?3:2.4)+'"/><circle cx="'+x+'" cy="'+y+'" r="'+(r*0.42)+'" fill="'+col+'"/>';}).join("");}
  function sou(n){if(n===1)return '<g transform="translate(36,50)"><ellipse cx="0" cy="7" rx="12" ry="15" fill="#1e7a46"/><circle cx="0" cy="-11" r="7.5" fill="#c0282d"/><path d="M0 15 L-5 28 L5 28 Z" fill="#e0a020"/><circle cx="-2.5" cy="-12" r="1.5" fill="#fff"/></g>';return grid(n).map(function(p){var x=p[0],y=p[1];return '<g><rect x="'+(x-3)+'" y="'+(y-11)+'" width="6" height="22" rx="3" fill="#1e7a46"/><rect x="'+(x-4.4)+'" y="'+(y-3)+'" width="8.8" height="2.6" rx="1.3" fill="#0c5c30"/><rect x="'+(x-4.4)+'" y="'+(y+5)+'" width="8.8" height="2.6" rx="1.3" fill="#0c5c30"/></g>';}).join("");}
  function wan(n){return '<text x="36" y="40" font-size="25" text-anchor="middle" fill="#c0282d" font-family="serif" font-weight="700">'+CN[n]+'</text><text x="36" y="76" font-size="29" text-anchor="middle" fill="#1b3a2a" font-family="serif" font-weight="800">萬</text>';}
  function honor(n){return '<text x="36" y="63" font-size="40" text-anchor="middle" fill="'+HCOL[n]+'" font-family="serif" font-weight="800">'+HCH[n]+'</text>';}
  function tileSVG(t){var n=+t[0],s=t[1];var inner=s==='m'?wan(n):s==='p'?pin(n):s==='s'?sou(n):honor(n);return '<svg viewBox="0 0 72 98" xmlns="http://www.w3.org/2000/svg"><defs><linearGradient id="rtfc" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#fffdf6"/><stop offset="1" stop-color="#ece4cf"/></linearGradient><linearGradient id="rtsd" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#e9dcc0"/><stop offset="1" stop-color="#bda77f"/></linearGradient></defs><rect x="3" y="8" width="66" height="88" rx="9" fill="url(#rtsd)"/><rect x="3" y="3" width="66" height="86" rx="9" fill="url(#rtfc)" stroke="#d9cdaf"/>'+inner+'</svg>';}

  /* ===== questions: from = kami(Left)/toi(Across)/shimo(Right) ===== */
  var Q=[
    { d:'5m', from:'toi',  hand:['5m','5m','2p','7s','3z'], ans:'pung', hl:['5m','5m'],
      why:'You hold two 5-Man, and Across discards the third → call Pung to form a triplet. Pung works from any player.' },
    { d:'6m', from:'kami', hand:['4m','5m','1p','8s','3z'], ans:'chow', hl:['4m','5m'],
      why:'Left discards 6-Man, and your 4-Man + 5-Man complete the run 4-5-6 Man → Chow! Remember, you can only Chow from your Left.' },
    { d:'6m', from:'toi',  hand:['4m','5m','1p','8s','3z'], ans:'pass', hl:[],
      why:'Same hand as the last question — but this time ACROSS discarded it. You can only Chow from your Left, so a tile from Across cannot be eaten → Pass. This is the #1 beginner trap!' },
    { d:'7p', from:'shimo',hand:['7p','7p','7p','3m','9s'], ans:'kong', hl:['7p','7p','7p'],
      why:'You hold three 7-Pin and someone discards the fourth → Open Kong! (You could also Pung with two, but with four tiles it is better to Kong and draw a replacement.)' },
    { d:'7z', from:'kami', hand:['2m','5p','8s','3z','6z'], ans:'pass', hl:[],
      why:'The discard is White Dragon (an honor tile). You have no second White to Pung, and honor tiles cannot be Chow’d → Pass.' },
    { d:'3m', from:'kami', hand:['1m','2m','4p','7s','9z'], ans:'chow', hl:['1m','2m'],
      why:'Left discards 3-Man; your 1-Man + 2-Man complete the run 1-2-3 Man → Chow! Edge runs count too.' },
    { d:'5z', from:'kami', hand:['5z','5z','3m','7p','8s'], ans:'pung', hl:['5z','5z'],
      why:'The discard is Red Dragon. You have two of them → Pung! Honor tiles have no runs, so they can only be Pung’d, never Chow’d (a Dragon triplet also scores).' },
    { d:'8s', from:'toi',  hand:['8s','2m','5p','1z','6z'], ans:'pass', hl:[],
      why:'You hold only ONE 8-Sou — Pung needs two matching tiles, and a tile from Across cannot be Chow’d anyway → Pass. Do not call Pung too early.' },
  ];

  function cnt(hand,t){var c=0;for(var i=0;i<hand.length;i++)if(hand[i]===t)c++;return c;}
  function validActions(hand,d,from){
    var acts=[]; var c=cnt(hand,d); var s=d[1],n=+d[0];
    if(c>=3) acts.push('kong');
    if(c>=2) acts.push('pung');
    if(from==='kami' && (s==='m'||s==='p'||s==='s')){
      var has=function(x){return hand.indexOf(x+s)!==-1;};
      if((n-2>=1&&has(n-2)&&has(n-1)) || (n-1>=1&&n+1<=9&&has(n-1)&&has(n+1)) || (n+2<=9&&has(n+1)&&has(n+2))) acts.push('chow');
    }
    return acts;
  }
  var LABEL={pung:'Pung',chow:'Chow',kong:'Kong',pass:'Pass'};

  var idx=0, correct=0, streak=0, best=0, locked=false;
  var $=function(id){return document.getElementById(id);};
  var LS='mjrules_en_stats';
  function loadStats(){try{var s=JSON.parse(localStorage.getItem(LS));if(s){correct=s.correct||0;best=s.best||0;}}catch(e){}}
  function saveStats(){try{localStorage.setItem(LS,JSON.stringify({correct:correct,best:best}));}catch(e){}}

  var ENCORE={2:'Two in a row! Getting the feel.',3:'3 straight! It is clicking.',4:"4 straight! You won't miss a call now.",5:'5 straight! Veteran level.',6:"6 straight! Steadiest at the table.",7:'7 straight! One away from perfect.',8:'Perfect run! Bala-zi bows to you 🍈'};

  function load(){
    locked=false;
    var q=Q[idx];
    $('rtPtext').textContent='Q '+(idx+1)+' / '+Q.length;
    $('rtPfill').style.width=((idx+1)/Q.length*100)+'%';
    var tableEl=$('rtTable');
    tableEl.className='rt-table'+(q.from==='kami'?' from-kami':'');
    tableEl.querySelectorAll('.rt-seat').forEach(function(s){ s.classList.toggle('active', s.dataset.seat===q.from); });
    var who = q.from==='kami'?'Left (plays before you)':q.from==='toi'?'Across':'Right';
    $('rtFrom').innerHTML = (q.from==='kami'?'<b>'+who+'</b>':who)+' discards a tile';
    var c=$('rtDiscard'); c.className='rt-center'; c.innerHTML=tileSVG(q.d);
    var g=$('rtGhost'); g.className='rt-ghost'; g.innerHTML=tileSVG(q.d); void g.offsetWidth; g.classList.add('loop-'+q.from);
    $('rtHand').innerHTML=q.hand.map(function(t){return tileSVG(t);}).join('');
    var btns=$('rtGuess').querySelectorAll('button');
    btns.forEach(function(b){ b.className=''; b.disabled=false; });
    $('rtReveal').className='rt-reveal';
    $('rtCard').style.display='';
    $('rtFinal').style.display='none';
  }

  function highlight(hl){
    if(!hl.length) return;
    var svgs=$('rtHand').querySelectorAll('svg');
    var used={}; var q=Q[idx];
    hl.forEach(function(t){
      for(var i=0;i<q.hand.length;i++){ if(q.hand[i]===t && !used[i]){ used[i]=1; if(svgs[i]) svgs[i].classList.add('hl'); break; } }
    });
  }

  function guess(pick){
    if(locked) return; locked=true;
    var q=Q[idx];
    var valid=validActions(q.hand,q.d,q.from);
    var btns=$('rtGuess').querySelectorAll('button');
    btns.forEach(function(b){ b.disabled=true; if(b.dataset.a!==pick && b.dataset.a!==q.ans) b.classList.add('dim'); });
    var pickBtn=Array.prototype.filter.call(btns,function(b){return b.dataset.a===pick;})[0];
    var ansBtn=Array.prototype.filter.call(btns,function(b){return b.dataset.a===q.ans;})[0];

    var verdict=$('rtVerdict'), why=$('rtWhy');
    highlight(q.hl);

    if(pick===q.ans){
      pickBtn.classList.add('right');
      correct++; streak++; if(streak>best) best=streak;
      verdict.className='rt-verdict ok'; verdict.textContent='✅ Correct!'+(ENCORE[streak]?'　'+ENCORE[streak]:'');
      why.textContent=q.why;
    } else if(valid.indexOf(pick)!==-1){
      pickBtn.classList.add('half'); ansBtn.classList.add('right'); pickBtn.style.borderColor='#ffd24a';
      streak=0;
      verdict.className='rt-verdict half'; verdict.textContent='🟡 Half right';
      why.textContent='"'+LABEL[pick]+'" works too, but this tile is better played as "'+LABEL[q.ans]+'". '+q.why;
    } else {
      pickBtn.classList.add('wrong'); ansBtn.classList.add('right');
      streak=0;
      verdict.className='rt-verdict no'; verdict.textContent='❌ Not quite — the answer is "'+LABEL[q.ans]+'"';
      why.textContent=q.why;
    }
    saveStats(); paintStats();
    $('rtReveal').className='rt-reveal show';
  }
  function paintStats(){ $('rtStreak').textContent=streak; $('rtCorrect').textContent=correct; $('rtBest').textContent=best; }

  function next(){
    if(idx>=Q.length-1){ showFinal(); return; }
    idx++; load();
    $('rtGame').scrollIntoView({behavior:'smooth',block:'start'});
  }
  function showFinal(){
    $('rtCard').style.display='none';
    $('rtFinal').style.display='block';
    var t,m;
    if(best>=Q.length){ t='🏆 Perfect — mahjong prodigy!'; m="You've nailed Pung, Chow and Kong. You won't miss a call at the table. Next, learn how Taiwanese scoring (Tai) works!"; }
    else if(best>=5){ t='🀄 Veteran level'; m='Your calls are solid! Run it a few more times until "Chow only from the Left" is pure instinct.'; }
    else{ t='🌱 Still training'; m="No worries — a few more rounds and calling becomes reflex. Remember: Chow only from your Left, and honor tiles can only be Pung'd!"; }
    $('rtFinalTitle').textContent=t; $('rtFinalMsg').textContent=m;
    $('rtFinalScore').textContent='Best streak '+best+' / '+Q.length;
    $('rtGame').scrollIntoView({behavior:'smooth',block:'start'});
  }
  function replay(){ idx=0; streak=0; load(); $('rtGame').scrollIntoView({behavior:'smooth',block:'start'}); }

  function init(){
    loadStats(); paintStats(); load();
    $('rtGuess').addEventListener('click',function(e){ var b=e.target.closest('button'); if(b&&b.dataset.a) guess(b.dataset.a); });
    $('rtNext').addEventListener('click',next);
    $('rtReplay').addEventListener('click',replay);
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',init); else init();
})();
</script>
</BaseLayout>
