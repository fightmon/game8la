  const mcBtn = document.querySelector('.sim-tab:last-child');
  if (mcBtn) switchSimTab(mcBtn, 'simMC');
}

// === EXPORT IMAGE ===
function generateWheelImage() {
  if (lotteryDraws.length === 0) return;
  const draws = currentRange === 0 ? lotteryDraws : lotteryDraws.slice(0, currentRange);
  const allDraws = lotteryDraws;
  const { pool, combos, maxBets, poolSize, totalCombos, isCustom } = generateWheel(draws, allDraws);
  if (combos.length === 0) return;

  const actualCost = combos.length * BET_COST;
  const today = new Date();
  const dateStr = today.getFullYear() + '/' + String(today.getMonth() + 1).padStart(2, '0') + '/' + String(today.getDate()).padStart(2, '0');
  const lastPeriod = allDraws[0]?.period || '';

  // Layout constants
  const W = 750;
  const PAD = 32;
  const COLS = 2;
  const COL_W = (W - PAD * 2 - 20) / COLS;
  const BALL_R = 16;
  const BALL_GAP = 6;
  const ROW_H = 42;
  const HEADER_H = 200;
  const maxDisplay = Math.min(combos.length, 60);
  const rows = Math.ceil(maxDisplay / COLS);
  const TABLE_H = rows * ROW_H + 40;
  const FOOTER_H = 100;
  const H = HEADER_H + TABLE_H + FOOTER_H;

  const canvas = document.createElement('canvas');
  canvas.width = W;
  canvas.height = H;
  const ctx = canvas.getContext('2d');

  // Background
  const bgGrad = ctx.createLinearGradient(0, 0, 0, H);
  bgGrad.addColorStop(0, '#1a1a2e');
  bgGrad.addColorStop(0.5, '#16213e');
  bgGrad.addColorStop(1, '#0f3460');
  ctx.fillStyle = bgGrad;
  ctx.fillRect(0, 0, W, H);

  // Subtle grid pattern
  ctx.strokeStyle = 'rgba(255,255,255,0.03)';
  ctx.lineWidth = 1;
  for (let i = 0; i < W; i += 40) { ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, H); ctx.stroke(); }
  for (let i = 0; i < H; i += 40) { ctx.beginPath(); ctx.moveTo(0, i); ctx.lineTo(W, i); ctx.stroke(); }

  // Header area
  const hdrGrad = ctx.createLinearGradient(0, 0, W, 0);
  hdrGrad.addColorStop(0, 'rgba(255,136,0,0.15)');
  hdrGrad.addColorStop(1, 'rgba(255,215,0,0.08)');
  ctx.fillStyle = hdrGrad;
  ctx.fillRect(0, 0, W, HEADER_H);

  // Accent line
  const accentGrad = ctx.createLinearGradient(0, 0, W, 0);
  accentGrad.addColorStop(0, '#ff8800');
  accentGrad.addColorStop(1, '#FFD700');
  ctx.fillStyle = accentGrad;
  ctx.fillRect(0, HEADER_H - 3, W, 3);

  // Logo text
  ctx.font = 'bold 28px "Segoe UI", "Noto Sans TC", sans-serif';
  ctx.fillStyle = '#FFD700';
  ctx.textAlign = 'left';
  ctx.fillText('🎯 GAME8LA', PAD, 48);

  // Title
  ctx.font = 'bold 22px "Segoe UI", "Noto Sans TC", sans-serif';
  ctx.fillStyle = '#ffffff';
  ctx.fillText('539 包牌組合', PAD, 84);

  // Date & period
  ctx.font = '14px "Segoe UI", "Noto Sans TC", sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.5)';
  ctx.textAlign = 'right';
  ctx.fillText(dateStr + (lastPeriod ? '  |  最新一期：' + lastPeriod : ''), W - PAD, 48);

  // Summary stats
  ctx.textAlign = 'left';
  const stats = [
    { label: '預算', val: '$' + currentBudget.toLocaleString() },
    { label: '注數', val: combos.length + ' 注' },
    { label: '花費', val: '$' + actualCost.toLocaleString() },
    { label: '碼數', val: poolSize + ' 碼' + (isCustom ? '（自選）' : '') }
  ];
  const statW = (W - PAD * 2) / stats.length;
  stats.forEach((s, i) => {
    const x = PAD + i * statW;
    ctx.fillStyle = 'rgba(255,255,255,0.12)';
    roundRect(ctx, x, 100, statW - 10, 52, 8);
    ctx.fill();
    ctx.font = 'bold 20px "Segoe UI", "Noto Sans TC", sans-serif';
    ctx.fillStyle = '#ff8800';
    ctx.textAlign = 'center';
    ctx.fillText(s.val, x + (statW - 10) / 2, 126);
    ctx.font = '11px "Segoe UI", "Noto Sans TC", sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.fillText(s.label, x + (statW - 10) / 2, 144);
  });

  // Pool balls row
  ctx.textAlign = 'left';
  ctx.font = '12px "Segoe UI", "Noto Sans TC", sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.4)';
  ctx.fillText('號碼池：' + pool.map(s => s.num).join(', '), PAD, HEADER_H - 16);

  // Table header
  const tableY = HEADER_H + 10;
  ctx.font = 'bold 12px "Segoe UI", "Noto Sans TC", sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.35)';
  for (let col = 0; col < COLS; col++) {
    const cx = PAD + col * (COL_W + 20);
    ctx.textAlign = 'left';
    ctx.fillText('#', cx, tableY + 14);
    ctx.fillText('號碼組合', cx + 30, tableY + 14);
  }

  // Combo rows
  ctx.textAlign = 'left';
  for (let i = 0; i < maxDisplay; i++) {
    const c = combos[i];
    const col = i < Math.ceil(maxDisplay / 2) ? 0 : 1;
    const row = col === 0 ? i : i - Math.ceil(maxDisplay / 2);
    const cx = PAD + col * (COL_W + 20);
    const cy = tableY + 30 + row * ROW_H;

    // Zebra stripe
    if (row % 2 === 0) {
      ctx.fillStyle = 'rgba(255,255,255,0.03)';
      ctx.fillRect(cx - 4, cy - 6, COL_W, ROW_H);
    }

    // Index
    ctx.font = '13px "Segoe UI", "Noto Sans TC", sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.fillText(String(i + 1).padStart(2, ' '), cx, cy + 16);

    // Balls
    c.nums.forEach((n, j) => {
      const bx = cx + 34 + j * (BALL_R * 2 + BALL_GAP) + BALL_R;
      const by = cy + 12;
      // Ball gradient
      const ballGrad = ctx.createRadialGradient(bx - 3, by - 3, 2, bx, by, BALL_R);
      ballGrad.addColorStop(0, '#FFD700');
      ballGrad.addColorStop(1, '#ff8800');
      ctx.beginPath();
      ctx.arc(bx, by, BALL_R, 0, Math.PI * 2);
      ctx.fillStyle = ballGrad;
      ctx.fill();
      // Number
      ctx.font = 'bold 13px "Segoe UI", sans-serif';
      ctx.fillStyle = '#000';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(String(n), bx, by + 1);
    });
    ctx.textBaseline = 'alphabetic';
    ctx.textAlign = 'left';
  }

  // Truncation note
  if (combos.length > maxDisplay) {
    ctx.font = '12px "Segoe UI", "Noto Sans TC", sans-serif';
    ctx.fillStyle = 'rgba(255,152,0,0.7)';
    ctx.textAlign = 'center';
    ctx.fillText('⚠ 共 ' + combos.length + ' 注，圖片僅顯示前 ' + maxDisplay + ' 注', W / 2, tableY + TABLE_H - 8);
    ctx.textAlign = 'left';
  }

  // Footer
  const footerY = H - FOOTER_H;
  ctx.fillStyle = 'rgba(0,0,0,0.3)';
  ctx.fillRect(0, footerY, W, FOOTER_H);

  // Divider
  ctx.fillStyle = accentGrad;
  ctx.fillRect(0, footerY, W, 2);

  // Disclaimer
  ctx.font = '12px "Segoe UI", "Noto Sans TC", sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.4)';
  ctx.textAlign = 'center';
  ctx.fillText('芭樂子提醒：包牌只是提高覆蓋率，不是提高中獎率。期望值永遠是負的，請量力而為。', W / 2, footerY + 30);

  // URL
  ctx.font = 'bold 14px "Segoe UI", sans-serif';
  ctx.fillStyle = '#FFD700';
  ctx.fillText('game8la.com/tools/539-wheel-calculator', W / 2, footerY + 56);

  ctx.font = '11px "Segoe UI", "Noto Sans TC", sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.3)';
  ctx.fillText('此圖片由 GAME8LA 包牌計算器自動產生', W / 2, footerY + 80);

  // Download
  const link = document.createElement('a');
  link.download = '539-wheel-' + dateStr.replace(/\//g, '') + '.png';
  link.href = canvas.toDataURL('image/png');
  link.click();
}

function roundRect(ctx, x, y, w, h, r) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

