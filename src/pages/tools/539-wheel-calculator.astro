.sim-panel {
  background: linear-gradient(135deg, rgba(138,43,226,0.06), rgba(255,215,0,0.04));
  border: 1px solid rgba(138,43,226,0.3);
  border-radius: 14px; padding: 1.5rem;
}
.sim-panel h4 {
  font-size: 1.1rem; color: var(--text-primary); margin: 0 0 0.3rem;
  display: flex; align-items: center; gap: 0.5rem;
}
.sim-badge {
  font-size: 0.65rem; font-weight: 900; color: #fff;
  background: linear-gradient(135deg, #8b5cf6, #a855f7);
  padding: 0.15rem 0.6rem; border-radius: 999px; letter-spacing: 0.5px;
}
.sim-subtitle { font-size: 0.9rem; color: var(--text-muted); margin: 0 0 1rem; }
.sim-tabs {
  display: flex; gap: 0.4rem; margin-bottom: 1.2rem;
  border-bottom: 2px solid var(--border); padding-bottom: 0.5rem;
}
.sim-tab {
  padding: 0.5rem 1rem; border-radius: 8px 8px 0 0;
  background: transparent; border: 1px solid transparent;
  color: var(--text-muted); font-size: 0.85rem; font-weight: 600;
  cursor: pointer; transition: all 0.2s;
}
.sim-tab:hover { color: var(--text-primary); }
.sim-tab.active {
  background: rgba(138,43,226,0.12); border-color: rgba(138,43,226,0.4);
  color: #a855f7; font-weight: 700;
}
.sim-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
.sim-table th {
  text-align: left; padding: 0.5rem 0.6rem; border-bottom: 2px solid var(--border);
  color: var(--text-muted); font-size: 0.78rem; white-space: nowrap;
}
.sim-table td {
  padding: 0.5rem 0.6rem; border-bottom: 1px solid var(--border);
  color: var(--text-secondary); font-size: 0.88rem;
}
.sim-tier { font-weight: 700; color: var(--text-primary); white-space: nowrap; }
.sim-highlight { color: #a855f7; font-weight: 700; }
.sim-total-row td { border-top: 2px solid var(--border); font-weight: 700; }
.sim-total-row .sim-highlight { color: #39FF14; font-size: 1rem; }
.sim-note { font-size: 0.78rem; color: var(--text-muted); margin: 0.6rem 0 0; font-style: italic; }

/* EV cards */
.sim-ev-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 0.6rem; margin-bottom: 1.2rem;
}
.sim-ev-card {
  display: flex; flex-direction: column; align-items: center;
  padding: 0.8rem; border-radius: 10px;
  background: var(--bg-secondary); border: 1px solid var(--border);
}
.sim-ev-label { font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.3rem; }
.sim-ev-val { font-size: 1.2rem; font-weight: 900; color: var(--gold-light); }
.sim-ev-val.cost { color: #ef4444; }
.sim-ev-card.negative .sim-ev-val { color: #ef4444; }
.sim-ev-card.positive .sim-ev-val { color: #39FF14; }
.sim-ev-bar-wrap { margin: 1rem 0; }
.sim-ev-bar-label {
  display: flex; justify-content: space-between;
  font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.3rem;
}
.sim-ev-bar-track {
  height: 24px; background: rgba(239,68,68,0.15);
  border-radius: 12px; overflow: hidden; border: 1px solid rgba(239,68,68,0.3);
}
.sim-ev-bar-fill {
  height: 100%; background: linear-gradient(90deg, #ef4444, #f97316, #FFD700);
  border-radius: 12px; transition: width 0.5s;
}
.sim-ev-verdict {
  text-align: center; font-size: 0.92rem; color: var(--text-secondary);
  margin: 0.6rem 0 0; line-height: 1.6;
}

/* Monte Carlo chart */
.sim-mc-title { font-size: 0.95rem; color: var(--text-primary); font-weight: 700; margin: 0 0 1rem; }
.sim-mc-chart {
  display: flex; align-items: flex-end; justify-content: center;
  gap: 0.5rem; height: 160px; margin-bottom: 1rem;
  padding: 0.5rem; background: var(--bg-secondary); border-radius: 10px;
}
.sim-mc-col {
  display: flex; flex-direction: column; align-items: center;
  flex: 1; max-width: 60px; height: 100%;
  justify-content: flex-end;
}
.sim-mc-pct { font-size: 0.7rem; color: var(--text-secondary); font-weight: 700; margin-bottom: 0.2rem; }
.sim-mc-bar { width: 100%; border-radius: 4px 4px 0 0; min-height: 2px; transition: height 0.3s; }
.sim-mc-label { font-size: 0.72rem; color: var(--text-muted); margin-top: 0.3rem; font-weight: 600; }
.sim-mc-summary {
  display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; margin: 1rem 0;
}
.sim-mc-stat {
  display: flex; flex-direction: column; align-items: center;
  padding: 0.6rem 1rem; background: var(--bg-secondary);
  border: 1px solid var(--border); border-radius: 10px; min-width: 120px;
}
.sim-mc-stat-label { font-size: 0.72rem; color: var(--text-muted); }
.sim-mc-stat-val { font-size: 1.1rem; font-weight: 900; color: var(--gold-light); margin-top: 0.2rem; }
.sim-mc-stat-val.cost { color: #ef4444; }
.sim-mc-stat-val.negative { color: #ef4444; }
.sim-mc-stat-val.positive { color: #39FF14; }
.sim-rerun {
  display: block; margin: 0.8rem auto 0; padding: 0.6rem 1.5rem;
  background: linear-gradient(135deg, #8b5cf6, #a855f7); color: #fff;
  border: none; border-radius: 10px; font-weight: 700; font-size: 0.9rem;
  cursor: pointer; transition: all 0.2s;
}
.sim-rerun:hover { transform: translateY(-2px); box-shadow: 0 4px 16px rgba(138,43,226,0.4); }

/* ═══ Export Buttons ═══ */
.whl-export-btns {
  display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; margin-top: 0.8rem;
}
.whl-tg-cta {
  grid-column: 1 / -1;
  display: flex; align-items: center; justify-content: center; gap: 0.5rem;
  padding: 0.75rem 1rem; border-radius: 10px;
  border: 2px solid rgba(0, 136, 204, 0.4);
  background: linear-gradient(135deg, rgba(0, 136, 204, 0.12), rgba(0, 136, 204, 0.06));
  color: #29b6f6; font-size: 0.95rem; font-weight: 700;
  cursor: pointer; transition: all 0.25s; text-decoration: none;
}
.whl-tg-cta small {
  font-weight: 400; font-size: 0.8rem; opacity: 0.8;
}
.whl-tg-cta:hover {
  background: linear-gradient(135deg, rgba(0, 136, 204, 0.25), rgba(0, 136, 204, 0.12));
  border-color: #29b6f6; transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(0, 136, 204, 0.2);
}
.whl-copy-text {
  display: flex; align-items: center; justify-content: center; gap: 0.4rem;
  padding: 0.75rem 1rem; border-radius: 10px;
  border: 2px solid rgba(57,255,20,0.4);
  background: linear-gradient(135deg, rgba(57,255,20,0.12), rgba(57,255,20,0.06));
  color: #39FF14; font-size: 0.95rem; font-weight: 700;
  cursor: pointer; transition: all 0.25s;
}
.whl-copy-text:hover {
  background: linear-gradient(135deg, rgba(57,255,20,0.25), rgba(57,255,20,0.12));
  border-color: #39FF14; transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(57,255,20,0.2);
}
.whl-copy-text.copied {
  background: linear-gradient(135deg, rgba(57,255,20,0.3), rgba(57,255,20,0.15));
  border-color: #39FF14;
}

/* ═══ Exclude Panel ═══ */
.whl-exclude-panel {
  margin-bottom: 1.2rem;
  border: 1px solid var(--border); border-radius: 12px;
  overflow: hidden;
}
.whl-exclude-head {
  display: flex; align-items: center; gap: 0.5rem;
  padding: 0.8rem 1rem; cursor: pointer;
  background: var(--bg-secondary); transition: background 0.2s;
}
.whl-exclude-head:hover { background: rgba(255,136,0,0.06); }
.whl-exclude-toggle-icon {
  font-size: 0.7rem; color: var(--text-muted);
  transition: transform 0.2s;
}
.whl-exclude-title { font-size: 0.92rem; font-weight: 700; color: var(--text-primary); }
.whl-exclude-count {
  margin-left: auto; font-size: 0.82rem; color: #ef4444;
}
.whl-exclude-count strong { font-size: 0.95rem; }
.whl-exclude-body { padding: 1rem; }
.whl-exc-hint {
  font-size: 0.88rem; color: var(--text-secondary); margin: 0 0 0.8rem;
}
.whl-exc-grid {
  display: flex; flex-wrap: wrap; gap: 0.35rem; justify-content: center;
  margin-bottom: 0.8rem;
}
.whl-exc-num {
  width: 40px; height: 40px; border-radius: 50%;
  background: var(--bg-secondary); border: 2px solid var(--border);
  color: var(--text-secondary); font-size: 0.92rem; font-weight: 700;
  cursor: pointer; transition: all 0.2s; display: flex;
  align-items: center; justify-content: center;
}
.whl-exc-num:hover { border-color: #ef4444; color: #ef4444; }
.whl-exc-num.excluded {
  background: linear-gradient(135deg, #ef4444, #dc2626); color: #fff;
  border-color: #ef4444; box-shadow: 0 3px 10px rgba(239,68,68,0.35);
  text-decoration: line-through; text-decoration-thickness: 2px;
}
.whl-exc-actions {
  display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap;
}
.whl-exc-quick {
  padding: 0.5rem 1rem; border-radius: 8px;
  background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3);
  color: #ef4444; font-size: 0.85rem; font-weight: 600;
  cursor: pointer; transition: all 0.2s;
}
.whl-exc-quick:hover { background: rgba(239,68,68,0.2); border-color: #ef4444; }
.whl-exc-clear {
  padding: 0.5rem 1rem; border-radius: 8px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  color: var(--text-secondary); font-size: 0.85rem; font-weight: 600;
  cursor: pointer; transition: all 0.2s;
}
.whl-exc-clear:hover { border-color: var(--text-muted); }

/* ═══ Coverage Heatmap ═══ */
.wheel-coverage { margin-bottom: 1.5rem; }
.wheel-coverage h4 { font-size: 0.95rem; color: var(--text-primary); margin-bottom: 0.3rem; }
.whl-cov-desc { font-size: 0.85rem; color: var(--text-muted); margin: 0 0 0.8rem; }
.whl-cov-grid {
  display: flex; flex-wrap: wrap; gap: 0.4rem; justify-content: center;
}
.whl-cov-cell {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; width: 48px; height: 48px;
  border-radius: 10px; border: 1px solid rgba(255,136,0,0.2);
  transition: transform 0.15s;
}
.whl-cov-cell:hover { transform: scale(1.1); }
.whl-cov-num { font-size: 0.95rem; font-weight: 800; line-height: 1; }
.whl-cov-cnt { font-size: 0.65rem; font-weight: 600; opacity: 0.8; margin-top: 1px; }

/* ═══ Multi-period Backtest ═══ */
.wheel-backtest { margin-bottom: 1.5rem; }
.whl-bt-panel {
  background: linear-gradient(135deg, rgba(16,185,129,0.06), rgba(255,215,0,0.04));
  border: 1px solid rgba(16,185,129,0.3);
  border-radius: 14px; padding: 1.5rem;
}
.whl-bt-panel h4 {
  font-size: 1.1rem; color: var(--text-primary); margin: 0 0 0.3rem;
}
.whl-bt-desc { font-size: 0.88rem; color: var(--text-muted); margin: 0 0 1rem; }
.whl-bt-summary {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 0.6rem; margin-bottom: 1.2rem;
}
.whl-bt-stat {
  display: flex; flex-direction: column; align-items: center;
  padding: 0.8rem 0.5rem; border-radius: 10px;
  background: var(--bg-secondary); border: 1px solid var(--border);
}
.whl-bt-stat-val { font-size: 1.3rem; font-weight: 900; color: #10b981; }
.whl-bt-stat-label { font-size: 0.72rem; color: var(--text-muted); margin-top: 0.2rem; text-align: center; }
.whl-bt-stat.negative .whl-bt-stat-val { color: #ef4444; }
.whl-bt-stat.positive .whl-bt-stat-val { color: #10b981; }
.whl-bt-table-wrap { overflow-x: auto; }
.whl-bt-table {
  width: 100%; border-collapse: collapse; font-size: 0.85rem;
}
.whl-bt-table th {
  text-align: left; padding: 0.5rem; border-bottom: 2px solid var(--border);
  color: var(--text-muted); font-size: 0.78rem; white-space: nowrap;
}
.whl-bt-table td {
  padding: 0.45rem 0.5rem; border-bottom: 1px solid var(--border);
  color: var(--text-secondary); font-size: 0.88rem; white-space: nowrap;
}
.bt-period { font-weight: 600; color: var(--text-muted); }
.bt-nums { display: flex; gap: 2px; align-items: center; }
.num-mini-sm {
  display: inline-flex; align-items: center; justify-content: center;
  width: 26px; height: 26px; border-radius: 50%;
  background: var(--bg-secondary); border: 1px solid var(--border);
  font-size: 0.75rem; font-weight: 700; color: var(--text-secondary);
}
.bt-best { color: #10b981; font-size: 1rem; }
.bt-profit { color: #10b981; font-weight: 700; }
.bt-loss { color: #ef4444; font-weight: 700; }
tr.bt-gold { background: rgba(255,215,0,0.08); }
tr.bt-silver { background: rgba(192,192,192,0.06); }
tr.bt-bronze { background: rgba(205,127,50,0.04); }
.whl-bt-note {
  font-size: 0.8rem; color: var(--text-muted); margin: 0.8rem 0 0;
  text-align: center; font-style: italic;
}

/* ═══ FAQ ═══ */
.faq-section { background: var(--bg-card); }
.faq-item {
  border-bottom: 1px solid var(--border); padding: 0.8rem 0;
}
.faq-item:last-child { border-bottom: none; }
.faq-item summary {
  font-weight: 700; color: var(--text-primary); font-size: 0.95rem;
  cursor: pointer; padding: 0.3rem 0;
}
.faq-item summary:hover { color: var(--gold-light); }
.faq-item p {
  margin: 0.5rem 0 0; font-size: 0.9rem; color: var(--text-secondary);
  line-height: 1.7;
}

/* ═══ CTA Grid ═══ */
.cta-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1rem;
}
.cta-card {
  display: flex; gap: 0.8rem; align-items: flex-start;
  padding: 1.2rem; border-radius: 12px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  text-decoration: none; color: var(--text-primary);
  transition: transform 0.2s, box-shadow 0.2s;
}
.cta-card:hover { transform: translateY(-2px); }
.cta-card.gold:hover { border-color: #FFD700; box-shadow: 0 6px 20px rgba(255,215,0,0.15); }
.cta-card.green:hover { border-color: #39FF14; box-shadow: 0 6px 20px rgba(57,255,20,0.15); }
.cta-card.pink:hover { border-color: #FF10F0; box-shadow: 0 6px 20px rgba(255,16,240,0.15); }
.cta-icon { font-size: 1.5rem; flex-shrink: 0; }
.cta-card strong { font-size: 0.95rem; display: block; margin-bottom: 0.3rem; }
.cta-card p { margin: 0; font-size: 0.82rem; color: var(--text-muted); line-height: 1.5; }

/* ═══ Responsive — 大齡友善 (larger tap targets + fonts on mobile) ═══ */
@media (max-width: 768px) {
  .page-hero h1 { font-size: 1.5rem; }
  .intro-section { padding: 1.2rem 1rem; margin-bottom: 1.5rem; }
  .intro-section h2 { font-size: 1.1rem; }
  .intro-section p { font-size: 0.9rem; line-height: 1.75; }
  .analysis-section { padding: 1.2rem; }
  .whl-summary-grid { gap: 0.5rem; }
  .whl-stat { min-width: 0; flex: 1 1 40%; padding: 0.7rem 0.5rem; }
  .whl-stat-val { font-size: 1.2rem; }
  .whl-stat-label { font-size: 0.78rem; }
  .whl-pool-balls { gap: 0.6rem; }
  .whl-pool-ball { width: 42px; height: 42px; font-size: 1.05rem; }
  .whl-pool-score { font-size: 0.78rem; }
  .whl-table { font-size: 0.85rem; }
  .whl-composition { display: none; }
  .whl-show-more { padding: 0.7rem; font-size: 0.95rem; min-height: 48px; }
  .whl-cp-num { width: 42px; height: 42px; font-size: 0.92rem; }
  .whl-cp-grid { gap: 0.35rem; }
  .whl-exc-num { width: 42px; height: 42px; font-size: 0.92rem; }
  .whl-exc-grid { gap: 0.35rem; }
  .sim-panel { padding: 1rem; }
  .sim-tabs { gap: 0.3rem; }
  .sim-tab { padding: 0.5rem 0.7rem; font-size: 0.85rem; min-height: 44px; }
  .sim-ev-grid { grid-template-columns: 1fr 1fr; }
  .sim-ev-val { font-size: 1rem; }
  .sim-mc-chart { height: 130px; gap: 0.3rem; }
  .sim-mc-col { max-width: 50px; }
  .sim-mc-pct { font-size: 0.7rem; }
  .sim-mc-label { font-size: 0.7rem; }
  .sim-mc-summary { gap: 0.5rem; }
  .sim-mc-stat { min-width: 90px; padding: 0.5rem 0.6rem; }
  .sim-table { font-size: 0.82rem; }
  .sim-table th { font-size: 0.75rem; padding: 0.4rem; }
  .sim-table td { padding: 0.4rem; font-size: 0.85rem; }
  .cta-grid { grid-template-columns: 1fr; }
  /* Export buttons stack on tablet */
  .whl-export-btns { grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .whl-copy-text, .whl-download-img { font-size: 0.9rem; padding: 0.7rem 0.6rem; }
  .whl-tg-cta { font-size: 0.9rem; padding: 0.7rem 0.6rem; }
  /* Coverage cells */
  .whl-cov-cell { width: 44px; height: 44px; }
  .whl-cov-num { font-size: 0.9rem; }
  .whl-cov-cnt { font-size: 0.65rem; }
  /* Backtest */
  .whl-bt-summary { grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .whl-bt-stat-val { font-size: 1.1rem; }
  .whl-bt-stat-label { font-size: 0.72rem; }
  .whl-bt-panel { padding: 1rem; }
  .whl-bt-table { font-size: 0.82rem; }
  .whl-bt-table th { font-size: 0.72rem; padding: 0.4rem; }
  .whl-bt-table td { padding: 0.4rem; font-size: 0.82rem; }
  .num-mini-sm { width: 24px; height: 24px; font-size: 0.7rem; }
}

@media (max-width: 480px) {
  /* ↓↓↓ 大齡友善：手機版加大所有字體和觸控區域 ↓↓↓ */
  .analysis-section { padding: 1rem 0.8rem; }
  .section-head h2 { font-size: 1.2rem; }

  /* Range selector */
  .whl-range-selector { gap: 0.4rem; }
  .whl-range-label { font-size: 0.95rem; width: 100%; text-align: center; }
  .whl-range-btn {
    flex: 1; padding: 0.6rem 0.4rem; font-size: 0.95rem;
    min-height: 46px; text-align: center;
  }

  /* Budget */
  .wheel-budget {
    display: grid; grid-template-columns: 1fr 1fr 1fr;
    gap: 0.4rem;
  }
  .wheel-budget-label {
    grid-column: 1 / -1; text-align: center; margin-bottom: 0.2rem;
    font-size: 0.95rem;
  }
  .whl-btn {
    padding: 0.6rem 0.4rem; font-size: 0.95rem;
    text-align: center; min-height: 46px;
  }
  .whl-custom {
    grid-column: 1 / -1;
    display: grid; grid-template-columns: 1fr auto; gap: 0.4rem;
  }
  .whl-custom input {
    width: 100%; padding: 0.6rem 0.7rem; font-size: 1rem;
    min-height: 46px;
  }
  .whl-custom-go { min-height: 46px; font-size: 0.95rem; padding: 0.6rem 1rem; }

  /* Summary */
  .whl-summary-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 0.4rem;
  }
  .whl-stat { padding: 0.7rem 0.5rem; }
  .whl-stat-val { font-size: 1.2rem; }
  .whl-stat-label { font-size: 0.78rem; }

  /* Pool balls — larger for older eyes */
  .whl-pool-balls { gap: 1rem 1.2rem; padding: 0.5rem 0; }
  .whl-pool-ball { width: 48px; height: 48px; font-size: 1.2rem; }
  .whl-pool-score { font-size: 0.82rem; margin-top: 0.15rem; }
  .sg-tag { font-size: 0.65rem; padding: 0.15rem 0.4rem; }

  /* Table */
  .whl-table { font-size: 0.85rem; }
  .whl-table th, .whl-table td { padding: 0.45rem 0.35rem; }
  .num-mini { width: 30px; height: 30px; font-size: 0.82rem; }
  .whl-show-more {
    padding: 0.8rem; font-size: 1rem;
    min-height: 48px; font-weight: 700;
  }

  /* Source toggle */
  .whl-source-toggle { gap: 0.4rem; }
  .whl-source-label { font-size: 0.95rem; width: 100%; text-align: center; }
  .whl-src-btn {
    flex: 1; text-align: center; padding: 0.6rem 0.5rem;
    font-size: 0.95rem; min-height: 46px;
  }

  /* Custom pool grid — bigger for fat fingers */
  .whl-cp-num { width: 44px; height: 44px; font-size: 1rem; }
  .whl-cp-hint { font-size: 0.92rem; }
  .whl-cp-status { font-size: 0.92rem; }

  /* Exclude panel */
  .whl-exclude-head { padding: 0.9rem 1rem; }
  .whl-exclude-title { font-size: 1rem; }
  .whl-exclude-count { font-size: 0.88rem; }
  .whl-exc-num { width: 44px; height: 44px; font-size: 1rem; }
  .whl-exc-hint { font-size: 0.92rem; }
  .whl-exc-quick, .whl-exc-clear {
    padding: 0.6rem 1rem; font-size: 0.92rem; min-height: 44px;
  }

  /* Export buttons stack vertically */
