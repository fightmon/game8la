    const ta = document.createElement('textarea');
    ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
    document.body.appendChild(ta); ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    const btn = document.querySelector('.whl-copy-text');
    if (btn) {
      const orig = btn.innerHTML;
      btn.innerHTML = '✅ 已複製！';
      btn.classList.add('copied');
      setTimeout(() => { btn.innerHTML = orig; btn.classList.remove('copied'); }, 2000);
    }
  });
}

// === EXCLUDE NUMBERS ===
function toggleExcludePanel() {
  const body = document.getElementById('whlExcludeBody');
  const icon = document.getElementById('whlExcToggleIcon');
  if (!body) return;
  if (body.style.display === 'none') {
    body.style.display = '';
    icon.textContent = '▼';
    renderExcludeGrid();
  } else {
    body.style.display = 'none';
    icon.textContent = '▶';
  }
}

function renderExcludeGrid() {
  const grid = document.getElementById('whlExcGrid');
  if (!grid) return;
  let html = '';
  for (let i = 1; i <= MAX_NUM; i++) {
    const exc = excludedNums.includes(i) ? ' excluded' : '';
    html += '<div class="whl-exc-num' + exc + '" data-n="' + i + '" onclick="toggleExclude(' + i + ')">' + i + '</div>';
  }
  grid.innerHTML = html;
  updateExcludeCount();
}

function toggleExclude(n) {
  const idx = excludedNums.indexOf(n);
  if (idx >= 0) {
    excludedNums.splice(idx, 1);
  } else {
    excludedNums.push(n);
  }
  excludedNums.sort((a, b) => a - b);
  renderExcludeGrid();
  renderWheel();
}

function excludeLastDraw() {
  if (lotteryDraws.length === 0) return;
  const lastNums = lotteryDraws[0].numbers;
  lastNums.forEach(n => {
    if (!excludedNums.includes(n)) excludedNums.push(n);
  });
  excludedNums.sort((a, b) => a - b);
  renderExcludeGrid();
  renderWheel();
}

function clearExcluded() {
  excludedNums = [];
  renderExcludeGrid();
  renderWheel();
}

function updateExcludeCount() {
  const el = document.getElementById('whlExcCount');
  const numEl = document.getElementById('whlExcCountNum');
  if (!el || !numEl) return;
  if (excludedNums.length > 0) {
    el.style.display = '';
    numEl.textContent = excludedNums.length;
  } else {
    el.style.display = 'none';
  }
}

// === NUMBER COVERAGE ===
function renderCoverage(combos, pool) {
  const el = document.getElementById('wheelCoverage');
  if (!el || combos.length === 0) { if (el) el.innerHTML = ''; return; }

  // Count appearances of each number across all combos
  const countMap = {};
  pool.forEach(s => countMap[s.num] = 0);
  combos.forEach(c => c.nums.forEach(n => { if (countMap[n] !== undefined) countMap[n]++; }));

  const maxCount = Math.max(...Object.values(countMap), 1);
  const nums = pool.map(s => s.num).sort((a, b) => a - b);

  el.innerHTML = '<h4>📊 號碼覆蓋率</h4>' +
    '<p class="whl-cov-desc">每個號碼在 ' + combos.length + ' 注組合中出現的次數，越深代表被「包得越厚」：</p>' +
    '<div class="whl-cov-grid">' +
    nums.map(n => {
      const cnt = countMap[n] || 0;
      const pct = cnt / maxCount;
      const hue = 30; // orange hue
      const alpha = 0.15 + pct * 0.85;
      const txtColor = pct > 0.5 ? '#000' : 'var(--text-secondary)';
      return '<div class="whl-cov-cell" style="background:rgba(255,136,0,' + alpha.toFixed(2) + ');color:' + txtColor + '">' +
        '<span class="whl-cov-num">' + n + '</span>' +
        '<span class="whl-cov-cnt">' + cnt + '次</span>' +
      '</div>';
    }).join('') +
    '</div>';
}

// === MULTI-PERIOD BACKTEST ===
function renderMultiBacktest(draws, allDraws) {
  const el = document.getElementById('wheelBacktest');
  if (!el || allDraws.length < 5) { if (el) el.innerHTML = ''; return; }

  const isCustomBT = wheelSource === 'custom' && customPoolNums.length > PICK_COUNT;
  const backtestPeriods = Math.min(20, allDraws.length - 5);
  if (backtestPeriods < 3) { el.innerHTML = ''; return; }

  const results = [];
  let totalCost = 0;
  let totalPrize = 0;

  for (let p = 0; p < backtestPeriods; p++) {
    const targetDraw = allDraws[p];
    const histDraws = allDraws.slice(p + 1);
    const rangeDraws = currentRange === 0 ? histDraws : histDraws.slice(0, currentRange);
    if (rangeDraws.length < 5) continue;

    const { combos: btCombos, poolSize: btPoolSize, pool: btPool } = generateWheel(rangeDraws, histDraws, !isCustomBT);
    if (btCombos.length === 0) continue;

    const actual = targetDraw.numbers;
    let bestHit = 0;
    let iterPrize = 0;
    let anyHit = 0;
    for (const combo of btCombos) {
      const hits = combo.nums.filter(n => actual.includes(n)).length;
      if (hits > bestHit) bestHit = hits;
      if (hits > 0) anyHit++;
      for (const tier of PRIZE_539) {
        if (hits === tier.match) { iterPrize += tier.prize; break; }
      }
    }
    const poolHitCount = btPool.filter(s => actual.includes(s.num)).length;
    const cost = btCombos.length * BET_COST;
    totalCost += cost;
    totalPrize += iterPrize;

    results.push({
      period: targetDraw.period,
      date: targetDraw.date,
      actual,
      bestHit,
      anyHit,
      totalCombos: btCombos.length,
      poolHits: poolHitCount,
      poolSize: btPoolSize,
      prize: iterPrize,
      cost,
      net: iterPrize - cost
    });
  }

  if (results.length === 0) { el.innerHTML = ''; return; }

  // Summary stats
  const avgBest = (results.reduce((s, r) => s + r.bestHit, 0) / results.length).toFixed(1);
  const prize3up = results.filter(r => r.bestHit >= 3).length;
  const prize4up = results.filter(r => r.bestHit >= 4).length;
  const netTotal = totalPrize - totalCost;

  el.innerHTML = `
    <div class="whl-bt-panel">
      <h4>🔁 多期回測（近 ${results.length} 期）</h4>
      <p class="whl-bt-desc">用${isCustomBT ? '你的自選號碼' : '同樣的演算法'}和預算 $${currentBudget.toLocaleString()} 回測每一期的表現：</p>
      <div class="whl-bt-summary">
        <div class="whl-bt-stat">
          <span class="whl-bt-stat-val">${avgBest}</span>
          <span class="whl-bt-stat-label">平均最佳命中</span>
        </div>
        <div class="whl-bt-stat">
          <span class="whl-bt-stat-val">${prize3up}</span>
          <span class="whl-bt-stat-label">中參獎以上</span>
        </div>
        <div class="whl-bt-stat">
          <span class="whl-bt-stat-val">${prize4up}</span>
          <span class="whl-bt-stat-label">中貳獎以上</span>
        </div>
        <div class="whl-bt-stat ${netTotal >= 0 ? 'positive' : 'negative'}">
          <span class="whl-bt-stat-val">${netTotal >= 0 ? '+' : ''}$${netTotal.toLocaleString()}</span>
          <span class="whl-bt-stat-label">累積損益</span>
        </div>
      </div>
      <div class="whl-bt-table-wrap">
        <table class="whl-bt-table">
          <thead>
            <tr>
              <th>期數</th>
              <th>開獎號碼</th>
              <th>池命中</th>
              <th>最佳</th>
              <th>損益</th>
            </tr>
          </thead>
          <tbody>
            ${results.map(r => {
              const hitClass = r.bestHit >= 4 ? 'bt-gold' : r.bestHit >= 3 ? 'bt-silver' : r.bestHit >= 2 ? 'bt-bronze' : '';
              return `<tr class="${hitClass}">
                <td class="bt-period">${r.period}</td>
                <td class="bt-nums">${r.actual.map(n => '<span class="num-mini-sm">' + n + '</span>').join('')}</td>
                <td>${r.poolHits}/${r.poolSize}</td>
                <td><strong class="bt-best">${r.bestHit}</strong></td>
                <td class="${r.net >= 0 ? 'bt-profit' : 'bt-loss'}">${r.net >= 0 ? '+' : ''}$${r.net.toLocaleString()}</td>
              </tr>`;
            }).join('')}
          </tbody>
        </table>
      </div>
      <p class="whl-bt-note">⚠️ 回測結果僅供參考，過去表現不代表未來結果。每期開獎都是獨立事件。</p>
    </div>`;
}

// === INIT ===
loadData();
</script>

