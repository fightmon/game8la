// === COMBINATIONS ===
const _cMemo = {};
function C(n, k) {
  if (k < 0 || k > n) return 0;
  if (k === 0 || k === n) return 1;
  const key = n + ',' + k;
  if (_cMemo[key]) return _cMemo[key];
  _cMemo[key] = C(n - 1, k - 1) + C(n - 1, k);
  return _cMemo[key];
}

function combinations(arr, k) {
  if (k === 0) return [[]];
  if (arr.length < k) return [];
  const result = [];
  function helper(start, combo) {
    if (combo.length === k) { result.push([...combo]); return; }
    for (let i = start; i <= arr.length - (k - combo.length); i++) {
      combo.push(arr[i]);
      helper(i + 1, combo);
      combo.pop();
    }
  }
  helper(0, []);
  return result;
}

function getPoolSize(maxBets) {
  const minPool = PICK_COUNT + 2;
  let pool = minPool;
  for (let n = minPool; n <= 20; n++) {
    let c = 1;
    for (let i = 0; i < PICK_COUNT; i++) c = c * (n - i) / (i + 1);
    if (c > maxBets * 3) break;
    pool = n;
  }
  return pool;
}

// === GENERATE WHEEL ===
function generateWheel(draws, allDraws, forceAuto) {
  const maxBets = Math.floor(currentBudget / BET_COST);
  if (maxBets < 1) return { pool: [], combos: [], maxBets: 0, poolSize: 0, totalCombos: 0, isCustom: false };

  const { allScores } = calcSuggestions(draws, allDraws);
  const useCustom = !forceAuto && wheelSource === 'custom' && customPoolNums.length > PICK_COUNT;

  let pool, poolNums, poolSize;

  if (useCustom) {
    poolNums = [...customPoolNums];
    poolSize = poolNums.length;
    pool = poolNums.map(n => {
      const found = allScores.find(s => s.num === n);
      return found || { num: n, total: 0, freqScore: 0, missScore: 0, inLastDraw: false };
    });
  } else {
    // Filter out excluded numbers from auto scoring
    const filteredScores = excludedNums.length > 0
      ? allScores.filter(s => !excludedNums.includes(s.num))
      : allScores;
    poolSize = getPoolSize(maxBets);
    poolSize = Math.min(poolSize, filteredScores.length);
    pool = filteredScores.slice(0, poolSize);
    poolNums = pool.map(s => s.num);
  }

  const totalCombosCount = C(poolSize, PICK_COUNT);

  const MAX_ENUM = 5000;
  let allCombos;

  const scoreMap = new Map();
  pool.forEach(p => scoreMap.set(p.num, p));

  function scoreCombo(combo) {
    let score = 0, hotCount = 0, missCount = 0;
    for (const n of combo) {
      const s = scoreMap.get(n);
      if (s) {
        score += s.total;
        if (s.freqScore >= 70) hotCount++;
        if (s.missScore >= 70) missCount++;
      }
    }
    return { nums: combo, score: Math.round(score * 10) / 10, hotCount, missCount };
  }

  const needCombos = Math.min(maxBets, MAX_ENUM);

  if (totalCombosCount <= MAX_ENUM) {
    allCombos = combinations(poolNums, PICK_COUNT).map(scoreCombo);
  } else {
    const sampleTarget = Math.min(needCombos * 3, MAX_ENUM);
    const seen = new Set();
    const sampled = [];
    const sorted = [...poolNums].sort((a, b) => {
      return (scoreMap.get(b)?.total || 0) - (scoreMap.get(a)?.total || 0);
    });
    const topN = Math.min(sorted.length, 12);
    const topCombos = combinations(sorted.slice(0, topN), PICK_COUNT);
    for (const c of topCombos) {
      const key = c.join(',');
      if (!seen.has(key)) { seen.add(key); sampled.push(scoreCombo(c)); }
      if (sampled.length >= sampleTarget) break;
    }
    let attempts = 0;
    while (sampled.length < sampleTarget && attempts < sampleTarget * 10) {
      attempts++;
      const combo = [];
      const used = new Set();
      while (combo.length < PICK_COUNT) {
        const idx = Math.floor(Math.random() * poolNums.length);
        if (!used.has(idx)) { used.add(idx); combo.push(poolNums[idx]); }
      }
      combo.sort((a, b) => a - b);
      const key = combo.join(',');
      if (!seen.has(key)) { seen.add(key); sampled.push(scoreCombo(combo)); }
    }
    allCombos = sampled;
  }

  allCombos.sort((a, b) => b.score - a.score);
  const combos = allCombos.slice(0, needCombos);

  return { pool, combos, maxBets, poolSize, totalCombos: totalCombosCount, isCustom: useCustom };
}

