<script is:inline>
// === 539 WHEEL CALCULATOR (standalone version of GAME8LA 包牌產生器) ===

const MAX_NUM = 39;
const PICK_COUNT = 5;
const BET_COST = 50;

let lotteryDraws = [];   // all historical draws
let currentBudget = 1000;
let currentRange = 50;
let wheelSource = 'auto';
let customPoolNums = [];
let excludedNums = [];
const MAX_CUSTOM_POOL = 12;

// === DATA LOADING (三層來源：Worker KV → 靜態 JSON → Live API 合併) ===
async function loadData() {
  const loading = document.getElementById('loadingState');
  const section = document.getElementById('wheelSection');
  try {
    let workerData = null;
    let staticData = null;
    const isLocal = location.hostname === 'localhost' || location.hostname === '127.0.0.1';

    // 來源 1：Worker KV（localhost 跳過）
    if (!isLocal) {
      try {
        const res = await fetch('https://lottery-cron.fightmon.workers.dev/data/daily_cash_539');
        if (res.ok) workerData = await res.json();
      } catch (e) { /* fall through */ }
    }

    // 來源 2：靜態 JSON
    try {
      const res2 = await fetch('/data/daily-cash-539.json');
      if (res2.ok) staticData = await res2.json();
    } catch (e) { /* fall through */ }

    // 取較新的作為 base
    let baseData = null;
    if (workerData && staticData) {
      baseData = (workerData.lastUpdated >= staticData.lastUpdated) ? workerData : staticData;
    } else {
      baseData = workerData || staticData;
    }

    // 來源 3：即時 API（補入最新一期）
    const LIVE_API = isLocal
      ? 'https://game8la.com/api/lottery'
      : '/api/lottery';
    try {
      const apiRes = await fetch(LIVE_API, { cache: 'no-store' });
      if (apiRes.ok) {
        const apiJson = await apiRes.json();
        const gameData = apiJson.data?.daily_cash;
        if (gameData && gameData.numbers && gameData.numbers.length > 0) {
          const freshDraws = [];
          freshDraws.push({ period: gameData.period, date: gameData.date, numbers: gameData.numbers });
          if (Array.isArray(gameData.history)) {
            for (const h of gameData.history) {
              freshDraws.push({ period: h.period, date: h.date, numbers: h.numbers });
            }
          }
          if (baseData && baseData.draws) {
            const existingPeriods = new Set(baseData.draws.map(d => d.period));
            let merged = false;
            for (const fd of freshDraws) {
              if (fd.period && !existingPeriods.has(fd.period)) {
                baseData.draws.unshift(fd);
                existingPeriods.add(fd.period);
                merged = true;
              }
            }
            if (merged) {
              baseData.draws.sort((a, b) => (b.date || '').localeCompare(a.date || '') || (Number(b.period) || 0) - (Number(a.period) || 0));
            }
          } else if (!baseData) {
            baseData = { draws: freshDraws };
          }
        }
      }
    } catch (e) { /* fall through */ }

    if (baseData && baseData.draws && baseData.draws.length > 0) {
      lotteryDraws = baseData.draws;
      loading.style.display = 'none';
      section.style.display = '';
      renderWheel();
    } else {
      loading.innerHTML = '<p class="loading-error">⚠️ 無法載入 539 開獎數據，請稍後再試。</p>';
    }
  } catch (err) {
