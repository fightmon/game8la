function copyWheelText() {
  if (lotteryDraws.length === 0) return;
  const draws = currentRange === 0 ? lotteryDraws : lotteryDraws.slice(0, currentRange);
  const allDraws = lotteryDraws;
  const { combos, poolSize, isCustom } = generateWheel(draws, allDraws);
  if (combos.length === 0) return;

  const today = new Date();
  const dateStr = today.getFullYear() + '/' + String(today.getMonth() + 1).padStart(2, '0') + '/' + String(today.getDate()).padStart(2, '0');
  const lastPeriod = allDraws[0]?.period || '';

  // 快速跑模擬取摘要數據
  const mc = monteCarloSim(combos, 10000);
  const totalCost = combos.length * BET_COST;
  const anyWinPct = (100 - mc.pct[0] - mc.pct[1]).toFixed(1);
  const threeUpPct = (mc.pct[3] + mc.pct[4] + mc.pct[5]).toFixed(1);

  let text = '🎯 539 包牌組合 — GAME8LA\n';
  text += '日期：' + dateStr + (lastPeriod ? '  最新一期：' + lastPeriod : '') + '\n';
  text += '預算：$' + currentBudget.toLocaleString() + ' ／ ' + combos.length + ' 注 ／ ' + poolSize + ' 碼' + (isCustom ? '（自選）' : '') + '\n';
  text += '────────────────\n';
  text += '🎲 萬次模擬結果：' + threeUpPct + '% 機率中參獎以上\n';
  text += '💸 期望回收：$' + mc.avgReturn.toLocaleString() + ' / 投入 $' + totalCost.toLocaleString() + '\n';
  text += '────────────────\n';
  combos.forEach((c, i) => {
    text += '第' + String(i + 1).padStart(2, ' ') + '注：' + c.nums.map(n => String(n).padStart(2, '0')).join(' ') + '\n';
  });
  text += '────────────────\n';
