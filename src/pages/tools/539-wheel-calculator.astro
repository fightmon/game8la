  }
}

// === STATISTICS HELPERS ===
function calcFrequency(draws) {
  const freq = {};
  for (let i = 1; i <= MAX_NUM; i++) freq[i] = 0;
  draws.forEach(d => d.numbers.forEach(n => freq[n]++));
  return freq;
}

function calcMissing(allDraws) {
  const missing = {};
  for (let i = 1; i <= MAX_NUM; i++) {
    missing[i] = 0;
    for (let j = 0; j < allDraws.length; j++) {
      if (allDraws[j].numbers.includes(i)) break;
      missing[i]++;
    }
  }
  return missing;
}

function calcRepeat(allDraws) {
  const stats = {};
  for (let n = 1; n <= MAX_NUM; n++) {
    stats[n] = { appeared: 0, repeated: 0 };
  }
  for (let i = 0; i < allDraws.length - 1; i++) {
    const curr = allDraws[i].numbers;
    const next = allDraws[i + 1].numbers;
    curr.forEach(n => {
      stats[n].appeared++;
      if (next.includes(n)) stats[n].repeated++;
    });
  }
  return stats;
}

// === SCORING (same algorithm as lottery/analysis) ===
function calcSuggestions(draws, allDraws) {
  const freq = calcFrequency(draws);
  const missing = calcMissing(allDraws);
  const repeatStats = calcRepeat(allDraws);
  const lastDraw = allDraws.length > 0 ? allDraws[0].numbers : [];

  const vals = arr => arr.length ? arr : [0];
  const minMax = (arr) => {
    const mn = Math.min(...vals(arr)), mx = Math.max(...vals(arr));
    return { min: mn, max: mx, range: mx - mn || 1 };
  };

  const freqVals = Object.values(freq);
  const missVals = Object.values(missing);
  const fNorm = minMax(freqVals);
  const mNorm = minMax(missVals);

  const scores = [];
  for (let n = 1; n <= MAX_NUM; n++) {
    const freqScore = ((freq[n] - fNorm.min) / fNorm.range) * 100;
    const missScore = ((missing[n] - mNorm.min) / mNorm.range) * 100;
    let repeatScore = 0;
    if (lastDraw.includes(n) && repeatStats[n]) {
      const s = repeatStats[n];
      repeatScore = s.appeared > 0 ? (s.repeated / s.appeared) * 100 : 0;
      repeatScore = Math.min(repeatScore * 2, 100);
    }
    const total = freqScore * 0.40 + missScore * 0.35 + repeatScore * 0.25;
    scores.push({
      num: n,
      total: Math.round(total * 10) / 10,
      freqScore: Math.round(freqScore),
      missScore: Math.round(missScore),
      repeatScore: Math.round(repeatScore),
      freq: freq[n],
      missing: missing[n],
      inLastDraw: lastDraw.includes(n)
    });
  }
  scores.sort((a, b) => b.total - a.total);
  return { allScores: scores };
}

