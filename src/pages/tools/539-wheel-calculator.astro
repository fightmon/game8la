---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareButtons from '../../components/ShareButtons.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "539包牌是什麼意思？",
      "acceptedAnswer": { "@type": "Answer", "text": "包牌是指從 1–39 號中選超過 5 個號碼，將所有可能的 5 碼組合都買下來，用更高的投注金額換取更大的中獎機會。例如包 7 碼就是把 7 個號碼的所有 21 種組合都買。" }
    },
    {
      "@type": "Question",
      "name": "539 包幾碼最划算？",
      "acceptedAnswer": { "@type": "Answer", "text": "沒有絕對划算的碼數。包 6 碼花 300 元，中頭獎機率提升到原本的 6 倍；包 7 碼花 1050 元，提升 21 倍。碼數越多花費呈組合數爆炸成長，建議用計算器算出預算範圍內的最佳碼數。" }
    },
    {
      "@type": "Question",
      "name": "539 包牌一定會中嗎？",
      "acceptedAnswer": { "@type": "Answer", "text": "不一定。即使包 10 碼（252 注），頭獎中獎率也只有約 0.047%。包牌只是提高機率，不保證中獎。長期來看，彩券的期望值是負的，包牌不會改變這個事實。" }
    },
    {
      "@type": "Question",
      "name": "539 包牌要花多少錢？",
      "acceptedAnswer": { "@type": "Answer", "text": "每注 50 元。包 6 碼 = 6 注 = 300 元；包 7 碼 = 21 注 = 1,050 元；包 8 碼 = 56 注 = 2,800 元；包 10 碼 = 252 注 = 12,600 元。碼數越多，費用呈指數增長。" }
    },
    {
      "@type": "Question",
      "name": "包牌的期望值是正還是負的？",
      "acceptedAnswer": { "@type": "Answer", "text": "負的。今彩 539 整體回饋率約 55–58%，意味著每花 100 元，長期平均只能拿回約 55–58 元。包牌不會改變這個數學事實，但可以讓中獎體驗更頻繁（雖然多數是小獎）。" }
    },
    {
      "@type": "Question",
      "name": "539 立柱包牌是什麼？",
      "acceptedAnswer": { "@type": "Answer", "text": "立柱包牌是把號碼分成幾組「柱」，每柱各選一定數量的號碼，再交叉排列產生組合。優點是可以用較少的注數涵蓋更多號碼，但涵蓋率不如全包。本計算器採用全組合包牌（也稱輪轉包牌），確保所選號碼的每一種 5 碼組合都不遺漏。" }
    },
    {
      "@type": "Question",
      "name": "539 包牌跟拖牌差在哪？",
      "acceptedAnswer": { "@type": "Answer", "text": "包牌是所有號碼地位相同，全部交叉組合；拖牌（膽拖）是指定 1～2 個「必出號」（膽碼），其餘號碼再跟膽碼配對。拖牌注數較少、花費較低，但如果膽碼沒開就全軍覆沒。兩者各有風險取捨。" }
    },
    {
      "@type": "Question",
      "name": "今彩 539 包牌可以線上買嗎？",
      "acceptedAnswer": { "@type": "Answer", "text": "可以。台灣彩券官方 App 和官網都支援今彩 539 線上投注，也可以選擇「多碼包牌」功能直接下注。投注前請確認自己的預算上限，量力而為。" }
    },
    {
      "@type": "Question",
      "name": "539 包牌有什麼技巧嗎？",
      "acceptedAnswer": { "@type": "Answer", "text": "數學上沒有任何方法能提高中獎期望值，因為每期開獎都是獨立隨機事件。但實務上有幾個方向：① 控制碼數和預算上限，不要包到超出能力；② 參考冷熱號統計決定選號範圍；③ 使用號碼排除功能去掉你認為不會出的號。記住：包牌是娛樂工具，不是致富手段。" }
    }
  ]
