---
import BaseLayout from '../../layouts/BaseLayout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "什麼是打碼量？",
      "acceptedAnswer": { "@type": "Answer", "text": "打碼量就是你必須累計下注的金額才能提款。例如打碼倍數 20 倍、存款加紅利共 2000 元，你就要下注 40,000 元才能出金。" }
    },
    {
      "@type": "Question",
      "name": "娛樂城紅利值得拿嗎？",
      "acceptedAnswer": { "@type": "Answer", "text": "取決於打碼倍數和遊戲類型。打碼倍數越高、有效投注比例越低，紅利的實際價值就越差。用計算器算一次就知道值不值得。" }
    },
    {
      "@type": "Question",
      "name": "有效投注比例是什麼意思？",
      "acceptedAnswer": { "@type": "Answer", "text": "有些娛樂城規定特定遊戲的投注只算部分有效。例如百家樂只算 30%，表示你押 1000 元只計入 300 元打碼量，實際要押的金額會變成 3.3 倍。" }
    }
  ]
};

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "娛樂城獎金計算器 — 打碼量與預期虧損試算",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "TWD" },
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.8", "ratingCount": "62" }
};
---
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />

<BaseLayout
  currentPage="tools"
  title="娛樂城獎金計算器（免費）｜打碼量試算、紅利值不值得拿一算就知 - GAME8LA"
  description="免費線上娛樂城獎金計算器！輸入存款、贈送金額、打碼倍數，即時算出總打碼量、預期虧損、淨收益。芭樂子幫你判斷這個紅利值不值得拿，別再被「存 20000 送 2000」騙了。"
  ogImage="https://game8la.com/images/og-image.webp"
>

<div class="container">
  <!-- Hero -->
  <div class="bc-hero">
    <h1>💰 娛樂城獎金計算器</h1>
    <p class="bc-slogan">存多少送多少？算一下就知道是糖還是毒。</p>
    <p class="bc-desc">輸入娛樂城的紅利條件，芭樂子幫你算出打碼量、預期虧損，告訴你這個紅利到底值不值得拿。</p>
  </div>

  <!-- 計算器主體 -->
  <div class="bc-calc-wrap">
    <div class="bc-inputs">
      <div class="bc-field">
        <label for="deposit">存款金額 (TWD)</label>
        <input type="number" id="deposit" value="10000" min="0" step="1000" inputmode="numeric">
      </div>
      <div class="bc-field">
        <label for="bonus">贈送金額 (TWD)</label>
        <input type="number" id="bonus" value="1000" min="0" step="100" inputmode="numeric">
        <span class="bc-pct" id="bonusPct">= 紅利 10%</span>
      </div>
      <div class="bc-field">
        <label for="wager">打碼倍數</label>
        <input type="number" id="wager" value="20" min="1" max="100" step="1" inputmode="numeric">
        <span class="bc-hint">常見範圍：1x ~ 60x</span>
      </div>
      <div class="bc-field">
        <label for="gameType">遊戲類型</label>
        <select id="gameType">
          <option value="baccarat" selected>百家樂（RTP 98.76%）</option>
          <option value="slots_high">老虎機 — 高 RTP（96%）</option>
          <option value="slots_mid">老虎機 — 中 RTP（93%）</option>
          <option value="slots_low">老虎機 — 低 RTP（88%）</option>
          <option value="sports">體育投注（RTP ~95%）</option>
          <option value="roulette">輪盤（RTP 97.3%）</option>
          <option value="blackjack">21 點（RTP 99.5%）</option>
          <option value="custom">自訂 RTP</option>
        </select>
      </div>
      <div class="bc-field bc-custom-rtp" id="customRtpWrap" style="display:none">
        <label for="customRtp">自訂 RTP (%)</label>
        <input type="number" id="customRtp" value="96" min="50" max="100" step="0.1" inputmode="decimal">
      </div>
      <div class="bc-field">
        <label for="validRatio">有效投注比例 (%)</label>
        <input type="number" id="validRatio" value="100" min="1" max="100" step="1" inputmode="numeric">
        <span class="bc-hint">百家樂常見 30%，老虎機通常 100%</span>
      </div>
    </div>

    <!-- 結果區 -->
    <div class="bc-result" id="resultArea">
      <div class="bc-result-grid">
        <div class="bc-stat">
          <span class="bc-stat-label">紅利百分比</span>
          <span class="bc-stat-value" id="rBonusPct">10%</span>
        </div>
        <div class="bc-stat">
          <span class="bc-stat-label">總打碼量</span>
          <span class="bc-stat-value" id="rWagerTotal">220,000</span>
        </div>
        <div class="bc-stat">
          <span class="bc-stat-label">實際要押注</span>
          <span class="bc-stat-value" id="rActualBet">220,000</span>
        </div>
        <div class="bc-stat">
          <span class="bc-stat-label">預期虧損</span>
          <span class="bc-stat-value bc-loss" id="rExpLoss">-2,728</span>
        </div>
        <div class="bc-stat bc-stat-big">
          <span class="bc-stat-label">淨收益</span>
          <span class="bc-stat-value" id="rNetGain">-1,728</span>
        </div>
        <div class="bc-stat bc-stat-worst">
          <span class="bc-stat-label">⚠️ 最壞情況</span>
          <span class="bc-stat-value bc-loss" id="rWorstCase">-11,000</span>
          <span class="bc-stat-sub" id="rWorstDesc">存款 + 紅利全部輸光</span>
        </div>
      </div>

      <!-- 芭樂子判定 -->
      <div class="bc-verdict" id="verdictArea">
        <div class="bc-verdict-img-wrap">
          <img class="bc-verdict-img" id="verdictImg" src="/images/tools/bonus-calc/guava-1.webp" alt="芭樂子判定" width="200" height="200" loading="lazy">
        </div>
        <div class="bc-verdict-text">
          <div class="bc-verdict-tag" id="verdictTag">✅ 值得拿</div>
          <p class="bc-verdict-msg" id="verdictMsg">這個紅利的數學是站在你這邊的。</p>
        </div>
      </div>

      <!-- 分享按鈕 -->
      <div class="bc-share-row">
        <button class="bc-share-toggle" id="shareToggle" type="button">📤 分享結果</button>
      </div>
      <div class="bc-share-panel" id="sharePanel" style="display:none">
        <div class="bc-share-buttons">
          <button type="button" data-bc-share="facebook" class="bshare-btn bshare-fb">Facebook</button>
          <button type="button" data-bc-share="x" class="bshare-btn bshare-x">X</button>
          <button type="button" data-bc-share="threads" class="bshare-btn bshare-threads">Threads</button>
          <button type="button" data-bc-share="ig" class="bshare-btn bshare-ig">Instagram</button>
          <button type="button" data-bc-share="copy" class="bshare-btn bshare-copy">複製連結</button>
        </div>
      </div>

      <!-- 詳細計算過程 -->
      <details class="bc-details">
        <summary>📊 查看計算過程</summary>
        <div class="bc-breakdown" id="breakdown"></div>
      </details>
    </div>
  </div>

  <!-- 知識區 -->
  <section class="bc-edu">
    <h2>打碼量怎麼算？</h2>
    <p>打碼量 =（存款 + 紅利）× 打碼倍數。假設你存 10,000 送 1,000，打碼 20 倍，那你必須累計下注 (10,000 + 1,000) × 20 = <strong>220,000 元</strong>才能提款。</p>
    <p>但這還沒完——每次下注都有莊家優勢。以百家樂（RTP 98.76%）為例，每押 100 元預期虧 1.24 元。下注 220,000 元預期虧損就是 220,000 × 1.24% = <strong>2,728 元</strong>，比你拿到的 1,000 元紅利還多。這就是為什麼很多紅利看起來划算，實際上是虧的。</p>

    <h2>有效投注比例的陷阱</h2>
    <p>很多娛樂城會規定「百家樂投注只計算 30% 有效」。這代表你押 1,000 元只算 300 元打碼量，實際要押的金額直接變 3.3 倍。如果打碼量已經很高，再打折就是雙重陷阱。</p>

    <h2>常見問題</h2>
    <h3>什麼是打碼量？</h3>
    <p>打碼量就是你必須累計下注的金額才能提款。例如打碼倍數 20 倍、存款加紅利共 2,000 元，你就要下注 40,000 元才能出金。</p>

    <h3>娛樂城紅利值得拿嗎？</h3>
    <p>取決於打碼倍數和遊戲類型。打碼倍數越高、有效投注比例越低，紅利的實際價值就越差。用計算器算一次就知道值不值得。</p>

    <h3>有效投注比例是什麼意思？</h3>
    <p>有些娛樂城規定特定遊戲的投注只算部分有效。例如百家樂只算 30%，表示你押 1,000 元只計入 300 元打碼量，實際要押的金額會變成 3.3 倍。</p>
  </section>

  <!-- 芭樂子老實說 -->
  <div class="bc-honest">
    <p class="bc-honest-title">🍐 芭樂子老實說</p>
    <p>「存 20000 送 2000」聽起來是 10% 的免費紅利，但你不會免費拿走這筆錢——打碼量會確保你在提款之前把紅利連本帶利還給莊家。這個計算器不是要教你怎麼賺錢，是要讓你在按下「領取紅利」之前，知道自己到底在簽什麼條件。如果算出來是負的，那就別拿。省下來的錢，就是你真正賺到的。</p>
  </div>

  <!-- 導流 CTA -->
  <div class="bc-cta-bar">
    <p>🌿 算完紅利，也順便檢查一下你的娛樂城安全嗎？</p>
    <div class="bc-cta-links">
      <a href="/casino-check/" class="bc-cta-link">🔍 娛樂城體檢</a>
      <a href="/tools/" class="bc-cta-link">🔧 更多免費工具</a>
      <a href="/articles/casino-withdrawal-masterguide/" class="bc-cta-link">💸 出金完整攻略</a>
    </div>
  </div>

  <div style="text-align:center;margin:2rem 0">
    <a href="/tools/" class="btn-outline">&larr; 回工具箱</a>
  </div>
</div>

<style>
/* ========== Hero ========== */
