  .bc-verdict { flex-direction: column; text-align: center; }
  .bc-verdict-img { width: 120px; height: 120px; }
  .bc-stat-big .bc-stat-value { font-size: 1.5rem; }
}

/* ========== Utility ========== */
.btn-outline {
  display: inline-block;
  padding: 10px 24px;
  border: 1.5px solid rgba(255,255,255,0.15);
  border-radius: 10px;
  color: #ccc;
  text-decoration: none;
  font-size: 0.95rem;
  transition: border-color 0.2s, color 0.2s;
}
.btn-outline:hover { border-color: var(--neon-green, #39FF14); color: #fff; }

/* Net gain color classes */
.net-positive { color: var(--neon-green, #39FF14) !important; }
.net-negative { color: #ff4d4d !important; }

@media (prefers-reduced-motion: reduce) {
  .bc-verdict-img { animation: none; }
}
</style>

<script>
(function() {
  // RTP 表
  var RTP = {
    baccarat: 0.9876,
    slots_high: 0.96,
    slots_mid: 0.93,
    slots_low: 0.88,
    sports: 0.95,
    roulette: 0.973,
    blackjack: 0.995,
    custom: 0.96
  };

  // 芭樂子判定素材
  var VERDICTS = {
    good: {
      img: '/images/tools/bonus-calc/guava-1.webp',
      tag: '✅ 值得拿',
      msgs: [
        '這個紅利數學站在你這邊，拿了不會虧。',
        '條件不錯，打碼量在合理範圍內。但還是要設停損。',
        '淨收益是正的，這在娛樂城紅利裡算很少見了。把握！'
      ]
    },
    meh: {
      img: '/images/tools/bonus-calc/guava-2.webp',
      tag: '⚠️ 勉強打平',
      msgs: [
        '數學上差不多打平，賺不多但也不會虧太慘。看你要不要花這時間。',
        '淨收益接近零。你的時間值多少？算進去可能就不划算了。',
        '這個紅利不算坑，但也不算好。你自己決定。'
      ]
    },
    bad: {
      img: '/images/tools/bonus-calc/guava-3.webp',
      tag: '❌ 不划算',
      msgs: [
        '打碼量太高了，預期虧損會吃掉你的紅利。別碰。',
        '看起來是紅利，實際上是陷阱。你會在打碼過程中虧更多。',
        '數學不會騙人——這個紅利拿了反而虧。留著本金比較聰明。'
      ]
    },
    danger: {
      img: '/images/tools/bonus-calc/guava-4.webp',
      tag: '☠️ 嚴重倒貼',
      msgs: [
        '這根本是陷阱！預期虧損遠超紅利金額，離越遠越好。',
        '你拿到的紅利根本不夠付打碼的代價。這不是優惠，是圈套。',
        '芭樂子看了都替你心疼。這種條件只有莊家在笑。拜託不要拿。'
      ]
    }
  };

  // DOM refs
  var depositEl = document.getElementById('deposit');
  var bonusEl = document.getElementById('bonus');
  var wagerEl = document.getElementById('wager');
  var gameTypeEl = document.getElementById('gameType');
  var customRtpEl = document.getElementById('customRtp');
  var customRtpWrap = document.getElementById('customRtpWrap');
  var validRatioEl = document.getElementById('validRatio');
  var bonusPctEl = document.getElementById('bonusPct');

  // Result DOM
  var rBonusPct = document.getElementById('rBonusPct');
  var rWagerTotal = document.getElementById('rWagerTotal');
  var rActualBet = document.getElementById('rActualBet');
  var rExpLoss = document.getElementById('rExpLoss');
  var rNetGain = document.getElementById('rNetGain');
  var rWorstCase = document.getElementById('rWorstCase');
  var rWorstDesc = document.getElementById('rWorstDesc');
  var verdictArea = document.getElementById('verdictArea');
  var verdictImg = document.getElementById('verdictImg');
  var verdictTag = document.getElementById('verdictTag');
  var verdictMsg = document.getElementById('verdictMsg');
  var breakdownEl = document.getElementById('breakdown');

  function fmt(n) {
    return Math.round(n).toLocaleString('zh-TW');
  }

  function calculate() {
    var deposit = parseFloat(depositEl.value) || 0;
    var bonus = parseFloat(bonusEl.value) || 0;
    var wagerX = parseFloat(wagerEl.value) || 1;
    var gameType = gameTypeEl.value;
    var validRatio = (parseFloat(validRatioEl.value) || 100) / 100;
    var rtp = gameType === 'custom' ? (parseFloat(customRtpEl.value) || 96) / 100 : RTP[gameType];

    // 紅利百分比
    var pct = deposit > 0 ? (bonus / deposit * 100) : 0;
    bonusPctEl.textContent = '= 紅利 ' + pct.toFixed(1) + '%';
    rBonusPct.textContent = pct.toFixed(1) + '%';

    // 打碼量
    var totalBase = deposit + bonus;
    var wagerTotal = totalBase * wagerX;
    rWagerTotal.textContent = fmt(wagerTotal);

    // 實際要押注（考慮有效比例）
    var actualBet = validRatio > 0 ? wagerTotal / validRatio : wagerTotal;
    rActualBet.textContent = fmt(actualBet);

    // 預期虧損
    var houseEdge = 1 - rtp;
    var expLoss = actualBet * houseEdge;
    rExpLoss.textContent = '-' + fmt(expLoss);

    // 淨收益
    var netGain = bonus - expLoss;
    rNetGain.textContent = (netGain >= 0 ? '+' : '') + fmt(netGain);
    rNetGain.className = 'bc-stat-value ' + (netGain >= 0 ? 'net-positive' : 'net-negative');

    // 最壞情況：存款 + 紅利全部輸光（破產）
    var worstLoss = deposit + bonus;
    rWorstCase.textContent = '-' + fmt(worstLoss);
    // 破產機率粗估：打碼量越高、RTP 越低，破產機率越高
    var roundsNeeded = Math.ceil(actualBet / totalBase);
    // 簡化估算：基於凱利公式概念，連輸機率
    var bustProb = Math.min(99, Math.max(1, Math.round((1 - rtp) * roundsNeeded * 1.5)));
    if (actualBet <= totalBase * 3) bustProb = Math.min(bustProb, 15);
    rWorstDesc.textContent = '存款 + 紅利全輸光（機率約 ' + bustProb + '%）';

    // 判定（以淨收益相對紅利金額分四級）
    var level;
    if (netGain > 0) {
      level = 'good';
    } else if (netGain >= -bonus) {
      level = 'meh';
    } else if (netGain >= -bonus * 2) {
      level = 'bad';
    } else {
      level = 'danger';
    }

    var v = VERDICTS[level];
    verdictArea.className = 'bc-verdict ' + level;
    verdictImg.src = v.img;
    verdictImg.alt = '芭樂子判定：' + v.tag;
    verdictTag.textContent = v.tag;
    verdictMsg.textContent = v.msgs[Math.floor(Math.random() * v.msgs.length)];

    // 計算過程
    var rtpPct = (rtp * 100).toFixed(2);
    var edgePct = (houseEdge * 100).toFixed(2);
    var validPct = (validRatio * 100).toFixed(0);
    breakdownEl.innerHTML =
      '<div class="step"><strong>紅利百分比：</strong>' + fmt(bonus) + ' ÷ ' + fmt(deposit) + ' = ' + pct.toFixed(1) + '%</div>' +
      '<div class="step"><strong>打碼基數：</strong>存款 ' + fmt(deposit) + ' + 紅利 ' + fmt(bonus) + ' = ' + fmt(totalBase) + '</div>' +
      '<div class="step"><strong>總打碼量：</strong>' + fmt(totalBase) + ' × ' + wagerX + ' 倍 = ' + fmt(wagerTotal) + '</div>' +
      (validRatio < 1 ? '<div class="step"><strong>有效比例修正：</strong>' + fmt(wagerTotal) + ' ÷ ' + validPct + '% = ' + fmt(actualBet) + '（實際要押注）</div>' : '') +
      '<div class="step"><strong>遊戲 RTP：</strong>' + rtpPct + '%，莊家優勢 = ' + edgePct + '%</div>' +
      '<div class="step"><strong>預期虧損：</strong>' + fmt(actualBet) + ' × ' + edgePct + '% = ' + fmt(expLoss) + '</div>' +
      '<div class="step"><strong>淨收益：</strong>紅利 ' + fmt(bonus) + ' − 虧損 ' + fmt(expLoss) + ' = <strong style="color:' + (netGain >= 0 ? '#39FF14' : '#ff4d4d') + '">' + (netGain >= 0 ? '+' : '') + fmt(netGain) + '</strong></div>';
  }

  // 事件綁定 — 即時計算
  [depositEl, bonusEl, wagerEl, validRatioEl, customRtpEl].forEach(function(el) {
    el.addEventListener('input', calculate);
  });
  gameTypeEl.addEventListener('change', function() {
    customRtpWrap.style.display = gameTypeEl.value === 'custom' ? 'flex' : 'none';
    calculate();
  });

  // 初始計算
  calculate();

  // =================================================================
  // Share Panel
  // =================================================================
  var shareToggle = document.getElementById('shareToggle');
  var sharePanel = document.getElementById('sharePanel');

  shareToggle.addEventListener('click', function() {
    if (sharePanel.style.display === 'none') {
      sharePanel.style.display = 'block';
      shareToggle.textContent = '✕ 收起';
    } else {
      sharePanel.style.display = 'none';
      shareToggle.textContent = '📤 分享結果';
    }
  });

  function getShareText() {
    var deposit = depositEl.value || 0;
    var bonus = bonusEl.value || 0;
    var net = rNetGain.textContent;
    var tag = verdictTag.textContent;
    var text = '娛樂城紅利值不值得拿？存 ' + Number(deposit).toLocaleString('zh-TW') + ' 送 ' + Number(bonus).toLocaleString('zh-TW') + '，淨收益 ' + net + ' ' + tag + ' — GAME8LA 獎金計算器';
    var url = 'https://game8la.com/tools/bonus-calculator/';
    return { text: text, url: url };
  }

  function openPopup(url) {
    window.open(url, '_blank', 'width=600,height=400,noopener,noreferrer');
  }

  function showBcToast(msg) {
    var existing = document.querySelector('.bc-share-toast');
    if (existing) existing.remove();
    var toast = document.createElement('div');
    toast.className = 'bc-share-toast';
    toast.textContent = msg;
    document.body.appendChild(toast);
    requestAnimationFrame(function() {
      requestAnimationFrame(function() { toast.classList.add('show'); });
    });
    setTimeout(function() {
      toast.classList.remove('show');
      setTimeout(function() { toast.remove(); }, 300);
    }, 2500);
  }

  document.querySelectorAll('[data-bc-share]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var kind = btn.getAttribute('data-bc-share');
      var d = getShareText();
      var eUrl = encodeURIComponent(d.url);
      var eText = encodeURIComponent(d.text);

      if (kind === 'facebook') {
        openPopup('https://www.facebook.com/sharer/sharer.php?u=' + eUrl + '&quote=' + eText);
      } else if (kind === 'x') {
        openPopup('https://twitter.com/intent/tweet?url=' + eUrl + '&text=' + eText);
      } else if (kind === 'threads') {
        openPopup('https://www.threads.net/intent/post?text=' + encodeURIComponent(d.text + ' ' + d.url));
      } else if (kind === 'ig') {
        navigator.clipboard.writeText(d.url).then(function() {
          showBcToast('已複製連結！請貼到 IG 限動或私訊分享 📲');
        }).catch(function() {
          showBcToast('請手動複製：' + d.url);
        });
        setTimeout(function() { window.open('https://www.instagram.com/', '_blank', 'noopener,noreferrer'); }, 600);
      } else if (kind === 'copy') {
        navigator.clipboard.writeText(d.url).then(function() {
          showBcToast('✅ 連結已複製到剪貼簿！');
        }).catch(function() {
          showBcToast('請手動複製：' + d.url);
        });
      }
    });
  });
})();
</script>

</BaseLayout>
