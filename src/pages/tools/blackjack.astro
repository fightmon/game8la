<style is:global>
  /* === HERO === */
  .bj-hero {
    text-align: center;
    padding: 3rem 1rem 1rem;
  }
  .bj-hero h1 {
    font-size: 2.2rem;
    margin-bottom: 0.5rem;
  }
  .bj-slogan {
    color: var(--guava-green, #39FF14);
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .bj-desc {
    color: #bbb;
    font-size: 1rem;
    max-width: 580px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* === GAME WRAPPER === */
  .bj-game-wrapper {
    max-width: 700px;
    margin: 2rem auto;
  }

  /* === BET AREA === */
  .bj-bet-area {
    text-align: center;
    padding: 1.5rem;
    background: rgba(255,255,255,0.02);
    border: 1px solid #2a2a2a;
    border-radius: 16px;
    margin-bottom: 1rem;
  }
  .bj-balance-display {
    margin-bottom: 1rem;
  }
  .bj-balance-label {
    color: #999;
    font-size: 0.9rem;
    margin-right: 8px;
  }
  .bj-balance-value {
    color: #f5b800;
    font-size: 1.8rem;
    font-weight: 800;
  }
  .bj-points-mode {
    margin-top: 0.5rem;
    padding: 0.45rem 0.9rem;
    border-radius: 10px;
    border: 1.5px solid #FFD700;
    background: rgba(255,215,0,0.12);
    color: #FFD700;
    font-weight: 800;
    cursor: pointer;
    font-size: 0.9rem;
  }
  .bj-points-mode:hover { background: rgba(255,215,0,0.22); }
  .bj-points-mode.on { border-color:#39ff14; color:#39ff14; background:rgba(57,255,20,0.12); cursor:default; }
  .bj-balance-value.bj-pulse {
    animation: bjPulse 0.4s ease;
  }
  @keyframes bjPulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.15); }
    100% { transform: scale(1); }
  }
  .bj-chip-row {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .bj-chip {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(135deg, #f5b800, #d4a000);
    border: 3px solid #a67c00;
    color: #1a1a1a;
    font-size: 0.85rem;
    font-weight: 800;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 3px 8px rgba(245,184,0,0.3);
  }
  .bj-chip:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 15px rgba(245,184,0,0.5);
  }
  .bj-chip:active {
    transform: translateY(0);
  }
  .bj-chip.selected {
    border-color: var(--guava-green, #39FF14);
    box-shadow: 0 0 12px rgba(57,255,20,0.5);
  }
  .bj-bet-input-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 1rem;
  }
  .bj-bet-label {
    color: #ccc;
    font-size: 0.95rem;
  }
  .bj-bet-input {
    width: 80px;
    padding: 8px 12px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    color: #fff;
    font-size: 1rem;
    text-align: center;
  }
  .bj-bet-input:focus {
    outline: none;
    border-color: #f5b800;
  }
  .bj-deal-btn {
    background: linear-gradient(135deg, #b8860b, #d4a056);
    border: 2px solid #c9983a;
    color: #1a1a1a;
    font-size: 1.2rem;
    font-weight: 800;
    padding: 12px 50px;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s;
    letter-spacing: 2px;
    box-shadow: 0 4px 15px rgba(184,134,11,0.3);
  }
  .bj-deal-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(184,134,11,0.4);
  }
  .bj-deal-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  /* === TABLE === */
  .bj-table {
    background: linear-gradient(180deg, #1a472a 0%, #0d2818 100%);
    border: 3px solid #2a5a3a;
    border-radius: 20px;
    padding: 1.5rem;
    margin-bottom: 1rem;
    position: relative;
    min-height: 400px;
  }
  .bj-dealer-area,
  .bj-player-area {
    margin-bottom: 1.5rem;
  }
  .bj-hand-label {
    color: rgba(255,255,255,0.7);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    font-weight: 600;
  }
  .bj-hand-label span {
    color: #f5b800;
    font-weight: 800;
    font-size: 1.1rem;
    margin-left: 8px;
  }
  .bj-cards {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    min-height: 100px;
