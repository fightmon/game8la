---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import FaqSchema from '../../components/FaqSchema.astro';
import ShareButtons from '../../components/ShareButtons.astro';

const faqs = [
  { q: '百家樂大路怎麼看？', a: '大路是百家樂最基本的路單。莊贏畫紅圈、閒贏畫藍圈。同一方連贏就往下排在同一列；換方就跳到下一列第一格。和局不開新格，在前一格畫綠斜線。看大路的重點是觀察「列的長短」——連續長列代表某方連贏（長龍），短列交替代表莊閒頻繁切換（單跳）。' },
  { q: '大眼仔、小路、蟑螂路是什麼？', a: '這三條統稱「下三路」或「衍生路」，是根據大路的走勢衍生出來的。大眼仔比較目前結果和前 1 列的對應位置，小路比前 2 列，蟑螂路比前 3 列。如果比較結果「有規律」（走勢相同）畫紅色，「沒規律」（走勢不同）畫藍色。注意：下三路的紅藍跟莊閒無關，只代表規律性。' },
  { q: '看路真的能預測下一局嗎？', a: '不能。百家樂每一局都是獨立事件，前面的結果不會影響下一局的機率。我們用 10 萬局蒙地卡羅模擬實測：看路策略 vs 無腦押莊，勝率差異在統計誤差範圍內。看路的真正價值是當作「紀律工具」——幫你控制下注頻率、避免情緒化追注，而不是預測開牌結果。' },
  { q: '這個模擬器的發牌規則準確嗎？', a: '完全照標準 8 副牌百家樂規則。閒家 0-5 補牌、6-7 不補；莊家根據閒家第三張牌決定是否補牌（標準補牌表）。莊贏抽 5% 水錢概念不影響路單記錄。和局與對子都會正確標記。' },
  { q: '什麼是長龍、單跳、雙龍、拍拍？', a: '這是四種常見路型。長龍：同一方連贏 6 局以上（大路上會出現很長的直列）。單跳：莊閒交替出現（BPBPBP）。雙龍：每兩局換一次邊（BBPPBBPP）。拍拍（Choppy）：沒有明顯規律的隨機分布。數學上這四種路型都是隨機產物，不代表趨勢會延續。' },
];
---
<FaqSchema faqs={faqs} />
<BaseLayout
  title="百家樂看路模擬器｜即時記錄＋練習・大路・大眼仔・小路・蟑螂路 - GAME8LA"
  description="免費百家樂看路記錄與練習工具：邊玩邊記錄牌局，即時繪製大路、大眼仔、小路、蟑螂路四條路單。支援手動輸入與自動發牌，附路型自動判斷。"
  ogImage="/images/tools/icon-baccarat-sim.webp"
  currentPage="tools"
>
