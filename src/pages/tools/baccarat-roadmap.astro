      <a href="/articles/baccarat-roadmap-guide/">百家樂看路完整教學<small>大路・大眼仔・小路・蟑螂路圖解</small></a>
      <a href="/tools/baccarat-simulator/">百家樂投注策略模擬器<small>5 種注碼法實測比較</small></a>
      <a href="/articles/baccarat-winning-strategy/">百家樂必勝法拆解<small>1-3-2-4 注碼管理教學</small></a>
      <a href="/articles/baccarat-card-counting-myth/">百家樂算牌真相<small>電影 vs 數學</small></a>
    </div>
  </div>

  <div class="guava-note">
    <p>🌿 本工具使用標準 8 副牌百家樂規則，發牌邏輯完全照第三補牌規則運作。路單繪製遵循國際通用規範。看路是紀律工具，不是預測工具——每一局都是獨立事件。</p>
  </div>

  <ShareButtons title="百家樂看路模擬器 — 大路、大眼仔、小路、蟑螂路即時練習" heading="🛡 想學看路又不想去賭場？把這個傳給朋友" />
</div>

<script is:inline>
(function(){
  // ===== DOM =====
  const $ = id => document.getElementById(id);
  const cvBig = $('cv-big'), cvBeb = $('cv-beb'), cvSr = $('cv-sr'), cvCr = $('cv-cr');

  // ===== CONFIG =====
  const MAX_HANDS = 500;

  // ===== STATE =====
  let results = []; // [{winner:'banker'|'player'|'tie', bpair:bool, ppair:bool}]
  let shoe = [], shoeIdx = 0;
  let handNum = 0;
  let mode = 'manual'; // 'auto' | 'manual'
  let speedCount = 0;

  // Big Road grid: columns of entries, each entry = {side:'B'|'P', ties:number, bpair:bool, ppair:bool}
  let bigRoadCols = [];

  // Stats
  let countB = 0, countP = 0, countT = 0, countBP = 0, countPP = 0;
  let curStreak = { side: null, count: 0 };
  let maxDragon = 0;
  let dragonCuts = 0; // columns of length >= 3 that ended

  // Undo history (max 10)
  let undoStack = [];

  // ===== SHOE & DEAL ENGINE (from baccarat-simulator) =====
  function createShoe() {
    const cards = [];
    for (let d = 0; d < 8; d++)
      for (let v = 1; v <= 13; v++)
        for (let s = 0; s < 4; s++)
          cards.push(Math.min(v, 10));
    for (let i = cards.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [cards[i], cards[j]] = [cards[j], cards[i]];
    }
    return cards;
  }

  function bacVal(v) { return v === 10 ? 0 : v; }
  function handTotal(cards) { return cards.reduce((s, c) => (s + bacVal(c)) % 10, 0); }

  function playHand() {
    if (shoeIdx + 6 > shoe.length) { shoe = createShoe(); shoeIdx = 0; }
    const p = [shoe[shoeIdx], shoe[shoeIdx+2]];
    const b = [shoe[shoeIdx+1], shoe[shoeIdx+3]];
    let ci = shoeIdx + 4;
    let pTotal = handTotal(p), bTotal = handTotal(b);

    // Check pairs
    const bpair = (bacVal(shoe[shoeIdx+1]) === bacVal(shoe[shoeIdx+3]));
    const ppair = (bacVal(shoe[shoeIdx]) === bacVal(shoe[shoeIdx+2]));

    if (pTotal >= 8 || bTotal >= 8) {
      shoeIdx = ci;
      const winner = pTotal > bTotal ? 'player' : bTotal > pTotal ? 'banker' : 'tie';
      return { winner, pTotal: handTotal(p), bTotal: handTotal(b), bpair, ppair };
    }

    let pThird = null;
    if (pTotal <= 5) { pThird = shoe[ci++]; p.push(pThird); pTotal = handTotal(p); }

    if (pThird === null) {
      if (bTotal <= 5) { b.push(shoe[ci++]); bTotal = handTotal(b); }
    } else {
      const pTV = bacVal(pThird);
      let bankerDraws = false;
      if (bTotal <= 2) bankerDraws = true;
      else if (bTotal === 3 && pTV !== 8) bankerDraws = true;
      else if (bTotal === 4 && pTV >= 2 && pTV <= 7) bankerDraws = true;
      else if (bTotal === 5 && pTV >= 4 && pTV <= 7) bankerDraws = true;
      else if (bTotal === 6 && (pTV === 6 || pTV === 7)) bankerDraws = true;
      if (bankerDraws) { b.push(shoe[ci++]); bTotal = handTotal(b); }
    }

    shoeIdx = ci;
    const winner = pTotal > bTotal ? 'player' : bTotal > pTotal ? 'banker' : 'tie';
    return { winner, pTotal, bTotal, bpair, ppair };
  }

  // ===== BIG ROAD LOGIC =====
  function addToBigRoad(result) {
    const side = result.winner === 'banker' ? 'B' : result.winner === 'player' ? 'P' : 'T';

    if (side === 'T') {
      // Tie: add to last entry
      if (bigRoadCols.length > 0) {
        const lastCol = bigRoadCols[bigRoadCols.length - 1];
        lastCol[lastCol.length - 1].ties++;
      }
      if (result.bpair && bigRoadCols.length > 0) {
        const lastCol = bigRoadCols[bigRoadCols.length - 1];
        lastCol[lastCol.length - 1].bpair = true;
      }
      if (result.ppair && bigRoadCols.length > 0) {
        const lastCol = bigRoadCols[bigRoadCols.length - 1];
        lastCol[lastCol.length - 1].ppair = true;
      }
      return;
    }

    const entry = { side, ties: 0, bpair: result.bpair || false, ppair: result.ppair || false };

    if (bigRoadCols.length === 0) {
      bigRoadCols.push([entry]);
    } else {
      const lastCol = bigRoadCols[bigRoadCols.length - 1];
      if (lastCol[0].side === side) {
        lastCol.push(entry);
      } else {
        bigRoadCols.push([entry]);
      }
    }
  }

  // ===== DERIVED ROAD LOGIC =====
  // Build a flat big road grid (col, row) for lookups
  function buildBigRoadGrid() {
    const maxRows = 6;
    const grid = []; // grid[col] = array of {side, row}
    let col = 0;
    for (let ci = 0; ci < bigRoadCols.length; ci++) {
      const column = bigRoadCols[ci];
      grid[col] = [];
      for (let ri = 0; ri < column.length; ri++) {
        let row = ri;
        if (ri >= maxRows) {
          // Dragon tail: extend right
          row = maxRows - 1;
          // Check if we need a new col for dragon
          if (ri === maxRows) {
            // stay in same visual col but offset right conceptually
          }
        }
        grid[col].push({ side: column[ri].side, origRow: ri });
      }
      col++;
    }
    return grid;
  }

  // Derived road: compare current column with column N back
  // Returns array of 'R' (red=regular) or 'B' (blue=irregular)
  function calcDerivedRoad(offset) {
    // offset: 1=big eye boy, 2=small road, 3=cockroach pig
    const road = [];
    // We need at least offset+1 columns to start
    // Start from column (offset+1), row 1 for first entry, then continue
    // Standard rules:
    // After the (offset+1)th column has at least 2 entries, OR the (offset+2)th column has started

    for (let ci = 0; ci < bigRoadCols.length; ci++) {
      for (let ri = 0; ri < bigRoadCols[ci].length; ri++) {
        // Skip until we have enough data
        // Big Eye Boy starts at col 2 (0-indexed 1), row 1
        // Small Road starts at col 3 (0-indexed 2), row 1
        // Cockroach Pig starts at col 4 (0-indexed 3), row 1
        const startCol = offset; // 0-indexed
        if (ci < startCol) continue;
        if (ci === startCol && ri < 1) continue;

        const compareCol = ci - offset;
        let isRed;

        if (ri === 0) {
          // First row of a new column: compare lengths of current col-1 and compareCol
          const prevColLen = bigRoadCols[ci - 1] ? bigRoadCols[ci - 1].length : 0;
          const compColLen = bigRoadCols[compareCol] ? bigRoadCols[compareCol].length : 0;
          // Red if same length, Blue if different
          isRed = (prevColLen === compColLen);
        } else {
          // Subsequent rows: check if compareCol had an entry at this row
          const compColLen = bigRoadCols[compareCol] ? bigRoadCols[compareCol].length : 0;
          // Red if compareCol also had this row (extended), Blue if it didn't
          isRed = (ri < compColLen);
        }

        road.push(isRed ? 'R' : 'B');
      }
    }
    return road;
  }

  // ===== PATTERN DETECTION =====
  function detectBigRoadPattern() {
    if (bigRoadCols.length < 3) return '--';
    const lens = bigRoadCols.slice(-6).map(c => c.length);
    const lastLen = bigRoadCols[bigRoadCols.length - 1].length;

    // Long Dragon: current column >= 6
    if (lastLen >= 6) return '🐉 長龍';

    // Check last few columns for patterns
    if (lens.length >= 4) {
      // Ping Pong (all length 1)
      const recent = lens.slice(-4);
      if (recent.every(l => l === 1)) return '🔄 單跳';
      // Double Dragon (alternating 2s)
      if (recent.every(l => l === 2)) return '🐲 雙龍';
    }

    if (lens.length >= 3) {
      const recent = lens.slice(-3);
      if (recent.every(l => l === 1)) return '🔄 單跳';
      if (recent.every(l => l === 2)) return '🐲 雙龍';
    }

    return '🎲 拍拍';
  }

  function detectDerivedPattern(road) {
    if (road.length < 6) return '--';
    const recent = road.slice(-6);
    const reds = recent.filter(r => r === 'R').length;
    if (reds >= 5) return '有規律';
    if (reds <= 1) return '沒規律';
    return '混合';
  }

  // ===== CANVAS DRAWING =====
  const COLORS = { B: '#e74c3c', P: '#3498db', T: '#2ecc71', R: '#e74c3c', BL: '#3498db' };

  function drawBigRoad() {
    const canvas = cvBig;
    const wrap = canvas.parentElement;
    const cellSize = 32;
    const maxRows = 6;
    const gap = 2;
    let visualCols = 0;
    for (let ci = 0; ci < bigRoadCols.length; ci++) {
      visualCols += 1 + Math.max(0, bigRoadCols[ci].length - maxRows);
    }
    const totalCols = Math.max(30, visualCols + 5);

    canvas.width = totalCols * (cellSize + gap) + gap;
    canvas.height = maxRows * (cellSize + gap) + gap;
    canvas.style.height = canvas.height + 'px';

    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // Grid lines
    ctx.strokeStyle = 'rgba(255,255,255,0.06)';
    ctx.lineWidth = 0.5;
    for (let r = 0; r <= maxRows; r++) {
      const y = r * (cellSize + gap);
      ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(canvas.width, y); ctx.stroke();
    }
    for (let c = 0; c <= totalCols; c++) {
      const x = c * (cellSize + gap);
      ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, canvas.height); ctx.stroke();
    }

    // Draw entries with dragon tail logic
    let drawCol = 0;
    for (let ci = 0; ci < bigRoadCols.length; ci++) {
      const column = bigRoadCols[ci];
      let extraRight = 0;
      for (let ri = 0; ri < column.length; ri++) {
        let row = ri;
        let col = drawCol;
        if (ri >= maxRows) {
          row = maxRows - 1;
          extraRight = ri - maxRows + 1;
          col = drawCol + extraRight;
        }
        const x = col * (cellSize + gap) + gap;
        const y = row * (cellSize + gap) + gap;
        const cx = x + cellSize / 2;
        const cy = y + cellSize / 2;
        const r = cellSize / 2 - 3;

        // Main circle
        ctx.beginPath();
        ctx.arc(cx, cy, r, 0, Math.PI * 2);
        ctx.fillStyle = COLORS[column[ri].side];
        ctx.fill();

        // Letter
        ctx.fillStyle = '#fff';
        ctx.font = 'bold 13px Arial';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(column[ri].side === 'B' ? '莊' : '閒', cx, cy);

        // Tie marks
        if (column[ri].ties > 0) {
          ctx.strokeStyle = COLORS.T;
          ctx.lineWidth = 2.5;
          ctx.beginPath();
          ctx.moveTo(x + 2, y + cellSize - 2);
          ctx.lineTo(x + cellSize - 2, y + 2);
          ctx.stroke();
          if (column[ri].ties > 1) {
            ctx.fillStyle = COLORS.T;
            ctx.font = 'bold 10px Arial';
            ctx.fillText(column[ri].ties, x + cellSize - 6, y + 10);
          }
        }

        // Banker pair: bottom-right dot
        if (column[ri].bpair) {
          ctx.beginPath();
          ctx.arc(x + cellSize - 5, y + cellSize - 5, 4, 0, Math.PI * 2);
          ctx.fillStyle = '#e74c3c';
          ctx.fill();
        }

        // Player pair: top-left dot
        if (column[ri].ppair) {
          ctx.beginPath();
          ctx.arc(x + 5, y + 5, 4, 0, Math.PI * 2);
          ctx.fillStyle = '#3498db';
          ctx.fill();
        }
      }
      drawCol += 1 + Math.max(0, column.length - maxRows);
    }

    // Smart scroll: only scroll if data exceeds visible area
    var dataWidth = drawCol * (cellSize + gap) + gap;
    if (dataWidth > wrap.clientWidth) {
      wrap.scrollLeft = Math.max(0, dataWidth - wrap.clientWidth + cellSize);
    } else {
      wrap.scrollLeft = 0;
    }
  }

  function drawDerivedRoad(canvas, road, cellSize) {
    const maxRows = 6;
    const gap = 1;
    // Layout derived road into columns
    const cols = [];
    let curCol = [];
    let curColor = null;
    for (const entry of road) {
      if (curColor === null) {
        curColor = entry;
        curCol.push(entry);
      } else if (entry === curColor) {
        curCol.push(entry);
      } else {
        cols.push(curCol);
        curCol = [entry];
        curColor = entry;
      }
    }
    if (curCol.length > 0) cols.push(curCol);

    let visualCols = 0;
    for (let ci = 0; ci < cols.length; ci++) {
      visualCols += 1 + Math.max(0, cols[ci].length - maxRows);
    }
    const totalCols = Math.max(30, visualCols + 5);
    canvas.width = totalCols * (cellSize + gap) + gap;
    canvas.height = maxRows * (cellSize + gap) + gap;
    canvas.style.height = canvas.height + 'px';

    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // Grid
    ctx.strokeStyle = 'rgba(255,255,255,0.04)';
    ctx.lineWidth = 0.5;
    for (let r = 0; r <= maxRows; r++) {
      const y = r * (cellSize + gap);
      ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(canvas.width, y); ctx.stroke();
    }
    for (let c = 0; c <= totalCols; c++) {
      const x = c * (cellSize + gap);
      ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, canvas.height); ctx.stroke();
    }

    // Draw circles (outline style for derived roads)
    let drawCol = 0;
    for (let ci = 0; ci < cols.length; ci++) {
      for (let ri = 0; ri < cols[ci].length; ri++) {
        let row = ri;
        let col = drawCol;
        if (ri >= maxRows) { row = maxRows - 1; col = drawCol + ri - maxRows + 1; }
        const x = col * (cellSize + gap) + gap;
        const y = row * (cellSize + gap) + gap;
        const cx = x + cellSize / 2;
        const cy = y + cellSize / 2;
        const r = cellSize / 2 - 2;
        const color = cols[ci][ri] === 'R' ? COLORS.R : COLORS.BL;

        ctx.beginPath();
        ctx.arc(cx, cy, r, 0, Math.PI * 2);
        ctx.fillStyle = color;
        ctx.fill();
      }
      drawCol += 1 + Math.max(0, cols[ci].length - maxRows);
    }

    // Smart scroll: only scroll if data exceeds visible area
    const wrap = canvas.parentElement;
    var dataWidth = drawCol * (cellSize + gap) + gap;
    if (dataWidth > wrap.clientWidth) {
      wrap.scrollLeft = Math.max(0, dataWidth - wrap.clientWidth + cellSize);
    } else {
      wrap.scrollLeft = 0;
    }
  }

  // ===== RENDER ALL =====
  function renderAll() {
    drawBigRoad();

    const bebRoad = calcDerivedRoad(1);
    const srRoad = calcDerivedRoad(2);
    const crRoad = calcDerivedRoad(3);

    drawDerivedRoad(cvBeb, bebRoad, 22);
    drawDerivedRoad(cvSr, srRoad, 20);
    drawDerivedRoad(cvCr, crRoad, 18);

    // Pattern tags
    $('tag-big').textContent = detectBigRoadPattern();
    $('tag-beb').textContent = bebRoad.length > 0 ? detectDerivedPattern(bebRoad) : '--';
    $('tag-sr').textContent = srRoad.length > 0 ? detectDerivedPattern(srRoad) : '--';
    $('tag-cr').textContent = crRoad.length > 0 ? detectDerivedPattern(crRoad) : '--';

    // Stats
    $('s-banker').textContent = countB + (countB + countP + countT > 0 ? ' (' + Math.round(countB / (countB + countP + countT) * 100) + '%)' : '');
    $('s-player').textContent = countP + (countB + countP + countT > 0 ? ' (' + Math.round(countP / (countB + countP + countT) * 100) + '%)' : '');
    $('s-tie').textContent = countT + (countB + countP + countT > 0 ? ' (' + Math.round(countT / (countB + countP + countT) * 100) + '%)' : '');
    $('s-bpair').textContent = countBP;
    $('s-ppair').textContent = countPP;
    $('s-streak').textContent = curStreak.side ? (curStreak.side === 'B' ? '莊' : '閒') + ' × ' + curStreak.count : '--';
    $('s-streak').style.color = curStreak.side === 'B' ? '#e74c3c' : curStreak.side === 'P' ? '#3498db' : 'var(--text-muted)';
    $('hand-num').textContent = handNum + ' / ' + MAX_HANDS;

    // Dragon stats
    var curMaxD = 0;
    var cuts = 0;
    for (var di = 0; di < bigRoadCols.length; di++) {
      var clen = bigRoadCols[di].length;
      if (clen > curMaxD) curMaxD = clen;
      if (di < bigRoadCols.length - 1 && clen >= 3) cuts++;
    }
    maxDragon = curMaxD;
    dragonCuts = cuts;
    var curColLen = bigRoadCols.length > 0 ? bigRoadCols[bigRoadCols.length - 1].length : 0;
    $('s-maxdragon').textContent = curMaxD > 0 ? curMaxD + ' 局' : '--';
    $('s-maxdragon').style.color = curMaxD >= 6 ? '#e74c3c' : 'var(--text-primary)';
    $('s-dragoncut').textContent = cuts;
    $('s-curcol').textContent = curColLen;
    $('s-curcol').style.color = curColLen >= 6 ? '#e74c3c' : curColLen >= 3 ? 'var(--gold-light)' : 'var(--text-primary)';

    // Undo button state
    $('undo-btn').disabled = undoStack.length === 0;

    // Save to sessionStorage
    saveState();

    // Verdict (show after 20 hands)
    if (handNum >= 20) {
      $('verdict-card').style.display = '';
      const total = countB + countP + countT;
      const bRate = (countB / total * 100).toFixed(1);
      const pRate = (countP / total * 100).toFixed(1);
      let v = handNum + ' 局結果：莊 ' + bRate + '% / 閒 ' + pRate + '%。';
      if (Math.abs(countB / total - 0.458) < 0.03) {
        v += '分布非常接近理論值（莊 45.8% / 閒 44.6%）。';
      }
      v += '記住：不管路單畫出什麼圖案，下一局的機率永遠不變。看路是幫你保持冷靜的工具，不是水晶球。';
      $('verdict-text').textContent = v;
    }
  }

  // ===== PROCESS ONE RESULT =====
  function processResult(result) {
    saveSnapshot();
    handNum++;
    results.push(result);
    addToBigRoad(result);

    // Update stats
    if (result.winner === 'banker') { countB++; }
    else if (result.winner === 'player') { countP++; }
    else { countT++; }
    if (result.bpair) countBP++;
    if (result.ppair) countPP++;

    // Streak
    if (result.winner !== 'tie') {
      const s = result.winner === 'banker' ? 'B' : 'P';
      if (curStreak.side === s) { curStreak.count++; }
      else { curStreak = { side: s, count: 1 }; }
    }

    // Show last result
    $('last-result').style.display = '';
    const winnerText = result.winner === 'banker' ? '莊勝' : result.winner === 'player' ? '閒勝' : '和局';
    const winnerColor = result.winner === 'banker' ? '#e74c3c' : result.winner === 'player' ? '#3498db' : '#2ecc71';
    let extra = '';
    if (result.bpair) extra += ' ＋莊對';
    if (result.ppair) extra += ' ＋閒對';
    $('result-text').innerHTML = '第 ' + handNum + ' 局：<strong style="color:' + winnerColor + '">' + winnerText + '</strong>' +
      (result.pTotal !== undefined ? '（莊 ' + result.bTotal + ' vs 閒 ' + result.pTotal + '）' : '') + extra;
  }

  // ===== LIMIT CHECK =====
  function checkLimit() {
    if (handNum >= MAX_HANDS) {
      $('deal-btn').disabled = true;
      $('man-banker').disabled = true;
      $('man-player').disabled = true;
      $('man-tie').disabled = true;
      $('result-text').innerHTML = '已達 ' + MAX_HANDS + ' 局上限，請按<strong style="color:#e67e22">「重新開局」</strong>開始新一輪';
      $('last-result').style.display = '';
      return true;
    }
    return false;
  }

  function unlockButtons() {
    $('deal-btn').disabled = false;
    $('man-banker').disabled = false;
    $('man-player').disabled = false;
    $('man-tie').disabled = false;
  }

  // ===== AUTO DEAL =====
  function autoDeal(count) {
    if (checkLimit()) return;
    count = count || 1;
    const remaining = MAX_HANDS - handNum;
    count = Math.min(count, remaining);
    for (let i = 0; i < count; i++) {
      const result = playHand();
      processResult(result);
    }
    renderAll();
    checkLimit();
  }

  // ===== MANUAL INPUT =====
  function manualInput(winner) {
    if (checkLimit()) return;
    const bpair = $('man-bpair').checked;
    const ppair = $('man-ppair').checked;
    processResult({ winner, bpair, ppair });
    $('man-bpair').checked = false;
    $('man-ppair').checked = false;
    renderAll();
    checkLimit();
  }

  // ===== UNDO =====
  function saveSnapshot() {
    if (undoStack.length >= 10) undoStack.shift();
    undoStack.push(JSON.stringify({
      results: results,
      bigRoadCols: bigRoadCols,
      handNum: handNum,
      countB: countB, countP: countP, countT: countT,
      countBP: countBP, countPP: countPP,
      curStreak: curStreak
    }));
  }

  function undoLast() {
    if (undoStack.length === 0) return;
    var snap = JSON.parse(undoStack.pop());
    results = snap.results;
    bigRoadCols = snap.bigRoadCols;
    handNum = snap.handNum;
    countB = snap.countB; countP = snap.countP; countT = snap.countT;
    countBP = snap.countBP; countPP = snap.countPP;
    curStreak = snap.curStreak;
    if (handNum < MAX_HANDS) unlockButtons();
    if (handNum === 0) {
      $('last-result').style.display = 'none';
    } else {
      var last = results[results.length - 1];
      var wt = last.winner === 'banker' ? '莊勝' : last.winner === 'player' ? '閒勝' : '和局';
      var wc = last.winner === 'banker' ? '#e74c3c' : last.winner === 'player' ? '#3498db' : '#2ecc71';
      $('result-text').innerHTML = '第 ' + handNum + ' 局：<strong style="color:' + wc + '">' + wt + '</strong>';
      $('last-result').style.display = '';
    }
    renderAll();
  }

  // ===== SESSION STORAGE =====
  function saveState() {
    try {
      sessionStorage.setItem('g8la-roadmap', JSON.stringify({
        results: results,
        bigRoadCols: bigRoadCols,
        handNum: handNum,
        countB: countB, countP: countP, countT: countT,
        countBP: countBP, countPP: countPP,
        curStreak: curStreak
      }));
    } catch(e) {}
  }

  function loadState() {
    try {
      var saved = sessionStorage.getItem('g8la-roadmap');
      if (!saved) return false;
      var snap = JSON.parse(saved);
      if (!snap.results || snap.results.length === 0) return false;
      results = snap.results;
      bigRoadCols = snap.bigRoadCols;
      handNum = snap.handNum;
      countB = snap.countB; countP = snap.countP; countT = snap.countT;
      countBP = snap.countBP; countPP = snap.countPP;
      curStreak = snap.curStreak;
      // Restore last result display
      if (handNum > 0) {
        var last = results[results.length - 1];
        var wt = last.winner === 'banker' ? '莊勝' : last.winner === 'player' ? '閒勝' : '和局';
        var wc = last.winner === 'banker' ? '#e74c3c' : last.winner === 'player' ? '#3498db' : '#2ecc71';
        $('result-text').innerHTML = '第 ' + handNum + ' 局：<strong style="color:' + wc + '">' + wt + '</strong>（已恢復上次進度）';
        $('last-result').style.display = '';
      }
      checkLimit();
      return true;
    } catch(e) { return false; }
  }

  // ===== EXPORT / SCREENSHOT =====
  function exportRoadmapImage() {
    var W = 1200, H = 1400;
    var out = document.createElement('canvas');
    out.width = W; out.height = H;
    var ctx = out.getContext('2d');

    // Background
    ctx.fillStyle = '#0d1117';
    ctx.fillRect(0, 0, W, H);

    // Header
    ctx.fillStyle = '#39FF14';
    ctx.font = 'bold 36px Arial, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('百家樂看路模擬器', W / 2, 50);
    ctx.fillStyle = '#8b949e';
    ctx.font = '18px Arial, sans-serif';
    var total = countB + countP + countT;
    ctx.fillText('第 ' + handNum + ' 局｜莊 ' + countB + ' (' + (total > 0 ? Math.round(countB/total*100) : 0) + '%)  閒 ' + countP + ' (' + (total > 0 ? Math.round(countP/total*100) : 0) + '%)  和 ' + countT, W / 2, 82);

    var maxD = 0;
    for (var di = 0; di < bigRoadCols.length; di++) if (bigRoadCols[di].length > maxD) maxD = bigRoadCols[di].length;
    ctx.fillText('最長龍 ' + maxD + ' 局｜斷龍 ' + dragonCuts + ' 次', W / 2, 106);

    // Draw roads
    var roads = [
      { cv: cvBig, label: '大路', tag: $('tag-big').textContent, y: 130, h: 280 },
      { cv: cvBeb, label: '大眼仔', tag: $('tag-beb').textContent, y: 430, h: 220 },
      { cv: cvSr, label: '小路', tag: $('tag-sr').textContent, y: 670, h: 200 },
      { cv: cvCr, label: '蟑螂路', tag: $('tag-cr').textContent, y: 890, h: 190 }
    ];

    for (var i = 0; i < roads.length; i++) {
      var r = roads[i];
      // Card background
      ctx.fillStyle = '#161b22';
      ctx.beginPath();
      ctx.roundRect(30, r.y, W - 60, r.h, 12);
      ctx.fill();
      ctx.strokeStyle = '#30363d';
      ctx.lineWidth = 1;
      ctx.stroke();

      // Label
      ctx.fillStyle = '#e6edf3';
      ctx.font = 'bold 16px Arial, sans-serif';
      ctx.textAlign = 'left';
      ctx.fillText(r.label, 50, r.y + 24);

      // Tag
      ctx.fillStyle = '#f5b800';
      ctx.font = '13px Arial, sans-serif';
      ctx.textAlign = 'right';
      ctx.fillText(r.tag, W - 50, r.y + 24);

      // Copy canvas content
      try {
        var srcCanvas = r.cv;
        var availW = W - 100;
        var availH = r.h - 40;
        var scale = Math.min(availW / srcCanvas.width, availH / srcCanvas.height, 1);
        var drawW = srcCanvas.width * scale;
        var drawH = srcCanvas.height * scale;
        ctx.drawImage(srcCanvas, 50, r.y + 35, drawW, drawH);
      } catch(e) {}
    }

    // Footer
    var fy = 1100;
    ctx.fillStyle = '#161b22';
    ctx.beginPath();
    ctx.roundRect(30, fy, W - 60, 100, 12);
    ctx.fill();

    ctx.fillStyle = '#39FF14';
    ctx.font = 'bold 22px Arial, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('GAME8LA', W / 2, fy + 35);
    ctx.fillStyle = '#8b949e';
    ctx.font = '14px Arial, sans-serif';
    ctx.fillText('game8la.com/tools/baccarat-roadmap', W / 2, fy + 58);
    ctx.fillText('台灣最敢講真話的遊戲評測平台 · 零業配 · 數據先行', W / 2, fy + 80);

    // Watermark
    ctx.fillStyle = 'rgba(57,255,20,0.06)';
    ctx.font = 'bold 60px Arial, sans-serif';
    ctx.fillText('GAME8LA.COM', W / 2, 700);

    // Download
    var link = document.createElement('a');
    link.download = 'baccarat-roadmap-' + handNum + '局.png';
    link.href = out.toDataURL('image/png');
    link.click();
  }

  // ===== RESET =====
  function resetAll() {
    if (handNum > 0 && !confirm('確定要重新開局嗎？目前的路單紀錄會全部清除。')) return;
    results = [];
    bigRoadCols = [];
    shoe = createShoe();
    shoeIdx = 0;
    handNum = 0;
    countB = countP = countT = countBP = countPP = 0;
    curStreak = { side: null, count: 0 };
    maxDragon = 0;
    dragonCuts = 0;
    undoStack = [];
    $('last-result').style.display = 'none';
    $('verdict-card').style.display = 'none';
    unlockButtons();
    try { sessionStorage.removeItem('g8la-roadmap'); } catch(e) {}
    renderAll();
  }

  // ===== EVENT LISTENERS =====
  // Mode toggle
  $('mode-auto').addEventListener('click', function() {
    mode = 'auto';
    $('mode-auto').classList.add('active');
    $('mode-manual').classList.remove('active');
    $('ctrl-auto').style.display = '';
    $('ctrl-manual').style.display = 'none';
  });
  $('mode-manual').addEventListener('click', function() {
    mode = 'manual';
    $('mode-manual').classList.add('active');
    $('mode-auto').classList.remove('active');
    $('ctrl-auto').style.display = 'none';
    $('ctrl-manual').style.display = '';
  });

  // Deal button
  $('deal-btn').addEventListener('click', function() {
    autoDeal(speedCount || 1);
  });

  // Speed buttons
  document.querySelectorAll('.speed-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.speed-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      speedCount = +btn.dataset.speed;
      $('deal-btn').querySelector('span') && ($('deal-btn').querySelector('span').textContent = speedCount > 1 ? '連發 ' + speedCount + ' 局' : '發牌（下一局）');
    });
  });

  // Manual buttons
  $('man-banker').addEventListener('click', function() { manualInput('banker'); });
  $('man-player').addEventListener('click', function() { manualInput('player'); });
  $('man-tie').addEventListener('click', function() { manualInput('tie'); });

  // Reset
  $('reset-btn').addEventListener('click', resetAll);

  // Undo
  $('undo-btn').addEventListener('click', undoLast);

  // Export
  $('export-btn').addEventListener('click', exportRoadmapImage);

  // ===== INIT =====
  shoe = createShoe();
  // Try restore from sessionStorage
  if (!loadState()) {
    renderAll();
  } else {
    renderAll();
  }
})();
</script>

