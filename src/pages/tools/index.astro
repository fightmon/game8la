---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';

/* ── ItemList Schema（SEO #5）── */
const tools = [
  { name: 'Game8la 線上擲筊', url: 'https://game8la.com/tools/bless-blocks/' },
  { name: '賽特2 RTP 模擬器', url: 'https://game8la.com/tools/slot-simulator/' },
  { name: '雷神之錘 II 模擬器', url: 'https://game8la.com/tools/thor-hammer-2-simulator/' },
  { name: '巴風特模擬器', url: 'https://game8la.com/tools/baphomet-simulator/' },
  { name: '樂透數據站', url: 'https://game8la.com/lottery/analysis/' },
  { name: '娛樂城體檢', url: 'https://game8la.com/casino-check/' },
  { name: '老虎機 RTP 紀錄器', url: 'https://game8la.com/tools/rtp-tracker/' },
  { name: '百家樂策略模擬器', url: 'https://game8la.com/tools/baccarat-simulator/' },
  { name: '百家樂看路模擬器', url: 'https://game8la.com/tools/baccarat-roadmap/' },
  { name: '資金管理計算器', url: 'https://game8la.com/tools/bankroll-calculator/' },
  { name: '娛樂城獎金計算器', url: 'https://game8la.com/tools/bonus-calculator/' },
  { name: 'PGSI 賭博成癮自我檢測', url: 'https://game8la.com/tools/gambling-self-check/' },
  { name: '539 包牌計算器', url: 'https://game8la.com/tools/539-wheel-calculator/' },
];

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "GAME8LA 免費博弈工具箱",
  "description": "11 款免費線上博弈分析工具，涵蓋老虎機 RTP 模擬、樂透冷熱號選號、539包牌計算器、娛樂城安全檢測、百家樂策略回測、資金管理與賭博成癮自我檢測。",
  "numberOfItems": tools.length,
  "itemListElement": tools.map((t, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": t.name,
    "url": t.url,
  })),
};
---
<script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

<BaseLayout
  currentPage="tools"
  title="免費博弈工具箱（2026）｜老虎機模擬器・539包牌計算器・樂透選號・娛樂城體檢 - GAME8LA"
  description="11 款免費線上博弈工具：539包牌計算器、戰神賽特 RTP 模擬器、雷神之錘倍數模擬、539/威力彩/大樂透冷熱號分析與包牌產生器、娛樂城詐騙體檢、百家樂策略回測、資金管理計算器、PGSI 賭博成癮自我檢測。免註冊、零廣告，數據留在你的瀏覽器。"
>
<div class="container">
  <div class="tools-hero">
    <h1>🔧 Game8la 免費博弈工具箱</h1>
    <p class="tools-sub">不報明牌，只給你用得上的數據工具。</p>
    <p class="tools-desc">以下所有工具完全免費、不需要註冊。你的數據留在你自己的瀏覽器裡，我們不會收集任何個人資訊。</p>
  </div>

  <div class="tools-grid">
    <a href="/tools/bless-blocks/" class="tool-tile">
      <div class="tile-glow" style="--glow-color:rgba(184,134,11,0.35)"></div>
      <img class="tile-icon" src="/images/tools/icon-bless-blocks.webp" alt="Game8la 線上擲筊 — 免費擲筊模擬器，即時機率統計" width="72" height="72" loading="lazy">
      <h2>Game8la 線上擲筊</h2>
      <p>線上擲筊模擬，即時機率統計</p>
    </a>
    <a href="/tools/slot-simulator/" class="tool-tile">
      <div class="tile-glow" style="--glow-color:rgba(236,72,153,0.35)"></div>
      <img class="tile-icon" src="/images/tools/icon-slot-sim.webp" alt="賽特2 RTP 模擬器 — 戰神賽特老虎機免費模擬" width="72" height="72" loading="lazy">
      <h2>賽特2 RTP 模擬器</h2>
      <p>戰神賽特老虎機免費模擬</p>
    </a>
    <a href="/tools/thor-hammer-2-simulator/" class="tool-tile">
      <div class="tile-glow" style="--glow-color:rgba(255,153,0,0.35)"></div>
      <img class="tile-icon" src="/images/tools/icon-thor-sim.webp" alt="雷神之錘 II 模擬器 — 倍數球鎖定爆分體驗" width="72" height="72" loading="lazy">
      <h2>雷神之錘 II 模擬器</h2>
      <p>倍數球鎖定爆分體驗</p>
    </a>
    <a href="/tools/baphomet-simulator/" class="tool-tile">
      <div class="tile-glow" style="--glow-color:rgba(168,85,252,0.35)"></div>
      <img class="tile-icon" src="/images/tools/icon-slot-sim.webp" alt="巴風特模擬器 — Cluster Pays 石板翻倍體驗" width="72" height="72" loading="lazy">
      <h2>巴風特模擬器</h2>
      <p>Cluster Pays 石板翻倍體驗</p>
    </a>
    <a href="/lottery/analysis/" class="tool-tile">
      <div class="tile-glow" style="--glow-color:rgba(124,58,237,0.35)"></div>
      <img class="tile-icon" src="/images/tools/icon-lottery.webp" alt="樂透數據站 — 539 威力彩大樂透冷熱號分析" width="72" height="72" loading="lazy">
      <h2>樂透數據站</h2>
      <p>539・威力彩・大樂透冷熱號分析</p>
    </a>
    <a href="/tools/539-wheel-calculator/" class="tool-tile">
      <div class="tile-glow" style="--glow-color:rgba(57,255,20,0.35)"></div>
      <img class="tile-icon" src="/images/tools/icon-lottery.webp" alt="539 包牌計算器 — 選碼數秒算注數花費中獎機率" width="72" height="72" loading="lazy">
      <h2>539 包牌計算器</h2>
      <p>注數、花費、中獎機率一鍵算</p>
    </a>
    <a href="/casino-check/" class="tool-tile">
      <div class="tile-glow" style="--glow-color:rgba(239,68,68,0.35)"></div>
      <img class="tile-icon" src="/images/tools/icon-casino-check.webp" alt="娛樂城體檢 — 165 黑名單比對與 WHOIS 查驗" width="72" height="72" loading="lazy">
      <h2>娛樂城體檢</h2>
      <p>165 黑名單比對 + WHOIS 查驗</p>
    </a>
    <a href="/tools/rtp-tracker/" class="tool-tile">
      <div class="tile-glow" style="--glow-color:rgba(245,184,0,0.35)"></div>
      <img class="tile-icon" src="/images/tools/icon-rtp-tracker.webp" alt="老虎機 RTP 紀錄器 — 記錄每局輸贏自動算 RTP" width="72" height="72" loading="lazy">
      <h2>老虎機 RTP 紀錄器</h2>
      <p>記錄每局輸贏，自動算 RTP</p>
    </a>
    <a href="/tools/baccarat-simulator/" class="tool-tile">
      <div class="tile-glow" style="--glow-color:rgba(0,200,255,0.35)"></div>
      <img class="tile-icon" src="/images/tools/icon-baccarat-sim.webp" alt="百家樂策略模擬器 — 五種注碼法跑 1000 局回測" width="72" height="72" loading="lazy">
      <h2>百家樂策略模擬器</h2>
      <p>五種注碼法跑 1000 局回測</p>
    </a>
    <a href="/tools/baccarat-roadmap/" class="tool-tile">
      <div class="tile-glow" style="--glow-color:rgba(231,76,60,0.35)"></div>
      <img class="tile-icon" src="/images/tools/icon-baccarat-sim.webp" alt="百家樂看路模擬器 — 大路・大眼仔・小路・蟑螂路即時練習" width="72" height="72" loading="lazy">
      <h2>百家樂看路模擬器</h2>
      <p>四條路即時練習，學會再上桌</p>
    </a>
    <a href="/tools/bankroll-calculator/" class="tool-tile">
      <div class="tile-glow" style="--glow-color:rgba(57,255,20,0.35)"></div>
      <img class="tile-icon" src="/images/tools/icon-bankroll.webp" alt="資金管理計算器 — 停損停利線一鍵算好" width="72" height="72" loading="lazy">
      <h2>資金管理計算器</h2>
      <p>停損停利線一鍵算好</p>
    </a>
    <a href="/tools/bonus-calculator/" class="tool-tile">
      <div class="tile-glow" style="--glow-color:rgba(245,184,0,0.35)"></div>
      <img class="tile-icon" src="/images/tools/bonus-calc/guava-1.webp" alt="娛樂城獎金計算器 — 打碼量試算，紅利值不值得拿" width="72" height="72" loading="lazy">
      <h2>娛樂城獎金計算器</h2>
      <p>打碼量試算，紅利值不值得拿</p>
    </a>
    <a href="/tools/gambling-self-check/" class="tool-tile">
      <div class="tile-glow" style="--glow-color:rgba(239,68,68,0.35)"></div>
      <img class="tile-icon" src="/images/tools/pgsi/pgsi-hero.webp" alt="PGSI 賭博成癮自我檢測 — 9 題快速評估你的博弈習慣" width="72" height="72" loading="lazy">
      <h2>賭博成癮自我檢測</h2>
      <p>PGSI 9 題快速評估博弈習慣</p>
    </a>
  </div>

  <!-- SEO #4：工具介紹文字段落，解決 thin content -->
  <section class="tools-intro">
    <h2>為什麼需要這些工具？</h2>
    <p>不管你玩的是老虎機、百家樂還是買樂透，「憑感覺下注」是最快燒錢的方式。GAME8LA 工具箱提供 11 款免費線上工具，讓你用數據取代直覺。</p>
    <p><strong>賽特2 RTP 模擬器</strong>和<strong>雷神之錘 II 模擬器</strong>能讓你免費試跑上千局，親眼看到 RTP 回歸的過程。</p>
    <p><strong>樂透數據站</strong>回測 539、威力彩、大樂透近期冷熱號，還有包牌產生器幫你組號。<strong>539 包牌計算器</strong>則讓你選碼後秒算注數、花費、各獎項命中機率，搭配蒙地卡羅模擬看清長期損益。</p>
    <p><strong>娛樂城體檢</strong>一鍵比對 165 詐騙黑名單 + WHOIS 網域資料，入金前 30 秒就能判斷安不安全。</p>
    <p><strong>百家樂策略模擬器</strong>讓你用馬丁格爾、柏利等五種注碼法跑 1000 局回測，看清莊家優勢。</p>
    <p><strong>資金管理計算器</strong>幫你算出停損停利線，控制每局下注比例。</p>
    <p><strong>老虎機 RTP 紀錄器</strong>記錄你的真實遊戲數據，自動計算實際 RTP。</p>
    <p><strong>娛樂城獎金計算器</strong>輸入存款、贈送金額和打碼倍數，即時算出預期虧損，告訴你紅利到底值不值得拿。</p>
    <p><strong>PGSI 賭博成癮自我檢測</strong>用國際通用的 9 題量表，幫你快速評估自己的博弈習慣是否健康。</p>
    <p>所有工具免註冊、零廣告，數據只存在你的瀏覽器裡。</p>
  </section>

  <!-- 底部提示 -->
  <div class="tools-footer-note">
    <p>🌿 更多工具持續開發中。如果你有想要的功能，歡迎到我們的社群告訴芭樂子。</p>
  </div>

  <div style="text-align:center;margin:2rem 0">
    <a href="/" class="btn-outline">&larr; 回首頁</a>
  </div>
</div>

<style>
  .tools-hero {
    text-align: center;
    padding: 3rem 1rem 0.5rem;
  }
  .tools-hero h1 {
    font-size: 2.2rem;
    margin-bottom: 0.5rem;
  }
  .tools-sub {
    font-size: 1.15rem;
    color: var(--gold);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .tools-desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* === TILE GRID === */
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin: 2.5rem auto 0;
    max-width: 820px;
  }

  .tool-tile {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2.2rem 1.2rem 1.8rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.3s;
    overflow: hidden;
  }

  /* Glow effect on hover */
  .tile-glow {
    position: absolute;
    inset: 0;
    opacity: 0;
    background: radial-gradient(circle at 50% 40%, var(--glow-color, rgba(57,255,20,0.2)), transparent 70%);
    transition: opacity 0.4s;
    pointer-events: none;
  }
  .tool-tile:hover .tile-glow {
    opacity: 1;
  }
  .tool-tile:hover {
    border-color: rgba(255,255,255,0.15);
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 16px 48px rgba(0,0,0,0.4);
  }

  .tile-icon {
    width: 72px;
    height: 72px;
    border-radius: 18px;
    margin-bottom: 1rem;
    position: relative;
    z-index: 1;
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
    object-fit: cover;
  }

  .tool-tile h2 {
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.4;
    margin: 0 0 0.4rem;
    position: relative;
    z-index: 1;
  }

  .tool-tile p {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin: 0;
    position: relative;
    z-index: 1;
    line-height: 1.4;
  }

  /* === 工具介紹段落 === */
  .tools-intro {
    max-width: 720px;
    margin: 3rem auto 0;
    padding: 1.5rem 1.2rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
  }
  .tools-intro h2 {
    font-size: 1.15rem;
    font-weight: 800;
    margin-bottom: 0.8rem;
    color: var(--gold);
  }
  .tools-intro p {
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--text-secondary, #ccc);
    margin: 0;
  }
  .tools-intro strong {
    color: var(--text-primary);
  }

  .tools-footer-note {
    text-align: center;
    margin: 3rem auto 0;
    padding: 1rem;
    max-width: 720px;
  }
  .tools-footer-note p {
    margin: 0;
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  /* === TABLET === */
  @media (max-width: 768px) {
    .tools-grid {
      grid-template-columns: repeat(2, 1fr);
      max-width: 420px;
      gap: 1rem;
    }
    .tile-icon {
      width: 60px;
      height: 60px;
      border-radius: 14px;
    }
    .tool-tile {
      padding: 1.8rem 1rem 1.5rem;
    }
    .tool-tile h2 { font-size: 0.9rem; }
  }

  /* === MOBILE === */
  @media (max-width: 480px) {
    .tools-hero { padding: 2rem 1rem 0.5rem; }
    .tools-hero h1 { font-size: 1.6rem; }
    .tools-sub { font-size: 1rem; }

    .tools-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.7rem;
      max-width: 100%;
      padding: 0 0.2rem;
    }
    .tool-tile {
      padding: 1.4rem 0.6rem 1.2rem;
      border-radius: 14px;
    }
    .tile-icon {
      width: 96px;
      height: 96px;
      border-radius: 20px;
      margin-bottom: 0.7rem;
    }
    .tool-tile h2 {
      font-size: 0.78rem;
    }
    .tool-tile p {
      font-size: 0.68rem;
    }
    .tools-intro {
      padding: 1.2rem;
    }
    .tools-intro h2 {
      font-size: 1.1rem;
    }
    .tools-intro p {
      font-size: 0.92rem;
    }
  }
</style>
</BaseLayout>
