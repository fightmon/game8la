  // 注意力檢查題庫（隨機選一題，要求選指定選項）
  const ATTENTION_CHECKS = [
    { text: '這題是確認你有在認真看題目 👀 請選擇「有時」。', expectedValue: 1, expectedLabel: '有時' },
    { text: '注意力確認：請選擇下方的「大多數時候」來繼續作答。', expectedValue: 2, expectedLabel: '大多數時候' },
