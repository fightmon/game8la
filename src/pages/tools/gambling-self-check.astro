        html += '<p>✅ 關心他/她在娛樂城的花費頻率與金額</p>';
        html += '<p>✅ 提醒「追輸」是最危險的行為模式</p>';
        html += '<p>✅ 讓他/她知道你在關心，而非批評</p>';
        html += '</div>';
      } else {
        html += '<p>你的回答顯示一些初期警訊。分數還在可控範圍，但要開始留意了。</p>';
        html += '<div class="action-list">';
        html += '<p>✅ 設定每月娛樂城預算上限，花完就停</p>';
        html += '<p>✅ 記錄在娛樂城的花費次數與金額</p>';
        html += '<p>✅ 避免「追輸」——輸了想贏回來是最危險的行為</p>';
        html += '<p>✅ 跟信任的人聊聊你玩娛樂城的狀況</p>';
        html += '</div>';
      }
      html += '</div>';
      // Low 結果 TG CTA
      html += '<div class="gradual-steps">';
      html += '<p class="gradual-title">💡 想了解更多？</p>';
      html += '<a href="https://t.me/game8la" target="_blank" rel="noopener" class="gradual-card step-low">';
      html += '<span class="gradual-icon">💬</span>';
      html += '<span class="gradual-body"><strong>加入 8LA Telegram 社群</strong><small>匿名加入，跟懂的人聊聊娛樂城的眉角</small></span>';
      html += '</a>';
      html += '</div>';
    } else {
      // none
      html += '<div class="result-desc">';
      if (proxyMode) {
        html += '<p>根據你的觀察，他/她目前沒有明顯的問題。</p>';
        html += '<div class="action-list">';
        html += '<p>✅ 目前看起來正常，但可以持續留意</p>';
        html += '<p>✅ 「目前沒問題」不代表「永遠不會有問題」</p>';
        html += '<p>✅ 如果之後發現情況變化，可以再來測一次</p>';
        html += '</div>';
        html += '<p style="margin-top:0.8rem;font-size:0.9rem;color:var(--text-muted)">你的關心是最好的防線。如有需要，<a href="tel:1925" style="color:var(--gold)">1925 安心專線</a>隨時在。</p>';
      } else {
        html += '<p>從你的回答來看，你目前沒有明顯的問題。</p>';
        html += '<div class="action-list">';
        html += '<p>✅ 娛樂城的長期期望值是負的——平均一定虧</p>';
        html += '<p>✅ 「目前沒問題」不代表「永遠不會有問題」</p>';
        html += '<p>✅ 持續關注自己在娛樂城的花費頻率與金額</p>';
        html += '</div>';
        html += '<p style="margin-top:0.8rem;font-size:0.9rem;color:var(--text-muted)">如果有需要，<a href="tel:1925" style="color:var(--gold)">1925 安心專線</a>隨時在。</p>';
      }
      html += '</div>';
      // None 結果 TG CTA
      html += '<div class="gradual-steps">';
      html += '<p class="gradual-title">🍈 想聊聊娛樂城的事？</p>';
      html += '<a href="https://t.me/game8la" target="_blank" rel="noopener" class="gradual-card step-low">';
      html += '<span class="gradual-icon">💬</span>';
      html += '<span class="gradual-body"><strong>加入 8LA Telegram 社群</strong><small>匿名加入，一起用數據看清娛樂城</small></span>';
      html += '</a>';
      html += '</div>';
    }

    // 分項回顧
    const dimensionLabels = {
      q1_overbet: '超額下注',
      q2_tolerance: '耐受性提高',
      q3_chasing: '追輸行為',
      q4_borrowing: '借錢／挪用',
      q5_problem: '自覺有問題',
      q6_health: '身心影響',
      q7_criticism: '被他人批評',
      q8_financial: '財務困難',
      q9_guilt: '愧疚感',
    };
    const dotColor = function (v) { return v === 0 ? '🟢' : v === 1 ? '🟡' : v === 2 ? '🟠' : '🔴'; };
    html += '<details class="review-collapse">';
    html += '<summary>📊 ' + (proxyMode ? '答題回顧（旁觀者評估）' : '你的答題回顧') + '</summary>';
    html += '<div class="review-items">';
    var realIdx = 0;
    QUESTIONS.forEach(function (q, i) {
      if (q.isAttentionCheck) return; // 跳過注意力檢查題
      realIdx++;
      const v = answers[i] || 0;
      const label = dimensionLabels[q.id] || q.id;
      html += '<div class="review-row">';
      html += '<span class="rq-dot">' + dotColor(v) + '</span>';
      html += '<span class="rq-label">Q' + realIdx + ' ' + label + '</span>';
      html += '<span class="rq-score" style="color:' + (v >= 2 ? '#ff8800' : 'var(--text-muted)') + '">' + v + ' / 3</span>';
      html += '</div>';
    });
    html += '</div></details>';

    resultArea.innerHTML = html;

    // Store level for share card
    resultArea.dataset.level = levelKey;
    resultArea.dataset.score = score;

    // GA4 event
    if (typeof gtag === 'function') gtag('event', 'pgsi_complete', { level: levelKey });
  }

  // ============ CANVAS SHARE CARD ============
  function generateShareCard() {
    const levelKey = resultArea.dataset.level;
    const level = LEVELS[levelKey];
    const canvas = document.getElementById('share-canvas');
    const ctx = canvas.getContext('2d');

    const colorMap = {
      none:     ['#0a1a0a', '#1a3a1a', '#39FF14'],
      low:      ['#1a1a0a', '#3a3a1a', '#f5b800'],
      moderate: ['#1a0e0a', '#3a1f1a', '#ff8800'],
      severe:   ['#1a0a0a', '#3a0a0a', '#ff4d4d']
    };
    const c = colorMap[levelKey];

    // Background gradient
    const grad = ctx.createLinearGradient(0, 0, 1080, 1080);
    grad.addColorStop(0, c[0]);
    grad.addColorStop(0.5, c[1]);
    grad.addColorStop(1, c[2] + '40');
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, 1080, 1080);

    // Title
    ctx.fillStyle = c[2];
    ctx.font = 'bold 52px sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('🛡️ 娛樂城成癮自我檢測', 540, 150);

    // Main result (large)
    const titleMap = { none: '✅ 健康', low: '🟡 低度風險', moderate: '🟠 中度風險', severe: '🔴 高度風險' };
    ctx.fillStyle = c[2];
    ctx.font = 'bold 100px sans-serif';
    ctx.fillText(titleMap[levelKey], 540, 450);

    // Subtitle
    ctx.fillStyle = '#ffffff';
    ctx.font = '32px sans-serif';
    ctx.fillText('基於 PGSI 國際標準量表', 540, 540);

    // 1925 for severe
    if (levelKey === 'severe' || levelKey === 'moderate') {
      ctx.fillStyle = '#f5b800';
      ctx.font = 'bold 42px sans-serif';
      ctx.fillText('📞 1925 安心專線', 540, 680);
      ctx.fillStyle = '#ffffff';
      ctx.font = '26px sans-serif';
      ctx.fillText('24 小時免費諮詢', 540, 730);
    }

    // Branding
    ctx.fillStyle = c[2];
    ctx.font = 'bold 36px sans-serif';
    ctx.fillText('🍈 Game8la', 540, 900);

    ctx.fillStyle = '#ffffff';
    ctx.font = '26px sans-serif';
    ctx.fillText('game8la.com/tools/gambling-self-check', 540, 950);

    ctx.fillStyle = '#aaaaaa';
    ctx.font = '22px sans-serif';
    ctx.fillText('你也來自評，5 分鐘搞定', 540, 1000);

    ctx.fillStyle = '#888888';
    ctx.font = '20px sans-serif';
    ctx.fillText('💬 匿名社群 t.me/game8la', 540, 1040);

    return canvas;
  }

  function downloadShareCard() {
    const canvas = generateShareCard();
    canvas.toBlob(function (blob) {
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'game8la-pgsi-' + (resultArea.dataset.level || 'result') + '.png';
      a.click();
      URL.revokeObjectURL(url);
    }, 'image/png');
    if (typeof gtag === 'function') gtag('event', 'pgsi_share');
  }

  // ============ MODE TOGGLE ============
  var modeBtns = document.querySelectorAll('.mode-btn');
  modeBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      modeBtns.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      proxyMode = btn.dataset.mode === 'proxy';
      // Update start button text
      if (!answers.some(function (a) { return a !== null; })) {
        btnStart.textContent = proxyMode ? '開始幫他/她評估 →' : '我了解，開始檢測 →';
      }
    });
  });

  // Restore mode toggle state from saved progress
  if (proxyMode) {
    modeBtns.forEach(function (b) { b.classList.remove('active'); });
    var proxyBtn = document.querySelector('.mode-btn[data-mode="proxy"]');
    if (proxyBtn) proxyBtn.classList.add('active');
  }

  // ============ EVENT HANDLERS ============
  btnStart.addEventListener('click', function () {
    // Re-pick questions based on current mode (only if no saved progress)
    if (!answers.some(function (a) { return a !== null; })) {
      QUESTIONS = pickQuestions();
      answers = new Array(QUESTIONS.length).fill(null);
    }
    showSection(secQuiz);
    renderQuestion();
    if (typeof gtag === 'function') gtag('event', 'pgsi_start', { mode: proxyMode ? 'proxy' : 'self' });
  });

  btnPrev.addEventListener('click', function () {
    if (currentQ > 0) { currentQ--; saveProgress(); renderQuestion(); }
  });

  btnNext.addEventListener('click', function () {
    if (answers[currentQ] === null) return;
    if (currentQ < QUESTIONS.length - 1) {
      currentQ++;
      saveProgress();
      renderQuestion();
    } else {
      // Submit — show results
      sessionStorage.removeItem('pgsi_progress');
      showSection(secResult);
      renderResult();
    }
  });

  btnDownload.addEventListener('click', downloadShareCard);

  btnRestart.addEventListener('click', function () {
    proxyMode = false;
    QUESTIONS = pickQuestions(); // 重測時重新隨機抽題
    answers = new Array(QUESTIONS.length).fill(null);
    currentQ = 0;
    sessionStorage.removeItem('pgsi_progress');
    // Reset mode toggle
    modeBtns.forEach(function (b) { b.classList.remove('active'); });
    var selfBtn = document.querySelector('.mode-btn[data-mode="self"]');
    if (selfBtn) selfBtn.classList.add('active');
    btnStart.textContent = '我了解，開始檢測 →';
    btnStart.style.background = '';
    showSection(secLanding);
  });

  // ============ DROPOFF TRACKING ============
  let dropoffFired = false;
  function fireDropoff() {
    if (dropoffFired) return;
    if (currentQ < QUESTIONS.length && answers.some(a => a !== null) && secQuiz.classList.contains('active')) {
      dropoffFired = true;
      if (typeof gtag === 'function') gtag('event', 'pgsi_dropoff', { last_q: currentQ + 1, answered: answers.filter(a => a !== null).length });
    }
  }
  document.addEventListener('visibilitychange', function () { if (document.visibilityState === 'hidden') fireDropoff(); });
  window.addEventListener('pagehide', fireDropoff);

  // If we had saved progress, show resume prompt on landing button
  if (answers.some(a => a !== null)) {
    const answeredCount = answers.filter(a => a !== null).length;
    btnStart.textContent = '繼續上次的檢測（第 ' + (currentQ + 1) + ' 題）→';
    btnStart.style.background = 'var(--gold)';
  }
})();
</script>
