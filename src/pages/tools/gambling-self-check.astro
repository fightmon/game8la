  ];

  // 每次測驗隨機選一組措辭（同一次測驗內固定）+ 插入注意力檢查題
  function pickQuestions() {
    const pool = proxyMode ? QUESTION_POOL_PROXY : QUESTION_POOL;
    const questions = pool.map(q => ({
      id: q.id,
      text: q.variants[Math.floor(Math.random() * q.variants.length)],
    }));
    // 在 Q4~Q6 之間隨機插入一題注意力檢查（index 3, 4, 或 5）
    const attPos = 3 + Math.floor(Math.random() * 3);
    const att = ATTENTION_CHECKS[Math.floor(Math.random() * ATTENTION_CHECKS.length)];
    questions.splice(attPos, 0, {
      id: 'attention_check',
      text: att.text,
      isAttentionCheck: true,
      expectedValue: att.expectedValue,
      expectedLabel: att.expectedLabel,
    });
    return questions;
  }

  let QUESTIONS = pickQuestions();

  const OPTIONS = [
