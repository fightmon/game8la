  // ============ QUIZ RENDER ============
  // 計算目前是「第幾題正式題」（跳過 attention check）
  function getRealQNum(idx) {
    let count = 0;
    for (let i = 0; i <= idx; i++) {
      if (!QUESTIONS[i].isAttentionCheck) count++;
    }
    return count;
  }
  function getTotalReal() {
    return QUESTIONS.filter(q => !q.isAttentionCheck).length;
  }

  function renderQuestion() {
    const q = QUESTIONS[currentQ];
    const isAtt = q.isAttentionCheck;
    const totalReal = getTotalReal();

    // 進度條：用正式題數算
    if (isAtt) {
      document.getElementById('q-progress-text').textContent = '注意力確認';
      // 進度條維持前一題的位置
      const prevReal = getRealQNum(currentQ - 1);
      progressFill.style.width = (prevReal / totalReal * 100) + '%';
    } else {
      const realNum = getRealQNum(currentQ);
      document.getElementById('q-progress-text').textContent = '第 ' + realNum + ' 題 / 共 ' + totalReal + ' 題';
      progressFill.style.width = (realNum / totalReal * 100) + '%';
    }

    let html = '<div class="question-card' + (isAtt ? ' attention-check-card' : '') + '">';
    if (isAtt) {
      html += '<p class="question-text"><span class="question-num att-badge">✋</span> ' + q.text + '</p>';
    } else {
      html += '<p class="question-text"><span class="question-num">Q' + getRealQNum(currentQ) + '.</span> ' + q.text + '</p>';
    }
    html += '<div class="option-list">';
    OPTIONS.forEach(opt => {
      const sel = answers[currentQ] === opt.value ? ' selected' : '';
      html += '<button type="button" class="option-btn' + sel + '" data-value="' + opt.value + '">';
      html += '<span class="radio-circle"></span>';
      html += '<span>' + opt.label + '</span>';
      html += '</button>';
    });
    html += '</div>';
    // 答錯提示區（初始隱藏）
    if (isAtt) {
      html += '<div class="att-wrong-hint" id="att-wrong-hint" style="display:none">';
      html += '<p>😅 看起來你太快作答了，請再看一次題目喔！</p>';
      html += '</div>';
    }
    html += '</div>';
    qArea.innerHTML = html;

    // Bind option clicks
    qArea.querySelectorAll('.option-btn').forEach(btn => {
      btn.addEventListener('click', function () {
        const val = parseInt(this.dataset.value);

        // 注意力檢查題：答錯要擋住
        if (isAtt && val !== q.expectedValue) {
          // 顯示提示 + shake 動畫
          var hint = document.getElementById('att-wrong-hint');
          if (hint) hint.style.display = 'block';
          var card = qArea.querySelector('.question-card');
          if (card) {
            card.classList.remove('shake');
            void card.offsetWidth; // force reflow to re-trigger animation
            card.classList.add('shake');
          }
          // 清除選取狀態
          qArea.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
          answers[currentQ] = null;
          updateNav();
          return;
        }

        // 注意力檢查答對：隱藏提示
        if (isAtt) {
          var hint = document.getElementById('att-wrong-hint');
          if (hint) hint.style.display = 'none';
        }

        answers[currentQ] = val;
        qArea.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
        this.classList.add('selected');
        updateNav();
        saveProgress();
        // GA4 event (question answered, no score detail)
        if (!isAtt && typeof gtag === 'function') gtag('event', 'pgsi_q_answered', { q_num: getRealQNum(currentQ) });
      });
    });

    updateNav();
  }

  function updateNav() {
    btnPrev.disabled = currentQ === 0;
    const answered = answers[currentQ] !== null;
    btnNext.disabled = !answered;

    if (currentQ === QUESTIONS.length - 1) {
      btnNext.textContent = '查看結果 ✓';
      btnNext.classList.add('submit-mode');
    } else {
      btnNext.textContent = '下一題 ➡';
      btnNext.classList.remove('submit-mode');
    }
