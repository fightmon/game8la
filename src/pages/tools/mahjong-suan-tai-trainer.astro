  /* ===== 動畫（讓畫面活起來） ===== */
  @keyframes stDeal{ 0%{opacity:0;transform:translateY(16px) scale(.85)} 100%{opacity:1;transform:none} }
  @keyframes stBtnIn{ 0%{opacity:0;transform:translateY(10px)} 100%{opacity:1;transform:none} }
  @keyframes stPop{ 0%{transform:scale(.3);opacity:0} 70%{transform:scale(1.18)} 100%{transform:scale(1);opacity:1} }
  @keyframes stCorrect{ 0%{transform:scale(1)} 35%{transform:scale(1.14)} 70%{transform:scale(.96)} 100%{transform:scale(1)} }
  @keyframes stShake{ 0%,100%{transform:translateX(0)} 20%{transform:translateX(-7px)} 40%{transform:translateX(7px)} 60%{transform:translateX(-5px)} 80%{transform:translateX(5px)} }
  @keyframes stHlPulse{ 0%,100%{box-shadow:0 0 0 2px var(--gold,#f5b800)} 50%{box-shadow:0 0 16px 3px var(--gold,#f5b800)} }
  @keyframes stNextPulse{ 0%,100%{box-shadow:0 4px 14px rgba(245,184,0,.25)} 50%{box-shadow:0 6px 26px rgba(245,184,0,.6)} }
  @keyframes stVerdictPop{ 0%{opacity:0;transform:scale(.7)} 60%{transform:scale(1.08)} 100%{opacity:1;transform:scale(1)} }
  @keyframes stFillShine{ 0%{background-position:0% 0} 100%{background-position:200% 0} }

  .st-meld{ animation: stDeal .42s cubic-bezier(.2,.8,.3,1) both; }
  .st-guess button{ animation: stBtnIn .34s ease both; }
  .st-guess button.right{ animation: stCorrect .5s ease; }
