    .st-ask{ font-size:1.15rem; margin:.95rem 0 .65rem; }
    .st-guess{ gap:9px; }
    .st-guess button{ font-size:1.25rem; padding:13px 18px; min-width:76px; }
    .st-stats{ padding:.85rem .9rem; margin-top:1.1rem; }
    .st-stat{ padding:.5rem .85rem; font-size:.92rem; }
    .st-stat strong{ font-size:1.25rem; }
    .st-verdict{ font-size:1.3rem; }
    .st-encore{ font-size:1rem; }
    .st-final{ padding:1.4rem 1rem; }
    .st-final-score{ font-size:2.5rem; }
    .st-final-title{ font-size:1.2rem; }
    .st-final-msg{ font-size:1rem; }
    .st-hl-hint{ font-size:.86rem; }
    table.st-tai{ font-size:1.02rem; }
    table.st-tai td{ padding:.55rem .3rem; }
    table.st-tai tr.total td{ font-size:1.15rem; }
    .st-next{ padding:13px 32px; font-size:1.1rem; margin-top:1.1rem; }
  }
  @media (max-width:380px){
    .st-meld-tiles svg{ width:30px; height:41px; }
    .st-hand{ gap:5px; }
    .st-meld{ padding:2px 2px; }
    .st-badge{ font-size:.76rem; padding:.26rem .48rem; }
    .st-guess button{ font-size:1.15rem; min-width:66px; padding:12px 14px; }
  }
</style>

<script is:inline>
/* ===== 算台引擎（逐副牌記錄明/暗）＋ UI ===== */
(function(){
  const TAI = { qingYiSe:8, hunYiSe:4, ziYiSe:16, pengPeng:4, anke:{3:2,4:5,5:8},
    dragon:1, xiaoSanYuan:4, daSanYuan:8, quanFeng:1, menFeng:1, xiaoSiXi:8, daSiXi:16, menQing:1, ziMo:1 };
  const CN=["","一","二","三","四","五","六","七","八","九"];
  const HCH={1:"東",2:"南",3:"西",4:"北",5:"中",6:"發",7:"白"};
  const HCOL={1:"#1d4ee8",2:"#1d4ee8",3:"#1d4ee8",4:"#1d4ee8",5:"#c0282d",6:"#1e7a46",7:"#2b7bb0"};

  function grid(n){ const L=24,C=36,R=48; return ({
    1:[[C,50]],2:[[C,30],[C,70]],3:[[L,28],[C,50],[R,72]],
    4:[[L,30],[R,30],[L,70],[R,70]],5:[[L,30],[R,30],[C,50],[L,70],[R,70]],
    6:[[L,28],[R,28],[L,50],[R,50],[L,72],[R,72]],
    7:[[L,26],[R,26],[L,50],[C,50],[R,50],[L,74],[R,74]],
    8:[[L,24],[R,24],[L,42],[R,42],[L,60],[R,60],[L,78],[R,78]],
    9:[[L,26],[C,26],[R,26],[L,50],[C,50],[R,50],[L,74],[C,74],[R,74]] })[n]; }
  function pin(n){ const cols=["#1e7a46","#c0282d","#1d4ee8"];
    return grid(n).map(function(p,i){ const x=p[0],y=p[1],col=n===1?"#c0282d":cols[i%3],r=n===1?16:7.5;
      return '<circle cx="'+x+'" cy="'+y+'" r="'+r+'" fill="#fff" stroke="'+col+'" stroke-width="'+(n===1?3:2.4)+'"/><circle cx="'+x+'" cy="'+y+'" r="'+(r*0.42)+'" fill="'+col+'"/>'; }).join(""); }
  function sou(n){ if(n===1) return '<g transform="translate(36,50)"><ellipse cx="0" cy="7" rx="12" ry="15" fill="#1e7a46"/><circle cx="0" cy="-11" r="7.5" fill="#c0282d"/><path d="M0 15 L-5 28 L5 28 Z" fill="#e0a020"/><circle cx="-2.5" cy="-12" r="1.5" fill="#fff"/></g>';
    return grid(n).map(function(p){ const x=p[0],y=p[1];
      return '<g><rect x="'+(x-3)+'" y="'+(y-11)+'" width="6" height="22" rx="3" fill="#1e7a46"/><rect x="'+(x-4.4)+'" y="'+(y-3)+'" width="8.8" height="2.6" rx="1.3" fill="#0c5c30"/><rect x="'+(x-4.4)+'" y="'+(y+5)+'" width="8.8" height="2.6" rx="1.3" fill="#0c5c30"/></g>'; }).join(""); }
  function wan(n){ return '<text x="36" y="40" font-size="25" text-anchor="middle" fill="#c0282d" font-family="serif" font-weight="700">'+CN[n]+'</text><text x="36" y="76" font-size="29" text-anchor="middle" fill="#1b3a2a" font-family="serif" font-weight="800">萬</text>'; }
  function honor(n){ return '<text x="36" y="63" font-size="40" text-anchor="middle" fill="'+HCOL[n]+'" font-family="serif" font-weight="800">'+HCH[n]+'</text>'; }
  function tileSVG(t){ const n=+t[0], s=t[1];
    const inner = s==='m'?wan(n):s==='p'?pin(n):s==='s'?sou(n):honor(n);
    return '<svg viewBox="0 0 72 98" xmlns="http://www.w3.org/2000/svg"><defs><linearGradient id="stfc" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#fffdf6"/><stop offset="1" stop-color="#ece4cf"/></linearGradient><linearGradient id="stsd" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#e9dcc0"/><stop offset="1" stop-color="#bda77f"/></linearGradient></defs><rect x="3" y="8" width="66" height="88" rx="9" fill="url(#stsd)"/><rect x="3" y="3" width="66" height="86" rx="9" fill="url(#stfc)" stroke="#d9cdaf"/>'+inner+'</svg>'; }

  /* 面子建構器：P=暗刻 MP=明刻(碰) CH=順子 */
  function P(t){ return {t:t,kind:'pung',exposed:false}; }
  function MP(t){ return {t:t,kind:'pung',exposed:true}; }
  function CH(t){ return {t:t,kind:'chow',exposed:false}; }
  function meldTiles(m){ const n=+m.t[0],s=m.t[1];
    return m.kind==='pung'?[m.t,m.t,m.t]:[m.t,(n+1)+s,(n+2)+s]; }

  const WHY={ '清一色':'整手都同一花色、沒有字牌','混一色':'同一花色 + 字牌','字一色':'整手都是字牌',
    '碰碰胡':'五副都是刻子、沒有順子','大三元':'中、發、白各一刻（明暗都算）','小三元':'中發白其中兩刻 + 第三個做對',
    '三元刻（中/發/白）':'中/發/白其中一種的刻子','圈風刻':'這局圈風的刻子','門風刻':'自己門風的刻子',
    '大四喜':'東南西北四刻','小四喜':'三個風刻 + 一對風','門清':'沒有吃、碰、明槓，整手自己摸成','自摸':'最後一張自己摸到',
    '三暗刻':'三副自己摸成的暗刻（沒碰）','四暗刻':'四副暗刻（沒碰）','五暗刻':'五副暗刻（門清自摸碰碰胡）' };

  function scoreHand(melds, pair, ctx){
    const lines=[];
    const idxAll=melds.map(function(_,i){return i;});
    const all=[]; melds.forEach(function(m){ meldTiles(m).forEach(function(t){all.push(t);}); }); all.push(pair,pair);
    const numSuits=new Set(all.filter(function(t){return t[1]!=='z';}).map(function(t){return t[1];}));
    const hasHonor=all.some(function(t){return t[1]==='z';});
    const pungIdx=[]; melds.forEach(function(m,i){ if(m.kind==='pung') pungIdx.push(i); });
    const concealedPungIdx=pungIdx.filter(function(i){ return !melds[i].exposed; });
    const allConcealed=melds.every(function(m){ return !m.exposed; });
    function push(name,tai,groups,pairRef,why){ lines.push({name:name,tai:tai,why:why||WHY[name]||'',groups:groups||[],pairRef:!!pairRef}); }

    if(numSuits.size===0) push('字一色',TAI.ziYiSe,idxAll,true);
    else if(numSuits.size===1 && hasHonor) push('混一色',TAI.hunYiSe,idxAll,true);
    else if(numSuits.size===1 && !hasHonor) push('清一色',TAI.qingYiSe,idxAll,true);

    if(pungIdx.length===5) push('碰碰胡',TAI.pengPeng,pungIdx,false);

    if(concealedPungIdx.length>=3){ const k=concealedPungIdx.length; if(TAI.anke[k]) push(CN[k]+'暗刻',TAI.anke[k],concealedPungIdx,false); }

    const dragonIdx=pungIdx.filter(function(i){ return melds[i].t[1]==='z' && +melds[i].t[0]>=5; });
    const dragonPair=(pair[1]==='z' && +pair[0]>=5);
    if(dragonIdx.length===3) push('大三元',TAI.daSanYuan,dragonIdx,false);
    else if(dragonIdx.length===2 && dragonPair) push('小三元',TAI.xiaoSanYuan,dragonIdx,true);
    else dragonIdx.forEach(function(i){ push('三元刻（中/發/白）',TAI.dragon,[i],false); });

    const windIdx=pungIdx.filter(function(i){ return melds[i].t[1]==='z' && +melds[i].t[0]<=4; });
    const windPair=(pair[1]==='z' && +pair[0]<=4);
    if(windIdx.length===4) push('大四喜',TAI.daSiXi,windIdx,false);
    else if(windIdx.length===3 && windPair) push('小四喜',TAI.xiaoSiXi,windIdx,true);
    else windIdx.forEach(function(i){ const w=+melds[i].t[0];
      if(w===ctx.round) push('圈風刻',TAI.quanFeng,[i],false,'上方標示「圈風 '+HCH[ctx.round]+'」→ '+HCH[ctx.round]+' 的刻子就是圈風刻（+1 台）');
      if(w===ctx.seat) push('門風刻',TAI.menFeng,[i],false,'上方標示「門風 '+HCH[ctx.seat]+'」→ '+HCH[ctx.seat]+' 的刻子就是門風刻（+1 台）'); });

    if(allConcealed) push('門清',TAI.menQing,idxAll,true);
    if(ctx.selfDraw) push('自摸',TAI.ziMo,[],false);

    const total=lines.reduce(function(s,l){ return s+l.tai; },0);
    return {total:total, lines:lines};
  }

  /* 題庫：每題明確列出 5 副面子 + 將，並標明哪副是「碰」(明刻) */
  const LESSONS=[
    // 1) 基本門清自摸（全順子）
    { melds:[CH('1m'),CH('4m'),CH('7m'),CH('2p'),CH('6p')], pair:'5s', ctx:{round:1,seat:4,selfDraw:true} },
    // 2) 清一色門清自摸
    { melds:[CH('1m'),CH('4m'),CH('7m'),CH('1m'),CH('5m')], pair:'9m', ctx:{round:1,seat:1,selfDraw:true} },
    // 3) 混一色 + 碰中（明刻）→ 教明刻、非門清
    { melds:[CH('1m'),CH('4m'),CH('7m'),CH('1m'),MP('5z')], pair:'9m', ctx:{round:3,seat:2,selfDraw:false} },
    // 4) 對照：同樣混一色，但中是自己摸的（暗刻）+ 門清自摸
    { melds:[CH('1m'),CH('4m'),CH('7m'),CH('1m'),P('5z')], pair:'9m', ctx:{round:3,seat:2,selfDraw:true} },
    // 5) 大三元（其中發是碰來的明刻）+ 自摸 → 碰了也算大三元
    { melds:[P('5z'),MP('6z'),P('7z'),CH('1m'),CH('4m')], pair:'9s', ctx:{round:1,seat:3,selfDraw:true} },
    // 6) 四暗刻 門清自摸
    { melds:[P('1m'),P('9m'),P('2p'),P('8s'),CH('4m')], pair:'5z', ctx:{round:1,seat:3,selfDraw:true} },
    // 7) 圈風刻 + 門風刻 門清自摸
    { melds:[P('1z'),P('2z'),CH('1m'),CH('4p'),CH('7s')], pair:'5s', ctx:{round:1,seat:2,selfDraw:true} }
  ];

  let idx=0, roundScore=0, correct=0, streak=0, best=0, cur=null, locked=false, pinned=null;
  const ENCORE={ 2:'連對 2 題！手感來了哦', 3:'3 連對！算台越來越順', 4:'4 連對！牌咖開始怕你算錯坑他們',
    5:'5 連對！這桌就你最會算台', 6:'6 連對！開桌記帳交給你就對了', 7:'7 連對！全對啦，芭樂子甘拜下風' };
  const $=function(id){ return document.getElementById(id); };
  const LS='suantai_stats';
  function loadStats(){ try{ return JSON.parse(localStorage.getItem(LS))||{correct:0,best:0}; }catch(e){ return {correct:0,best:0}; } }
  function saveStats(){ try{ localStorage.setItem(LS,JSON.stringify({correct:correct,best:best})); }catch(e){} }

  function capFor(m){ if(m.kind==='chow') return '順子'; return m.exposed?'明刻（碰）':'暗刻'; }
  function renderHand(melds,pair){
    let html='';
    melds.forEach(function(m,i){
      const tiles=meldTiles(m).map(tileSVG).join('');
      html+='<div class="st-meld'+(m.exposed?' exposed':'')+'" data-gi="'+i+'" style="animation-delay:'+(i*0.06)+'s">'
          + (m.kind==='pung' ? (m.exposed?'<span class="st-pong-chip">碰</span>':'<span class="st-an-chip">暗</span>') : '')
          + '<div class="st-meld-tiles">'+tiles+'</div>'
          + '<span class="st-meld-cap">'+capFor(m)+'</span></div>';
    });
    html+='<div class="st-meld" data-gi="pair" style="animation-delay:'+(melds.length*0.06)+'s"><div class="st-meld-tiles">'
        + [pair,pair].map(tileSVG).join('')
        + '</div><span class="st-meld-cap">將（眼）</span></div>';
    const hand=$('stHand'); hand.innerHTML=html; hand.classList.remove('revealed');
  }
  function renderCtx(melds,ctx){ const w={1:'東',2:'南',3:'西',4:'北'};
    let b='<span class="st-badge st-b-wind">圈風 '+w[ctx.round]+'</span><span class="st-badge st-b-wind">門風 '+w[ctx.seat]+'</span>';
    b+= ctx.selfDraw?'<span class="st-badge st-b-draw">自摸</span>':'<span class="st-badge st-b-ron">胡別人</span>';
    if(melds.every(function(m){return !m.exposed;})) b+='<span class="st-badge st-b-men">🔒 門清</span>';
    else b+='<span class="st-badge st-b-pong">有碰</span>';
    $('stCtx').innerHTML=b; }

  function clearHL(){ $('stHand').querySelectorAll('.st-meld.hl').forEach(function(e){ e.classList.remove('hl'); }); }
  function showRow(tr){ clearHL();
    (tr.dataset.groups||'').split(',').filter(function(x){return x!=='';}).forEach(function(i){
      const el=$('stHand').querySelector('[data-gi="'+i+'"]'); if(el) el.classList.add('hl'); });
    if(tr.dataset.pair==='1'){ const p=$('stHand').querySelector('[data-gi="pair"]'); if(p) p.classList.add('hl'); }
  }
  function wireHighlight(){ pinned=null;
    $('stBreakdown').querySelectorAll('tr').forEach(function(tr){
      if(tr.classList.contains('total')) return;
      tr.onmouseenter=function(){ if(!pinned) showRow(tr); };
      tr.onmouseleave=function(){ if(!pinned) clearHL(); };
      tr.onclick=function(){
        if(pinned===tr){ pinned=null; tr.classList.remove('pinned'); clearHL(); }
        else { $('stBreakdown').querySelectorAll('tr.pinned').forEach(function(x){x.classList.remove('pinned');});
               pinned=tr; tr.classList.add('pinned'); showRow(tr); }
      };
    });
  }

  function scrollGameIntoView(){
    const el=document.querySelector('.st-game'); if(!el) return;
    const y=el.getBoundingClientRect().top + window.pageYOffset - 84;
    window.scrollTo({ top:Math.max(0,y), behavior:'smooth' });
  }
  function load(doScroll){
    locked=false; pinned=null;
    const L=LESSONS[idx];
    cur={ res:scoreHand(L.melds,L.pair,L.ctx), melds:L.melds, pair:L.pair, ctx:L.ctx };
    $('stPtext').textContent='第 '+(idx+1)+' / '+LESSONS.length+' 題';
    $('stPfill').style.width=((idx+1)/LESSONS.length*100)+'%';
    $('stNext').textContent=(idx>=LESSONS.length-1)?'看結果 →':'下一題 →';
    $('stEncore').textContent='';
    renderCtx(L.melds,L.ctx); renderHand(L.melds,L.pair);
    const ans=cur.res.total, set=new Set([ans]);
    [ans-2,ans-1,ans+1,ans+2,ans+4].forEach(function(v){ if(v>0) set.add(v); });
    const opts=Array.from(set).sort(function(a,b){return a-b;}).slice(0,6);
    $('stGuess').innerHTML=opts.map(function(v,bi){ return '<button data-v="'+v+'" style="animation-delay:'+(bi*0.05)+'s">'+v+'</button>'; }).join('');
    $('stGuess').querySelectorAll('button').forEach(function(btn){ btn.onclick=function(){ guess(+btn.dataset.v,btn); }; });
    $('stReveal').classList.remove('show');
    clearHL();
    if(doScroll) scrollGameIntoView();
  }
  function guess(v,btn){
    if(locked) return; locked=true;
    const ans=cur.res.total, ok=(v===ans);
    $('stGuess').querySelectorAll('button').forEach(function(b){ b.disabled=true; });
    if(ok){ correct++; roundScore++; streak++; best=Math.max(best,streak); btn.classList.add('right'); }
    else { streak=0; btn.classList.add('wrong');
      $('stGuess').querySelectorAll('button').forEach(function(b){ if(+b.dataset.v===ans) b.classList.add('right'); }); }
    saveStats();
    $('stStreak').textContent=streak; $('stCorrect').textContent=correct; $('stBest').textContent=best;
    $('stVerdict').className='st-verdict '+(ok?'ok':'no');
    $('stVerdict').textContent= ok?('✅ 答對！這手 '+ans+' 台'):('❌ 正解是 '+ans+' 台');
    $('stEncore').textContent = (ok && streak>=2) ? ('🔥 '+(ENCORE[streak]||('連對 '+streak+' 題！神到不行')))
      : (!ok ? '連對紀錄歸零，下一題再拚回來！' : '');
    $('stBreakdown').innerHTML=cur.res.lines.map(function(l){
      return '<tr data-groups="'+l.groups.join(',')+'" data-pair="'+(l.pairRef?1:0)+'"><td>'+l.name
        +'<div class="st-why">'+l.why+'</div></td><td class="n">'+l.tai+' 台</td></tr>'; }).join('')
      +'<tr class="total"><td>合計</td><td class="n">'+ans+' 台</td></tr>';
    $('stHand').classList.add('revealed');
    wireHighlight();
    $('stReveal').classList.add('show');
  }

  function nextOrFinal(){ if(idx>=LESSONS.length-1){ showFinal(); } else { idx++; load(true); } }
  function showFinal(){
    const s=roundScore, n=LESSONS.length; let t,m;
    if(s===n){ t='🏆 算台宗師！'; m='全對！這桌記帳就交給你，誰也別想少算你的台。'; }
    else if(s>=n-1){ t='⭐ 老司機等級'; m='幾乎全對，算台難不倒你了，上桌穩穩收錢。'; }
    else if(s>=Math.ceil(n*0.55)){ t='👍 抓到訣竅了'; m='基本的台都會算了，幾個大牌再熟一點就無敵。再來一輪？'; }
    else if(s>=Math.ceil(n*0.28)){ t='😅 還會漏台'; m='有些台還沒抓穩，往上滑看一下「台數速查表」再挑戰一次。'; }
    else { t='💀 先別急著上桌 XD'; m='台數大多漏掉了，回頭把暗刻、門清那幾段看熟，慢慢來不急。'; }
    $('stFinalScore').textContent=s+' / '+n;
    $('stFinalTitle').textContent=t; $('stFinalMsg').textContent=m;
    document.querySelector('.st-card').style.display='none';
    $('stFinal').style.display='block';
    scrollGameIntoView();
  }
  function startRound(){ idx=0; roundScore=0; streak=0;
    document.querySelector('.st-card').style.display='';
    $('stFinal').style.display='none';
    $('stStreak').textContent=streak;
    load(false);
  }
  function init(){
    $('stNext').onclick=nextOrFinal;
    $('stReplay').onclick=function(){ startRound(); scrollGameIntoView(); };
    const st=loadStats(); correct=st.correct||0; best=st.best||0;
    $('stCorrect').textContent=correct; $('stBest').textContent=best;
    startRound();
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',init); else init();
})();
</script>
</BaseLayout>
