---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareButtons from '../../components/ShareButtons.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "麻將算台是什麼意思？", "acceptedAnswer": { "@type": "Answer", "text": "算台就是計算一手胡牌總共值多少「台」。台灣麻將的輸贏 = 底 + 台×台數，胡牌時把所有符合的台（門清、自摸、碰碰胡、清一色、大三元等）加總，乘上每台的金額，就是這把贏多少。台數算錯，錢就收錯。" } },
    { "@type": "Question", "name": "台灣麻將的「底」和「台」差在哪？", "acceptedAnswer": { "@type": "Answer", "text": "「底」是每把固定的基本彩金，不管牌型大小都要付；「台」是依牌型加成的部分。例如講好「10 底 10 台」，胡了一把 5 台的牌，輸家要付 10 + 10×5 = 60。底固定、台浮動，台數高低就靠牌型。" } },
    { "@type": "Question", "name": "暗刻和明刻差在哪？怎麼看？", "acceptedAnswer": { "@type": "Answer", "text": "暗刻是自己摸成、沒碰出來的刻子；明刻是碰別人打的牌湊成的刻子。兩者牌面一樣，差別在「怎麼來的」——碰過的牌會亮在桌面上（明刻），沒碰的留在手裡（暗刻）。只有暗刻能算三/四/五暗刻的台，碰出來的明刻不算。" } },
    { "@type": "Question", "name": "門清、自摸各算幾台？門清自摸呢？", "acceptedAnswer": { "@type": "Answer", "text": "常見規則下，門清（沒有吃、碰、明槓）1 台、自摸 1 台。如果是門清又自摸，兩個台會一起算，等於 2 台（部分地方台規會另加「不求人」台，依各桌約定）。" } },
    { "@type": "Question", "name": "圈風、門風是什麼？怎麼知道哪個是圈風刻？", "acceptedAnswer": { "@type": "Answer", "text": "圈風是「這場打到第幾圈」的風（東圈→南圈→西圈→北圈，打到哪圈那個風就是圈風）；門風是你「座位」的風（莊家東、下家南、對家西、上家北）。湊成圈風或門風的刻子各 1 台，同時是圈風又門風（連風）可算兩台，兩者都不是的風牌刻子（客風）則不算台。本練習器上方會直接標示這局的圈風和門風，對照手上哪副風牌刻子，就知道是不是圈風刻或門風刻。" } },
    { "@type": "Question", "name": "碰碰胡、清一色、混一色各幾台？", "acceptedAnswer": { "@type": "Answer", "text": "常見台數：碰碰胡（五副都是刻子）4 台、混一色（同一花色＋字牌）4 台、清一色（整手同一花色、無字牌）8 台。清一色比混一色高一倍，因為更難湊。這些台可以疊加，例如清一色碰碰胡就是 8＋4 台。" } },
    { "@type": "Question", "name": "大三元、小三元幾台？", "acceptedAnswer": { "@type": "Answer", "text": "大三元（中、發、白各一刻）常見 8 台；小三元（中發白其中兩刻＋第三個做對）常見 4 台。三元牌湊齊大三元幾乎是這把封王。注意：大三元不管刻子是自己摸的還是碰來的都算。" } },
    { "@type": "Question", "name": "三暗刻、四暗刻、五暗刻怎麼算？", "acceptedAnswer": { "@type": "Answer", "text": "暗刻是自己摸成、沒有碰出來的刻子。常見台數：三暗刻 2 台、四暗刻 5 台、五暗刻 8 台。重點是「沒碰」——只要其中一副刻子是碰來的（明刻），就不能算進暗刻數。五暗刻通常出現在門清自摸的碰碰胡，是非常稀有的大牌。" } },
    { "@type": "Question", "name": "各地算台規則不一樣嗎？這個練習器準嗎？", "acceptedAnswer": { "@type": "Answer", "text": "會。台灣各地、各桌的台數細節（尤其花牌、小三元、地方台）常有差異。本練習器採用台灣 16 張常見台數，所有數值都可調整。練習的重點是「看懂每個台怎麼來」，實際牌桌請以你那桌約定的台規為準。" } }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "首頁", "item": "https://game8la.com/" },
    { "@type": "ListItem", "position": 2, "name": "工具箱", "item": "https://game8la.com/tools/" },
    { "@type": "ListItem", "position": 3, "name": "麻將算台練習器" }
  ]
};

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "麻將算台練習器｜看牌猜台數，台灣16張算台一次學會",
  "applicationCategory": "GameApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "TWD" }
};
---
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

<BaseLayout
  currentPage="tools"
  title="麻將算台練習器｜看牌猜台數，台灣16張算台一次學會 — GAME8LA"
  description="不會算台？看牌型猜台數，門清、自摸、碰碰胡、清一色、大三元…即時拆解每個台怎麼來，還會標出暗刻、明刻、順子。台灣 16 張麻將算台教學，免費線上練習。"
  ogImage="https://game8la.com/images/og-image.webp"
>
<div class="container">

  <!-- ═══ Hero ═══ -->
  <div class="page-hero">
    <h1>🀄 麻將算台練習器</h1>
    <p class="hero-sub">看牌型，猜這手胡牌總共幾台 — 立刻看詳細拆解。</p>
    <p class="hero-desc">台灣 16 張規則，門清、自摸、碰碰胡、清一色、大三元…每副牌標出暗刻／明刻／順子，點台數還會幫你把對應的牌圈起來。</p>
  </div>

  <!-- ═══ 介紹段落（SEO 靜態內容）═══ -->
  <div class="intro-section">
    <h2>麻將算台是什麼？怎麼算？</h2>
    <p>
      <strong>麻將算台</strong>就是計算一手胡牌總共值多少「台」。台灣 16 張麻將的輸贏公式是
      <strong>底 ＋ 台 × 台數</strong>——「底」是每把固定的基本彩金，「台」則依牌型加成。
      胡牌時把所有符合的台（門清、自摸、碰碰胡、清一色、大三元…）加總，台數算錯，錢就收錯。
    </p>
    <p>
      新手最常卡在「<strong>暗刻</strong>到底長怎樣」——因為暗刻和明刻牌面一模一樣，差別只在「碰過沒」。
      這個<strong>算台練習器</strong>幫你看懂：碰來的牌會<strong>標上「碰」、亮在桌面（明刻）</strong>，沒碰的留在手裡（暗刻）；
      猜完每副牌下面會標出<strong>暗刻／明刻／順子／將</strong>，點任一個台還會把對應的牌<strong>圈起來發光</strong>，
      讓「為什麼是這個台」一眼看懂。不管你是第一次學<strong>台灣麻將算台教學</strong>，還是想搞清楚「門清自摸碰碰胡幾台」，一題一題練最快。
    </p>
  </div>

  <!-- ═══ 算台練習器（互動）═══ -->
  <section class="st-game">
    <div class="st-progress">
      <span class="st-progress-text" id="stPtext">第 1 / 7 題</span>
      <div class="st-progress-track"><div class="st-progress-fill" id="stPfill" style="width:14%"></div></div>
    </div>

    <div class="st-card">
      <div class="st-ctx" id="stCtx"></div>
      <div class="st-felt"><div class="st-hand" id="stHand"></div></div>
      <div class="st-legend">
        <span><span class="st-an-chip">暗</span> 自己摸的暗刻</span>
        <span><span class="st-pong-chip">碰</span> 碰來的明刻</span>
      </div>
      <div class="st-ask" id="stAsk">這手胡牌，總共幾台？</div>
      <div class="st-guess" id="stGuess"></div>
      <div class="st-reveal" id="stReveal">
        <div class="st-verdict" id="stVerdict"></div>
        <div class="st-encore" id="stEncore"></div>
        <p class="st-hl-hint">👆 點下面每一個台，桌上對應的牌會發光</p>
        <div class="st-breakdown-card"><table class="st-tai"><tbody id="stBreakdown"></tbody></table></div>
        <button class="st-next" id="stNext">下一題 →</button>
      </div>
    </div>

    <div class="st-final" id="stFinal" style="display:none">
      <div class="st-final-score" id="stFinalScore">0 / 7</div>
      <div class="st-final-title" id="stFinalTitle"></div>
      <div class="st-final-msg" id="stFinalMsg"></div>
      <button class="st-next" id="stReplay">🔄 再玩一次</button>
    </div>

    <div class="st-stats">
      <div class="st-stats-title">📊 你的練習紀錄</div>
      <div class="st-stats-row">
        <span class="st-stat">本輪連對 <strong id="stStreak">0</strong></span>
        <span class="st-stat">累計答對 <strong id="stCorrect">0</strong></span>
        <span class="st-stat">最佳連對 <strong id="stBest">0</strong></span>
      </div>
    </div>

    <div class="st-guava">
      <span class="st-guava-icon">🍈</span>
      <p>芭樂子提醒：算台規則各地各桌略有不同，這裡用台灣 16 張常見台數。練習重點是「看懂每個台怎麼來」，上桌請以你那桌約定的台規為準。本練習為娛樂教學，不涉及真實金錢。</p>
    </div>
  </section>

  <!-- ═══ 台數速查表（SEO 靜態內容）═══ -->
  <div class="intro-section">
    <h2>台灣 16 張常見台數速查表</h2>
    <div class="st-table-wrap">
      <table class="st-reftable">
        <thead><tr><th>牌型 / 情境</th><th>台數</th><th>說明</th></tr></thead>
        <tbody>
          <tr><td>門清</td><td>1</td><td>沒有吃、碰、明槓</td></tr>
          <tr><td>自摸</td><td>1</td><td>最後一張自己摸到</td></tr>
          <tr><td>圈風刻 / 門風刻</td><td>1 / 1</td><td>圈風、門風的刻子各 1 台</td></tr>
          <tr><td>三元刻（中/發/白）</td><td>1</td><td>單一三元牌的刻子（明暗都算）</td></tr>
          <tr><td>碰碰胡</td><td>4</td><td>五副都是刻子、沒有順子</td></tr>
          <tr><td>混一色</td><td>4</td><td>同一花色 ＋ 字牌</td></tr>
          <tr><td>小三元</td><td>4</td><td>中發白兩刻 ＋ 第三個做對</td></tr>
          <tr><td>三暗刻 / 四暗刻 / 五暗刻</td><td>2 / 5 / 8</td><td>自己摸成的暗刻（碰來的不算）</td></tr>
          <tr><td>清一色</td><td>8</td><td>整手同一花色、無字牌</td></tr>
          <tr><td>小四喜</td><td>8</td><td>三個風刻 ＋ 一對風</td></tr>
          <tr><td>大三元</td><td>8</td><td>中、發、白各一刻</td></tr>
          <tr><td>字一色</td><td>16</td><td>整手都是字牌</td></tr>
          <tr><td>大四喜</td><td>16</td><td>東南西北四刻</td></tr>
        </tbody>
      </table>
    </div>
    <p style="font-size:0.95rem;color:var(--text-muted,#999)">※ 以上為常見台數，地方台規（花牌、地方台、連莊拉莊等）依各桌約定。</p>
  </div>

  <!-- ═══ FAQ ═══ -->
  <section class="st-faq">
    <h2>❓ 麻將算台常見問題</h2>
    <details class="st-faq-item"><summary>麻將算台是什麼意思？</summary><p>算台就是計算一手胡牌總共值多少「台」。台灣麻將的輸贏 = 底 + 台×台數，胡牌時把所有符合的台（門清、自摸、碰碰胡、清一色、大三元等）加總，乘上每台的金額，就是這把贏多少。台數算錯，錢就收錯。</p></details>
    <details class="st-faq-item"><summary>台灣麻將的「底」和「台」差在哪？</summary><p>「底」是每把固定的基本彩金，不管牌型大小都要付；「台」是依牌型加成的部分。例如講好「10 底 10 台」，胡了一把 5 台的牌，輸家要付 10 + 10×5 = 60。底固定、台浮動，台數高低就靠牌型。</p></details>
    <details class="st-faq-item"><summary>暗刻和明刻差在哪？怎麼看？</summary><p>暗刻是自己摸成、沒碰出來的刻子；明刻是碰別人打的牌湊成的刻子。兩者牌面一樣，差別在「怎麼來的」——碰過的牌會亮在桌面上（明刻），沒碰的留在手裡（暗刻）。只有暗刻能算三/四/五暗刻的台，碰出來的明刻不算。本練習器會把碰來的牌標上「碰」並變暗，幫你一眼看出哪些是暗刻。</p></details>
    <details class="st-faq-item"><summary>門清、自摸各算幾台？門清自摸呢？</summary><p>常見規則下，門清（沒有吃、碰、明槓）1 台、自摸 1 台。如果是門清又自摸，兩個台會一起算，等於 2 台（部分地方台規會另加「不求人」台，依各桌約定）。</p></details>
    <details class="st-faq-item"><summary>圈風、門風是什麼？怎麼知道哪個是圈風刻？</summary><p>圈風是「這場打到第幾圈」的風（東圈→南圈→西圈→北圈，打到哪圈那個風就是圈風）；門風是你「座位」的風（莊家東、下家南、對家西、上家北）。湊成圈風或門風的刻子各 1 台，同時是圈風又門風（連風）可算兩台，兩者都不是的風牌刻子（客風）則不算台。本練習器上方會直接標示這局的圈風和門風，對照手上哪副風牌刻子，就知道是不是圈風刻或門風刻。</p></details>
    <details class="st-faq-item"><summary>碰碰胡、清一色、混一色各幾台？</summary><p>常見台數：碰碰胡（五副都是刻子）4 台、混一色（同一花色＋字牌）4 台、清一色（整手同一花色、無字牌）8 台。清一色比混一色高一倍，因為更難湊。這些台可以疊加，例如清一色碰碰胡就是 8＋4 台。</p></details>
    <details class="st-faq-item"><summary>大三元、小三元幾台？</summary><p>大三元（中、發、白各一刻）常見 8 台；小三元（中發白其中兩刻＋第三個做對）常見 4 台。三元牌湊齊大三元幾乎是這把封王。注意：大三元不管刻子是自己摸的還是碰來的都算。</p></details>
    <details class="st-faq-item"><summary>三暗刻、四暗刻、五暗刻怎麼算？</summary><p>暗刻是自己摸成、沒有碰出來的刻子。常見台數：三暗刻 2 台、四暗刻 5 台、五暗刻 8 台。重點是「沒碰」——只要其中一副刻子是碰來的（明刻），就不能算進暗刻數。五暗刻通常出現在門清自摸的碰碰胡，是非常稀有的大牌。</p></details>
    <details class="st-faq-item"><summary>各地算台規則不一樣嗎？這個練習器準嗎？</summary><p>會。台灣各地、各桌的台數細節（尤其花牌、小三元、地方台）常有差異。本練習器採用台灣 16 張常見台數，所有數值都可調整。練習的重點是「看懂每個台怎麼來」，實際牌桌請以你那桌約定的台規為準。</p></details>
  </section>

  <!-- ═══ CTA 導流 ═══ -->
  <section class="st-cta">
    <div class="st-cta-grid">
      <a href="/game-ranking/" class="st-cta-card">
        <span class="st-cta-icon">🏆</span>
        <div><strong>2026 金8LA遊戲排行</strong><p>熱門遊戲完整評分，誰是今年的 8LA 之王？</p></div>
      </a>
      <a href="/tools/" class="st-cta-card">
        <span class="st-cta-icon">🧰</span>
        <div><strong>8LA 工具箱</strong><p>更多免費計算器、模擬器、檢測工具</p></div>
      </a>
      <a href="/articles/" class="st-cta-card">
        <span class="st-cta-icon">📖</span>
        <div><strong>芭樂攻略</strong><p>看更多遊戲教學、玩法解析與防詐指南</p></div>
      </a>
    </div>
  </section>

  <ShareButtons title="麻將算台練習器 — 看牌猜台數，台灣16張算台一次學會" heading="🀄 不會算台的朋友該試試這個" />
</div>

<style is:global>
  /* 算台練習器（全部 st- 前綴；用 is:global，因為牌/徽章/按鈕是 JS 動態插入，scoped 樣式套不到） */
  .st-game{ max-width:680px; margin:1.5rem auto; }

  .st-progress{ margin-bottom:1.1rem; }
  .st-progress-text{ display:block; text-align:center; font-size:1.05rem; color:var(--text-secondary,#ccc); margin-bottom:.5rem; font-weight:700; }
  .st-progress-track{ height:8px; background:rgba(255,255,255,.1); border-radius:4px; overflow:hidden; }
  .st-progress-fill{ height:100%; background:var(--guava-green,#39FF14); border-radius:4px; transition:width .4s ease; }

  .st-card{ background:var(--bg-card,rgba(255,255,255,.03)); border:1px solid var(--border,#2a2a2a); border-radius:18px; padding:clamp(1.1rem,4vw,1.6rem); box-shadow:0 10px 40px rgba(0,0,0,.4); }

  .st-ctx{ display:flex; flex-wrap:wrap; gap:.6rem; justify-content:center; margin-bottom:1.1rem; }
  .st-badge{ font-size:1.02rem; padding:.42rem 1rem; border-radius:999px; border:1.5px solid; font-weight:800; }
  .st-b-wind{ color:#9cc2ff; border-color:#3a5a9a; background:rgba(60,100,200,.14); }
  .st-b-draw{ color:var(--guava-green,#39FF14); border-color:#2a7a18; background:rgba(57,255,20,.12); }
  .st-b-ron{ color:#ff7eb0; border-color:#a03060; background:rgba(255,94,156,.12); }
  .st-b-men{ color:#ffe08a; border-color:var(--gold,#f5b800); background:rgba(245,184,0,.18); box-shadow:0 0 12px rgba(245,184,0,.5); }
