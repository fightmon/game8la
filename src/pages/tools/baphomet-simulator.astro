---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
---
<BaseLayout
  title="巴風特｜Cluster Pays 石板翻倍模擬器 - GAME8LA"
  description="巴風特教育用模擬器——體驗 5×5 Cluster Pays 消除掉落 + 累進翻倍石板的數學真相。自己設定 RTP，看石板如何在免費遊戲中指數暴漲。"
  currentPage="tools"
  noindex={true}
>
<div class="sim-wrap">
  <!-- === 頂部說明 === -->
  <div class="sim-header">
    <a href="/tools/" style="color:var(--text-muted);font-size:0.85rem;text-decoration:none">← 回工具箱</a>
    <h1>🔮 巴風特<span>Cluster Pays 石板翻倍模擬器</span></h1>
    <p class="sim-disclaimer">⚠️ 這不是賭博遊戲，沒有真錢、沒有儲值、沒有獎金。這是一台讓你「親手體驗 Cluster Pays 消除 + 累進翻倍石板」的教育模擬器——自己設定 RTP，看倍數如何在免費遊戲中指數爆炸。</p>
  </div>

  <!-- === 控制面板 === -->
  <div class="ctrl-panel">
    <div class="ctrl-group">
      <label>🎯 RTP（你是神，你決定）</label>
      <div class="ctrl-row">
        <input type="range" id="rtp-slider" min="80" max="99" value="96" step="1" />
        <span id="rtp-val" class="ctrl-val">96%</span>
      </div>
      <div class="rtp-hint" id="rtp-hint">接近巴風特官方 RTP（96.35%）</div>
    </div>
    <div class="ctrl-group">
      <label>🌊 波動度</label>
      <div class="vol-btns">
        <button class="vol-btn" data-vol="low">低波</button>
        <button class="vol-btn" data-vol="mid">中波</button>
        <button class="vol-btn active" data-vol="high">高波</button>
      </div>
    </div>
    <div class="ctrl-group">
      <label>💰 單注金額</label>
      <div class="ctrl-row">
        <button class="bet-btn" data-d="-10">-</button>
        <span id="bet-val" class="ctrl-val" style="min-width:60px;text-align:center">20</span>
        <button class="bet-btn" data-d="+10">+</button>
      </div>
    </div>
    <div class="ctrl-group">
      <label>🏦 餘額</label>
      <span id="balance-val" class="ctrl-val balance-display">10,000</span>
    </div>
    <div class="ctrl-group" id="pointsModeWrap" style="display:none">
      <label>🪙 會員點數</label>
      <button id="btn-points-mode" class="btn-points-mode">用會員點數玩</button>
    </div>
    <div class="ctrl-group" id="extraBetWrap">
      <label>✨ XTRA-BET</label>
      <button id="btn-extra-bet" class="extra-bet-toggle">OFF</button>
      <span class="extra-bet-info">+50% 下注 = 3x Free Game 機率</span>
    </div>
  </div>

  <!-- === 遊戲盤面 === -->
  <div class="game-area">
    <!-- 左側石板 -->
    <div class="tablet-wrap" id="tablet-wrap">
      <div class="tablet-title">倍數石板</div>
      <div class="tablet-levels" id="tablet-levels"></div>
    </div>
    <!-- 盤面 -->
    <div class="board-frame">
      <div class="board" id="board">
        <!-- 5 cols × 5 rows = 25 cells -->
      </div>
      <!-- 中獎提示 -->
      <div class="win-display" id="win-display" style="display:none">
        <div class="win-amount" id="win-amount">0</div>
        <div class="win-label">WIN</div>
      </div>
      <!-- 隨機倍數提示 -->
      <div class="wrath-display" id="wrath-display" style="display:none">
        <div class="wrath-text" id="wrath-text">×2</div>
        <div class="wrath-label">WRATH OF BAPHOMET</div>
      </div>
    </div>
  </div>

  <!-- Free Game 提示 -->
  <div class="free-game-bar" id="fg-bar" style="display:none">
    <span>🔮 真理之門 FREE GAME</span>
    <span id="fg-count">0 / 0</span>
  </div>

  <!-- 按鈕區 -->
  <div class="action-bar">
    <button id="btn-spin" class="btn-spin">SPIN</button>
    <div class="auto-group">
      <button id="btn-auto" class="btn-auto" data-count="50">AUTO ×50</button>
      <button class="btn-auto-opt" data-count="200">×200</button>
    </div>
  </div>

  <!-- Buy Features 按鈕 -->
  <div class="buy-feature-btns">
    <button id="btn-buy-fg" class="btn-buy-feature btn-buy-fg" title="必定觸發 8 回合 FG">🎁 FREE GAME (×100)</button>
    <button id="btn-buy-super" class="btn-buy-feature btn-buy-super" title="必定觸發 12 回合 FG">💎 SUPER FREE (×400)</button>
    <button id="btn-buy-luck" class="btn-buy-feature btn-buy-luck" title="50% 機率觸發 12 回合 FG">🎲 LUCK OR BAD (×200)</button>
    <button id="btn-buy-wrath" class="btn-buy-feature btn-buy-wrath" title="必定觸發隨機倍數">⚡ WRATH (×25)</button>
    <button id="btn-buy-power" class="btn-buy-feature btn-buy-power" title="必定觸發巨型圖標">🔲 POWER (×5)</button>
  </div>

  <!-- === 即時統計 === -->
  <div class="stats-panel">
    <h3>📊 即時數據</h3>
    <div class="stat-row"><span>設定 RTP</span><span id="s-rtp-set">96%</span></div>
    <div class="stat-row"><span>實際 RTP</span><span id="s-rtp-actual" style="color:var(--text-primary)">—</span></div>
    <div class="stat-row"><span>總轉數</span><span id="s-spins">0</span></div>
    <div class="stat-row"><span>總下注</span><span id="s-total-bet">0</span></div>
    <div class="stat-row"><span>總回收</span><span id="s-total-win">0</span></div>
    <div class="stat-row"><span>淨輸贏</span><span id="s-net" style="color:var(--text-muted)">—</span></div>
    <div class="stat-row"><span>最大單次獎金</span><span id="s-max-win" style="color:var(--gold)">0</span></div>
    <div class="stat-row"><span>最長乾旱（連續不中）</span><span id="s-max-drought" style="color:#ff6b6b">0</span></div>
    <div class="stat-row"><span>Free Game 觸發次數</span><span id="s-fg-count">0</span></div>
    <div class="stat-row"><span>Cascade 總次數</span><span id="s-cascade-total">0</span></div>
    <div class="stat-row"><span>石板最高倍數</span><span id="s-max-multi" style="color:#c084fc">×1</span></div>
    <canvas id="balance-chart" width="360" height="180"></canvas>
    <p style="text-align:center;font-size:0.75rem;color:var(--text-muted);margin-top:0.3rem">餘額走勢圖（轉數 vs 餘額）</p>
  </div>

  <!-- === 情境導流 CTA === -->
  <div class="context-cta" id="contextCta">
    <div class="cta-hook" id="ctaHook"></div>
    <div class="cta-sub" id="ctaSub"></div>
    <div>
      <a class="cta-btn" id="ctaBtn" href="/games/elder-god-baphomet/">🔮 巴風特完整攻略</a>
      <a class="cta-btn-secondary" id="ctaBtn2" href="/articles/baphomet-vs-seth2-comparison/">⚔️ 巴風特 vs 賽特2</a>
    </div>
  </div>

  <!-- === 賠率表 === -->
  <details class="paytable-toggle">
    <summary>📋 符號賠率表（點擊展開）</summary>
    <div class="paytable" id="paytable"></div>
  </details>

  <!-- === 導流 CTA === -->
  <div class="sim-cta">
    <p>玩完模擬器了？用下面的工具管理你在真實娛樂城的體驗：</p>
    <div class="cta-links">
      <a href="/tools/rtp-tracker/">🎰 RTP 實測紀錄器</a>
      <a href="/tools/bankroll-calculator/">🧮 資金管理計算器</a>
      <a href="/tools/gambling-self-check/">🛡️ PGSI 自我檢測</a>
    </div>
  </div>

  <ShareButtons title="巴風特 — Cluster Pays 石板翻倍模擬器" heading="🔮 不用花錢體驗巴風特的累進翻倍石板" />
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script is:inline>
(function(){
  'use strict';

  /* ===== SVG 符號定義 ===== */
  const SVG_SYMS = {
    triangle: '<svg viewBox="0 0 32 32" width="100%" height="100%"><path d="M16 4L28 28H4z" fill="none" stroke="#f59e0b" stroke-width="2.5"/><circle cx="16" cy="18" r="3" fill="#f59e0b"/></svg>',
    pentagram: '<svg viewBox="0 0 32 32" width="100%" height="100%"><path d="M16 2l4.1 8.3 9.2 1.3-6.6 6.5 1.6 9.1L16 23.1l-8.3 4.1 1.6-9.1-6.6-6.5 9.2-1.3z" fill="none" stroke="#c084fc" stroke-width="1.8"/></svg>',
    horns: '<svg viewBox="0 0 32 32" width="100%" height="100%"><path d="M8 28c0-12 2-20 6-22M24 28c0-12-2-20-6-22M14 6c1-2 3-2 4 0" fill="none" stroke="#ef4444" stroke-width="2.2" stroke-linecap="round"/><circle cx="16" cy="22" r="4" fill="none" stroke="#ef4444" stroke-width="1.5"/></svg>',
    skull: '<svg viewBox="0 0 32 32" width="100%" height="100%"><ellipse cx="16" cy="14" rx="9" ry="10" fill="none" stroke="#e2e8f0" stroke-width="1.8"/><circle cx="12" cy="13" r="2.5" fill="#e2e8f0"/><circle cx="20" cy="13" r="2.5" fill="#e2e8f0"/><path d="M13 20v5M16 20v6M19 20v5" stroke="#e2e8f0" stroke-width="1.5" stroke-linecap="round"/></svg>',
    wild: '<svg viewBox="0 0 32 32" width="100%" height="100%"><text x="16" y="23" text-anchor="middle" font-size="18" font-weight="900" fill="#fbbf24" font-family="sans-serif">W</text></svg>',
    scatter: '<svg viewBox="0 0 32 32" width="100%" height="100%"><circle cx="16" cy="16" r="11" fill="none" stroke="#a855f7" stroke-width="1.5"/><path d="M16 5v22M5 16h22M8 8l16 16M24 8L8 24" stroke="#a855f7" stroke-width="0.8" opacity="0.6"/><circle cx="16" cy="16" r="4" fill="#a855f7" opacity="0.7"/></svg>',
  };

  /* ===== 符號定義（巴風特） ===== */
  const SYMS = [
    { id:'triangle', svg: SVG_SYMS.triangle, name:'暗黑三角', color:'#f59e0b', bg:'#2a1a00', pay:{5:0.4,6:0.8,7:1.2,8:2.0,9:4.0,10:6.0,11:9.0,12:12.5}, tier:1 },
    { id:'pentagram', svg: SVG_SYMS.pentagram, name:'五芒星', color:'#c084fc', bg:'#1a0a2e', pay:{5:0.35,6:0.6,7:0.9,8:1.5,9:3.0,10:5.0,11:7.0,12:9.0}, tier:1 },
    { id:'horns', svg: SVG_SYMS.horns, name:'惡魔之角', color:'#ef4444', bg:'#2a0505', pay:{5:0.3,6:0.5,7:0.8,8:1.2,9:2.5,10:4.0,11:6.0,12:8.0}, tier:2 },
    { id:'skull', svg: SVG_SYMS.skull, name:'骷髏', color:'#e2e8f0', bg:'#1a1a2e', pay:{5:0.25,6:0.45,7:0.7,8:1.0,9:2.0,10:3.5,11:5.0,12:7.0}, tier:2 },
    { id:'symA', svg:null, name:'A', color:'#94a3b8', bg:'#0f172a', pay:{5:0.15,6:0.3,7:0.5,8:0.75,9:1.25,10:2.5,11:4.0,12:6.0}, tier:3 },
    { id:'symK', svg:null, name:'K', color:'#94a3b8', bg:'#0f172a', pay:{5:0.15,6:0.3,7:0.5,8:0.75,9:1.25,10:2.5,11:4.0,12:5.5}, tier:3 },
    { id:'symQ', svg:null, name:'Q', color:'#94a3b8', bg:'#0f172a', pay:{5:0.15,6:0.3,7:0.5,8:0.75,9:1.25,10:2.5,11:4.0,12:5.0}, tier:3 },
  ];

  const WILD = { id:'wild', svg: SVG_SYMS.wild, name:'WILD', color:'#fbbf24', bg:'#3d2f0a' };
  const SCATTER = { id:'scatter', svg: SVG_SYMS.scatter, name:'SCATTER', color:'#a855f7', bg:'#2a0a3d' };

  const ROWS = 5, COLS = 5, TOTAL = ROWS * COLS;

  /* ===== 遊戲狀態 ===== */
  let balance = 10000, bet = 20;
  let totalBet = 0, totalWin = 0, spinCount = 0;
  let maxSingleWin = 0, currentDrought = 0, maxDrought = 0;
  let fgTriggered = 0, cascadeTotal = 0;
  let board = [];
  let gameState = 'idle';
  let freeSpinsLeft = 0, freeSpinsTotal = 0, freeSpinsMax = 48;
  let isAutoSpin = false, autoRemaining = 0, autoTotal = 0;
  let spinWin = 0;
  let cascadeCount = 0;
  let extraBetEnabled = false;
  let tabletMultiplier = 1; // 當前石板倍數
  let maxTabletMultiplier = 1;
  let wrathMultiplier = 1; // 隨機倍數
  let forceWrath = false;
  let forcePower = false;
  let treasureWin = 0;

  function autoDelay(ms) { return delay(isAutoSpin ? Math.max(ms * 0.6, 120) : ms); }
  /* ===== 會員點數模式 ===== */
  let POINTS_MODE = false, lastSyncBal = 0, syncTimer = null;
  async function syncWallet() {
    if (!POINTS_MODE) return;
    var delta = Math.round(balance - lastSyncBal);
    if (delta === 0) return;
    try {
      var r = await fetch('/api/play', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ delta: delta, game: 'baphomet' }) });
      var j = await r.json();
      if (j.ok) { balance = j.points; lastSyncBal = j.points; var bv = document.getElementById('balance-val'); if (bv) bv.textContent = balance.toLocaleString(); }
    } catch (e) { /* 同步失敗就先保留本地,下次再試 */ }
  }
  function scheduleSync() { if (!POINTS_MODE) return; clearTimeout(syncTimer); syncTimer = setTimeout(syncWallet, 700); }

  // Chart
  let chartData = { labels: [0], datasets: [{ label:'餘額', data:[10000], borderColor:'#a855f7', backgroundColor:'rgba(168,85,252,0.1)', fill:true, tension:0.3, pointRadius:0 }] };
  let balanceChart;

  /* ===== RTP & 波動度 ===== */
  let targetRTP = 96;
  let volatility = 'high';

  function getRtpDrift() {
    if (totalBet < 60) return 0;
    const actualRTP = (totalWin / totalBet) * 100;
    const diff = actualRTP - targetRTP;
    const raw = diff / 4;
    let d = Math.max(-1.5, Math.min(1.5, raw));
    if (freeSpinsLeft > 0 && d > 0) d = Math.min(1.5, d * 1.5);
    return d;
  }

  function getRtpBase() {
    return Math.max(0, Math.min(1, (targetRTP - 80) / 19));
  }

  function getBaseWeights() {
    return [3, 4, 6, 7, 10, 12, 14];
  }

  function getAdjustedWeights() {
    const base = getBaseWeights();
    const drift = getRtpDrift();
    return base.map((w, i) => {
      const tier = SYMS[i].tier;
      if (tier <= 1) {
        let v = w * (1 - drift * 0.6);
        return Math.max(v, 0.3);
      }
      if (tier === 2) {
        let v = w * (1 - drift * 0.3);
        return Math.max(v, 0.5);
      }
      let v = w * (1 + drift * 0.3);
      return v;
    });
  }

  function getScatterWeight() {
    const totalSymWeight = getAdjustedWeights().reduce((a,b) => a+b, 0);
    const drift = getRtpDrift();
    const rtpBase = getRtpBase();
    let baseRate = 0.015 + rtpBase * 0.015;
    if (extraBetEnabled) baseRate *= 3;
    const rate = baseRate * (1 - Math.max(0, drift) * 0.5);
    return totalSymWeight * Math.max(rate, 0.003);
  }

  function pickSymbol() {
    const weights = getAdjustedWeights();
    const scatterW = getScatterWeight();
    const all = [...weights, scatterW];
    const total = all.reduce((a,b) => a+b, 0);
    let r = Math.random() * total;
    for (let i = 0; i < all.length; i++) {
      r -= all[i];
      if (r <= 0) {
        if (i < SYMS.length) return { ...SYMS[i], type: 'sym' };
        return { ...SCATTER, type: 'scatter' };
      }
    }
    return { ...SYMS[SYMS.length-1], type: 'sym' };
  }

  /* ===== 盤面操作 ===== */
  function fillBoard() {
    board = [];
    for (let i = 0; i < TOTAL; i++) {
      board[i] = pickSymbol();
    }
  }

  function fillEmpty() {
    const newDist = new Array(TOTAL).fill(0);
    for (let c = 0; c < COLS; c++) {
      let emptyCount = 0;
      for (let r = 0; r < ROWS; r++) {
        if (!board[r * COLS + c]) emptyCount++;
      }
      let dropFrom = emptyCount;
      for (let r = 0; r < ROWS; r++) {
        const idx = r * COLS + c;
        if (!board[idx]) {
          board[idx] = pickSymbol();
          newDist[idx] = dropFrom;
          dropFrom--;
        }
      }
    }
    return newDist;
  }

  function cascadeDown() {
    const dropDist = new Array(TOTAL).fill(0);
    for (let c = 0; c < COLS; c++) {
      let writeRow = ROWS - 1;
      for (let r = ROWS - 1; r >= 0; r--) {
        const idx = r * COLS + c;
        if (board[idx]) {
          const writeIdx = writeRow * COLS + c;
          dropDist[writeIdx] = writeRow - r;
          if (writeIdx !== idx) {
            board[writeIdx] = board[idx];
            board[idx] = null;
          }
          writeRow--;
        }
      }
    }
    return dropDist;
  }

  /* ===== Cluster Pays 偵測（flood fill） ===== */
  function findClusters() {
    const visited = new Array(TOTAL).fill(false);
    const clusters = [];

    for (let i = 0; i < TOTAL; i++) {
      if (visited[i] || !board[i] || board[i].type !== 'sym') continue;
      const symId = board[i].id;
      const cluster = [];
      const queue = [i];
      visited[i] = true;

      while (queue.length > 0) {
        const pos = queue.shift();
        cluster.push(pos);
        const row = Math.floor(pos / COLS);
        const col = pos % COLS;
        // 四方向鄰居
        const neighbors = [];
        if (row > 0) neighbors.push(pos - COLS);
        if (row < ROWS - 1) neighbors.push(pos + COLS);
        if (col > 0) neighbors.push(pos - 1);
        if (col < COLS - 1) neighbors.push(pos + 1);

        for (const n of neighbors) {
          if (visited[n]) continue;
          if (!board[n]) continue;
          // WILD 可替代任何符號
          if (board[n].type === 'sym' && board[n].id === symId) {
            visited[n] = true;
            queue.push(n);
          } else if (board[n].type === 'wild') {
            visited[n] = true;
            queue.push(n);
          }
        }
      }

      if (cluster.length >= 5) {
        clusters.push({ id: symId, positions: cluster, count: cluster.length });
      }
    }

    // 也找 WILD 自己形成的群組（配對最近的高級符號）
    // 簡化：WILD 只透過鄰接幫助其他符號
    return clusters;
  }

  function countScatter() {
    let count = 0;
    const positions = [];
    for (let i = 0; i < TOTAL; i++) {
      if (board[i] && board[i].type === 'scatter') {
        count++;
        positions.push(i);
      }
    }
    return { count, positions };
  }

  function getPayout(symId, count) {
    const sym = SYMS.find(s => s.id === symId);
    if (!sym) return 0;
    const clampCount = Math.min(count, 12);
    let pay = 0;
    // 找到最大的 <= clampCount 的key
    for (let k = clampCount; k >= 5; k--) {
      if (sym.pay[k]) { pay = sym.pay[k]; break; }
    }
    const rtpBase = getRtpBase();
    return pay * (0.81 + rtpBase * 0.20);
  }

  function calculateSpinResult(clusters) {
    let win = 0;
    for (const c of clusters) {
      const payout = getPayout(c.id, c.count);
      win += (bet / 20) * payout;
    }
    return win;
  }

  /* ===== 巨型圖標 ===== */
  function applyGiantSymbol() {
    const sizes = [2, 2, 2, 3, 3, 4, 5]; // 加權
    const size = sizes[Math.floor(Math.random() * sizes.length)];
    const maxRow = ROWS - size;
    const maxCol = COLS - size;
    if (maxRow < 0 || maxCol < 0) return;
    const startRow = Math.floor(Math.random() * (maxRow + 1));
    const startCol = Math.floor(Math.random() * (maxCol + 1));
    // 選一個高級符號
    const sym = SYMS[Math.floor(Math.random() * 4)]; // 高級1~4
    for (let r = startRow; r < startRow + size; r++) {
      for (let c = startCol; c < startCol + size; c++) {
        const idx = r * COLS + c;
        board[idx] = { ...sym, type: 'sym', giant: true };
      }
    }
  }

  /* ===== DOM 操作 ===== */
  const $board = document.getElementById('board');
  const $winDisplay = document.getElementById('win-display');
  const $winAmount = document.getElementById('win-amount');
  const $wrathDisplay = document.getElementById('wrath-display');
  const $wrathText = document.getElementById('wrath-text');
  const $btnSpin = document.getElementById('btn-spin');
  const $btnAuto = document.getElementById('btn-auto');
  const $btnReset = document.getElementById('btn-reset');
  const $fgBar = document.getElementById('fg-bar');
  const $fgCount = document.getElementById('fg-count');
  const $rtpSlider = document.getElementById('rtp-slider');
  const $rtpVal = document.getElementById('rtp-val');
  const $rtpHint = document.getElementById('rtp-hint');
  const $betVal = document.getElementById('bet-val');
  const $balanceVal = document.getElementById('balance-val');
  const $btnExtraBet = document.getElementById('btn-extra-bet');
  const $tabletLevels = document.getElementById('tablet-levels');

  function renderBoard(highlightPositions, removePositions, dropData, spinIn) {
    $board.innerHTML = '';
    for (let i = 0; i < TOTAL; i++) {
      const cell = document.createElement('div');
      cell.className = 'cell';
      const s = board[i];
      if (s) {
        cell.style.background = s.bg || '#111';
        cell.style.borderColor = (s.color || '#333') + '44';

        if (s.type === 'wild') {
          cell.innerHTML = s.svg || SVG_SYMS.wild;
          cell.classList.add('cell-wild');
          cell.style.borderColor = '#fbbf2488';
          cell.style.boxShadow = '0 0 10px rgba(251,191,36,0.4)';
        } else if (s.type === 'scatter') {
          cell.innerHTML = s.svg || SVG_SYMS.scatter;
          cell.classList.add('cell-scatter');
          cell.style.borderColor = '#a855f788';
          cell.style.boxShadow = '0 0 12px rgba(168,85,252,0.4)';
        } else if (s.svg) {
          cell.innerHTML = s.svg;
        } else {
          // 文字符號 (A, K, Q)
          cell.innerHTML = '<span class="sym-text" style="color:'+s.color+'">'+s.name+'</span>';
        }

        if (s.giant) {
          cell.classList.add('cell-giant');
        }

        if (highlightPositions && highlightPositions.includes(i)) {
          cell.classList.add('cell-matched');
        }
        if (removePositions && removePositions.includes(i)) {
          cell.classList.add('cell-removing');
        }
        if (dropData && dropData[i] > 0) {
          const rows = dropData[i];
          cell.style.setProperty('--drop-rows', rows);
          cell.style.animationDuration = (0.08 + rows * 0.06) + 's';
          cell.classList.add('cell-drop');
        }
      } else {
        cell.style.background = '#111';
        cell.style.opacity = '0.3';
      }
      if (spinIn && !spinIn.has(i)) {
        const col = i % COLS;
        const row = Math.floor(i / COLS);
        const dropRows = ROWS - row + 1;
        cell.style.setProperty('--drop-rows', dropRows);
        cell.style.animationDuration = (0.1 + row * 0.04) + 's';
        cell.style.animationDelay = (col * 0.02) + 's';
        cell.classList.add('cell-drop');
      }
      $board.appendChild(cell);
    }
  }

  function renderTablet() {
    $tabletLevels.innerHTML = '';
    const levels = [1, 2, 4, 8, 16, 32, 64, 128, 256, 512];
    for (let i = levels.length - 1; i >= 0; i--) {
      const el = document.createElement('div');
      el.className = 'tablet-level';
      el.textContent = '×' + levels[i];
      if (tabletMultiplier >= levels[i] && (i === levels.length - 1 || tabletMultiplier < levels[i + 1])) {
        el.classList.add('tablet-active');
      } else if (tabletMultiplier > levels[i]) {
        el.classList.add('tablet-passed');
      }
      $tabletLevels.appendChild(el);
    }
  }

  function updateStats() {
    document.getElementById('s-rtp-set').textContent = targetRTP + '%';
    const actualRTP = totalBet > 0 ? ((totalWin / totalBet) * 100).toFixed(1) : '—';
    const $actual = document.getElementById('s-rtp-actual');
    $actual.textContent = totalBet > 0 ? actualRTP + '%' : '—';
    if (totalBet > 0) {
      const diff = parseFloat(actualRTP) - targetRTP;
      $actual.style.color = Math.abs(diff) < 5 ? '#39ff14' : '#ff6b6b';
    }
    document.getElementById('s-spins').textContent = spinCount;
    document.getElementById('s-total-bet').textContent = totalBet.toLocaleString();
    document.getElementById('s-total-win').textContent = totalWin.toLocaleString();
    const $net = document.getElementById('s-net');
    const net = totalWin - totalBet;
    if (totalBet === 0) { $net.textContent = '—'; $net.style.color = 'var(--text-muted)'; }
    else { $net.textContent = (net >= 0 ? '+' : '') + net.toLocaleString(); $net.style.color = net >= 0 ? '#39ff14' : '#ff6b6b'; }
    document.getElementById('s-max-win').textContent = maxSingleWin.toLocaleString();
    document.getElementById('s-max-drought').textContent = maxDrought;
    document.getElementById('s-fg-count').textContent = fgTriggered;
    document.getElementById('s-cascade-total').textContent = cascadeTotal;
    document.getElementById('s-max-multi').textContent = '×' + maxTabletMultiplier;
    $balanceVal.textContent = balance.toLocaleString();
    $betVal.textContent = bet;
    scheduleSync();
    updateContextCta();
  }

  function updateContextCta() {
    const $cta = document.getElementById('contextCta');
    const $hook = document.getElementById('ctaHook');
    const $sub = document.getElementById('ctaSub');
    const $btn = document.getElementById('ctaBtn');
    const $btn2 = document.getElementById('ctaBtn2');
    if (!$cta || spinCount < 20) return;
    $cta.classList.add('visible');
    const net = totalWin - totalBet;
    if (net >= 0) {
      $hook.textContent = '贏了 ' + net.toLocaleString() + ' 元？石板翻倍的威力讓你興奮了嗎？';
      $sub.textContent = '短期連鎖爆分的快感是真的，但 RTP ' + targetRTP + '% 的重力也是真的。看看完整攻略了解怎麼聰明地享受巴風特。';
      $btn.textContent = '🔮 巴風特完整攻略';
      $btn.href = '/games/elder-god-baphomet/';
      $btn2.textContent = '⚔️ 巴風特 vs 賽特2';
      $btn2.href = '/articles/baphomet-vs-seth2-comparison/';
    } else {
      $hook.textContent = '已經虧了 ' + Math.abs(net).toLocaleString() + ' 元，石板翻倍也救不了。';
      $sub.textContent = '高波動 + RTP ' + targetRTP + '% 意味著大部分時間你都在餵機台。想了解真實數據？';
      $btn.textContent = '💡 看懂石板翻倍的真相';
      $btn.href = '/games/elder-god-baphomet/';
      $btn2.textContent = '📊 用 RTP 紀錄器追蹤';
      $btn2.href = '/tools/rtp-tracker/';
