  function updateChart() {
    if (!balanceChart) return;
    chartData.labels.push(spinCount);
    chartData.datasets[0].data.push(balance);
    if (chartData.labels.length > 300) { chartData.labels.shift(); chartData.datasets[0].data.shift(); }
