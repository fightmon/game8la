  /* ===== 主遊戲流程 ===== */
  async function spin() {
    if (gameState !== 'idle') return;

    const actualBet = Math.round(bet * (extraBetEnabled ? 1.5 : 1));
    if (balance < actualBet && freeSpinsLeft <= 0) {
      $btnSpin.textContent = '餘額不足';
      setTimeout(() => { $btnSpin.textContent = 'SPIN'; }, 1500);
      isAutoSpin = false;
      return;
    }

    gameState = 'spinning';
    $btnSpin.disabled = true;
    $btnSpin.textContent = '...';
    spinWin = 0;
    cascadeCount = 0;
    wrathMultiplier = 1;

    // MG: 石板每轉重置；FG: 不重置
    if (freeSpinsLeft <= 0) {
      tabletMultiplier = 1;
      balance -= actualBet;
      totalBet += actualBet;
    } else {
      freeSpinsLeft--;
      $fgCount.textContent = (freeSpinsTotal - freeSpinsLeft) + ' / ' + freeSpinsTotal;
      if (freeSpinsLeft <= 0) {
        $fgBar.style.display = 'none';
        tabletMultiplier = 1;
      }
    }
    spinCount++;
    renderTablet();

    // 隨機倍數（Wrath of Baphomet）
    const wrathChance = forceWrath ? 1 : (freeSpinsLeft > 0 ? 0.08 : 0.03);
    if (Math.random() < wrathChance) {
      const powers = [1, 1, 2, 2, 3, 4];
      const p = powers[Math.floor(Math.random() * powers.length)];
      wrathMultiplier = Math.pow(2, p);
      await showWrath(wrathMultiplier);
    }
    forceWrath = false;

    // 移出舊盤面動畫
    if (!isAutoSpin) {
      const cells = $board.querySelectorAll('.cell');
      cells.forEach(c => c.classList.add('cell-fly-out'));
      await delay(180);
    }

    fillBoard();

    // 巨型圖標（Power of Baphomet）
    const powerChance = forcePower ? 1 : (freeSpinsLeft > 0 ? 0.12 : 0.05);
    if (Math.random() < powerChance) {
      applyGiantSymbol();
    }
    forcePower = false;

    renderBoard(null, null, null, isAutoSpin ? null : new Set());
    await autoDelay(350);

    // Cascade loop
    await cascadeLoop();

    // 檢查 SCATTER
    const scatterResult = countScatter();
    if (scatterResult.count >= 3 && freeSpinsLeft <= 0) {
      // 觸發 FG
      const rounds = scatterResult.count === 3 ? 8 : scatterResult.count === 4 ? 10 : 12;
      freeSpinsLeft = rounds;
      freeSpinsTotal = rounds;
      tabletMultiplier = 1;
      fgTriggered++;
      $fgBar.style.display = 'flex';
      $fgCount.textContent = '0 / ' + freeSpinsTotal;
      renderBoard(scatterResult.positions);
      await autoDelay(800);
    } else if (scatterResult.count >= 3 && freeSpinsLeft > 0) {
      // FG 中再觸發
      const extra = scatterResult.count === 3 ? 8 : scatterResult.count === 4 ? 10 : 12;
      const newTotal = Math.min(freeSpinsLeft + extra, freeSpinsMax - (freeSpinsTotal - freeSpinsLeft));
      freeSpinsLeft = Math.min(freeSpinsLeft + extra, freeSpinsMax);
      freeSpinsTotal = freeSpinsTotal + extra;
      if (freeSpinsTotal > freeSpinsMax) freeSpinsTotal = freeSpinsMax;
      $fgCount.textContent = (freeSpinsTotal - freeSpinsLeft) + ' / ' + freeSpinsTotal;
      renderBoard(scatterResult.positions);
      await autoDelay(500);
    }

    // 禁忌寶藏（隨機小獎）
    if (freeSpinsLeft <= 0 && spinWin === 0 && Math.random() < 0.03) {
      treasureWin = Math.round(bet * (0.5 + Math.random() * 3));
      spinWin += treasureWin;
    }

    // 結算
    if (spinWin > 0) {
      let finalMulti = tabletMultiplier * wrathMultiplier;
      const drift = getRtpDrift();

      if (drift > 0 && finalMulti > 1) {
        finalMulti = 1 + (finalMulti - 1) * Math.max(0, 1 - drift);
      } else if (drift < 0 && finalMulti > 1) {
        finalMulti = finalMulti * (1 + Math.abs(drift) * 0.3);
      }

      spinWin = Math.round(spinWin * finalMulti);

      if (drift > 0.05) {
        const scale = Math.max(0.05, 1 - drift * 0.9);
        spinWin = Math.round(spinWin * scale);
      } else if (drift < -0.1) {
        const boost = 1 + Math.abs(drift) * 0.8;
        spinWin = Math.round(spinWin * boost);
      }

      const maxBetMultiple = drift > 0.5 ? 8 : drift > 0 ? 25 : 200;
      spinWin = Math.min(spinWin, actualBet * maxBetMultiple);

      if (totalBet > 0 && totalBet < 500 * actualBet && spinWin > 0) {
        const cap = (targetRTP * 1.05) / 100;
        const allowed = Math.max(0, cap * totalBet - totalWin);
        spinWin = Math.min(spinWin, allowed);
      }

      spinWin = Math.max(0, Math.floor(spinWin)); // 點數為整數，杜絕小數餘額
      if (spinWin > 0) {
        balance += spinWin;
        totalWin += spinWin;
        if (spinWin > maxSingleWin) maxSingleWin = spinWin;
        currentDrought = 0;
        showWin(spinWin);
      } else {
        currentDrought++;
        if (currentDrought > maxDrought) maxDrought = currentDrought;
      }
    } else {
      currentDrought++;
      if (currentDrought > maxDrought) maxDrought = currentDrought;
    }

    renderBoard();
    renderTablet();
    updateStats();
    updateChart();

    gameState = 'idle';
    $btnSpin.disabled = false;
    $btnSpin.textContent = freeSpinsLeft > 0 ? 'FREE SPIN' : 'SPIN';
    $btnSpin.classList.toggle('btn-free', freeSpinsLeft > 0);

    if (freeSpinsLeft > 0 || (isAutoSpin && autoRemaining > 0)) {
      if (isAutoSpin && freeSpinsLeft <= 0) {
        autoRemaining--;
        $btnAuto.textContent = 'STOP (' + (autoTotal - autoRemaining) + '/' + autoTotal + ')';
      }
      if (autoRemaining <= 0 && freeSpinsLeft <= 0) { stopAuto(); }
      await autoDelay(freeSpinsLeft > 0 ? 400 : 250);
      if (gameState === 'idle') spin();
    }
  }

  async function cascadeLoop() {
    let hasMatch = true;
    while (hasMatch) {
      const clusters = findClusters();
      if (clusters.length === 0) { hasMatch = false; break; }
      cascadeCount++;
      cascadeTotal++;

      // 石板翻倍
      if (cascadeCount === 1) tabletMultiplier = tabletMultiplier; // 第一次用目前倍數
      else tabletMultiplier *= 2;
      if (tabletMultiplier > maxTabletMultiplier) maxTabletMultiplier = tabletMultiplier;
      renderTablet();

      const cascadeWin = calculateSpinResult(clusters);
      spinWin += cascadeWin * tabletMultiplier;

      const allPositions = clusters.flatMap(c => c.positions);
      renderBoard(allPositions);
      await autoDelay(400);

      // 消除並生成 WILD
      const wildPositions = [];
      for (const pos of allPositions) {
        board[pos] = null;
      }
      // 每次消除在隨機一個被消除位置生成 WILD
      if (allPositions.length > 0) {
        const wildPos = allPositions[Math.floor(Math.random() * allPositions.length)];
        board[wildPos] = { ...WILD, type: 'wild' };
        wildPositions.push(wildPos);
      }

      renderBoard(null, allPositions.filter(p => !wildPositions.includes(p)));
      await autoDelay(300);

      // 掉落
      const dropDist = cascadeDown();
      const newDist = fillEmpty();
      const combinedDrop = new Array(TOTAL).fill(0);
      for (let i = 0; i < TOTAL; i++) {
        combinedDrop[i] = dropDist[i] || newDist[i] || 0;
      }
      renderBoard(null, null, combinedDrop);
      await autoDelay(350);
    }
    // 如果本轉有 cascade，石板倍數從第2次開始翻倍，第1次是 ×1
    // 修正：cascadeCount=1 → ×1, cascadeCount=2 → ×2, cascadeCount=3 → ×4...
    // 但上面邏輯已經在 loop 裡處理了（第一次不翻，第二次 *2）
  }

  function delay(ms) { return new Promise(r => setTimeout(r, ms)); }

