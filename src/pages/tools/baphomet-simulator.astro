    html += 'POWER (×5)：必定觸發巨型圖標</p></div>';
    html += '<div class="pt-section"><h4>✨ XTRA-BET</h4>';
    html += '<p>啟動時 +50% 下注成本，FG 觸發機率 ×3。</p></div>';
    $pt.innerHTML = html;
  }

  /* ===== 初始化 ===== */
  function init() {
    fillBoard(); renderBoard(); renderTablet(); renderPaytable(); updateStats();
    const ctx = document.getElementById('balance-chart').getContext('2d');
    balanceChart = new Chart(ctx, {
      type: 'line', data: chartData,
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { display: false },
          y: { ticks: { color: '#888', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.06)' } }
        },
        animation: false,
      }
    });
  }

  /* ===== 會員點數模式：初始化（先於 init，避免 init 內 Chart 例外中斷綁定）===== */
  (function () {
    var $wrap = document.getElementById('pointsModeWrap');
    var $btn = document.getElementById('btn-points-mode');
    if (!$btn) return;
    fetch('/api/me').then(function (r) { return r.json(); }).then(function (j) {
      if (j && j.member) {
        $wrap.style.display = '';
        $btn.dataset.points = j.member.points || 0;
        $btn.textContent = '用會員點數玩 (' + (j.member.points || 0).toLocaleString() + ')';
      }
    }).catch(function () {});
    $btn.addEventListener('click', function () {
      if (POINTS_MODE) return;
      var pts = parseInt($btn.dataset.points, 10) || 0;
      POINTS_MODE = true;
      balance = pts; lastSyncBal = pts;
      bet = 2; $betVal.textContent = bet;
      totalBet = 0; totalWin = 0; spinCount = 0; maxSingleWin = 0;
      extraBetEnabled = false;
      if ($btnExtraBet) { $btnExtraBet.textContent = 'OFF'; $btnExtraBet.classList.remove('extra-bet-active'); }
      var $ebWrap = document.getElementById('extraBetWrap'); if ($ebWrap) $ebWrap.style.display = 'none';
      document.querySelectorAll('.btn-buy-feature').forEach(function (b) { b.style.display = 'none'; });
      if ($btnReset) $btnReset.style.display = 'none';
      document.querySelectorAll('.btn-auto-opt').forEach(function (b) { b.style.display = 'none'; });
      if ($btnAuto) { $btnAuto.dataset.count = '20'; $btnAuto.textContent = 'AUTO ×20'; }
      $btn.textContent = '🪙 點數模式 ON';
      $btn.disabled = true; $btn.classList.add('on');
      updateStats();
    });
  })();

  init();
})();
</script>

