---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="芭樂轉轉機｜RTP 體感模擬器 — 自己當老虎機的神 - GAME8LA"
  description="自己設定 RTP 和波動度，親手體驗老虎機的數學真相。芭樂轉轉機是一台教育用模擬器，讓你用身體感受 RTP 97% 和 85% 的差別。"
  currentPage="tools"
  noindex={true}
>
<div class="sim-wrap">
  <!-- === 頂部說明 === -->
  <div class="sim-header">
    <a href="/tools/" style="color:var(--text-muted);font-size:0.85rem;text-decoration:none">← 回工具箱</a>
    <h1>🎰 芭樂轉轉機<span>RTP 體感模擬器</span></h1>
    <p class="sim-disclaimer">⚠️ 這不是賭博遊戲，沒有真錢、沒有儲值、沒有獎金。這是一台讓你「當老虎機的神」的教育模擬器——自己設定 RTP，看數學怎麼吃掉你的餘額。</p>
  </div>

  <!-- === 控制面板 === -->
  <div class="ctrl-panel">
    <div class="ctrl-group">
      <label>🎯 RTP（你是神，你決定）</label>
      <div class="ctrl-row">
        <input type="range" id="rtp-slider" min="80" max="99" value="96" step="1" />
        <span id="rtp-val" class="ctrl-val">96%</span>
      </div>
      <div class="rtp-hint" id="rtp-hint">接近真實老虎機水準</div>
    </div>
    <div class="ctrl-group">
      <label>🌊 波動度</label>
      <div class="vol-btns">
        <button class="vol-btn" data-vol="low">低波</button>
        <button class="vol-btn active" data-vol="mid">中波</button>
        <button class="vol-btn" data-vol="high">高波</button>
      </div>
    </div>
    <div class="ctrl-group">
      <label>💰 單注金額</label>
      <div class="ctrl-row">
        <button class="bet-btn" data-d="-10">-</button>
        <span id="bet-val" class="ctrl-val" style="min-width:60px;text-align:center">20</span>
        <button class="bet-btn" data-d="+10">+</button>
      </div>
    </div>
    <div class="ctrl-group">
      <label>🏦 餘額</label>
      <span id="balance-val" class="ctrl-val balance-display">10,000</span>
    </div>
  </div>

  <!-- === 遊戲盤面 === -->
  <div class="game-area">
    <div class="board-frame">
      <div class="board" id="board">
        <!-- 6 cols × 5 rows = 30 cells, filled by JS -->
      </div>
      <!-- 右上角總倍數計數器 -->
      <div class="multi-counter" id="multi-counter">
        <span class="multi-counter-val" id="multi-value">×0</span>
      </div>
      <!-- 中獎提示 -->
      <div class="win-display" id="win-display" style="display:none">
        <div class="win-amount" id="win-amount">0</div>
        <div class="win-label">WIN</div>
      </div>
    </div>
    <!-- Free Game 提示 -->
    <div class="free-game-bar" id="fg-bar" style="display:none">
      <span>🪲 FREE GAME</span>
      <span id="fg-count">0 / 0</span>
    </div>
    <!-- 按鈕區 -->
    <div class="action-bar">
      <button id="btn-spin" class="btn-spin">SPIN</button>
      <div class="auto-group">
        <button id="btn-auto" class="btn-auto" data-count="50">AUTO ×50</button>
        <button class="btn-auto-opt" data-count="200">×200</button>
        <button class="btn-auto-opt" data-count="500">×500</button>
      </div>
      <button id="btn-reset" class="btn-reset">重置餘額</button>
    </div>
    <!-- 覺醒預約按鈕 -->
    <div class="awaken-btns">
      <button id="btn-awk-pow" class="btn-awaken btn-awk-pow" title="下一回合盤面強制出現 3 個力量覺醒符號＋倍數球，觸發分裂">⚡ 力量覺醒</button>
      <button id="btn-awk-lck" class="btn-awaken btn-awk-lck" title="下一回合盤面強制出現 3 個鎖定覺醒符號＋倍數球，觸發鎖定">🔒 鎖定覺醒</button>
    </div>
  </div>

  <!-- === 即時統計 === -->
  <div class="stats-panel">
    <h3>📊 即時數據</h3>
    <div class="stat-row"><span>設定 RTP</span><span id="s-rtp-set">96%</span></div>
    <div class="stat-row"><span>實際 RTP</span><span id="s-rtp-actual" style="color:var(--guava-green)">—</span></div>
    <div class="stat-row"><span>總轉數</span><span id="s-spins">0</span></div>
    <div class="stat-row"><span>總下注</span><span id="s-total-bet">0</span></div>
    <div class="stat-row"><span>總回收</span><span id="s-total-win">0</span></div>
    <div class="stat-row"><span>淨輸贏</span><span id="s-net" style="color:var(--text-muted)">—</span></div>
    <div class="stat-row"><span>最大單次獎金</span><span id="s-max-win" style="color:var(--gold)">0</span></div>
    <div class="stat-row"><span>最長乾旱（連續不中）</span><span id="s-max-drought" style="color:var(--guava-pink)">0</span></div>
    <div class="stat-row"><span>Free Game 觸發次數</span><span id="s-fg-count">0</span></div>
    <canvas id="balance-chart" width="360" height="180"></canvas>
    <p style="text-align:center;font-size:0.75rem;color:var(--text-muted);margin-top:0.3rem">餘額走勢圖（轉數 vs 餘額）</p>
  </div>

  <!-- === 賠率表 === -->
  <details class="paytable-toggle">
    <summary>📋 符號賠率表（點擊展開）</summary>
    <div class="paytable" id="paytable"></div>
  </details>

  <!-- === 導流 CTA === -->
  <div class="sim-cta">
    <p>玩完模擬器了？用下面的工具管理你在真實娛樂城的體驗：</p>
    <div class="cta-links">
      <a href="/tools/rtp-tracker/">🎰 RTP 實測紀錄器</a>
      <a href="/tools/bankroll-calculator/">🧮 資金管理計算器</a>
      <a href="/casino-check/">🛡️ 娛樂城體檢工具</a>
    </div>
  </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script is:inline>
(function(){
  'use strict';

  /* ===== 符號定義（賽特2 賠率表） ===== */
  const SYMS = [
    { id:'eye',  label:'👁',  name:'荷魯斯之眼', color:'#f5b800', bg:'#3d2f0a', pay:{8:200,10:500,12:1000}, tier:1 },
    { id:'snake',label:'🐍',  name:'權杖',       color:'#f5b800', bg:'#3d2f0a', pay:{8:50, 10:200,12:500},  tier:1 },
    { id:'bow',  label:'🏹',  name:'弓箭',       color:'#f5b800', bg:'#3d2f0a', pay:{8:40, 10:100,12:300},  tier:2 },
    { id:'blade',label:'⚔️',  name:'彎刀',       color:'#c0c0c0', bg:'#2a2a2a', pay:{8:30, 10:40, 12:240},  tier:2 },
    { id:'org',  label:'🟠',  name:'橘寶石',     color:'#ff8c00', bg:'#2a1a00', pay:{8:20, 10:30, 12:200},  tier:3 },
    { id:'red',  label:'🔴',  name:'紅寶石',     color:'#ef4444', bg:'#2a0505', pay:{8:16, 10:24, 12:160},  tier:3 },
    { id:'pur',  label:'🟣',  name:'紫寶石',     color:'#a855f7', bg:'#1a0a2e', pay:{8:10, 10:20, 12:100},  tier:4 },
    { id:'blu',  label:'🔵',  name:'藍寶石',     color:'#3b82f6', bg:'#0a1a2e', pay:{8:8,  10:18, 12:80},   tier:4 },
    { id:'grn',  label:'🟢',  name:'綠寶石',     color:'#22c55e', bg:'#0a1a0a', pay:{8:5,  10:15, 12:40},   tier:4 },
  ];
  const SCATTER = { id:'scat', label:'🪲', name:'聖甲蟲', color:'#f5b800', bg:'#4a0a2e' };
  // 4 色倍數球（依倍率範圍分色，對應賽特 2 配色）
  const MULTI_COLORS = [
    { id:'multi-g', color:'#39ff14', bg:'#0a2a0a', glow:'rgba(57,255,20,0.5)',  name:'綠倍數球', ring:'#22c55e' },
    { id:'multi-b', color:'#60a5fa', bg:'#0a1a3a', glow:'rgba(96,165,250,0.5)', name:'藍倍數球', ring:'#3b82f6' },
    { id:'multi-p', color:'#c084fc', bg:'#1a0a3a', glow:'rgba(192,132,252,0.5)',name:'紫倍數球', ring:'#a855f7' },
    { id:'multi-r', color:'#fb7185', bg:'#3a0a1a', glow:'rgba(251,113,133,0.5)',name:'紅倍數球', ring:'#ef4444' },
  ];
  // 覺醒之力符號（Free Game 限定）
  const AWAKEN_POWER = { id:'awk-pow', label:'⚡', name:'力量覺醒', color:'#f59e0b', bg:'#2a1a00', glow:'rgba(245,158,11,0.5)' };
  const AWAKEN_LOCK  = { id:'awk-lck', label:'🔒', name:'鎖定覺醒', color:'#c084fc', bg:'#1a0030', glow:'rgba(192,132,252,0.5)' };

  const ROWS = 5, COLS = 6, TOTAL = ROWS * COLS;

  /* ===== 遊戲狀態 ===== */
  let balance = 10000, bet = 20;
  let totalBet = 0, totalWin = 0, spinCount = 0;
  let maxSingleWin = 0, currentDrought = 0, maxDrought = 0;
  let fgTriggered = 0;
  let board = [];        // flat array[20] of symbol objects
  let multiOnBoard = []; // {pos, value, colorIdx, locked} 倍數球位置
  let gameState = 'idle'; // idle | spinning | cascading | freegame
  let freeSpinsLeft = 0, freeSpinsTotal = 0;
  let lockedMultis = []; // {pos, value, rounds} 鎖定的倍數球，rounds 倒數到 0 解鎖
  let pendingAwaken = null; // 'power' | 'lock' | null — 預約下一回合強制觸發覺醒
  const LOCK_ROUNDS = 3; // 鎖定覺醒鎖定回合數
  let isAutoSpin = false, autoRemaining = 0, autoTotal = 0;
  function autoDelay(ms) { return delay(isAutoSpin ? Math.max(ms * 0.25, 30) : ms); }
  let spinWin = 0; // current spin total win
  let cascadeCount = 0;

  // Chart
  let chartData = { labels: [0], datasets: [{ label:'餘額', data:[10000], borderColor:'#39ff14', backgroundColor:'rgba(57,255,20,0.1)', fill:true, tension:0.3, pointRadius:0 }] };
  let balanceChart;

  /* ===== RTP & 波動度控制 ===== */
  let targetRTP = 96;
  let volatility = 'mid'; // low | mid | high

  /**
   * 動態 RTP 回饋：根據實際 RTP 與目標的偏差調整出牌傾向
   * drift > 0 表示玩家贏太多 → 壓低高賠符號/倍數球
   * drift < 0 表示玩家輸太多 → 拉高高賠符號/倍數球
   * 回傳 -1 ~ +1 的修正值
   */
  function getRtpDrift() {
    if (totalBet < 60) return 0; // 只跳過前 3 轉
    const actualRTP = (totalWin / totalBet) * 100;
    const diff = actualRTP - targetRTP;
    // RTP-Audit fix: 響應從 ÷8 改 ÷4,上限 ±1.5,讓短場 session 防線更快收斂
    const raw = diff / 4;
    let d = Math.max(-1.5, Math.min(1.5, raw));
    if (freeSpinsLeft > 0 && d > 0) d = Math.min(1.5, d * 1.5);
    return d;
  }

  // RTP 基礎因子：0（80%）→ 1（99%），影響倍數球/scatter 的「底線」出現率
  function getRtpBase() {
    return Math.max(0, Math.min(1, (targetRTP - 80) / 19));
  }

  function getBaseWeights() {
    return [2, 3, 4, 5, 7, 8, 10, 12, 15];
  }

  function getAdjustedWeights() {
    // RTP-Audit fix: 不在低 RTP 膨脹低分符號權重
    // 舊版本 (1.5 - rtpFactor*0.5) 在 RTP 80% 把低分權重 ×1.5,造成 hit rate 90% 的虛假爽感
    // 改用「固定基礎權重 + drift 微調」, RTP 高低靠 payout 縮放控制 (見 getPayout)
    const base = getBaseWeights();
    const drift = getRtpDrift();
    const adjusted = base.map((w, i) => {
      const tier = SYMS[i].tier;
      if (tier <= 2) {
        // 高賠符號：drift 控制 (贏太多 → 壓低高賠出現率)
        let v = w * (1 - drift * 0.6);
        return Math.max(v, 0.3);
      }
      // 低賠符號：固定權重,僅 drift 微調 (不再依 RTP 縮放)
      let v = w * (1 + drift * 0.3);
      return v;
    });
    return adjusted;
  }

  function getScatterWeight() {
    const totalSymWeight = getAdjustedWeights().reduce((a,b) => a+b, 0);
    const drift = getRtpDrift();
    const rtpBase = getRtpBase();
    // RTP 80%→1%, RTP 99%→3%，drift 再修正
    const baseRate = 0.01 + rtpBase * 0.02;
    const rate = baseRate * (1 - Math.max(0, drift) * 0.5);
    return totalSymWeight * Math.max(rate, 0.003);
  }

  function getMultiWeight() {
    // RTP-Audit fix: 反轉 volatility 出現率,符合業界「高波 = 憋大招」
    // 舊版本: low=0.01 / mid=0.02 / high=0.03 (高波出現率最高,加上球值最大,雙倍放大)
    // 新版本: 高波球少但值大,低波球多但值小
    const volRates = { low: 0.025, mid: 0.015, high: 0.008 };
    const totalSymWeight = getAdjustedWeights().reduce((a,b) => a+b, 0);
    const drift = getRtpDrift();
    const rtpBase = getRtpBase();
    // RTP 80%→基礎×0.2, RTP 99%→基礎×1.0, drift 再修正
    const volRate = volRates[volatility] || 0.015;
    const baseRate = volRate * (0.2 + rtpBase * 0.8);
    const rate = baseRate * (1 - Math.max(0, drift) * 0.7);
    return totalSymWeight * Math.max(rate, 0.001);
  }

  function getAwakenWeight() {
    if (freeSpinsLeft <= 0) return 0;
    const totalSymWeight = getAdjustedWeights().reduce((a,b) => a+b, 0);
    const rtpBase = getRtpBase();
    // RTP 低時覺醒也少出
    return totalSymWeight * (0.005 + rtpBase * 0.01);
  }

  function pickSymbol() {
    const weights = getAdjustedWeights();
    const scatW = getScatterWeight();
    const multiW = getMultiWeight();
    const awkPowW = getAwakenWeight();
    const awkLckW = getAwakenWeight();
    const all = [...weights, scatW, multiW, awkPowW, awkLckW];
    const total = all.reduce((a,b) => a+b, 0);
    let r = Math.random() * total;
    for (let i = 0; i < all.length; i++) {
      r -= all[i];
      if (r <= 0) {
        if (i < SYMS.length) return { ...SYMS[i], type: 'sym' };
        if (i === SYMS.length) return { ...SCATTER, type: 'scatter' };
        if (i === SYMS.length + 1) {
          // multiplier ball
          const val = pickMultiValue();
          const ci = getMultiColorIdx(val);
          return { ...MULTI_COLORS[ci], type: 'multi', label: '×' + val, multiVal: val, colorIdx: ci };
        }
        if (i === SYMS.length + 2) return { ...AWAKEN_POWER, type: 'awaken-pow' };
        if (i === SYMS.length + 3) return { ...AWAKEN_LOCK, type: 'awaken-lck' };
      }
    }
    return { ...SYMS[SYMS.length-1], type: 'sym' };
  }

  function pickMultiValue() {
    const rtpBase = getRtpBase();
    // RTP 低時高倍數球權重大幅降低
    const highCut = rtpBase; // 0 at 80%, 1 at 99%
    const volWeights = {
      low:  [[2,50],[3,30],[5,15 * highCut],[10,4 * highCut],[25,1 * highCut]],
      mid:  [[2,30],[3,25],[5,20 * highCut],[10,15 * highCut],[25,7 * highCut],[50,2 * highCut],[100,1 * highCut]],
      high: [[2,15],[5,20 * highCut],[10,20 * highCut],[25,15 * highCut],[50,15 * highCut],[100,10 * highCut],[200,4 * highCut],[500,1 * highCut]],
    };
    const table = (volWeights[volatility] || volWeights.mid).filter(([v,w]) => w > 0.01);
    const total = table.reduce((a,b) => a + b[1], 0);
    let r = Math.random() * total;
    for (const [val, w] of table) {
      r -= w;
      if (r <= 0) return val;
    }
    return 2;
  }

  function getMultiColorIdx(val) {
    // 綠(小) → 藍(中) → 紫(大) → 紅(超大)
    if (val <= 5)   return 0; // green
    if (val <= 25)  return 1; // blue
    if (val <= 100) return 2; // purple
    return 3;                 // red
  }

  /* ===== 盤面操作 ===== */
  function fillBoard() {
    board = [];
    multiOnBoard = [];

    // 鎖定倍數球倒數：每次 fillBoard（=每次 spin）扣 1 回合
    lockedMultis = lockedMultis.filter(lm => {
      lm.rounds--;
      return lm.rounds > 0;
    });

    // 先放置還在鎖定中的倍數球
    const lockedPositions = new Set();
    for (const lm of lockedMultis) {
      const ci = getMultiColorIdx(lm.value);
      board[lm.pos] = { ...MULTI_COLORS[ci], type: 'multi', label: '×' + lm.value, multiVal: lm.value, colorIdx: ci, locked: true };
      multiOnBoard.push({ pos: lm.pos, value: lm.value, colorIdx: ci, locked: true });
      lockedPositions.add(lm.pos);
    }
    for (let i = 0; i < TOTAL; i++) {
      if (lockedPositions.has(i)) continue;
      const s = pickSymbol();
      board[i] = s;
      if (s.type === 'multi') multiOnBoard.push({ pos: i, value: s.multiVal, colorIdx: s.colorIdx, locked: false });
    }
  }

  function fillEmpty() {
    // RTP-Audit fix: cascade 補牌不再補倍數球,避免單轉內倍數球無限累積
    // 舊版本 cascade 過程中可能掉新倍數球 → getTotalMultiplier 加總爆衝 → RTP 過 100%
    // 新版本: 倍數球只在「初始開盤」與「覺醒分裂」出現,cascade 補的牌全部是普通符號
    const newDist = new Array(TOTAL).fill(0);
    for (let c = 0; c < COLS; c++) {
      let emptyCount = 0;
      for (let r = 0; r < ROWS; r++) {
        if (!board[r * COLS + c]) emptyCount++;
      }
      let dropFrom = emptyCount;
      for (let r = 0; r < ROWS; r++) {
        const idx = r * COLS + c;
        if (!board[idx]) {
          // 重抽直到拿到非倍數球符號 (最多 20 次防無窮迴圈)
          let s, attempts = 0;
          do { s = pickSymbol(); attempts++; }
          while (s.type === 'multi' && attempts < 20);
          board[idx] = s;
          newDist[idx] = dropFrom;
          dropFrom--;
        }
      }
    }
    return newDist;
  }

  function cascadeDown() {
    // 回傳每格掉了幾行（用於掉落動畫）
    const dropDist = new Array(TOTAL).fill(0);
    for (let c = 0; c < COLS; c++) {
      let writeRow = ROWS - 1;
      for (let r = ROWS - 1; r >= 0; r--) {
        const idx = r * COLS + c;
        if (board[idx]) {
          const writeIdx = writeRow * COLS + c;
          dropDist[writeIdx] = writeRow - r;
          if (writeIdx !== idx) {
            board[writeIdx] = board[idx];
            board[idx] = null;
            const mi = multiOnBoard.findIndex(m => m.pos === idx);
            if (mi >= 0) multiOnBoard[mi].pos = writeIdx;
          }
          writeRow--;
        }
      }
    }
    return dropDist;
  }

  /* ===== 中獎偵測（Scatter Pays） ===== */
  function findMatches() {
    const counts = {};
    for (let i = 0; i < TOTAL; i++) {
      if (!board[i] || board[i].type !== 'sym') continue;
      const id = board[i].id;
      if (!counts[id]) counts[id] = [];
      counts[id].push(i);
    }
    const matches = [];
    for (const [id, positions] of Object.entries(counts)) {
      if (positions.length >= 8) {
        matches.push({ id, positions, count: positions.length });
      }
    }
    return matches;
  }

  function countScatters() {
    let count = 0;
    const positions = [];
    for (let i = 0; i < TOTAL; i++) {
      if (board[i] && board[i].type === 'scatter') {
        count++;
        positions.push(i);
      }
    }
    return { count, positions };
  }

  function getPayout(symId, count) {
    const sym = SYMS.find(s => s.id === symId);
    if (!sym) return 0;
    let pay = 0;
    if (count >= 12) pay = sym.pay[12];
    else if (count >= 10) pay = sym.pay[10];
    else if (count >= 8) pay = sym.pay[8];
    // RTP-Audit fix v2: 線性縮放對齊「天然 RTP」
    // Monte Carlo 實測:本機天然 RTP (PAYOUT_K=1.0) ≈ 98.4%
    // 線性公式 (0.81 + rtpBase * 0.20): RTP 80%→×0.81 / RTP 96%→×0.978 / RTP 99%→×1.01
    // 這個公式讓「設定的 RTP」跟「實際 RTP」誤差落在 ±2pp 內
    const rtpBase = getRtpBase();
    return pay * (0.81 + rtpBase * 0.20);
  }

  function getTotalMultiplier() {
    if (multiOnBoard.length === 0) return 1;
    return multiOnBoard.reduce((sum, m) => sum + m.value, 0);
  }

  /* ===== 贏分計算 ===== */
  function calculateSpinResult(matches) {
    let win = 0;
    for (const m of matches) {
      const payout = getPayout(m.id, m.count);
      win += (bet / 20) * payout;
    }
    return win;
  }

  /* ===== 倍數球升級 ===== */
  function upgradeMultiBalls() {
    const upgrades = [2,3,5,6,8,10,15,20,25,30,50,75,100,150,200,250,300,500];
    const drift = getRtpDrift();
    // 升級機率：基礎 30%，贏太多時降到最低 5%，輸太多時拉到 50%
    const upgradeChance = Math.max(0.05, Math.min(0.5, 0.3 * (1 - drift * 0.8)));
    for (const m of multiOnBoard) {
      if (Math.random() < upgradeChance) {
        const curIdx = upgrades.indexOf(m.value);
        if (curIdx >= 0 && curIdx < upgrades.length - 1) {
          m.value = upgrades[curIdx + 1];
          m.colorIdx = getMultiColorIdx(m.value);
          const cell = board[m.pos];
          if (cell) {
            cell.label = '×' + m.value;
            cell.multiVal = m.value;
            cell.colorIdx = m.colorIdx;
            // 更新顏色
            const mc = MULTI_COLORS[m.colorIdx];
            cell.color = mc.color;
            cell.bg = mc.bg;
            cell.glow = mc.glow;
            cell.ring = mc.ring;
          }
        }
      }
    }
  }

  /* ===== 覺醒之力觸發偵測 ===== */
  function detectAwaken() {
    // 偵測覺醒條件，不修改盤面，只回傳資料
    let powCount = 0, lckCount = 0;
    const powPos = [], lckPos = [];
    for (let i = 0; i < TOTAL; i++) {
      if (board[i] && board[i].type === 'awaken-pow') { powCount++; powPos.push(i); }
      if (board[i] && board[i].type === 'awaken-lck') { lckCount++; lckPos.push(i); }
    }
    if (powCount >= 3 && multiOnBoard.length > 0) return { kind: 'power', positions: powPos };
    if (lckCount >= 3 && multiOnBoard.length > 0) return { kind: 'lock', positions: lckPos };
    return null;
  }

  function executeAwaken(info) {
    // 執行覺醒效果（在動畫之後呼叫）
    if (info.kind === 'power') {
      // 力量覺醒（賽特）：倍數球分裂（替換普通符號或空位）
      // 先清掉覺醒符號，讓那些位置也可以被分裂使用
      for (const p of info.positions) board[p] = null;
      // 收集可用位置：空位 + 普通符號位置
      const availPositions = [];
      for (let i = 0; i < TOTAL; i++) {
        if (!board[i] || board[i].type === 'sym') availPositions.push(i);
      }
      const toClone = [...multiOnBoard];
      const newBalls = [];
      const SPLIT_COPIES = 2; // 每顆分裂出 2 顆（1→3）
      for (const m of toClone) {
        for (let c = 0; c < SPLIT_COPIES; c++) {
          if (availPositions.length === 0) break;
          const randIdx = Math.floor(Math.random() * availPositions.length);
          const newPos = availPositions.splice(randIdx, 1)[0];
          const ci = getMultiColorIdx(m.value);
          board[newPos] = { ...MULTI_COLORS[ci], type: 'multi', label: '×' + m.value, multiVal: m.value, colorIdx: ci, locked: false };
          multiOnBoard.push({ pos: newPos, value: m.value, colorIdx: ci, locked: false });
          newBalls.push(newPos);
        }
      }
      return newBalls; // 回傳新分裂球的位置
    } else {
      // 鎖定覺醒（奈芙蒂絲）：鎖定所有倍數球
      for (const m of multiOnBoard) {
        m.locked = true;
        if (!lockedMultis.find(lm => lm.pos === m.pos)) {
          lockedMultis.push({ pos: m.pos, value: m.value, rounds: LOCK_ROUNDS + 1 });
        }
        const cell = board[m.pos];
        if (cell) cell.locked = true;
      }
      for (const p of info.positions) board[p] = null;
      return multiOnBoard.map(m => m.pos); // 回傳被鎖定球的位置
    }
  }

  /* ===== DOM 操作 ===== */
  const $board = document.getElementById('board');
  const $winDisplay = document.getElementById('win-display');
  const $winAmount = document.getElementById('win-amount');
  const $btnSpin = document.getElementById('btn-spin');
  const $btnAuto = document.getElementById('btn-auto');
  const $btnReset = document.getElementById('btn-reset');
  const $fgBar = document.getElementById('fg-bar');
  const $fgCount = document.getElementById('fg-count');
  const $multiCounter = document.getElementById('multi-counter');
  const $multiValue = document.getElementById('multi-value');
  const $btnAwkPow = document.getElementById('btn-awk-pow');
  const $btnAwkLck = document.getElementById('btn-awk-lck');
  const $rtpSlider = document.getElementById('rtp-slider');
  const $rtpVal = document.getElementById('rtp-val');
  const $rtpHint = document.getElementById('rtp-hint');
  const $betVal = document.getElementById('bet-val');
  const $balanceVal = document.getElementById('balance-val');

  function renderBoard(highlightPositions, removePositions, dropData, spinIn) {
    $board.innerHTML = '';
    for (let i = 0; i < TOTAL; i++) {
      const cell = document.createElement('div');
      cell.className = 'cell';
      const s = board[i];
      if (s) {
        cell.style.background = s.bg;
        cell.style.color = s.color;
        cell.style.borderColor = s.color + '44';
        cell.dataset.type = s.type;

        if (s.type === 'multi') {
          cell.classList.add('cell-multi');
          const glow = s.glow || 'rgba(57,255,20,0.3)';
          const ring = s.ring || s.color;
          cell.style.borderColor = ring + '88';
          cell.style.boxShadow = '0 0 14px ' + glow + ', inset 0 0 10px ' + glow;
          cell.style.background = 'radial-gradient(circle at 35% 35%, ' + s.color + '99, ' + s.bg + ')';
          cell.innerHTML = '<span class="multi-ball-val">' + s.label + '</span>';
          if (s.locked) {
            cell.innerHTML += '<span class="multi-lock-icon">🔒</span>';
            cell.classList.add('cell-locked');
          }
        } else if (s.type === 'scatter') {
          cell.textContent = s.label;
          cell.classList.add('cell-scatter');
          cell.style.borderColor = '#f5b80066';
          cell.style.boxShadow = '0 0 12px rgba(245,184,0,0.3)';
        } else if (s.type === 'awaken-pow' || s.type === 'awaken-lck') {
          cell.classList.add('cell-awaken');
          const glow = s.glow || 'rgba(245,158,11,0.4)';
          cell.style.borderColor = s.color + '88';
          cell.style.boxShadow = '0 0 16px ' + glow;
          cell.style.background = 'radial-gradient(circle at 50% 40%, ' + s.color + '44, ' + s.bg + ')';
          cell.innerHTML = '<span style="font-size:1.4rem">' + s.label + '</span><span class="awaken-name">' + (s.type === 'awaken-pow' ? '力量' : '鎖定') + '</span>';
        } else {
          cell.textContent = s.label;
        }

        if (highlightPositions && highlightPositions.includes(i)) {
          cell.classList.add('cell-matched');
        }
        if (removePositions && removePositions.includes(i)) {
          cell.classList.add('cell-removing');
        }
        // 掉落動畫
        if (dropData && dropData[i] > 0) {
          const rows = dropData[i];
          cell.style.setProperty('--drop-rows', rows);
          cell.style.animationDuration = (0.08 + rows * 0.06) + 's';
          cell.classList.add('cell-drop');
        }
      } else {
        cell.style.background = '#111';
        cell.style.opacity = '0.3';
      }
      // 新局掉入動畫（鎖定球不動，其餘從上方掉入）
      if (spinIn && !spinIn.has(i)) {
        const col = i % COLS;
        const row = Math.floor(i / COLS);
        const dropRows = ROWS - row + 1;
        cell.style.setProperty('--drop-rows', dropRows);
        cell.style.animationDuration = (0.1 + row * 0.04) + 's';
        cell.style.animationDelay = (col * 0.02) + 's';
        cell.classList.add('cell-drop');
      }
      $board.appendChild(cell);
    }
  }

  function updateStats() {
    document.getElementById('s-rtp-set').textContent = targetRTP + '%';
    const actualRTP = totalBet > 0 ? ((totalWin / totalBet) * 100).toFixed(1) : '—';
    const $actual = document.getElementById('s-rtp-actual');
    $actual.textContent = totalBet > 0 ? actualRTP + '%' : '—';
    if (totalBet > 0) {
      const diff = parseFloat(actualRTP) - targetRTP;
      $actual.style.color = Math.abs(diff) < 5 ? 'var(--guava-green)' : 'var(--guava-pink)';
    }
    document.getElementById('s-spins').textContent = spinCount;
    document.getElementById('s-total-bet').textContent = totalBet.toLocaleString();
    document.getElementById('s-total-win').textContent = totalWin.toLocaleString();
    // RTP-Audit fix: 加「淨輸贏」顯示,讓玩家看到真實虧損
    // 即使 hit rate 90% 看起來都在贏,實際 RTP 80% 是緩慢虧損 — 數字攤開玩家才看得懂
    const $net = document.getElementById('s-net');
    if ($net) {
      const net = totalWin - totalBet;
      if (totalBet === 0) {
        $net.textContent = '—';
        $net.style.color = 'var(--text-muted)';
      } else {
        $net.textContent = (net >= 0 ? '+' : '') + net.toLocaleString();
        $net.style.color = net >= 0 ? 'var(--guava-green)' : 'var(--guava-pink)';
      }
    }
    document.getElementById('s-max-win').textContent = maxSingleWin.toLocaleString();
    document.getElementById('s-max-drought').textContent = maxDrought;
    document.getElementById('s-fg-count').textContent = fgTriggered;
    $balanceVal.textContent = balance.toLocaleString();
    $betVal.textContent = bet;
  }

  function updateChart() {
    if (!balanceChart) return;
    chartData.labels.push(spinCount);
    chartData.datasets[0].data.push(balance);
    // Keep last 300 points
    if (chartData.labels.length > 300) {
      chartData.labels.shift();
      chartData.datasets[0].data.shift();
    }
    // 自動轉時每 5 轉才重繪圖表，省 GPU
    if (isAutoSpin && spinCount % 5 !== 0) return;
    balanceChart.update('none');
  }

  let winTimer = null;
  function showWin(amount) {
    if (winTimer) clearTimeout(winTimer);
    $winAmount.textContent = '+' + Math.round(amount).toLocaleString();
    $winDisplay.style.display = 'flex';
    $winDisplay.classList.add('win-pop');
    const dur = isAutoSpin ? 400 : 1500;
    winTimer = setTimeout(() => {
      $winDisplay.classList.remove('win-pop');
      $winDisplay.style.display = 'none';
      winTimer = null;
    }, dur);
  }

  function updateMultiBar() {
    const total = getTotalMultiplier();
    $multiValue.textContent = '×' + (total === 1 ? 0 : total);
    if (total > 1) {
      $multiCounter.classList.add('multi-active');
    } else {
      $multiCounter.classList.remove('multi-active');
    }
  }

  /* ===== 主遊戲流程 ===== */
  async function spin() {
    if (gameState !== 'idle') return;
    if (balance < bet && freeSpinsLeft <= 0) {
      $btnSpin.textContent = '餘額不足';
      setTimeout(() => { $btnSpin.textContent = 'SPIN'; }, 1500);
      isAutoSpin = false;
      return;
    }

    gameState = 'spinning';
    $btnSpin.disabled = true;
    $btnSpin.textContent = '...';
    spinWin = 0;
    cascadeCount = 0;

    // Deduct bet (not in free game)
    if (freeSpinsLeft <= 0) {
      balance -= bet;
      totalBet += bet;
    } else {
      freeSpinsLeft--;
      $fgCount.textContent = (freeSpinsTotal - freeSpinsLeft) + ' / ' + freeSpinsTotal;
      if (freeSpinsLeft <= 0) {
        $fgBar.style.display = 'none';
      }
    }
    spinCount++;

    // === 新局動畫：舊符號飛出 → 新符號掉入 ===
    const lockedPositions = new Set(lockedMultis.map(lm => lm.pos));
    if (!isAutoSpin) {
      const cells = $board.querySelectorAll('.cell');
      cells.forEach((c, i) => {
        if (!lockedPositions.has(i)) c.classList.add('cell-fly-out');
      });
      await delay(180);
    }

    // Generate new board
    fillBoard();

    // 預約覺醒：強制放 3 個覺醒符號 + 至少 1 顆倍數球，讓 cascadeLoop 自然觸發
    if (pendingAwaken) {
      // 確保盤面至少有 1 顆倍數球
      if (multiOnBoard.length === 0) {
        const symSlots = [];
        for (let i = 0; i < TOTAL; i++) { if (board[i] && board[i].type === 'sym') symSlots.push(i); }
        if (symSlots.length > 0) {
          const fp = symSlots[Math.floor(Math.random() * symSlots.length)];
          const fv = pickMultiValue();
          const ci = getMultiColorIdx(fv);
          board[fp] = { ...MULTI_COLORS[ci], type: 'multi', label: '×' + fv, multiVal: fv, colorIdx: ci, locked: false };
          multiOnBoard.push({ pos: fp, value: fv, colorIdx: ci, locked: false });
        }
      }
      // 找普通符號位置放覺醒符號（避開倍數球和 scatter）
      const awkTemplate = pendingAwaken === 'power' ? AWAKEN_POWER : AWAKEN_LOCK;
      const awkType = pendingAwaken === 'power' ? 'awaken-pow' : 'awaken-lck';
      const availSlots = [];
      for (let i = 0; i < TOTAL; i++) {
        if (board[i] && board[i].type === 'sym') availSlots.push(i);
      }
      // 放 3 個覺醒符號
      const count = Math.min(3, availSlots.length);
      for (let n = 0; n < count; n++) {
        const ri = Math.floor(Math.random() * availSlots.length);
        const pos = availSlots.splice(ri, 1)[0];
        board[pos] = { ...awkTemplate, type: awkType };
      }
      pendingAwaken = null;
      $btnAwkPow.classList.remove('awk-armed');
      $btnAwkLck.classList.remove('awk-armed');
    }

    renderBoard(null, null, null, isAutoSpin ? null : lockedPositions);
    updateMultiBar();
    await autoDelay(350);

    // Cascade loop
    await cascadeLoop();

    // Check scatter for free game trigger
    const scatResult = countScatters();
    if (scatResult.count >= 4 && freeSpinsLeft <= 0) {
      freeSpinsLeft = 15;
      freeSpinsTotal = 15;
      fgTriggered++;
      $fgBar.style.display = 'flex';
      $fgCount.textContent = '0 / 15';
      renderBoard(scatResult.positions);
      await autoDelay(800);
    } else if (scatResult.count >= 3 && freeSpinsLeft > 0) {
      freeSpinsLeft += 5;
      freeSpinsTotal += 5;
      $fgCount.textContent = (freeSpinsTotal - freeSpinsLeft) + ' / ' + freeSpinsTotal;
      renderBoard(scatResult.positions);
      await autoDelay(500);
    }

    // Apply multiplier + RTP 三道防線
    if (spinWin > 0) {
      let multi = getTotalMultiplier();
      const drift = getRtpDrift();

      // 防線 1：壓制倍數球乘數（最大推手）
      // drift 1.0 → 乘數效果歸零（退化成 ×1）
      // drift 0.5 → 乘數效果剩一半
      if (drift > 0 && multi > 1) {
        multi = 1 + (multi - 1) * Math.max(0, 1 - drift);
      } else if (drift < 0 && multi > 1) {
        // 輸太多：小幅加成倍數
        multi = multi * (1 + Math.abs(drift) * 0.3);
      }

      spinWin = Math.round(spinWin * multi);

      // 防線 2：贏分縮放（更陡峭）
      if (drift > 0.05) {
        const scale = Math.max(0.05, 1 - drift * 0.9);
        spinWin = Math.round(spinWin * scale);
      } else if (drift < -0.1) {
        const boost = 1 + Math.abs(drift) * 0.8;
        spinWin = Math.round(spinWin * boost);
      }

      // 防線 3：單轉硬上限（防止單筆爆衝）
      const maxBetMultiple = drift > 0.5 ? 8 : drift > 0 ? 25 : 150;
      spinWin = Math.min(spinWin, bet * maxBetMultiple);

      // RTP-Audit fix: 防線 4 — 短場累積 RTP 鉗位
      // 前 500 轉內,如果這次贏會讓累積 RTP 超過 target × 1.05,直接砍到剛好不超過
      // 解決短場 200 轉玩家 57% 機率賺錢的問題
      if (totalBet > 0 && totalBet < 500 * bet && spinWin > 0) {
        const cap = (targetRTP * 1.05) / 100;
        const allowed = Math.max(0, cap * totalBet - totalWin);
        spinWin = Math.min(spinWin, allowed);
      }

      if (spinWin > 0) {
        balance += spinWin;
        totalWin += spinWin;
        if (spinWin > maxSingleWin) maxSingleWin = spinWin;
        currentDrought = 0;
        showWin(spinWin);
      } else {
        currentDrought++;
        if (currentDrought > maxDrought) maxDrought = currentDrought;
      }
    } else {
      currentDrought++;
      if (currentDrought > maxDrought) maxDrought = currentDrought;
    }

    renderBoard();
    updateStats();
    updateChart();
    updateMultiBar();

    gameState = 'idle';
    $btnSpin.disabled = false;
    $btnSpin.textContent = freeSpinsLeft > 0 ? 'FREE SPIN' : 'SPIN';
    $btnSpin.classList.toggle('btn-free', freeSpinsLeft > 0);

    // Auto spin or free game continue
    if (freeSpinsLeft > 0 || (isAutoSpin && autoRemaining > 0)) {
      if (isAutoSpin && freeSpinsLeft <= 0) {
        autoRemaining--;
        $btnAuto.textContent = 'STOP (' + (autoTotal - autoRemaining) + '/' + autoTotal + ')';
      }
      if (autoRemaining <= 0 && freeSpinsLeft <= 0) {
        stopAuto();
      }
      await autoDelay(freeSpinsLeft > 0 ? 400 : 250);
      if (gameState === 'idle') spin();
    }
  }

  async function cascadeLoop() {
    let hasMatch = true;
    while (hasMatch) {
      // 先檢查覺醒觸發（免費遊戲中自然出現，或強制按鈕放置）
      const awkInfo = detectAwaken();
      if (awkInfo) {
        // 階段 1：覺醒符號高亮脈動
        renderBoard(awkInfo.positions);
        await autoDelay(500);

        // 階段 2：覺醒符號爆炸消失
        renderBoard(null, awkInfo.positions);
        await autoDelay(350);

        // 階段 3：執行覺醒效果（分裂 or 鎖定）
        const affectedPos = executeAwaken(awkInfo);
        renderBoard();
        updateMultiBar();

        // 階段 4：受影響的倍數球閃爍高亮
        if (affectedPos.length > 0) {
          const cells = $board.querySelectorAll('.cell');
          for (const pos of affectedPos) {
            if (cells[pos]) {
              cells[pos].classList.add(awkInfo.kind === 'power' ? 'cell-split-in' : 'cell-lock-in');
            }
          }
          await autoDelay(600);
        }
      }

      const matches = findMatches();
      if (matches.length === 0) {
        hasMatch = false;
        break;
      }
      cascadeCount++;

      const cascadeWin = calculateSpinResult(matches);
      spinWin += cascadeWin;

      const allPositions = matches.flatMap(m => m.positions);
      renderBoard(allPositions);
      await autoDelay(400);

      // Remove matched（但鎖定的倍數球不移除）
      for (const pos of allPositions) {
        const isLocked = multiOnBoard.some(m => m.pos === pos && m.locked);
        if (!isLocked) board[pos] = null;
      }
      multiOnBoard = multiOnBoard.filter(m => board[m.pos] !== null);

      renderBoard(null, allPositions);
      await autoDelay(300);

      if (multiOnBoard.length > 0) upgradeMultiBalls();
      updateMultiBar();

      // 下落 + 補充，帶動畫
      const dropDist = cascadeDown();
      const newDist = fillEmpty();
      const combinedDrop = new Array(TOTAL).fill(0);
      for (let i = 0; i < TOTAL; i++) {
        combinedDrop[i] = dropDist[i] || newDist[i] || 0;
      }
      renderBoard(null, null, combinedDrop);
      await autoDelay(350);
    }
  }

  function delay(ms) { return new Promise(r => setTimeout(r, ms)); }

  /* ===== 事件綁定 ===== */
  $btnSpin.addEventListener('click', () => {
    if (gameState === 'idle') spin();
  });

  let autoCount = 50; // 預設自動轉次數

  function startAuto(count) {
    isAutoSpin = true;
    autoCount = count;
    autoRemaining = count;
    autoTotal = count;
    $btnAuto.textContent = 'STOP (0/' + autoTotal + ')';
    $btnAuto.dataset.count = count;
    // 隱藏其他選項按鈕
    document.querySelectorAll('.btn-auto-opt').forEach(b => b.style.display = 'none');
    if (gameState === 'idle') spin();
  }

  function stopAuto() {
    isAutoSpin = false;
    autoRemaining = 0;
    $btnAuto.textContent = 'AUTO ×' + autoCount;
    document.querySelectorAll('.btn-auto-opt').forEach(b => b.style.display = '');
  }

  $btnAuto.addEventListener('click', () => {
    if (isAutoSpin) {
      stopAuto();
    } else {
      startAuto(parseInt($btnAuto.dataset.count) || 50);
    }
  });

  document.querySelectorAll('.btn-auto-opt').forEach(btn => {
    btn.addEventListener('click', () => {
      if (isAutoSpin) return;
      startAuto(parseInt(btn.dataset.count));
    });
  });

  $btnReset.addEventListener('click', () => {
    if (gameState !== 'idle') return;
    balance = 10000;
    totalBet = 0; totalWin = 0; spinCount = 0;
    maxSingleWin = 0; currentDrought = 0; maxDrought = 0;
    fgTriggered = 0; freeSpinsLeft = 0;
    lockedMultis = [];
    isAutoSpin = false; autoRemaining = 0; autoCount = 50;
    chartData.labels = [0];
    chartData.datasets[0].data = [10000];
    balanceChart && balanceChart.update();
    fillBoard();
    renderBoard();
    updateStats();
    updateMultiBar();
    $fgBar.style.display = 'none';
    $btnSpin.textContent = 'SPIN';
    $btnAuto.textContent = 'AUTO ×50';
    $btnAuto.dataset.count = '50';
    document.querySelectorAll('.btn-auto-opt').forEach(b => b.style.display = '');
  });

  $rtpSlider.addEventListener('input', function() {
    targetRTP = parseInt(this.value);
    $rtpVal.textContent = targetRTP + '%';
    const hints = {
      80:'黑心娛樂城水準', 81:'黑心娛樂城水準', 82:'黑心娛樂城水準',
      83:'盜版老虎機水準', 84:'盜版老虎機水準', 85:'盜版老虎機水準',
      86:'偏低，玩家虧很快', 87:'偏低，玩家虧很快', 88:'偏低，玩家虧很快',
      89:'實體遊藝場水準', 90:'實體遊藝場水準', 91:'實體遊藝場水準',
      92:'一般線上老虎機', 93:'一般線上老虎機', 94:'一般線上老虎機',
      95:'業界平均水準', 96:'接近真實老虎機水準', 97:'正版大廠水準（ATG/PG/RSG）',
      98:'對玩家非常友好', 99:'幾乎不賺錢的佛心 RTP',
    };
    $rtpHint.textContent = hints[targetRTP] || '';
    document.getElementById('s-rtp-set').textContent = targetRTP + '%';
  });

  document.querySelectorAll('.vol-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.vol-btn').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      volatility = this.dataset.vol;
    });
  });

  // 覺醒預約按鈕
  $btnAwkPow.addEventListener('click', () => {
    if (pendingAwaken === 'power') {
      pendingAwaken = null;
      $btnAwkPow.classList.remove('awk-armed');
    } else {
      pendingAwaken = 'power';
      $btnAwkPow.classList.add('awk-armed');
      $btnAwkLck.classList.remove('awk-armed');
    }
  });
  $btnAwkLck.addEventListener('click', () => {
    if (pendingAwaken === 'lock') {
      pendingAwaken = null;
      $btnAwkLck.classList.remove('awk-armed');
    } else {
      pendingAwaken = 'lock';
      $btnAwkLck.classList.add('awk-armed');
      $btnAwkPow.classList.remove('awk-armed');
    }
  });

  document.querySelectorAll('.bet-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const d = parseInt(this.dataset.d);
      bet = Math.max(10, Math.min(500, bet + d));
      $betVal.textContent = bet;
    });
  });

  // Keyboard shortcut
  document.addEventListener('keydown', e => {
    if (e.code === 'Space' && gameState === 'idle') { e.preventDefault(); spin(); }
  });

  /* ===== GA4 事件追蹤 ===== */
  function trackEvent(name, params) {
    if (typeof gtag === 'function') gtag('event', name, params);
  }

  // RTP 滑桿：debounce，放開後才送
  let rtpDebounce = null;
  $rtpSlider.addEventListener('change', function() {
    clearTimeout(rtpDebounce);
    rtpDebounce = setTimeout(() => {
      trackEvent('sim_rtp_adjust', { rtp_value: parseInt(this.value) });
    }, 300);
  });

  // 波動度切換
  document.querySelectorAll('.vol-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      trackEvent('sim_volatility', { volatility: this.dataset.vol });
    });
  });

  // SPIN（只追蹤手動，auto 不送避免灌爆）
  const origSpin = $btnSpin.onclick;
  $btnSpin.addEventListener('click', () => {
    if (!isAutoSpin && gameState === 'idle') trackEvent('sim_spin', { spin_type: 'manual' });
  });

  // AUTO 啟動
  const origAutoClick = $btnAuto.onclick;
  $btnAuto.addEventListener('click', () => {
    if (!isAutoSpin) trackEvent('sim_auto_start', { auto_count: parseInt($btnAuto.dataset.count) || 50 });
  });
  document.querySelectorAll('.btn-auto-opt').forEach(btn => {
    btn.addEventListener('click', () => {
      trackEvent('sim_auto_start', { auto_count: parseInt(btn.dataset.count) });
    });
  });

  // 覺醒按鈕
  $btnAwkPow.addEventListener('click', () => trackEvent('sim_awaken', { awaken_type: 'power' }));
  $btnAwkLck.addEventListener('click', () => trackEvent('sim_awaken', { awaken_type: 'lock' }));

  // 重置
  $btnReset.addEventListener('click', () => trackEvent('sim_reset', {}));

  /* ===== 賠率表渲染 ===== */
  function renderPaytable() {
    const $pt = document.getElementById('paytable');
    let html = '<table><thead><tr><th>符號</th><th>8~9 個</th><th>10~11 個</th><th>12+ 個</th></tr></thead><tbody>';
    for (const s of SYMS) {
      html += '<tr><td><span class="pt-sym" style="background:'+s.bg+';color:'+s.color+'">'+s.label+'</span> '+s.name+'</td>';
      html += '<td>'+s.pay[8]+'</td><td>'+s.pay[10]+'</td><td>'+s.pay[12]+'</td></tr>';
    }
    html += '</tbody></table>';
    // 倍數球說明
    html += '<div class="pt-section"><h4>🔮 倍數球</h4>';
    html += '<div class="pt-multi-row">';
    html += '<span class="pt-ball" style="background:#39ff14;color:#000">×2~5</span> ';
    html += '<span class="pt-ball" style="background:#60a5fa;color:#000">×6~25</span> ';
    html += '<span class="pt-ball" style="background:#c084fc;color:#000">×26~100</span> ';
    html += '<span class="pt-ball" style="background:#fb7185;color:#000">×101~500</span>';
    html += '</div>';
    html += '<p>盤面上出現倍數球，當回合贏分 × 所有倍數球加總。<br>每次消除後，倍數球有 30% 機會升級。</p></div>';
    // 覺醒之力說明
    html += '<div class="pt-section"><h4>⚡ 覺醒之力（Free Game 限定）</h4>';
    html += '<p><span style="color:#f59e0b">⚡ 力量覺醒（賽特）</span> ×3 + 倍數球 → 倍數球分裂為多顆相同倍數<br>';
    html += '<span style="color:#c084fc">🔒 鎖定覺醒（奈芙蒂絲）</span> ×3 + 倍數球 → 倍數球鎖定 ' + LOCK_ROUNDS + ' 回合，期間不消失</p></div>';
    // 基本公式
    html += '<div class="pt-section"><p>贏分公式：（單注÷20）× 符號賠率 × 盤面總倍數<br>Scatter 🪲 出現 4 個以上 → 觸發 15 場 FREE GAME</p></div>';
    $pt.innerHTML = html;
  }

  /* ===== 初始化 ===== */
  function init() {
    fillBoard();
    renderBoard();
    renderPaytable();
    updateStats();

    // Init chart
    const ctx = document.getElementById('balance-chart').getContext('2d');
    balanceChart = new Chart(ctx, {
      type: 'line',
      data: chartData,
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { display: false },
          y: { ticks: { color: '#888', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.06)' } }
        },
        animation: false,
      }
    });
  }

  init();
})();
</script>

<style is:global>
