// === COMBINATORICS ===
const _plCMemo = {};
function plC(n, k) {
  if (k < 0 || k > n) return 0;
  if (k === 0 || k === n) return 1;
  const key = n + ',' + k;
  if (_plCMemo[key]) return _plCMemo[key];
  _plCMemo[key] = plC(n - 1, k - 1) + plC(n - 1, k);
  return _plCMemo[key];
}

function plCombinations(arr, k) {
  if (k === 0) return [[]];
  if (arr.length < k) return [];
  const result = [];
  function helper(start, combo) {
    if (combo.length === k) { result.push([...combo]); return; }
    for (let i = start; i <= arr.length - (k - combo.length); i++) {
      combo.push(arr[i]);
      helper(i + 1, combo);
      combo.pop();
    }
  }
  helper(0, []);
  return result;
}

function plGetPoolSizeA(maxBetsA) {
  const minPool = PICK_COUNT_A + 1;
  let pool = minPool;
  for (let n = minPool; n <= 20; n++) {
    let c = 1;
    for (let i = 0; i < PICK_COUNT_A; i++) c = c * (n - i) / (i + 1);
    if (c > maxBetsA * 3) break;
    pool = n;
  }
  return pool;
}

// === GENERATE WHEEL ===
function plGenerateWheel(draws, allDraws, forceAuto) {
  const bPicks = plGetBPicks(draws);
  const bCount = bPicks.length;
  const maxTotalBets = Math.floor(plBudget / BET_COST);
  if (maxTotalBets < 1) return { poolA: [], bPicks: bPicks, combos: [], maxBets: 0, poolSizeA: 0, totalCombos: 0, isCustom: false };

  const maxBetsA = Math.floor(maxTotalBets / bCount);
  if (maxBetsA < 1) return { poolA: [], bPicks: bPicks, combos: [], maxBets: 0, poolSizeA: 0, totalCombos: 0, isCustom: false };

  const { allScores } = plCalcSuggestions(draws, allDraws);
  const useCustom = !forceAuto && plSource === 'custom' && plCustomA.length > PICK_COUNT_A;

  let poolA, poolNumsA, poolSizeA;

  if (useCustom) {
    poolNumsA = [...plCustomA];
    poolSizeA = poolNumsA.length;
    poolA = poolNumsA.map(n => {
      const found = allScores.find(s => s.num === n);
      return found || { num: n, total: 0, freqScore: 0, missScore: 0, inLastDraw: false };
    });
  } else {
    const filteredScores = plExcluded.length > 0
      ? allScores.filter(s => !plExcluded.includes(s.num))
      : allScores;
    poolSizeA = plGetPoolSizeA(maxBetsA);
    poolSizeA = Math.min(poolSizeA, filteredScores.length);
    poolA = filteredScores.slice(0, poolSizeA);
    poolNumsA = poolA.map(s => s.num);
  }

  const totalCombosA = plC(poolSizeA, PICK_COUNT_A);
  const totalCombosAll = totalCombosA * bCount;

  const MAX_ENUM = 5000;
  let allCombosA;

  const scoreMap = new Map();
  poolA.forEach(p => scoreMap.set(p.num, p));

  function scoreCombo(combo) {
    let score = 0, hotCount = 0, missCount = 0;
    for (const n of combo) {
      const s = scoreMap.get(n);
      if (s) {
        score += s.total;
        if (s.freqScore >= 70) hotCount++;
        if (s.missScore >= 70) missCount++;
      }
    }
    return { nums: combo, score: Math.round(score * 10) / 10, hotCount, missCount };
  }

  const needCombosA = Math.min(maxBetsA, MAX_ENUM);

  if (totalCombosA <= MAX_ENUM) {
    allCombosA = plCombinations(poolNumsA, PICK_COUNT_A).map(scoreCombo);
  } else {
    const sampleTarget = Math.min(needCombosA * 3, MAX_ENUM);
    const seen = new Set();
    const sampled = [];
    const sorted = [...poolNumsA].sort((a, b) => {
      return (scoreMap.get(b)?.total || 0) - (scoreMap.get(a)?.total || 0);
    });
    const topN = Math.min(sorted.length, 12);
    const topCombos = plCombinations(sorted.slice(0, topN), PICK_COUNT_A);
    for (const c of topCombos) {
      const key = c.join(',');
      if (!seen.has(key)) { seen.add(key); sampled.push(scoreCombo(c)); }
      if (sampled.length >= sampleTarget) break;
    }
    let attempts = 0;
    while (sampled.length < sampleTarget && attempts < sampleTarget * 10) {
      attempts++;
      const combo = [];
      const used = new Set();
      while (combo.length < PICK_COUNT_A) {
        const idx = Math.floor(Math.random() * poolNumsA.length);
        if (!used.has(idx)) { used.add(idx); combo.push(poolNumsA[idx]); }
      }
      combo.sort((a, b) => a - b);
      const key = combo.join(',');
      if (!seen.has(key)) { seen.add(key); sampled.push(scoreCombo(combo)); }
    }
    allCombosA = sampled;
  }

  allCombosA.sort((a, b) => b.score - a.score);
  const combosA = allCombosA.slice(0, needCombosA);

  // Expand with second area picks
  const combos = [];
  for (const ca of combosA) {
    for (const b of bPicks) {
      combos.push({ nums: ca.nums, bNum: b, score: ca.score, hotCount: ca.hotCount, missCount: ca.missCount });
    }
  }

  // Trim to budget
  const finalCombos = combos.slice(0, maxTotalBets);

  return {
    poolA, bPicks, combos: finalCombos,
    maxBets: maxTotalBets, poolSizeA,
    totalCombos: totalCombosAll,
    combosACount: combosA.length,
    isCustom: useCustom
  };
}

// === RENDER WHEEL ===
function plRenderWheel() {
  if (plDraws.length === 0) return;

  const draws = plRange === 0 ? plDraws : plDraws.slice(0, plRange);
  const allDraws = plDraws;
  const result = plGenerateWheel(draws, allDraws);
  const { poolA, bPicks, combos, maxBets, poolSizeA, totalCombos, isCustom } = result;

  // Custom mode: not enough A numbers
  if (plSource === 'custom' && plCustomA.length <= PICK_COUNT_A) {
    document.getElementById('plSummary').innerHTML = '';
    document.getElementById('plPool').innerHTML =
      '<div class="pl-cp-not-enough"><span>✋</span> 請至少選 <strong>' + (PICK_COUNT_A + 1) + '</strong> 個第一區號碼才能組成包牌（目前選了 ' + plCustomA.length + ' 個）</div>';
    document.getElementById('plCombos').innerHTML = '';
    document.getElementById('plCoverage').innerHTML = '';
    document.getElementById('plReview').innerHTML = '';
    document.getElementById('plBacktest').innerHTML = '';
    document.getElementById('plSim').innerHTML = '';
    return;
  }

  // Summary
  const actualCost = combos.length * BET_COST;
  document.getElementById('plSummary').innerHTML =
    '<div class="pl-summary-grid">' +
      '<div class="pl-stat"><span class="pl-stat-val">$' + plBudget.toLocaleString() + '</span><span class="pl-stat-label">投注預算</span></div>' +
      '<div class="pl-stat"><span class="pl-stat-val">' + combos.length + ' 注</span><span class="pl-stat-label">包牌組合（每注 $' + BET_COST + '）</span></div>' +
      '<div class="pl-stat"><span class="pl-stat-val">' + poolSizeA + ' 碼</span><span class="pl-stat-label">' + (isCustom ? '自選第一區' : '第一區候選池') + '</span></div>' +
      '<div class="pl-stat"><span class="pl-stat-val">' + bPicks.length + ' 顆</span><span class="pl-stat-label">第二區號碼</span></div>' +
      '<div class="pl-stat"><span class="pl-stat-val">$' + actualCost.toLocaleString() + '</span><span class="pl-stat-label">實際花費</span></div>' +
    '</div>';

  // Budget overflow
  if (isCustom && totalCombos > combos.length) {
    const fullCost = totalCombos * BET_COST;
    document.getElementById('plSummary').innerHTML +=
      '<div class="pl-budget-overflow">' +
        '<div class="pl-bo-icon">⚠️</div>' +
        '<div class="pl-bo-text">' +
          '<strong>預算不足以包完所有組合</strong>' +
          '<p>第一區 <strong>' + poolSizeA + ' 碼</strong> × 第二區 <strong>' + bPicks.length + ' 顆</strong>，共 <strong>' + totalCombos.toLocaleString() + ' 注</strong>，全包需要 <strong>$' + fullCost.toLocaleString() + '</strong>。</p>' +
          '<p>目前預算 $' + plBudget.toLocaleString() + ' 只能買 <strong>' + combos.length + ' 注</strong>（已按強度排序取最強組合）。</p>' +
        '</div>' +
        '<button class="pl-bo-btn" onclick="plAdjustBudget(' + fullCost + ')">💰 調整預算為 $' + fullCost.toLocaleString() + '（全包 ' + totalCombos + ' 注）</button>' +
      '</div>';
  }

  // Pool display
  const poolTitle = isCustom
    ? '✋ 你的自選號碼（第一區 ' + poolSizeA + ' 碼）'
    : '🎯 第一區候選號碼池（TOP ' + poolSizeA + ' 高分號碼）';
  let poolHtml = '<h4>' + poolTitle + '</h4>' +
    '<div class="pl-pool-balls">' +
    poolA.map(function(s) {
      return '<div class="pl-pool-item">' +
        '<div class="pl-pool-ball">' + s.num + '</div>' +
        '<div class="pl-pool-score">' + s.total + '</div>' +
        '<div class="pl-suggest-tags">' +
          (s.freqScore >= 70 ? '<span class="pl-sg-tag hot">熱</span>' : '') +
          (s.missScore >= 70 ? '<span class="pl-sg-tag miss">遺</span>' : '') +
          (s.inLastDraw ? '<span class="pl-sg-tag repeat">連</span>' : '') +
        '</div>' +
      '</div>';
    }).join('') +
    '</div>';

  // Show second area picks
  poolHtml += '<div class="pl-b-picks-display">' +
    '<h4>🔵 第二區號碼（' + bPicks.length + ' 顆）</h4>' +
    '<div class="pl-b-balls">' +
    bPicks.map(function(n) {
      return '<div class="pl-b-ball">' + n + '</div>';
    }).join('') +
    '</div>' +
    '</div>';

  document.getElementById('plPool').innerHTML = poolHtml;

  // Combos table
  if (combos.length === 0) {
    document.getElementById('plCombos').innerHTML = '<p class="pl-empty">預算不足，至少需要 $' + BET_COST + ' 才能買一注。</p>';
  } else {
    const showFirst = 5;
    const MAX_DISPLAY = 200;
    const displayCombos = combos.slice(0, MAX_DISPLAY);
    const hasMore = displayCombos.length > showFirst;
    const truncated = combos.length > MAX_DISPLAY;

    const comboRow = function(c, i) {
      return '<tr>' +
        '<td class="pl-idx">' + (i + 1) + '</td>' +
        '<td class="pl-td-nums">' + c.nums.map(function(n) { return '<span class="pl-num-mini">' + n + '</span>'; }).join('') + '</td>' +
        '<td><span class="pl-b-mini">' + c.bNum + '</span></td>' +
        '<td><span class="pl-strength">' + c.score + '</span></td>' +
        '<td class="pl-composition">' +
          (c.hotCount > 0 ? '<span class="pl-sg-tag hot">' + c.hotCount + '熱</span>' : '') +
          (c.missCount > 0 ? '<span class="pl-sg-tag miss">' + c.missCount + '遺</span>' : '') +
        '</td>' +
      '</tr>';
    };

    document.getElementById('plCombos').innerHTML =
      '<h4>📋 包牌組合表' + (totalCombos > combos.length ? '（從 ' + totalCombos.toLocaleString() + ' 種組合中選出最強 ' + combos.length.toLocaleString() + ' 注）' : '') + '</h4>' +
      '<div class="pl-table-wrap">' +
        '<table class="pl-table">' +
          '<thead><tr>' +
            '<th>#</th>' +
            '<th>第一區</th>' +
            '<th>第二區</th>' +
            '<th>強度</th>' +
            '<th>組成</th>' +
          '</tr></thead>' +
          '<tbody>' +
            displayCombos.slice(0, showFirst).map(function(c, i) { return comboRow(c, i); }).join('') +
          '</tbody>' +
          (hasMore ? '<tbody id="plHiddenRows" style="display:none">' +
            displayCombos.slice(showFirst).map(function(c, i) { return comboRow(c, i + showFirst); }).join('') +
          '</tbody>' : '') +
        '</table>' +
      '</div>' +
      (hasMore ? '<button class="pl-show-more" id="plToggle" onclick="plToggleCombos()">顯示前 ' + displayCombos.length + ' 注</button>' : '') +
      (truncated ? '<p class="pl-trunc-note">⚠️ 共 ' + combos.length.toLocaleString() + ' 注，為保持頁面流暢僅顯示前 ' + MAX_DISPLAY + ' 注（已按強度排序）</p>' : '') +
      '<div class="pl-export-btns">' +
        '<button class="pl-copy-text" onclick="plCopyText()">📋 複製組合文字</button>' +
        '<button class="pl-download-img" onclick="plDownloadImage()">📸 下載包牌圖片</button>' +
        '<a href="https://t.me/game8la" target="_blank" rel="noopener" class="pl-tg-cta">📱 加入 8LA Telegram<small>每週開獎前推播熱號分析（免費）</small></a>' +
      '</div>';
  }

  // Coverage heatmap
  plRenderCoverage(combos, poolA);

  // Last draw review
  plRenderReview(draws, allDraws);

  // Multi-period backtest
  plRenderBacktest(draws, allDraws);

  // Simulation
  plRenderSim(poolSizeA, bPicks, combos);
}

function plToggleCombos() {
  const el = document.getElementById('plHiddenRows');
  const btn = document.getElementById('plToggle');
  if (!el || !btn) return;
  if (el.style.display === 'none') {
    el.style.display = '';
    btn.textContent = '收合';
  } else {
    el.style.display = 'none';
    const total = el.querySelectorAll('tr').length + 5;
    btn.textContent = '顯示全部 ' + total + ' 注';
  }
}

// === COVERAGE HEATMAP ===
function plRenderCoverage(combos, poolA) {
  const el = document.getElementById('plCoverage');
  if (!el || combos.length === 0) { if (el) el.innerHTML = ''; return; }

  const countMap = {};
  poolA.forEach(function(s) { countMap[s.num] = 0; });
  combos.forEach(function(c) { c.nums.forEach(function(n) { if (countMap[n] !== undefined) countMap[n]++; }); });

  const maxCount = Math.max(...Object.values(countMap), 1);
  const nums = poolA.map(function(s) { return s.num; }).sort(function(a, b) { return a - b; });

  el.innerHTML = '<h4>📊 第一區號碼覆蓋率</h4>' +
    '<p class="pl-cov-desc">每個號碼在 ' + combos.length + ' 注組合中出現的次數，越深代表被「包得越厚」：</p>' +
    '<div class="pl-cov-grid">' +
    nums.map(function(n) {
      var cnt = countMap[n] || 0;
      var pct = cnt / maxCount;
      var alpha = 0.15 + pct * 0.85;
      var txtColor = pct > 0.5 ? '#000' : 'var(--text-secondary)';
      return '<div class="pl-cov-cell" style="background:rgba(255,136,0,' + alpha.toFixed(2) + ');color:' + txtColor + '">' +
        '<span class="pl-cov-num">' + n + '</span>' +
        '<span class="pl-cov-cnt">' + cnt + '次</span>' +
      '</div>';
    }).join('') +
    '</div>';
}

// === LAST DRAW REVIEW ===
function plRenderReview(draws, allDraws) {
  const el = document.getElementById('plReview');
  if (allDraws.length < 2) { el.innerHTML = ''; return; }

  const pastDraws = draws.length > 1 ? draws.slice(1) : allDraws.slice(1);
  const pastAllDraws = allDraws.slice(1);
  if (pastDraws.length < 5) { el.innerHTML = ''; return; }

  const lastDraw = allDraws[0];
  const isCustomReview = plSource === 'custom' && plCustomA.length > PICK_COUNT_A;
  const simResult = plGenerateWheel(pastDraws, pastAllDraws, !isCustomReview);
  const simCombos = simResult.combos;
  const simPoolA = simResult.poolA;

  if (simCombos.length === 0) { el.innerHTML = ''; return; }

  const actualA = lastDraw.numbers;
  const actualB = lastDraw.special;
  let bestHitA = 0;
  let bestHitB = 0;
  let bestCombo = null;

  simCombos.forEach(function(c) {
    const hitsA = c.nums.filter(function(n) { return actualA.includes(n); }).length;
    const hitB = c.bNum === actualB ? 1 : 0;
    if (hitsA > bestHitA || (hitsA === bestHitA && hitB > bestHitB)) {
      bestHitA = hitsA;
      bestHitB = hitB;
      bestCombo = c;
    }
  });

  const poolHitsA = simPoolA.filter(function(s) { return actualA.includes(s.num); });
  const bPickHit = simResult.bPicks.includes(actualB);
  const anyHit = simCombos.filter(function(c) {
    return c.nums.filter(function(n) { return actualA.includes(n); }).length > 0;
  }).length;

  el.innerHTML =
    '<h4>📋 上期回顧 — 第 ' + lastDraw.period + ' 期 (' + lastDraw.date + ')</h4>' +
    '<div class="pl-review-grid">' +
      '<div class="pl-review-item">' +
        '<span class="pl-review-label">第一區開獎</span>' +
        '<div class="pl-td-nums">' + actualA.map(function(n) {
          return '<span class="pl-num-mini ' + (simPoolA.some(function(s) { return s.num === n; }) ? 'hit' : '') + '">' + n + '</span>';
        }).join('') + '</div>' +
      '</div>' +
      '<div class="pl-review-item">' +
        '<span class="pl-review-label">第二區開獎</span>' +
        '<span class="pl-review-val"><span class="pl-b-mini ' + (bPickHit ? 'hit' : '') + '">' + actualB + '</span> ' + (bPickHit ? '✅ 命中' : '❌ 未命中') + '</span>' +
      '</div>' +
      '<div class="pl-review-item">' +
        '<span class="pl-review-label">號碼池命中</span>' +
        '<span class="pl-review-val">' + poolHitsA.length + ' / ' + simPoolA.length + ' 個號碼在池中</span>' +
      '</div>' +
      '<div class="pl-review-item">' +
        '<span class="pl-review-label">最佳單注</span>' +
        '<span class="pl-review-val">' +
          (bestCombo ? '第一區命中 ' + bestHitA + ' 個 + 第二區 ' + (bestHitB ? '✅' : '❌') : '—') +
        '</span>' +
      '</div>' +
      '<div class="pl-review-item">' +
        '<span class="pl-review-label">有命中的注數</span>' +
        '<span class="pl-review-val">' + anyHit + ' / ' + simCombos.length + ' 注</span>' +
      '</div>' +
    '</div>' +
    '<p class="pl-review-note">💡 以上是假設用' + (isCustomReview ? '你的自選號碼池' : '同樣的演算法') + '和預算 $' + plBudget.toLocaleString() + ' 回測上一期的結果。</p>';
}

// === MULTI-PERIOD BACKTEST ===
function plRenderBacktest(draws, allDraws) {
  const el = document.getElementById('plBacktest');
  if (!el || allDraws.length < 5) { if (el) el.innerHTML = ''; return; }

  const isCustomBT = plSource === 'custom' && plCustomA.length > PICK_COUNT_A;
  const backtestPeriods = Math.min(20, allDraws.length - 5);
  if (backtestPeriods < 3) { el.innerHTML = ''; return; }

  const results = [];
  let totalCost = 0;
  let totalPrize = 0;

  for (let p = 0; p < backtestPeriods; p++) {
    const targetDraw = allDraws[p];
    const histDraws = allDraws.slice(p + 1);
    const rangeDraws = plRange === 0 ? histDraws : histDraws.slice(0, plRange);
    if (rangeDraws.length < 5) continue;

    const btResult = plGenerateWheel(rangeDraws, histDraws, !isCustomBT);
    const btCombos = btResult.combos;
    if (btCombos.length === 0) continue;

    const actualA = targetDraw.numbers;
    const actualB = targetDraw.special;
    let bestHitA = 0;
    let bestHitB = 0;
    let iterPrize = 0;
    let anyHit = 0;

    for (const combo of btCombos) {
      const hitsA = combo.nums.filter(function(n) { return actualA.includes(n); }).length;
      const hitB = combo.bNum === actualB ? 1 : 0;
      if (hitsA > bestHitA || (hitsA === bestHitA && hitB > bestHitB)) {
        bestHitA = hitsA;
        bestHitB = hitB;
      }
      if (hitsA > 0) anyHit++;
      // Calculate prize
      const prize = plMatchPrize(hitsA, hitB);
      iterPrize += prize;
    }

    const poolHitCount = btResult.poolA.filter(function(s) { return actualA.includes(s.num); }).length;
    const cost = btCombos.length * BET_COST;
    totalCost += cost;
    totalPrize += iterPrize;

    results.push({
      period: targetDraw.period,
      date: targetDraw.date,
      actualA: actualA,
      actualB: actualB,
      bestHitA: bestHitA,
      bestHitB: bestHitB,
      anyHit: anyHit,
      totalCombos: btCombos.length,
      poolHits: poolHitCount,
      poolSize: btResult.poolSizeA,
      prize: iterPrize,
      cost: cost,
      net: iterPrize - cost
    });
  }

  if (results.length === 0) { el.innerHTML = ''; return; }

  const avgBest = (results.reduce(function(s, r) { return s + r.bestHitA; }, 0) / results.length).toFixed(1);
  const prize4up = results.filter(function(r) { return r.bestHitA >= 4; }).length;
  const prize5up = results.filter(function(r) { return r.bestHitA >= 5; }).length;
  const netTotal = totalPrize - totalCost;

  el.innerHTML =
    '<div class="pl-bt-panel">' +
      '<h4>🔁 多期回測（近 ' + results.length + ' 期）</h4>' +
      '<p class="pl-bt-desc">用' + (isCustomBT ? '你的自選號碼' : '同樣的演算法') + '和預算 $' + plBudget.toLocaleString() + ' 回測每一期的表現：</p>' +
      '<div class="pl-bt-summary">' +
        '<div class="pl-bt-stat"><span class="pl-bt-stat-val">' + avgBest + '</span><span class="pl-bt-stat-label">平均最佳命中（第一區）</span></div>' +
        '<div class="pl-bt-stat"><span class="pl-bt-stat-val">' + prize4up + '</span><span class="pl-bt-stat-label">第一區中 4+ 碼</span></div>' +
        '<div class="pl-bt-stat"><span class="pl-bt-stat-val">' + prize5up + '</span><span class="pl-bt-stat-label">第一區中 5+ 碼</span></div>' +
        '<div class="pl-bt-stat ' + (netTotal >= 0 ? 'positive' : 'negative') + '"><span class="pl-bt-stat-val">' + (netTotal >= 0 ? '+' : '') + '$' + netTotal.toLocaleString() + '</span><span class="pl-bt-stat-label">累積損益</span></div>' +
      '</div>' +
      '<div class="pl-bt-table-wrap">' +
        '<table class="pl-bt-table">' +
          '<thead><tr>' +
            '<th>期數</th>' +
            '<th>第一區</th>' +
            '<th>二區</th>' +
            '<th>池命中</th>' +
            '<th>最佳</th>' +
            '<th>損益</th>' +
          '</tr></thead>' +
          '<tbody>' +
            results.map(function(r) {
              var hitClass = r.bestHitA >= 5 ? 'pl-bt-gold' : r.bestHitA >= 4 ? 'pl-bt-silver' : r.bestHitA >= 3 ? 'pl-bt-bronze' : '';
              return '<tr class="' + hitClass + '">' +
                '<td class="pl-bt-period">' + r.period + '</td>' +
                '<td class="pl-bt-nums">' + r.actualA.map(function(n) { return '<span class="pl-num-mini-sm">' + n + '</span>'; }).join('') + '</td>' +
                '<td><span class="pl-b-mini-sm">' + r.actualB + '</span></td>' +
                '<td>' + r.poolHits + '/' + r.poolSize + '</td>' +
                '<td><strong class="pl-bt-best">' + r.bestHitA + '+' + r.bestHitB + '</strong></td>' +
                '<td class="' + (r.net >= 0 ? 'pl-bt-profit' : 'pl-bt-loss') + '">' + (r.net >= 0 ? '+' : '') + '$' + r.net.toLocaleString() + '</td>' +
              '</tr>';
            }).join('') +
          '</tbody>' +
        '</table>' +
      '</div>' +
      '<p class="pl-bt-note">⚠️ 回測結果僅供參考，過去表現不代表未來結果。每期開獎都是獨立事件。</p>' +
    '</div>';
}

// === PRIZE MATCHING ===
function plMatchPrize(hitsA, hitB) {
  // 玖獎: 0+1 or 1+1 → 100
  // 捌獎: 2+1 → 200
  // 柒獎: 3+1 → 400
  // 陸獎: 4+0 → 800
  // 伍獎: 4+1 → 4000
  // 肆獎: 5+0 → 20000
  // 參獎: 5+1 → 150000
  // 貳獎: 6+0 → 4000000
  // 頭獎: 6+1 → 200000000
  if (hitsA === 6 && hitB === 1) return 200000000;
  if (hitsA === 6 && hitB === 0) return 4000000;
  if (hitsA === 5 && hitB === 1) return 150000;
  if (hitsA === 5 && hitB === 0) return 20000;
  if (hitsA === 4 && hitB === 1) return 4000;
  if (hitsA === 4 && hitB === 0) return 800;
  if (hitsA === 3 && hitB === 1) return 400;
  if (hitsA === 2 && hitB === 1) return 200;
  if ((hitsA === 1 || hitsA === 0) && hitB === 1) return 100;
  return 0;
}

// === PROBABILITY SIMULATION ===
function plCalcProbabilities(poolSizeA, bPickCount) {
  const totalCA = plC(MAX_NUM_A, PICK_COUNT_A);
  const totalC = totalCA * MAX_NUM_B;
  const results = [];

  for (const tier of PRIZE_PL) {
    const kA = tier.matchA;
    const kB = tier.matchB;
    // Single bet probability
    let pSingleA;
    if (kA === 0 && kB === 1) {
      // 0+1: match 0 of first area + match second area
      pSingleA = plC(PICK_COUNT_A, 0) * plC(MAX_NUM_A - PICK_COUNT_A, PICK_COUNT_A - 0) / totalCA;
    } else if (kA === 1 && kB === 1) {
      // 1+1
      pSingleA = plC(PICK_COUNT_A, 1) * plC(MAX_NUM_A - PICK_COUNT_A, PICK_COUNT_A - 1) / totalCA;
    } else {
      pSingleA = plC(PICK_COUNT_A, kA) * plC(MAX_NUM_A - PICK_COUNT_A, PICK_COUNT_A - kA) / totalCA;
    }
    const pSingleB = kB === 1 ? (1 / MAX_NUM_B) : ((MAX_NUM_B - 1) / MAX_NUM_B);

    let pSingle;
    if (tier.label.includes('玖獎')) {
      // 玖獎 includes both 0+1 and 1+1
      const p0A = plC(PICK_COUNT_A, 0) * plC(MAX_NUM_A - PICK_COUNT_A, PICK_COUNT_A - 0) / totalCA;
      const p1A = plC(PICK_COUNT_A, 1) * plC(MAX_NUM_A - PICK_COUNT_A, PICK_COUNT_A - 1) / totalCA;
      pSingle = (p0A + p1A) * (1 / MAX_NUM_B);
    } else {
      pSingle = pSingleA * pSingleB;
    }

    // Wheel probability: at least one bet wins this tier
    // For first area: probability of at least kA matches from poolSizeA
    let probWheelA = 0;
    if (tier.label.includes('玖獎')) {
      // 0+1 or 1+1
      let probA01 = 0;
      for (let m = 0; m <= 1; m++) {
        probA01 += plC(poolSizeA, m) * plC(MAX_NUM_A - poolSizeA, PICK_COUNT_A - m) / totalCA;
      }
      const probB = 1 - Math.pow((MAX_NUM_B - bPickCount) / MAX_NUM_B, 1);
      probWheelA = probA01;
      results.push({ ...tier, probSingle: pSingle, probWheel: probA01 * (bPickCount / MAX_NUM_B) });
    } else {
      for (let m = kA; m <= Math.min(poolSizeA, PICK_COUNT_A); m++) {
        probWheelA += plC(poolSizeA, m) * plC(MAX_NUM_A - poolSizeA, PICK_COUNT_A - m) / totalCA;
      }
      const probWheelB = kB === 1 ? (bPickCount / MAX_NUM_B) : ((MAX_NUM_B - bPickCount) / MAX_NUM_B);
      results.push({ ...tier, probSingle: pSingle, probWheel: probWheelA * probWheelB });
    }
  }
  return results;
}

function plCalcEV(poolSizeA, bPickCount, numBets) {
  const totalCA = plC(MAX_NUM_A, PICK_COUNT_A);
  let evPerBet = 0;

  for (const tier of PRIZE_PL) {
    const kA = tier.matchA;
    const kB = tier.matchB;
    let pSingle;
    if (tier.label.includes('玖獎')) {
      const p0A = plC(PICK_COUNT_A, 0) * plC(MAX_NUM_A - PICK_COUNT_A, PICK_COUNT_A - 0) / totalCA;
      const p1A = plC(PICK_COUNT_A, 1) * plC(MAX_NUM_A - PICK_COUNT_A, PICK_COUNT_A - 1) / totalCA;
      pSingle = (p0A + p1A) * (1 / MAX_NUM_B);
    } else {
      const pA = plC(PICK_COUNT_A, kA) * plC(MAX_NUM_A - PICK_COUNT_A, PICK_COUNT_A - kA) / totalCA;
      const pB = kB === 1 ? (1 / MAX_NUM_B) : ((MAX_NUM_B - 1) / MAX_NUM_B);
      pSingle = pA * pB;
    }
    evPerBet += pSingle * tier.prize;
  }

  const totalEV = evPerBet * numBets;
  const totalCost = numBets * BET_COST;
  const roi = ((totalEV - totalCost) / totalCost * 100);
  return { evPerBet: Math.round(evPerBet * 100) / 100, totalEV: Math.round(totalEV), totalCost: totalCost, roi: Math.round(roi * 10) / 10 };
}

function plMonteCarloSim(combosList, iterations) {
  // Track best match per draw and total prize
  const distA = new Array(PICK_COUNT_A + 1).fill(0);
  let totalPrize = 0;
  let anyPrizeCount = 0;

  for (let i = 0; i < iterations; i++) {
    // Draw first area
    const drawA = [];
    const usedA = new Set();
    while (drawA.length < PICK_COUNT_A) {
      const n = Math.floor(Math.random() * MAX_NUM_A) + 1;
      if (!usedA.has(n)) { usedA.add(n); drawA.push(n); }
    }
    // Draw second area
    const drawB = Math.floor(Math.random() * MAX_NUM_B) + 1;

    let bestMatchA = 0;
    let iterPrize = 0;

    for (const combo of combosList) {
      const hitsA = combo.nums.filter(function(n) { return drawA.includes(n); }).length;
      const hitB = combo.bNum === drawB ? 1 : 0;
      if (hitsA > bestMatchA) bestMatchA = hitsA;
      const prize = plMatchPrize(hitsA, hitB);
      iterPrize += prize;
    }

    distA[bestMatchA]++;
    totalPrize += iterPrize;
    if (iterPrize > 0) anyPrizeCount++;
  }

  const pct = distA.map(function(d) { return Math.round(d / iterations * 10000) / 100; });
  const avgReturn = Math.round(totalPrize / iterations);
  const anyWinPct = Math.round(anyPrizeCount / iterations * 10000) / 100;
  return { distA: distA, pct: pct, avgReturn: avgReturn, iterations: iterations, anyWinPct: anyWinPct };
}

function plFormatProb(p) {
  if (p >= 0.01) return (p * 100).toFixed(2) + '%';
  if (p >= 0.0001) return '1/' + Math.round(1 / p).toLocaleString();
  if (p > 0) return '1/' + Math.round(1 / p).toLocaleString();
  return '0';
}

function plRenderSim(poolSizeA, bPicks, combos) {
  const el = document.getElementById('plSim');
  if (!el || combos.length === 0) { if (el) el.innerHTML = ''; return; }

  const numBets = combos.length;
  const bPickCount = bPicks.length;
  const totalCost = numBets * BET_COST;
  const probs = plCalcProbabilities(poolSizeA, bPickCount);
  const ev = plCalcEV(poolSizeA, bPickCount, numBets);
  const mc = plMonteCarloSim(combos, 10000);

  el.innerHTML =
    '<div class="pl-sim-panel">' +
      '<h4>🔮 包牌機率模擬 <span class="pl-sim-badge">威力彩</span></h4>' +
      '<p class="pl-sim-subtitle">第一區 ' + poolSizeA + ' 碼 × 第二區 ' + bPickCount + ' 顆 = ' + numBets + ' 注（$' + totalCost.toLocaleString() + '），到底有多少機會中獎？</p>' +

      '<div class="pl-sim-tabs">' +
        '<button class="pl-sim-tab active" onclick="plSwitchSimTab(this,\'plSimProb\')">精算機率</button>' +
        '<button class="pl-sim-tab" onclick="plSwitchSimTab(this,\'plSimEV\')">期望值</button>' +
        '<button class="pl-sim-tab" onclick="plSwitchSimTab(this,\'plSimMC\')">萬次模擬</button>' +
      '</div>' +

      '<div class="pl-sim-content" id="plSimProb">' +
        '<table class="pl-sim-table">' +
          '<thead><tr>' +
            '<th>獎項</th>' +
            '<th>單注機率</th>' +
            '<th>' + numBets + ' 注至少中一次</th>' +
            '<th>獎金</th>' +
          '</tr></thead>' +
          '<tbody>' +
            probs.map(function(p) {
              return '<tr>' +
                '<td class="pl-sim-tier">' + p.label + '</td>' +
                '<td>' + (p.probSingle > 0 ? plFormatProb(p.probSingle) : '—') + '</td>' +
                '<td class="pl-sim-highlight">' + (p.probWheel > 0 ? plFormatProb(p.probWheel) : '—') + '</td>' +
                '<td>$' + p.prize.toLocaleString() + '</td>' +
              '</tr>';
            }).join('') +
          '</tbody>' +
        '</table>' +
        '<p class="pl-sim-note">※ 「至少中一次」考慮號碼池覆蓋率及第二區選號策略。頭獎獎金以最低保證 2 億計算。</p>' +
      '</div>' +

      '<div class="pl-sim-content" id="plSimEV" style="display:none">' +
        '<div class="pl-sim-ev-grid">' +
          '<div class="pl-sim-ev-card"><span class="pl-sim-ev-label">投注成本</span><span class="pl-sim-ev-val cost">-$' + totalCost.toLocaleString() + '</span></div>' +
          '<div class="pl-sim-ev-card"><span class="pl-sim-ev-label">單注期望回收</span><span class="pl-sim-ev-val">$' + ev.evPerBet.toFixed(1) + '</span></div>' +
          '<div class="pl-sim-ev-card"><span class="pl-sim-ev-label">' + numBets + ' 注期望回收</span><span class="pl-sim-ev-val">$' + ev.totalEV.toLocaleString() + '</span></div>' +
          '<div class="pl-sim-ev-card ' + (ev.roi >= 0 ? 'positive' : 'negative') + '"><span class="pl-sim-ev-label">期望報酬率</span><span class="pl-sim-ev-val">' + (ev.roi > 0 ? '+' : '') + ev.roi + '%</span></div>' +
        '</div>' +
        '<div class="pl-sim-ev-bar-wrap">' +
          '<div class="pl-sim-ev-bar-label"><span>投入 $' + totalCost.toLocaleString() + '</span><span>期望回收 $' + ev.totalEV.toLocaleString() + '</span></div>' +
          '<div class="pl-sim-ev-bar-track"><div class="pl-sim-ev-bar-fill" style="width:' + Math.min(100, ev.totalEV / totalCost * 100) + '%"></div></div>' +
          '<p class="pl-sim-ev-verdict">每花 $100，平均拿回 $' + Math.round(ev.totalEV / totalCost * 100) + '<br>' +
          '<strong style="color:var(--text-muted);font-weight:400">（期望值為負 = 長期一定虧，這是數學事實，跟運氣無關）</strong></p>' +
        '</div>' +
      '</div>' +

      '<div class="pl-sim-content" id="plSimMC" style="display:none">' +
        '<p class="pl-sim-mc-title">🎲 模擬 ' + mc.iterations.toLocaleString() + ' 次開獎結果</p>' +
        '<div class="pl-sim-mc-chart">' +
          mc.pct.map(function(p, i) {
            var barH = Math.max(2, p / Math.max.apply(null, mc.pct) * 100);
            var tierLabel = i === 0 ? '槓龜' : i === 1 ? '中1' : i === 2 ? '中2' : i === 3 ? '中3' : i === 4 ? '中4' : i === 5 ? '中5' : '中6';
            var tierColor = i === 0 ? '#555' : i <= 2 ? '#666' : i === 3 ? '#f5b800' : i === 4 ? '#ff8800' : i === 5 ? '#39FF14' : '#ec4899';
            return '<div class="pl-sim-mc-col">' +
              '<span class="pl-sim-mc-pct">' + (p > 0 ? p + '%' : '0%') + '</span>' +
              '<div class="pl-sim-mc-bar" style="height:' + barH + '%;background:' + tierColor + '"></div>' +
              '<span class="pl-sim-mc-label">' + tierLabel + '</span>' +
            '</div>';
          }).join('') +
        '</div>' +
        '<div class="pl-sim-mc-summary">' +
          '<div class="pl-sim-mc-stat"><span class="pl-sim-mc-stat-label">每次開獎平均回收</span><span class="pl-sim-mc-stat-val">$' + mc.avgReturn.toLocaleString() + '</span></div>' +
          '<div class="pl-sim-mc-stat"><span class="pl-sim-mc-stat-label">每次開獎投入</span><span class="pl-sim-mc-stat-val cost">$' + totalCost.toLocaleString() + '</span></div>' +
          '<div class="pl-sim-mc-stat"><span class="pl-sim-mc-stat-label">模擬淨損益</span><span class="pl-sim-mc-stat-val ' + (mc.avgReturn >= totalCost ? 'positive' : 'negative') + '">' + (mc.avgReturn >= totalCost ? '+' : '-') + '$' + Math.abs(mc.avgReturn - totalCost).toLocaleString() + '</span></div>' +
          '<div class="pl-sim-mc-stat"><span class="pl-sim-mc-stat-label">中任一獎機率</span><span class="pl-sim-mc-stat-val">' + mc.anyWinPct + '%</span></div>' +
        '</div>' +
        '<button class="pl-sim-rerun" onclick="plRerunMC()">🔄 重跑一次模擬</button>' +
        '<p class="pl-sim-note">※ 每次模擬結果略有不同（隨機性），但趨勢一致：長期期望值為負</p>' +
      '</div>' +
    '</div>';
}

function plSwitchSimTab(btn, tabId) {
  btn.parentElement.querySelectorAll('.pl-sim-tab').forEach(function(t) { t.classList.remove('active'); });
  btn.classList.add('active');
  btn.closest('.pl-sim-panel').querySelectorAll('.pl-sim-content').forEach(function(c) { c.style.display = 'none'; });
  document.getElementById(tabId).style.display = '';
}

function plRerunMC() {
  if (plDraws.length === 0) return;
  var draws = plRange === 0 ? plDraws : plDraws.slice(0, plRange);
  var allDraws = plDraws;
  var result = plGenerateWheel(draws, allDraws);
  plRenderSim(result.poolSizeA, result.bPicks, result.combos);
  var mcBtn = document.querySelector('.pl-sim-tab:last-child');
  if (mcBtn) plSwitchSimTab(mcBtn, 'plSimMC');
}

// === COPY TEXT ===
function plCopyText() {
  if (plDraws.length === 0) return;
  var draws = plRange === 0 ? plDraws : plDraws.slice(0, plRange);
  var allDraws = plDraws;
  var result = plGenerateWheel(draws, allDraws);
  var combos = result.combos;
  if (combos.length === 0) return;

  var today = new Date();
  var dateStr = today.getFullYear() + '/' + String(today.getMonth() + 1).padStart(2, '0') + '/' + String(today.getDate()).padStart(2, '0');
  var lastPeriod = allDraws[0]?.period || '';

  var mc = plMonteCarloSim(combos, 10000);
  var totalCost = combos.length * BET_COST;

  var text = '🎯 威力彩包牌組合 — GAME8LA\n';
  text += '日期：' + dateStr + (lastPeriod ? '  最新一期：' + lastPeriod : '') + '\n';
  text += '預算：$' + plBudget.toLocaleString() + ' ／ ' + combos.length + ' 注 ／ 第一區 ' + result.poolSizeA + ' 碼 × 第二區 ' + result.bPicks.length + ' 顆\n';
  text += '────────────────\n';
  text += '🎲 萬次模擬結果：' + mc.anyWinPct + '% 機率中任一獎\n';
  text += '💸 期望回收：$' + mc.avgReturn.toLocaleString() + ' / 投入 $' + totalCost.toLocaleString() + '\n';
  text += '────────────────\n';
  combos.forEach(function(c, i) {
    text += '第' + String(i + 1).padStart(3, ' ') + '注：' + c.nums.map(function(n) { return String(n).padStart(2, '0'); }).join(' ') + ' ＋ ' + c.bNum + '\n';
  });
  text += '────────────────\n';
  text += '⚠️ 包牌只是提高覆蓋率，期望值永遠是負的\n';
  text += '🔗 game8la.com/tools/power-lottery-calculator';

  navigator.clipboard.writeText(text).then(function() {
    var btn = document.querySelector('.pl-copy-text');
    if (btn) {
      var orig = btn.innerHTML;
      btn.innerHTML = '✅ 已複製！';
      btn.classList.add('copied');
      setTimeout(function() { btn.innerHTML = orig; btn.classList.remove('copied'); }, 2000);
    }
  }).catch(function() {
    var ta = document.createElement('textarea');
    ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
    document.body.appendChild(ta); ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    var btn = document.querySelector('.pl-copy-text');
    if (btn) {
      var orig = btn.innerHTML;
      btn.innerHTML = '✅ 已複製！';
      btn.classList.add('copied');
      setTimeout(function() { btn.innerHTML = orig; btn.classList.remove('copied'); }, 2000);
    }
  });
}

// === DOWNLOAD IMAGE ===
function plDownloadImage() {
  if (plDraws.length === 0) return;
  var draws = plRange === 0 ? plDraws : plDraws.slice(0, plRange);
  var allDraws = plDraws;
  var result = plGenerateWheel(draws, allDraws);
  var combos = result.combos;
  if (combos.length === 0) return;

  var actualCost = combos.length * BET_COST;
  var today = new Date();
  var dateStr = today.getFullYear() + '/' + String(today.getMonth() + 1).padStart(2, '0') + '/' + String(today.getDate()).padStart(2, '0');
  var lastPeriod = allDraws[0]?.period || '';

  var W = 800;
  var PAD = 32;
  var COLS = 2;
  var COL_W = (W - PAD * 2 - 20) / COLS;
  var BALL_R = 14;
  var BALL_GAP = 4;
  var ROW_H = 42;
  var HEADER_H = 210;
  var maxDisplay = Math.min(combos.length, 60);
  var rows = Math.ceil(maxDisplay / COLS);
  var TABLE_H = rows * ROW_H + 40;
  var FOOTER_H = 100;
  var H = HEADER_H + TABLE_H + FOOTER_H;

  var canvas = document.createElement('canvas');
  canvas.width = W;
  canvas.height = H;
  var ctx = canvas.getContext('2d');

  // Background
  var bgGrad = ctx.createLinearGradient(0, 0, 0, H);
  bgGrad.addColorStop(0, '#1a1a2e');
  bgGrad.addColorStop(0.5, '#16213e');
  bgGrad.addColorStop(1, '#0f3460');
  ctx.fillStyle = bgGrad;
  ctx.fillRect(0, 0, W, H);

  // Grid pattern
  ctx.strokeStyle = 'rgba(255,255,255,0.03)';
  ctx.lineWidth = 1;
  for (var i = 0; i < W; i += 40) { ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, H); ctx.stroke(); }
  for (var j = 0; j < H; j += 40) { ctx.beginPath(); ctx.moveTo(0, j); ctx.lineTo(W, j); ctx.stroke(); }

  // Header
  var hdrGrad = ctx.createLinearGradient(0, 0, W, 0);
  hdrGrad.addColorStop(0, 'rgba(255,136,0,0.15)');
  hdrGrad.addColorStop(1, 'rgba(255,215,0,0.08)');
  ctx.fillStyle = hdrGrad;
  ctx.fillRect(0, 0, W, HEADER_H);

  var accentGrad = ctx.createLinearGradient(0, 0, W, 0);
  accentGrad.addColorStop(0, '#ff8800');
  accentGrad.addColorStop(1, '#FFD700');
  ctx.fillStyle = accentGrad;
  ctx.fillRect(0, HEADER_H - 3, W, 3);

  ctx.font = 'bold 28px "Segoe UI", "Noto Sans TC", sans-serif';
  ctx.fillStyle = '#FFD700';
  ctx.textAlign = 'left';
  ctx.fillText('🎯 GAME8LA', PAD, 48);

  ctx.font = 'bold 22px "Segoe UI", "Noto Sans TC", sans-serif';
  ctx.fillStyle = '#ffffff';
  ctx.fillText('威力彩包牌組合', PAD, 84);

  ctx.font = '14px "Segoe UI", "Noto Sans TC", sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.5)';
  ctx.textAlign = 'right';
  ctx.fillText(dateStr + (lastPeriod ? '  |  最新一期：' + lastPeriod : ''), W - PAD, 48);

  ctx.textAlign = 'left';
  var stats = [
    { label: '預算', val: '$' + plBudget.toLocaleString() },
    { label: '注數', val: combos.length + ' 注' },
    { label: '花費', val: '$' + actualCost.toLocaleString() },
    { label: '第一區', val: result.poolSizeA + ' 碼' },
    { label: '第二區', val: result.bPicks.length + ' 顆' }
  ];
  var statW = (W - PAD * 2) / stats.length;
  stats.forEach(function(s, idx) {
    var x = PAD + idx * statW;
    ctx.fillStyle = 'rgba(255,255,255,0.12)';
    plRoundRect(ctx, x, 100, statW - 8, 52, 8);
    ctx.fill();
    ctx.font = 'bold 18px "Segoe UI", "Noto Sans TC", sans-serif';
    ctx.fillStyle = '#ff8800';
    ctx.textAlign = 'center';
    ctx.fillText(s.val, x + (statW - 8) / 2, 126);
    ctx.font = '11px "Segoe UI", "Noto Sans TC", sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.fillText(s.label, x + (statW - 8) / 2, 144);
  });

  ctx.textAlign = 'left';
  ctx.font = '12px "Segoe UI", "Noto Sans TC", sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.4)';
  ctx.fillText('第一區號碼池：' + result.poolA.map(function(s) { return s.num; }).join(', ') + '  |  第二區：' + result.bPicks.join(', '), PAD, HEADER_H - 16);

  // Table header
  var tableY = HEADER_H + 10;
  ctx.font = 'bold 12px "Segoe UI", "Noto Sans TC", sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.35)';
  for (var col = 0; col < COLS; col++) {
    var cx = PAD + col * (COL_W + 20);
    ctx.textAlign = 'left';
    ctx.fillText('#', cx, tableY + 14);
    ctx.fillText('第一區 + 第二區', cx + 30, tableY + 14);
  }

  // Combo rows
  ctx.textAlign = 'left';
  for (var idx2 = 0; idx2 < maxDisplay; idx2++) {
    var c = combos[idx2];
    var colIdx = idx2 < Math.ceil(maxDisplay / 2) ? 0 : 1;
    var rowIdx = colIdx === 0 ? idx2 : idx2 - Math.ceil(maxDisplay / 2);
    var cx2 = PAD + colIdx * (COL_W + 20);
    var cy = tableY + 30 + rowIdx * ROW_H;

    if (rowIdx % 2 === 0) {
      ctx.fillStyle = 'rgba(255,255,255,0.03)';
      ctx.fillRect(cx2 - 4, cy - 6, COL_W, ROW_H);
    }

    ctx.font = '12px "Segoe UI", "Noto Sans TC", sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.fillText(String(idx2 + 1).padStart(3, ' '), cx2, cy + 16);

    // First area balls
    c.nums.forEach(function(n, j) {
      var bx = cx2 + 40 + j * (BALL_R * 2 + BALL_GAP) + BALL_R;
      var by = cy + 12;
      var ballGrad = ctx.createRadialGradient(bx - 3, by - 3, 2, bx, by, BALL_R);
      ballGrad.addColorStop(0, '#FFD700');
      ballGrad.addColorStop(1, '#ff8800');
      ctx.beginPath();
      ctx.arc(bx, by, BALL_R, 0, Math.PI * 2);
      ctx.fillStyle = ballGrad;
      ctx.fill();
      ctx.font = 'bold 12px "Segoe UI", sans-serif';
      ctx.fillStyle = '#000';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(String(n), bx, by + 1);
    });

    // Second area ball
    var bx2 = cx2 + 40 + 6 * (BALL_R * 2 + BALL_GAP) + BALL_R + 8;
    var by2 = cy + 12;
    var bGrad2 = ctx.createRadialGradient(bx2 - 3, by2 - 3, 2, bx2, by2, BALL_R);
    bGrad2.addColorStop(0, '#66bbff');
    bGrad2.addColorStop(1, '#2196F3');
    ctx.beginPath();
    ctx.arc(bx2, by2, BALL_R, 0, Math.PI * 2);
    ctx.fillStyle = bGrad2;
    ctx.fill();
    ctx.font = 'bold 12px "Segoe UI", sans-serif';
    ctx.fillStyle = '#fff';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(String(c.bNum), bx2, by2 + 1);

    ctx.textBaseline = 'alphabetic';
    ctx.textAlign = 'left';
  }

  // Truncation note
  if (combos.length > maxDisplay) {
    ctx.font = '12px "Segoe UI", "Noto Sans TC", sans-serif';
    ctx.fillStyle = 'rgba(255,152,0,0.7)';
    ctx.textAlign = 'center';
    ctx.fillText('⚠ 共 ' + combos.length + ' 注，圖片僅顯示前 ' + maxDisplay + ' 注', W / 2, tableY + TABLE_H - 8);
    ctx.textAlign = 'left';
  }

  // Footer
  var footerY = H - FOOTER_H;
  ctx.fillStyle = 'rgba(0,0,0,0.3)';
  ctx.fillRect(0, footerY, W, FOOTER_H);
  ctx.fillStyle = accentGrad;
  ctx.fillRect(0, footerY, W, 2);

  ctx.font = '12px "Segoe UI", "Noto Sans TC", sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.4)';
  ctx.textAlign = 'center';
  ctx.fillText('芭樂子提醒：包牌只是提高覆蓋率，不是提高中獎率。期望值永遠是負的，請量力而為。', W / 2, footerY + 30);

  ctx.font = 'bold 14px "Segoe UI", sans-serif';
  ctx.fillStyle = '#FFD700';
  ctx.fillText('game8la.com/tools/power-lottery-calculator', W / 2, footerY + 56);

  ctx.font = '11px "Segoe UI", "Noto Sans TC", sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.3)';
  ctx.fillText('此圖片由 GAME8LA 威力彩包牌計算器自動產生', W / 2, footerY + 80);

  var link = document.createElement('a');
  link.download = 'power-lottery-wheel-' + dateStr.replace(/\//g, '') + '.png';
  link.href = canvas.toDataURL('image/png');
  link.click();
}

function plRoundRect(ctx, x, y, w, h, r) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

// === INIT ===
plLoadData();
</script>

<style is:global>
