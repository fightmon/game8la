    <div class="pl-skeleton-pulse" style="height:200px;margin-bottom:1rem"></div>
    <div class="pl-skeleton-pulse" style="height:150px"></div>
    <p class="pl-loading-text">正在載入威力彩開獎數據...</p>
  </div>

  <!-- Calculator section -->
  <section class="analysis-section pl-wheel-section" id="plWheelSection" style="display:none">
    <div class="section-head">
