// === DATA LOADING ===
async function plLoadData() {
  const loading = document.getElementById('plLoadingState');
  const section = document.getElementById('plWheelSection');
  try {
    let workerData = null;
    let staticData = null;
    const isLocal = location.hostname === 'localhost' || location.hostname === '127.0.0.1';

    if (!isLocal) {
      try {
        const res = await fetch('https://lottery-cron.fightmon.workers.dev/data/super-lotto.json');
        if (res.ok) workerData = await res.json();
      } catch (e) { /* fall through */ }
    }

    try {
      const res2 = await fetch('/data/super-lotto.json');
      if (res2.ok) staticData = await res2.json();
    } catch (e) { /* fall through */ }

    let baseData = null;
    if (workerData && staticData) {
      baseData = (workerData.lastUpdated >= staticData.lastUpdated) ? workerData : staticData;
    } else {
      baseData = workerData || staticData;
    }

    const LIVE_API = isLocal ? 'https://game8la.com/api/lottery' : '/api/lottery';
    try {
      const apiRes = await fetch(LIVE_API, { cache: 'no-store' });
      if (apiRes.ok) {
        const apiJson = await apiRes.json();
        const gameData = apiJson.data?.super_lotto;
        if (gameData && gameData.numbers && gameData.numbers.length > 0) {
          const freshDraws = [];
          freshDraws.push({ period: gameData.period, date: gameData.date, numbers: gameData.numbers, special: gameData.special });
          if (Array.isArray(gameData.history)) {
            for (const h of gameData.history) {
              freshDraws.push({ period: h.period, date: h.date, numbers: h.numbers, special: h.special });
            }
          }
          if (baseData && baseData.draws) {
            const existingPeriods = new Set(baseData.draws.map(d => d.period));
            let merged = false;
            for (const fd of freshDraws) {
              if (fd.period && !existingPeriods.has(fd.period)) {
                baseData.draws.unshift(fd);
                existingPeriods.add(fd.period);
                merged = true;
              }
            }
            if (merged) {
              baseData.draws.sort((a, b) => (b.date || '').localeCompare(a.date || '') || (Number(b.period) || 0) - (Number(a.period) || 0));
            }
          } else if (!baseData) {
            baseData = { draws: freshDraws };
          }
        }
      }
    } catch (e) { /* fall through */ }

    if (baseData && baseData.draws && baseData.draws.length > 0) {
      // Filter out bad data: numbers > 38 or special > 8 or special < 1
      plDraws = baseData.draws.filter(d => {
        if (!d.numbers || d.numbers.length < PICK_COUNT_A) return false;
        if (Math.max(...d.numbers) > MAX_NUM_A) return false;
        if (d.special > MAX_NUM_B || d.special < 1) return false;
        return true;
      });
      if (plDraws.length > 0) {
        loading.style.display = 'none';
        section.style.display = '';
        plRenderWheel();
      } else {
        loading.innerHTML = '<p class="pl-loading-error">⚠️ 篩選後無有效威力彩開獎數據，請稍後再試。</p>';
      }
    } else {
      loading.innerHTML = '<p class="pl-loading-error">⚠️ 無法載入威力彩開獎數據，請稍後再試。</p>';
    }
  } catch (err) {
    loading.innerHTML = '<p class="pl-loading-error">⚠️ 載入失敗：' + err.message + '</p>';
  }
}

// === STATISTICS ===
function plCalcFrequency(draws) {
  const freq = {};
  for (let i = 1; i <= MAX_NUM_A; i++) freq[i] = 0;
  draws.forEach(d => d.numbers.forEach(n => { if (n >= 1 && n <= MAX_NUM_A) freq[n]++; }));
  return freq;
}

function plCalcMissing(allDraws) {
  const missing = {};
  for (let i = 1; i <= MAX_NUM_A; i++) {
    missing[i] = 0;
    for (let j = 0; j < allDraws.length; j++) {
      if (allDraws[j].numbers.includes(i)) break;
      missing[i]++;
    }
  }
  return missing;
}

function plCalcRepeat(allDraws) {
  const stats = {};
  for (let n = 1; n <= MAX_NUM_A; n++) {
    stats[n] = { appeared: 0, repeated: 0 };
  }
  for (let i = 0; i < allDraws.length - 1; i++) {
    const curr = allDraws[i].numbers;
    const next = allDraws[i + 1].numbers;
    curr.forEach(n => {
      if (n >= 1 && n <= MAX_NUM_A) {
        stats[n].appeared++;
        if (next.includes(n)) stats[n].repeated++;
      }
    });
  }
  return stats;
}

function plCalcSuggestions(draws, allDraws) {
  const freq = plCalcFrequency(draws);
  const missing = plCalcMissing(allDraws);
  const repeatStats = plCalcRepeat(allDraws);
  const lastDraw = allDraws.length > 0 ? allDraws[0].numbers : [];

  const vals = arr => arr.length ? arr : [0];
  const minMax = (arr) => {
    const mn = Math.min(...vals(arr)), mx = Math.max(...vals(arr));
    return { min: mn, max: mx, range: mx - mn || 1 };
  };

  const freqVals = Object.values(freq);
  const missVals = Object.values(missing);
  const fNorm = minMax(freqVals);
  const mNorm = minMax(missVals);

  const scores = [];
  for (let n = 1; n <= MAX_NUM_A; n++) {
    const freqScore = ((freq[n] - fNorm.min) / fNorm.range) * 100;
    const missScore = ((missing[n] - mNorm.min) / mNorm.range) * 100;
    let repeatScore = 0;
    if (lastDraw.includes(n) && repeatStats[n]) {
      const s = repeatStats[n];
      repeatScore = s.appeared > 0 ? (s.repeated / s.appeared) * 100 : 0;
      repeatScore = Math.min(repeatScore * 2, 100);
    }
    const total = freqScore * 0.40 + missScore * 0.35 + repeatScore * 0.25;
    scores.push({
      num: n,
      total: Math.round(total * 10) / 10,
      freqScore: Math.round(freqScore),
      missScore: Math.round(missScore),
      repeatScore: Math.round(repeatScore),
      freq: freq[n],
      missing: missing[n],
      inLastDraw: lastDraw.includes(n)
    });
  }
  scores.sort((a, b) => b.total - a.total);
  return { allScores: scores };
}

// === SECOND AREA HELPERS ===
function plCalcBFrequency(draws) {
  const freq = {};
  for (let i = 1; i <= MAX_NUM_B; i++) freq[i] = 0;
  draws.forEach(d => { if (d.special >= 1 && d.special <= MAX_NUM_B) freq[d.special]++; });
  return freq;
}

function plGetBPicks(draws) {
  if (plBStrategy === 'all') {
    return [1, 2, 3, 4, 5, 6, 7, 8];
  }
  if (plBStrategy === 'custom') {
    return plCustomB.length > 0 ? [...plCustomB] : [1];
  }
  // auto: pick the most frequent second area number
  const freq = plCalcBFrequency(draws);
  let bestNum = 1, bestFreq = 0;
  for (let i = 1; i <= MAX_NUM_B; i++) {
    if (freq[i] > bestFreq) { bestFreq = freq[i]; bestNum = i; }
  }
  return [bestNum];
}

