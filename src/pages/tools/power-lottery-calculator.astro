  cursor: pointer; transition: all 0.2s;
}
.pl-btn:hover { border-color: var(--gold); }
.pl-btn.active {
  background: linear-gradient(135deg, #ff8800, #FFD700); color: #000;
  border-color: #ff8800; font-weight: 700;
}
.pl-custom {
  display: flex; gap: 0.3rem; align-items: center;
}
.pl-custom input {
  width: 100px; padding: 0.45rem 0.6rem; border-radius: 8px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  color: var(--text-primary); font-size: 0.85rem;
}
.pl-custom input::placeholder { color: var(--text-muted); }
.pl-custom-go { padding: 0.45rem 0.8rem; font-size: 0.85rem; }

/* Source toggle */
.pl-source-toggle {
  display: flex; align-items: center; gap: 0.5rem;
  flex-wrap: wrap; margin-bottom: 1rem;
}
.pl-source-label { color: var(--text-muted); font-size: 0.9rem; font-weight: 600; }
.pl-src-btn {
  padding: 0.5rem 1rem; border-radius: 8px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  color: var(--text-secondary); font-size: 0.88rem; font-weight: 600;
  cursor: pointer; transition: all 0.2s;
}
.pl-src-btn:hover { border-color: var(--gold); }
.pl-src-btn.active {
  background: linear-gradient(135deg, #ff8800, #FFD700); color: #000;
  border-color: #ff8800; font-weight: 700;
}

/* Area B strategy */
.pl-area-b-strategy {
  display: flex; align-items: center; gap: 0.5rem;
  flex-wrap: wrap; margin-bottom: 1rem;
  padding-top: 1rem; border-top: 1px solid var(--border);
}
.pl-area-b-label { color: var(--text-muted); font-size: 0.9rem; font-weight: 600; }
.pl-b-btn {
  padding: 0.5rem 1rem; border-radius: 8px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  color: var(--text-secondary); font-size: 0.88rem; font-weight: 600;
  cursor: pointer; transition: all 0.2s;
}
.pl-b-btn:hover { border-color: #2196F3; }
.pl-b-btn.active {
  background: linear-gradient(135deg, #2196F3, #42a5f5); color: #fff;
  border-color: #2196F3; font-weight: 700;
}

/* Custom pool A (first area) */
.pl-custom-pool {
  margin-bottom: 1.2rem; padding: 1rem;
  background: rgba(255,136,0,0.04); border: 1px dashed rgba(255,136,0,0.3);
  border-radius: 12px;
}
.pl-cp-hint { font-size: 0.88rem; color: var(--text-secondary); margin: 0 0 0.8rem; }
.pl-cp-hint strong { color: var(--gold-light); }
.pl-cp-grid {
  display: flex; flex-wrap: wrap; gap: 0.35rem; justify-content: center; margin-bottom: 0.8rem;
}
.pl-cp-num {
  width: 40px; height: 40px; border-radius: 50%;
  background: var(--bg-secondary); border: 2px solid var(--border);
  color: var(--text-secondary); font-size: 0.92rem; font-weight: 700;
  cursor: pointer; transition: all 0.2s; display: flex;
  align-items: center; justify-content: center;
}
.pl-cp-num:hover { border-color: #ff8800; color: #ff8800; }
.pl-cp-num.selected {
  background: linear-gradient(135deg, #ff8800, #FFD700); color: #000;
  border-color: #ff8800; box-shadow: 0 3px 10px rgba(255,136,0,0.35);
  transform: scale(1.08);
}
.pl-cp-status {
  display: flex; align-items: center; justify-content: center; gap: 1rem;
  font-size: 0.88rem; color: var(--text-muted);
}
.pl-cp-status strong { color: #ff8800; font-size: 1.05rem; }
.pl-cp-clear {
  padding: 0.3rem 0.8rem; border-radius: 6px;
  background: var(--bg-card); border: 1px solid var(--border);
  color: var(--text-secondary); font-size: 0.8rem; cursor: pointer;
}
.pl-cp-clear:hover { border-color: var(--text-muted); }

/* Custom pool warning */
.pl-cp-warn {
  margin-top: 0.8rem; padding: 1rem 1.2rem;
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
  border: 2px solid #ff9800; border-radius: 12px;
  display: flex; gap: 0.8rem; align-items: flex-start;
}
[data-theme="dark"] .pl-cp-warn {
  background: linear-gradient(135deg, rgba(255,152,0,0.15) 0%, rgba(255,152,0,0.06) 100%);
}
.pl-cp-warn-icon { font-size: 1.5rem; flex-shrink: 0; margin-top: 0.1rem; }
.pl-cp-warn-body { font-size: 0.85rem; line-height: 1.6; }
.pl-cp-warn-body strong { color: #e65100; display: block; margin-bottom: 0.3rem; font-size: 0.92rem; }
[data-theme="dark"] .pl-cp-warn-body strong { color: #ffab40; }
.pl-cp-warn-body p { margin: 0.25rem 0; color: #5d4037; }
[data-theme="dark"] .pl-cp-warn-body p { color: #ffcc80; }
.pl-cp-warn.shake { animation: pl-shake 0.4s ease-in-out; }
@keyframes pl-shake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-6px); }
  40% { transform: translateX(6px); }
  60% { transform: translateX(-4px); }
  80% { transform: translateX(4px); }
}

/* Custom B (second area) */
.pl-custom-b {
  margin-bottom: 1.2rem; padding: 1rem;
  background: rgba(33,150,243,0.04); border: 1px dashed rgba(33,150,243,0.3);
  border-radius: 12px;
}
.pl-cb-hint { font-size: 0.88rem; color: var(--text-secondary); margin: 0 0 0.8rem; }
.pl-cb-hint strong { color: #42a5f5; }
.pl-cb-grid {
  display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; margin-bottom: 0.8rem;
}
.pl-cb-num {
  width: 48px; height: 48px; border-radius: 50%;
  background: var(--bg-secondary); border: 2px solid var(--border);
  color: var(--text-secondary); font-size: 1.1rem; font-weight: 700;
  cursor: pointer; transition: all 0.2s; display: flex;
  align-items: center; justify-content: center;
}
.pl-cb-num:hover { border-color: #2196F3; color: #2196F3; }
.pl-cb-num.selected {
  background: linear-gradient(135deg, #2196F3, #42a5f5); color: #fff;
  border-color: #2196F3; box-shadow: 0 3px 10px rgba(33,150,243,0.35);
  transform: scale(1.08);
}
.pl-cb-status {
  display: flex; align-items: center; justify-content: center; gap: 1rem;
  font-size: 0.88rem; color: var(--text-muted);
}
.pl-cb-status strong { color: #2196F3; font-size: 1.05rem; }

/* Not enough nums */
.pl-cp-not-enough {
  padding: 1rem; text-align: center; font-size: 0.92rem;
  color: var(--text-muted); background: rgba(255,136,0,0.04);
  border: 1px dashed rgba(255,136,0,0.25); border-radius: 10px;
}
.pl-cp-not-enough strong { color: #ff8800; }

/* ═══ Summary ═══ */
.pl-summary-grid {
  display: flex; gap: 0.8rem; justify-content: center;
  flex-wrap: wrap; margin-bottom: 1.5rem;
}
.pl-stat {
  display: flex; flex-direction: column; align-items: center;
  padding: 0.8rem 1rem; border-radius: 12px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  min-width: 100px;
}
.pl-stat-val { font-size: 1.3rem; font-weight: 900; color: #ff8800; }
.pl-stat-label { font-size: 0.72rem; color: var(--text-muted); margin-top: 0.2rem; text-align: center; }

/* Budget overflow */
.pl-budget-overflow {
  margin-top: 1rem; padding: 1rem 1.2rem;
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
  border: 2px solid #ff9800; border-radius: 12px;
  text-align: center;
}
[data-theme="dark"] .pl-budget-overflow {
  background: linear-gradient(135deg, rgba(255,152,0,0.15) 0%, rgba(255,152,0,0.08) 100%);
  border-color: #ff9800;
}
.pl-bo-icon { font-size: 1.6rem; margin-bottom: 0.3rem; }
.pl-bo-text { font-size: 0.88rem; color: #5d4037; line-height: 1.6; }
[data-theme="dark"] .pl-bo-text { color: #ffcc80; }
.pl-bo-text strong { color: #e65100; }
[data-theme="dark"] .pl-bo-text strong { color: #ffab40; }
.pl-bo-text p { margin: 0.2rem 0; }
.pl-bo-btn {
  margin-top: 0.8rem; padding: 0.6rem 1.4rem;
  background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
  color: #fff; border: none; border-radius: 8px;
  font-size: 0.9rem; font-weight: 700; cursor: pointer;
  transition: transform 0.15s, box-shadow 0.15s;
}
.pl-bo-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(255,152,0,0.4);
}

/* ═══ Pool ═══ */
.pl-pool { margin-bottom: 1.5rem; }
.pl-pool h4 { font-size: 0.95rem; color: var(--text-primary); margin-bottom: 0.8rem; }
.pl-pool-balls {
  display: flex; gap: 0.8rem; flex-wrap: wrap; justify-content: center;
}
.pl-pool-item {
  display: flex; flex-direction: column; align-items: center; gap: 0.2rem;
}
.pl-pool-ball {
  width: 42px; height: 42px; border-radius: 50%;
  background: linear-gradient(135deg, #ff8800, #FFD700);
  color: #000; font-weight: 900; font-size: 1.1rem;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 3px 10px rgba(255,136,0,0.3);
}
.pl-pool-score { font-size: 0.7rem; color: var(--gold-light); font-weight: 700; }
.pl-suggest-tags { display: flex; gap: 0.2rem; }
.pl-sg-tag {
  font-size: 0.6rem; padding: 0.1rem 0.35rem; border-radius: 4px;
  font-weight: 700;
}
.pl-sg-tag.hot { background: rgba(255,68,68,0.2); color: #ff6666; }
.pl-sg-tag.miss { background: rgba(68,170,255,0.2); color: #66bbff; }
.pl-sg-tag.repeat { background: rgba(57,255,20,0.2); color: #39FF14; }

/* Second area picks display */
.pl-b-picks-display {
  margin-top: 1rem; padding-top: 1rem;
  border-top: 1px solid var(--border);
}
.pl-b-picks-display h4 { font-size: 0.95rem; color: var(--text-primary); margin-bottom: 0.8rem; }
.pl-b-balls {
  display: flex; gap: 0.6rem; justify-content: center;
}
.pl-b-ball {
  width: 42px; height: 42px; border-radius: 50%;
  background: linear-gradient(135deg, #2196F3, #42a5f5);
  color: #fff; font-weight: 900; font-size: 1.1rem;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 3px 10px rgba(33,150,243,0.3);
}

/* ═══ Combos Table ═══ */
.pl-combos { margin-bottom: 1.5rem; }
.pl-combos h4 { font-size: 0.95rem; color: var(--text-primary); margin-bottom: 0.8rem; }
.pl-table-wrap { overflow-x: auto; }
.pl-table {
  width: 100%; border-collapse: collapse; font-size: 0.85rem;
}
.pl-table th {
  text-align: left; padding: 0.5rem; border-bottom: 2px solid var(--border);
  color: var(--text-muted); font-size: 0.78rem; white-space: nowrap;
}
.pl-table td {
  padding: 0.45rem 0.5rem; border-bottom: 1px solid var(--border);
  color: var(--text-secondary); white-space: nowrap;
}
.pl-idx { color: var(--text-muted); font-weight: 600; width: 30px; }
.pl-strength { font-weight: 800; color: #ff8800; }
.pl-composition { display: flex; gap: 0.2rem; }
.pl-td-nums { display: flex; gap: 3px; flex-wrap: wrap; align-items: center; }
.pl-num-mini {
  display: inline-flex; align-items: center; justify-content: center;
  width: 30px; height: 30px; border-radius: 50%;
  background: var(--bg-secondary); border: 1px solid var(--border);
  font-size: 0.8rem; font-weight: 700; color: var(--text-secondary);
}
.pl-num-mini.hit {
  background: linear-gradient(135deg, #39FF14, #2bcc10);
  color: #000; border-color: #39FF14;
  box-shadow: 0 2px 8px rgba(57,255,20,0.3);
}
.pl-b-mini {
  display: inline-flex; align-items: center; justify-content: center;
  width: 30px; height: 30px; border-radius: 50%;
  background: rgba(33,150,243,0.15); border: 1px solid rgba(33,150,243,0.4);
  font-size: 0.8rem; font-weight: 700; color: #42a5f5;
}
.pl-b-mini.hit {
  background: linear-gradient(135deg, #2196F3, #42a5f5);
  color: #fff; border-color: #2196F3;
  box-shadow: 0 2px 8px rgba(33,150,243,0.3);
}
.pl-empty {
  text-align: center; color: var(--text-muted); font-size: 0.9rem;
  padding: 2rem; background: var(--bg-secondary); border-radius: 10px;
}
.pl-show-more {
  display: block; width: 100%; margin-top: 0.8rem;
  padding: 0.6rem; border-radius: 8px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  color: var(--gold-light); font-size: 0.85rem; font-weight: 600;
  cursor: pointer; transition: all 0.2s;
}
.pl-show-more:hover { border-color: var(--gold); background: rgba(255,215,0,0.08); }
.pl-trunc-note {
  margin-top: 0.6rem; padding: 0.5rem 0.8rem;
  font-size: 0.8rem; color: #ff9800;
  background: rgba(255,152,0,0.08); border-radius: 8px;
  text-align: center;
}

/* ═══ Export Buttons ═══ */
.pl-export-btns {
  display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; margin-top: 0.8rem;
}
.pl-tg-cta {
  grid-column: 1 / -1;
  display: flex; align-items: center; justify-content: center; gap: 0.5rem;
  padding: 0.75rem 1rem; border-radius: 10px;
  border: 2px solid rgba(0, 136, 204, 0.4);
  background: linear-gradient(135deg, rgba(0, 136, 204, 0.12), rgba(0, 136, 204, 0.06));
  color: #29b6f6; font-size: 0.95rem; font-weight: 700;
  cursor: pointer; transition: all 0.25s; text-decoration: none;
}
.pl-tg-cta small {
  font-weight: 400; font-size: 0.8rem; opacity: 0.8;
}
.pl-tg-cta:hover {
  background: linear-gradient(135deg, rgba(0, 136, 204, 0.25), rgba(0, 136, 204, 0.12));
  border-color: #29b6f6; transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(0, 136, 204, 0.2);
}
.pl-copy-text {
  display: flex; align-items: center; justify-content: center; gap: 0.4rem;
  padding: 0.75rem 1rem; border-radius: 10px;
  border: 2px solid rgba(57,255,20,0.4);
  background: linear-gradient(135deg, rgba(57,255,20,0.12), rgba(57,255,20,0.06));
  color: #39FF14; font-size: 0.95rem; font-weight: 700;
  cursor: pointer; transition: all 0.25s;
}
.pl-copy-text:hover {
  background: linear-gradient(135deg, rgba(57,255,20,0.25), rgba(57,255,20,0.12));
  border-color: #39FF14; transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(57,255,20,0.2);
}
.pl-copy-text.copied {
  background: linear-gradient(135deg, rgba(57,255,20,0.3), rgba(57,255,20,0.15));
  border-color: #39FF14;
}
.pl-download-img {
  display: flex; align-items: center; justify-content: center; gap: 0.4rem;
  padding: 0.75rem 1rem; border-radius: 10px;
  border: 2px solid rgba(255,215,0,0.4);
  background: linear-gradient(135deg, rgba(255,136,0,0.12), rgba(255,215,0,0.08));
  color: #FFD700; font-size: 0.95rem; font-weight: 700;
  cursor: pointer; transition: all 0.25s;
}
.pl-download-img:hover {
  background: linear-gradient(135deg, rgba(255,136,0,0.25), rgba(255,215,0,0.15));
  border-color: #FFD700; transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(255,215,0,0.2);
}

/* ═══ Exclude Panel ═══ */
.pl-exclude-panel {
  margin-bottom: 1.2rem;
  border: 1px solid var(--border); border-radius: 12px;
  overflow: hidden;
}
.pl-exclude-head {
  display: flex; align-items: center; gap: 0.5rem;
  padding: 0.8rem 1rem; cursor: pointer;
  background: var(--bg-secondary); transition: background 0.2s;
}
.pl-exclude-head:hover { background: rgba(255,136,0,0.06); }
.pl-exclude-toggle-icon {
  font-size: 0.7rem; color: var(--text-muted);
  transition: transform 0.2s;
}
.pl-exclude-title { font-size: 0.92rem; font-weight: 700; color: var(--text-primary); }
.pl-exclude-count {
  margin-left: auto; font-size: 0.82rem; color: #ef4444;
}
.pl-exclude-count strong { font-size: 0.95rem; }
.pl-exclude-body { padding: 1rem; }
.pl-exc-hint {
  font-size: 0.88rem; color: var(--text-secondary); margin: 0 0 0.8rem;
}
.pl-exc-grid {
  display: flex; flex-wrap: wrap; gap: 0.35rem; justify-content: center;
  margin-bottom: 0.8rem;
}
.pl-exc-num {
  width: 40px; height: 40px; border-radius: 50%;
  background: var(--bg-secondary); border: 2px solid var(--border);
  color: var(--text-secondary); font-size: 0.92rem; font-weight: 700;
  cursor: pointer; transition: all 0.2s; display: flex;
  align-items: center; justify-content: center;
}
.pl-exc-num:hover { border-color: #ef4444; color: #ef4444; }
.pl-exc-num.excluded {
  background: linear-gradient(135deg, #ef4444, #dc2626); color: #fff;
  border-color: #ef4444; box-shadow: 0 3px 10px rgba(239,68,68,0.35);
  text-decoration: line-through; text-decoration-thickness: 2px;
}
.pl-exc-actions {
  display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap;
}
.pl-exc-quick {
  padding: 0.5rem 1rem; border-radius: 8px;
  background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3);
  color: #ef4444; font-size: 0.85rem; font-weight: 600;
  cursor: pointer; transition: all 0.2s;
}
.pl-exc-quick:hover { background: rgba(239,68,68,0.2); border-color: #ef4444; }
.pl-exc-clear {
  padding: 0.5rem 1rem; border-radius: 8px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  color: var(--text-secondary); font-size: 0.85rem; font-weight: 600;
  cursor: pointer; transition: all 0.2s;
}
.pl-exc-clear:hover { border-color: var(--text-muted); }

/* ═══ Coverage ═══ */
.pl-coverage { margin-bottom: 1.5rem; }
.pl-coverage h4 { font-size: 0.95rem; color: var(--text-primary); margin-bottom: 0.3rem; }
.pl-cov-desc { font-size: 0.85rem; color: var(--text-muted); margin: 0 0 0.8rem; }
.pl-cov-grid {
  display: flex; flex-wrap: wrap; gap: 0.4rem; justify-content: center;
}
.pl-cov-cell {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; width: 48px; height: 48px;
  border-radius: 10px; border: 1px solid rgba(255,136,0,0.2);
  transition: transform 0.15s;
}
.pl-cov-cell:hover { transform: scale(1.1); }
.pl-cov-num { font-size: 0.95rem; font-weight: 800; line-height: 1; }
.pl-cov-cnt { font-size: 0.65rem; font-weight: 600; opacity: 0.8; margin-top: 1px; }

/* ═══ Review ═══ */
.pl-review { margin-bottom: 1rem; }
.pl-review h4 { font-size: 0.95rem; color: var(--text-primary); margin-bottom: 0.8rem; }
.pl-review-grid {
  display: flex; flex-direction: column; gap: 0.6rem;
  padding: 1rem; background: var(--bg-secondary); border: 1px solid var(--border);
  border-radius: 12px;
}
.pl-review-item {
  display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap;
}
.pl-review-label {
  font-size: 0.82rem; color: var(--text-muted); font-weight: 600;
  min-width: 100px;
}
.pl-review-val { font-size: 0.85rem; color: var(--text-secondary); display: flex; align-items: center; gap: 3px; flex-wrap: wrap; }
.pl-review-note {
  font-size: 0.8rem; color: var(--text-muted); margin-top: 0.6rem;
  text-align: center;
}

/* ═══ Backtest ═══ */
.pl-backtest { margin-bottom: 1.5rem; }
.pl-bt-panel {
  background: linear-gradient(135deg, rgba(16,185,129,0.06), rgba(255,215,0,0.04));
  border: 1px solid rgba(16,185,129,0.3);
  border-radius: 14px; padding: 1.5rem;
}
.pl-bt-panel h4 {
  font-size: 1.1rem; color: var(--text-primary); margin: 0 0 0.3rem;
}
.pl-bt-desc { font-size: 0.88rem; color: var(--text-muted); margin: 0 0 1rem; }
.pl-bt-summary {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 0.6rem; margin-bottom: 1.2rem;
}
.pl-bt-stat {
  display: flex; flex-direction: column; align-items: center;
  padding: 0.8rem 0.5rem; border-radius: 10px;
  background: var(--bg-secondary); border: 1px solid var(--border);
}
.pl-bt-stat-val { font-size: 1.3rem; font-weight: 900; color: #10b981; }
.pl-bt-stat-label { font-size: 0.72rem; color: var(--text-muted); margin-top: 0.2rem; text-align: center; }
.pl-bt-stat.negative .pl-bt-stat-val { color: #ef4444; }
.pl-bt-stat.positive .pl-bt-stat-val { color: #10b981; }
.pl-bt-table-wrap { overflow-x: auto; }
.pl-bt-table {
  width: 100%; border-collapse: collapse; font-size: 0.85rem;
}
.pl-bt-table th {
  text-align: left; padding: 0.5rem; border-bottom: 2px solid var(--border);
  color: var(--text-muted); font-size: 0.78rem; white-space: nowrap;
}
.pl-bt-table td {
  padding: 0.45rem 0.5rem; border-bottom: 1px solid var(--border);
  color: var(--text-secondary); font-size: 0.88rem; white-space: nowrap;
}
.pl-bt-period { font-weight: 600; color: var(--text-muted); }
.pl-bt-nums { display: flex; gap: 2px; align-items: center; }
.pl-num-mini-sm {
  display: inline-flex; align-items: center; justify-content: center;
