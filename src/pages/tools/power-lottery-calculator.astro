  </section>

  <ShareButtons title="威力彩包牌計算器 — 免費一鍵算注數＋花費＋中獎率" heading="🛡 玩威力彩的朋友該知道這個工具" />
</div>

<script is:inline>
// === POWER LOTTERY WHEEL CALCULATOR ===

const MAX_NUM_A = 38;
const PICK_COUNT_A = 6;
const MAX_NUM_B = 8;
const PICK_COUNT_B = 1;
const BET_COST = 100;

let plDraws = [];
let plBudget = 1000;
let plRange = 50;
let plSource = 'auto';
let plCustomA = [];
let plExcluded = [];
let plBStrategy = 'auto';
let plCustomB = [];
const PL_MAX_CUSTOM_A = 15;

// === PRIZE TIERS ===
const PRIZE_PL = [
  { matchA: 6, matchB: 1, prize: 200000000, label: '頭獎（6+1）' },
  { matchA: 6, matchB: 0, prize: 4000000,   label: '貳獎（6+0）' },
  { matchA: 5, matchB: 1, prize: 150000,    label: '參獎（5+1）' },
  { matchA: 5, matchB: 0, prize: 20000,     label: '肆獎（5+0）' },
