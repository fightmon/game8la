    IRQ: { prob: '0.1%', title: '浪漫主義者', best: '1986 小組賽', star: 'Aymen Hussein', comment: '消失 40 年後回來了！包機飛到墨西哥、2-1 逆轉玻利維亞，光是資格賽的故事就夠拍一部電影。贏不贏不重要，站在這裡就是勝利。', group: 'I', opponents: '法國、塞內加爾、挪威' },
    HAI: { prob: '0.1%', title: '加勒比海盜', best: '1974 小組賽', star: 'Duckens Nazon', comment: '1974 年以來第一次回到世界盃，跟巴西同組。嗯⋯芭樂子只能祝你好運了。', group: 'C', opponents: '巴西、摩洛哥、蘇格蘭' },
    CPV: { prob: '0.1%', title: '小島奇蹟創造者', best: '首次參賽', star: 'Ryan Mendes', comment: '人口 60 萬的小島國第一次打世界盃！不管結果如何，站上這個舞台就已經是奇蹟了。', group: 'H', opponents: '西班牙、沙烏地阿拉伯、烏拉圭' },
    CUW: { prob: '0.05%', title: '真正的勇者', best: '首次參賽', star: 'Juninho Bacuna', comment: '史上最小參賽國！人口 15 萬，比你家附近的區還少。能站在世界盃的草地上就已經贏了。', group: 'E', opponents: '德國、象牙海岸、厄瓜多' },
    JOR: { prob: '0.1%', title: '約旦驚奇', best: '首次參賽', star: 'Mousa Al-Taamari', comment: '2024 亞洲盃亞軍、第一次打世界盃。跟阿根廷同組？好的，至少能跟 Messi 合照。', group: 'J', opponents: '阿根廷、阿爾及利亞、奧地利' },
    UZB: { prob: '0.1%', title: '中亞冒險家', best: '首次參賽', star: 'Eldor Shomurodov', comment: '第一次打世界盃就抽到葡萄牙和哥倫比亞？芭樂子默默幫你點了一炷香。', group: 'K', opponents: '葡萄牙、剛果民主共和國、哥倫比亞' },
  };
  // Default info for teams not in TEAM_INFO
  var DEFAULT_INFO = { prob: '<0.5%', title: '勇氣可嘉', best: '—', star: '—', comment: '你選了一支冷門隊！不管結果如何，支持自己喜歡的球隊就是最棒的。', group: '?', opponents: '—' };

  // === STATE ===
  var selectedCode = null;
  var userVote = localStorage.getItem('wc2026_vote');

  // === INIT ===
  function init() {
    if (userVote) {
      showAlreadyVoted();
    } else {
      renderGroups();
    }
  }

  // === RENDER GROUPS ===
  function renderGroups() {
    var grid = document.getElementById('groupsGrid');
    var html = '';
    Object.keys(GROUPS).forEach(function(groupKey) {
      var teams = GROUPS[groupKey];
      html += '<div class="wc-group-card">';
      html += '<div class="wc-group-label">Group ' + groupKey + '</div>';
      teams.forEach(function(team) {
        html += '<div class="wc-team-item" data-code="' + team.code + '">';
        html += '<span class="wc-team-flag">' + team.flag + '</span>';
        html += '<span class="wc-team-name">' + team.name + '</span>';
        html += '<span class="wc-team-rank">#' + team.rank + '</span>';
        html += '</div>';
      });
      html += '</div>';
    });
    grid.innerHTML = html;

    // Add click handlers
    var items = grid.querySelectorAll('.wc-team-item');
    items.forEach(function(item) {
      item.addEventListener('click', function() {
        selectTeam(item.getAttribute('data-code'));
      });
    });
  }

  // === SELECT TEAM ===
  function selectTeam(code) {
    selectedCode = code;
    var team = TEAM_MAP[code];

    // Update visual selection
    var items = document.querySelectorAll('.wc-team-item');
    items.forEach(function(item) {
      item.classList.remove('wc-selected');
    });
    var selected = document.querySelector('.wc-team-item[data-code="' + code + '"]');
    if (selected) selected.classList.add('wc-selected');

    // Update display
    var display = document.getElementById('selectedDisplay');
    display.textContent = '你的選擇：' + team.flag + ' ' + team.name;
    display.classList.add('wc-has-pick');

    // Enable button
    var btn = document.getElementById('voteBtn');
    btn.classList.add('wc-active');
    btn.disabled = false;
  }

  // === VOTE ===
  function castVote() {
    if (!selectedCode) return;
    userVote = selectedCode;
    localStorage.setItem('wc2026_vote', selectedCode);

    // Increment user vote in localStorage
    var userVotes = JSON.parse(localStorage.getItem('wc2026_user_votes') || '{}');
    userVotes[selectedCode] = (userVotes[selectedCode] || 0) + 1;
    localStorage.setItem('wc2026_user_votes', JSON.stringify(userVotes));

    // Show confirmation with fate card
    showFateCard(selectedCode);

    // Hide voting section
    document.getElementById('votingSection').style.display = 'none';

    // Show results
    showResults();
  }

  // === REVOTE ===
  window.revote = function() {
    // Remove old vote from user votes
    var oldVote = localStorage.getItem('wc2026_vote');
    if (oldVote) {
      var userVotes = JSON.parse(localStorage.getItem('wc2026_user_votes') || '{}');
      if (userVotes[oldVote]) {
        userVotes[oldVote] = Math.max(0, userVotes[oldVote] - 1);
        if (userVotes[oldVote] === 0) delete userVotes[oldVote];
        localStorage.setItem('wc2026_user_votes', JSON.stringify(userVotes));
      }
    }
    localStorage.removeItem('wc2026_vote');
    userVote = null;
    selectedCode = null;

    // Hide confirmation and results
    document.getElementById('confirmation').style.display = 'none';
    document.getElementById('resultsSection').style.display = 'none';

    // Show voting section and re-render
    document.getElementById('votingSection').style.display = '';
    document.getElementById('selectedDisplay').textContent = '點選你心中的冠軍隊伍';
    document.getElementById('selectedDisplay').classList.remove('wc-has-pick');
    var btn = document.getElementById('voteBtn');
    btn.classList.remove('wc-active');
    btn.disabled = true;
    renderGroups();
  };

  // === SHOW FATE CARD ===
  function showFateCard(code) {
    var team = TEAM_MAP[code];
    var info = TEAM_INFO[code] || DEFAULT_INFO;

    document.getElementById('confirmText').textContent = '你預測 ' + team.flag + ' ' + team.name + ' 奪冠！';
    document.getElementById('titleBadge').innerHTML = '🏅 你的稱號：<strong>' + info.title + '</strong>';
    document.getElementById('teamComment').textContent = '芭樂子說：' + info.comment;

    // Fate card data
    document.getElementById('fateHeader').innerHTML = team.flag + ' ' + team.name + ' 命運卡';
    document.getElementById('fateGrid').innerHTML =
      '<div class="wc-fate-item"><span class="wc-fate-label">FIFA 排名</span><span class="wc-fate-val">#' + team.rank + '</span></div>' +
      '<div class="wc-fate-item"><span class="wc-fate-label">奪冠機率</span><span class="wc-fate-val wc-fate-prob">' + info.prob + '</span></div>' +
      '<div class="wc-fate-item"><span class="wc-fate-label">小組</span><span class="wc-fate-val">Group ' + info.group + '</span></div>' +
      '<div class="wc-fate-item"><span class="wc-fate-label">小組對手</span><span class="wc-fate-val">' + info.opponents + '</span></div>' +
      '<div class="wc-fate-item"><span class="wc-fate-label">關鍵球星</span><span class="wc-fate-val">' + info.star + '</span></div>' +
      '<div class="wc-fate-item"><span class="wc-fate-label">歷史最佳</span><span class="wc-fate-val">' + info.best + '</span></div>';

    // Reset jiao
    document.getElementById('jiaoResult').style.display = 'none';
    document.getElementById('jiaoBtn').style.display = '';

    document.getElementById('confirmation').style.display = 'block';
  }

  // === ASK GODS (擲筊) ===
  window.askGods = function() {
    var code = userVote || selectedCode;
    var team = TEAM_MAP[code];
    var info = TEAM_INFO[code] || DEFAULT_INFO;

    // Probability of 聖筊 based on team strength (higher rank = higher chance)
    var probNum = parseFloat(info.prob) || 0.1;
    var holyChance = Math.min(0.85, Math.max(0.15, probNum / 20 + 0.3));

    var results = [];
    for (var i = 0; i < 3; i++) {
      results.push(Math.random() < holyChance ? 'holy' : (Math.random() < 0.5 ? 'laugh' : 'dark'));
    }

    var holyCount = results.filter(function(r) { return r === 'holy'; }).length;
    var icons = results.map(function(r) {
      if (r === 'holy') return '<span class="wc-jiao-icon wc-jiao-holy">🌕 聖筊</span>';
      if (r === 'laugh') return '<span class="wc-jiao-icon wc-jiao-laugh">🌗 笑筊</span>';
      return '<span class="wc-jiao-icon wc-jiao-dark">🌑 陰筊</span>';
    }).join('');

    var verdict = '';
    if (holyCount === 3) {
      verdict = '<div class="wc-jiao-verdict wc-jiao-yes">✨ 三聖筊！神明大力看好 ' + team.flag + ' ' + team.name + '！天意不可違！</div>';
    } else if (holyCount === 2) {
      verdict = '<div class="wc-jiao-verdict wc-jiao-maybe">🤔 兩聖筊一笑筊⋯神明覺得有機會，但不保證。建議再觀望一下？</div>';
    } else if (holyCount === 1) {
      verdict = '<div class="wc-jiao-verdict wc-jiao-hmm">😅 只有一個聖筊⋯神明持保留態度。要不要考慮換一隊？</div>';
    } else {
      verdict = '<div class="wc-jiao-verdict wc-jiao-no">💀 零聖筊！神明搖頭了⋯' + team.name + ' 今年可能不太行。快按重選吧！</div>';
    }

    var el = document.getElementById('jiaoResult');
    el.innerHTML = '<div class="wc-jiao-throws">' + icons + '</div>' + verdict +
      '<button class="wc-jiao-retry" onclick="askGods()">🔄 再擲一次</button>';
    el.style.display = 'block';
    document.getElementById('jiaoBtn').style.display = 'none';
  };

  // === ALREADY VOTED ===
  function showAlreadyVoted() {
    showFateCard(userVote);
    document.getElementById('votingSection').style.display = 'none';
    showResults();
  }

  // === GET COMBINED VOTES ===
  function getCombinedVotes() {
    var userVotes = JSON.parse(localStorage.getItem('wc2026_user_votes') || '{}');
    var combined = {};
    Object.keys(SEED_VOTES).forEach(function(code) {
      combined[code] = SEED_VOTES[code] + (userVotes[code] || 0);
    });
    // Also add any codes user voted for that aren't in seed
    Object.keys(userVotes).forEach(function(code) {
      if (!combined[code]) {
        combined[code] = userVotes[code];
      }
    });
    return combined;
  }

  // === SHOW RESULTS ===
  function showResults() {
    var resultsSection = document.getElementById('resultsSection');
    resultsSection.style.display = 'block';

    var combined = getCombinedVotes();

    // Sort by votes desc, get top 10
    var sorted = Object.keys(combined).map(function(code) {
      return { code: code, votes: combined[code] };
    }).sort(function(a, b) { return b.votes - a.votes; });

    var top10 = sorted.slice(0, 10);
    var totalVotes = sorted.reduce(function(sum, item) { return sum + item.votes; }, 0);
    var maxVotes = top10[0] ? top10[0].votes : 1;

    // Total votes display
    document.getElementById('totalVotes').textContent = '共 ' + totalVotes.toLocaleString() + ' 票已投出';

    // Render chart
    var chartHtml = '';
    top10.forEach(function(item) {
      var team = TEAM_MAP[item.code];
      if (!team) return;
      var pct = ((item.votes / totalVotes) * 100).toFixed(1);
      var barWidth = ((item.votes / maxVotes) * 100).toFixed(1);
      var isUserPick = item.code === userVote;
      var barClass = 'wc-chart-bar' + (isUserPick ? ' wc-user-pick' : '');

      chartHtml += '<div class="wc-chart-item">';
      chartHtml += '<div class="wc-chart-label">' + team.flag + ' ' + team.name + '</div>';
      chartHtml += '<div class="wc-chart-bar-wrap">';
      chartHtml += '<div class="' + barClass + '" style="width:' + barWidth + '%"></div>';
      chartHtml += '<span class="wc-chart-value">' + item.votes.toLocaleString() + '</span>';
      chartHtml += '</div>';
      chartHtml += '<div class="wc-chart-pct">' + pct + '%</div>';
      chartHtml += '</div>';
    });
    document.getElementById('chart').innerHTML = chartHtml;
  }

  // === EVENT LISTENERS ===
  document.getElementById('voteBtn').addEventListener('click', castVote);

  // === RUN ===
  init();
})();
</script>

</BaseLayout>
