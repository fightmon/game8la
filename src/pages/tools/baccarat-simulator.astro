        </button>
        <button class="strat-btn" data-s="dalembert">
          <strong>達蘭伯</strong>
          <span>輸加一注 贏減一注</span>
        </button>
        <button class="strat-btn" data-s="fibonacci">
          <strong>斐波那契</strong>
          <span>輸照數列推進 贏退兩步</span>
        </button>
      </div>
    </div>

    <div class="ctrl-group">
      <label>🎲 押注目標</label>
      <div class="bet-target-btns">
        <button class="target-btn active" data-t="banker">押莊 <small>莊家優勢 1.06%</small></button>
        <button class="target-btn" data-t="player">押閒 <small>莊家優勢 1.24%</small></button>
      </div>
      <p class="edge-note">⚠️ 以上莊家優勢已含和局（tie 算 push 退注）。若排除和局，押莊實際優勢為 1.17%、押閒為 1.36%。</p>
    </div>

    <button class="run-btn" id="run-btn">
      <Icon name="play" size="1rem" /> 開始模擬
    </button>
  </div>

  <!-- Results -->
  <div class="results-area" id="results-area" style="display:none">
    <!-- Chart -->
    <div class="chart-card">
      <h2>📈 資金曲線</h2>
      <canvas id="chart" width="800" height="360"></canvas>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-label">最終餘額</span>
        <span class="stat-value" id="s-final">--</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">盈虧</span>
        <span class="stat-value" id="s-pnl">--</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">實際 RTP</span>
        <span class="stat-value" id="s-rtp">--</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">破產</span>
        <span class="stat-value" id="s-bust">--</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">最高餘額</span>
        <span class="stat-value" id="s-peak">--</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">最低餘額</span>
        <span class="stat-value" id="s-trough">--</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">最大連贏</span>
        <span class="stat-value" id="s-streak-w">--</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">最大連輸</span>
        <span class="stat-value" id="s-streak-l">--</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">莊 / 閒 / 和</span>
        <span class="stat-value" id="s-bpt">--</span>
      </div>
    </div>

    <!-- Verdict -->
    <div class="verdict-card" id="verdict-card">
      <h3>🍈 芭樂子怎麼說</h3>
      <p id="verdict-text"></p>
    </div>
  </div>

  <!-- Related Links -->
  <div class="related-links">
    <h3>📚 想更了解百家樂？</h3>
    <div class="rl-grid">
      <a href="/articles/baccarat-card-counting-myth/">百家樂算牌真相<small>電影 vs 數學</small></a>
      <a href="/articles/baccarat-winning-strategy/">1-3-2-4 投注法拆解<small>注碼管理教學</small></a>
      <a href="/tools/baccarat-roadmap/">百家樂看路模擬器<small>四條路即時練習</small></a>
      <a href="/articles/baccarat-roadmap-guide/">百家樂看路完整教學<small>大路・大眼仔・小路・蟑螂路圖解</small></a>
      <a href="/tools/bankroll-calculator/">資金管理計算器<small>算出你的停損線</small></a>
    </div>
  </div>

  <div class="guava-note">
    <p>🌿 本工具使用標準 8 副牌百家樂規則，發牌邏輯完全照第三補牌規則運作。每次模擬用新洗的牌堆。莊贏抽 5% 水錢、和局退注、對子邊注不計。數學是公平的，但賭場永遠站在贏面那邊。</p>
  </div>

  <ShareButtons title="百家樂策略模擬器 — 5 種注碼法實測比較" heading="🛡 想知道你的押注策略長期會虧多少？來這算" />
</div>

<!-- Chart.js CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js" defer></script>

<script is:inline>
(function(){
  // === State ===
  let rounds = 1000;
  let strategy = 'flat';
  let betTarget = 'banker';
  let chartInstance = null;

  // === DOM ===
  const $ = id => document.getElementById(id);
  const roundsBtns = document.querySelectorAll('.rounds-btn');
  const stratBtns = document.querySelectorAll('.strat-btn');
  const targetBtns = document.querySelectorAll('.target-btn');

  roundsBtns.forEach(b => b.addEventListener('click', () => {
    roundsBtns.forEach(x => x.classList.remove('active'));
    b.classList.add('active');
    rounds = +b.dataset.r;
  }));
  stratBtns.forEach(b => b.addEventListener('click', () => {
    stratBtns.forEach(x => x.classList.remove('active'));
    b.classList.add('active');
    strategy = b.dataset.s;
  }));
  targetBtns.forEach(b => b.addEventListener('click', () => {
    targetBtns.forEach(x => x.classList.remove('active'));
    b.classList.add('active');
    betTarget = b.dataset.t;
  }));

  $('run-btn').addEventListener('click', runSimulation);

  // === Baccarat Engine ===
  function createShoe() {
    const cards = [];
    for (let d = 0; d < 8; d++) {
      for (let v = 1; v <= 13; v++) {
        for (let s = 0; s < 4; s++) {
          cards.push(Math.min(v, 10)); // Face cards = 10, but baccarat value...
        }
      }
    }
    // Shuffle (Fisher-Yates)
    for (let i = cards.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [cards[i], cards[j]] = [cards[j], cards[i]];
    }
    return cards;
  }

  function bacVal(v) {
    // Baccarat card value: A=1, 2-9=face, 10/J/Q/K=0
    if (v === 10) return 0;
    return v;
  }

  function handTotal(cards) {
    return cards.reduce((s, c) => (s + bacVal(c)) % 10, 0);
  }

  function playHand(shoe, idx) {
    // Deal 4 cards: P1, B1, P2, B2
    if (idx + 6 > shoe.length) return null; // need reshuffle
    const p = [shoe[idx], shoe[idx+2]];
    const b = [shoe[idx+1], shoe[idx+3]];
    let ci = idx + 4;
    let pTotal = handTotal(p);
    let bTotal = handTotal(b);

    // Natural
    if (pTotal >= 8 || bTotal >= 8) {
      return { winner: pTotal > bTotal ? 'player' : bTotal > pTotal ? 'banker' : 'tie', ci };
    }

    // Player third card rule
    let pThird = null;
    if (pTotal <= 5) {
      pThird = shoe[ci++];
      p.push(pThird);
      pTotal = handTotal(p);
    }

    // Banker third card rule
    if (pThird === null) {
      // Player stood — banker draws on 0-5
      if (bTotal <= 5) {
        b.push(shoe[ci++]);
        bTotal = handTotal(b);
      }
    } else {
      const pTV = bacVal(pThird);
      let bankerDraws = false;
      if (bTotal <= 2) bankerDraws = true;
      else if (bTotal === 3 && pTV !== 8) bankerDraws = true;
      else if (bTotal === 4 && pTV >= 2 && pTV <= 7) bankerDraws = true;
      else if (bTotal === 5 && pTV >= 4 && pTV <= 7) bankerDraws = true;
      else if (bTotal === 6 && (pTV === 6 || pTV === 7)) bankerDraws = true;
      // bTotal 7: stand
      if (bankerDraws) {
        b.push(shoe[ci++]);
        bTotal = handTotal(b);
      }
    }

    const winner = pTotal > bTotal ? 'player' : bTotal > pTotal ? 'banker' : 'tie';
    return { winner, ci };
  }

  // === Betting Strategies ===
  function getNextBet(strat, unit, state) {
    switch (strat) {
      case 'flat':
        return unit;
      case 'martingale':
        return Math.min(state.currentBet || unit, unit * 128); // cap at 128x
      case 'paroli1324': {
        const seq = [1, 3, 2, 4];
        return unit * seq[state.seqIdx % 4];
      }
      case 'dalembert':
        return Math.max(unit, state.currentBet + (state.lastWin ? -unit : unit));
      case 'fibonacci': {
        const fib = state.fibSeq || [1];
        return unit * fib[fib.length - 1];
      }
      default:
        return unit;
    }
  }

  function updateState(strat, state, won, unit) {
    state.lastWin = won;
    switch (strat) {
      case 'martingale':
        state.currentBet = won ? unit : (state.currentBet || unit) * 2;
        break;
      case 'paroli1324':
        if (won) {
          state.seqIdx = (state.seqIdx + 1) % 4;
        } else {
          state.seqIdx = 0;
        }
        break;
      case 'dalembert':
        // handled in getNextBet
        break;
      case 'fibonacci':
        if (!state.fibSeq) state.fibSeq = [1];
        if (won) {
          // Move back 2 steps
          if (state.fibSeq.length > 2) {
            state.fibSeq.pop();
            state.fibSeq.pop();
          } else {
            state.fibSeq = [1];
          }
        } else {
          const len = state.fibSeq.length;
          const next = len >= 2 ? state.fibSeq[len-1] + state.fibSeq[len-2] : 1;
          state.fibSeq.push(next);
        }
        break;
    }
    return state;
  }

  // === Simulation ===
  function runSimulation() {
    const bankroll = +$('bankroll').value || 10000;
    const unit = +$('unit-bet').value || 100;

    let balance = bankroll;
    let shoe = createShoe();
    let shoeIdx = 0;
    const history = [balance];
    let peak = balance, trough = balance;
    let totalBetAmount = 0, totalReturnAmount = 0;
    let busted = false;
    let streakW = 0, streakL = 0, maxStreakW = 0, maxStreakL = 0;
    let countB = 0, countP = 0, countT = 0;

    let state = { lastWin: true, currentBet: unit, seqIdx: 0, fibSeq: [1] };

    for (let i = 0; i < rounds; i++) {
      // Reshuffle if shoe is running low
      if (shoeIdx + 6 > shoe.length) {
        shoe = createShoe();
        shoeIdx = 0;
      }

      const result = playHand(shoe, shoeIdx);
      if (!result) {
        shoe = createShoe();
        shoeIdx = 0;
        continue;
      }
      shoeIdx = result.ci;

      // Count outcomes
      if (result.winner === 'banker') countB++;
      else if (result.winner === 'player') countP++;
      else countT++;

      // Calculate bet
      let betSize = getNextBet(strategy, unit, state);
      betSize = Math.min(betSize, balance); // can't bet more than balance
      if (betSize <= 0 || balance <= 0) {
        busted = true;
        // Fill remaining history with 0
        for (let j = i; j < rounds; j++) history.push(0);
        break;
      }

      totalBetAmount += betSize;

      // Resolve bet
      let won = false;
      if (result.winner === 'tie') {
        // Push — return bet
        totalReturnAmount += betSize;
        // Tie doesn't affect strategy state
        history.push(balance);
        continue;
      } else if (result.winner === betTarget) {
        won = true;
        const payout = betTarget === 'banker' ? betSize * 0.95 : betSize;
        balance += payout;
        totalReturnAmount += betSize + payout;
      } else {
        balance -= betSize;
      }

      // Update strategy state
      state.currentBet = betSize;
      state = updateState(strategy, state, won, unit);

      // Track streaks
      if (won) {
        streakW++;
        streakL = 0;
        if (streakW > maxStreakW) maxStreakW = streakW;
      } else {
        streakL++;
        streakW = 0;
        if (streakL > maxStreakL) maxStreakL = streakL;
      }

      if (balance > peak) peak = balance;
      if (balance < trough) trough = balance;
      history.push(Math.round(balance));

      if (balance <= 0) {
        busted = true;
        for (let j = i + 1; j < rounds; j++) history.push(0);
        break;
      }
    }

    // Display results
    $('results-area').style.display = '';
    const pnl = balance - bankroll;
    const rtp = totalBetAmount > 0 ? ((totalReturnAmount / totalBetAmount) * 100).toFixed(2) : '0';

    $('s-final').textContent = '$' + Math.round(balance).toLocaleString();
    $('s-final').style.color = balance >= bankroll ? '#39FF14' : '#ef4444';

    $('s-pnl').textContent = (pnl >= 0 ? '+$' : '-$') + Math.abs(Math.round(pnl)).toLocaleString();
    $('s-pnl').style.color = pnl >= 0 ? '#39FF14' : '#ef4444';

    $('s-rtp').textContent = rtp + '%';
    $('s-rtp').style.color = rtp >= 100 ? '#39FF14' : '#ef4444';

    $('s-bust').textContent = busted ? '💀 破產' : '✅ 存活';
    $('s-bust').style.color = busted ? '#ef4444' : '#39FF14';

    $('s-peak').textContent = '$' + Math.round(peak).toLocaleString();
    $('s-peak').style.color = '#39FF14';

    $('s-trough').textContent = '$' + Math.round(trough).toLocaleString();
    $('s-trough').style.color = trough < bankroll * 0.5 ? '#ef4444' : 'var(--text-muted)';

    $('s-streak-w').textContent = maxStreakW + ' 局';
    $('s-streak-l').textContent = maxStreakL + ' 局';
    $('s-streak-l').style.color = maxStreakL >= 8 ? '#ef4444' : 'var(--text-muted)';

    const total = countB + countP + countT;
    $('s-bpt').textContent = countB + ' / ' + countP + ' / ' + countT;

    // Verdict
    const stratNames = { flat:'平注法', martingale:'馬丁格爾', paroli1324:'1-3-2-4', dalembert:'達蘭伯', fibonacci:'斐波那契' };
    let verdict = '';
    if (busted) {
      verdict = '使用「' + stratNames[strategy] + '」策略，你在第 ' + history.indexOf(0) + ' 局破產了。';
      if (strategy === 'martingale') verdict += '馬丁格爾的問題就是連輸時注碼指數爆炸——你遲早會遇到一次超過本金的翻倍。';
      else if (strategy === 'fibonacci') verdict += '斐波那契在連輸時注碼增長比馬丁慢，但一樣扛不住長連黑。';
      else verdict += '即使是最保守的策略，在局數夠多的情況下，1.06% 的莊家優勢也會把你磨穿。';
    } else if (pnl >= 0) {
      verdict = '恭喜，這次模擬你用「' + stratNames[strategy] + '」賺了 $' + Math.round(pnl).toLocaleString() + '。但別高興太早——這只是一次模擬。再跑 10 次，你會發現大部分時候都是虧的。百家樂的莊家優勢 1.06%～1.24% 不會因為你選了某種策略就消失。';
    } else {
      verdict = '使用「' + stratNames[strategy] + '」策略，' + rounds + ' 局後你虧了 $' + Math.abs(Math.round(pnl)).toLocaleString() + '。這不是運氣差——這是數學。莊家優勢 ' + (betTarget === 'banker' ? '1.06%' : '1.24%') + ' 意味著每下注 $10,000，你平均虧 $' + (betTarget === 'banker' ? '106' : '124') + '。沒有任何投注策略能改變這個事實。';
    }
    verdict += ' 所有策略改變的都是「損益分布」，不是「期望值」。想少虧一點？管好你的錢比選策略重要一萬倍。';
    $('verdict-text').textContent = verdict;

    // Draw chart
    drawChart(history, bankroll);

    // Scroll to results
    $('results-area').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // === Chart ===
  function drawChart(history, bankroll) {
    const ctx = $('chart').getContext('2d');
    if (chartInstance) chartInstance.destroy();

    // Downsample for performance if too many points
    let labels = [];
    let data = [];
    const step = history.length > 2000 ? Math.floor(history.length / 1000) : 1;
    for (let i = 0; i < history.length; i += step) {
      labels.push(i);
      data.push(history[i]);
    }
    // Always include last point
    if (labels[labels.length - 1] !== history.length - 1) {
      labels.push(history.length - 1);
      data.push(history[history.length - 1]);
    }

    const final = data[data.length - 1];
    const lineColor = final >= bankroll ? '#39FF14' : '#ef4444';

    chartInstance = new Chart(ctx, {
      type: 'line',
      data: {
        labels,
        datasets: [
          {
            label: '餘額',
            data,
            borderColor: lineColor,
            backgroundColor: lineColor + '18',
            borderWidth: 2,
            pointRadius: 0,
            fill: true,
            tension: 0.1,
          },
          {
            label: '起始本金',
            data: data.map(() => bankroll),
            borderColor: 'rgba(245,184,0,0.4)',
            borderWidth: 1,
            borderDash: [6, 4],
            pointRadius: 0,
            fill: false,
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: { duration: 600 },
        interaction: { intersect: false, mode: 'index' },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#1a1a2e',
            borderColor: '#333',
            borderWidth: 1,
            callbacks: {
              title: items => '第 ' + items[0].label + ' 局',
              label: item => item.datasetIndex === 0 ? '餘額: $' + item.raw.toLocaleString() : ''
            }
          }
        },
        scales: {
          x: {
            title: { display: true, text: '局數', color: '#888' },
            ticks: { color: '#666', maxTicksLimit: 8 },
            grid: { color: 'rgba(255,255,255,0.05)' }
          },
          y: {
            title: { display: true, text: '餘額 ($)', color: '#888' },
            ticks: { color: '#666', callback: v => '$' + v.toLocaleString() },
            grid: { color: 'rgba(255,255,255,0.05)' }
          }
        }
      }
    });
  }
})();
</script>

