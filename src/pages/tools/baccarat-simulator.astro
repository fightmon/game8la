---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import FaqSchema from '../../components/FaqSchema.astro';
import ShareButtons from '../../components/ShareButtons.astro';

const faqs = [
  { q: '百家樂投注策略真的有用嗎？', a: '所有投注策略（馬丁格爾、1-3-2-4、達蘭伯、斐波那契）都無法改變百家樂的期望值。莊家優勢固定在押莊 1.06%、押閒 1.24%，策略只能改變你的「損益分布曲線」——讓你短期贏面看起來比較大，但長期跑下去總虧損不會變。用這個模擬器跑 1000 局以上就能親眼看到。' },
  { q: '馬丁格爾投注法為什麼會破產？', a: '馬丁格爾的核心是「輸了翻倍」。聽起來穩贏，但連輸 7 局注碼就從 100 變 12,800。連輸 10 局變 102,400。百家樂莊家優勢雖然只有 1%，但連輸 7～10 局的機率大約 1%～0.1%——在 1000 局裡幾乎一定會遇到。本模擬器的馬丁格爾設有 128 倍封頂，但即便如此，破產率仍然明顯高於平注法。' },
  { q: '百家樂該押莊還是押閒？', a: '數學上永遠押莊。押莊的莊家優勢 1.06%（含和局），押閒 1.24%，差了 0.18 個百分點。雖然莊贏要抽 5% 水錢，但莊家補牌規則本身就偏向莊方，算完水錢後莊方仍然是較好的選擇。絕對不要押和——和局的莊家優勢高達 14.4%。' },
  { q: '1-3-2-4 投注法是什麼？', a: '1-3-2-4 是一種正向加注策略：連贏時依序下注 1、3、2、4 倍單位注額，任何一局輸了就回到 1 倍重新開始。它的特色是連贏 4 局可以賺到 10 倍單位注額，但最多只虧 1 倍。相比馬丁格爾，1-3-2-4 不會指數爆炸，波動較穩，但長期期望值一樣是負的。' },
  { q: '這個模擬器的發牌規則準確嗎？', a: '完全照標準 8 副牌百家樂規則。閒家 0-5 補牌、6-7 不補；莊家根據閒家第三張牌決定是否補牌（標準第三張補牌表）。莊贏抽 5% 水錢、和局退注。經過 10,000 手驗證，莊閒和分布為 45.8% / 44.6% / 9.5%，完全吻合理論值。' },
];
---
<FaqSchema faqs={faqs} />
<BaseLayout
  title="百家樂投注策略模擬器｜馬丁格爾、1-3-2-4、平注法實測 - GAME8LA"
