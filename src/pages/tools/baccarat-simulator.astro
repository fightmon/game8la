        <div class="input-wrap">
          <span class="input-prefix">$</span>
          <input type="number" id="unit-bet" value="100" min="10" max="10000" step="10" />
        </div>
      </div>
      <div class="ctrl-group">
        <label>🔄 模擬局數</label>
        <div class="rounds-btns">
          <button class="rounds-btn" data-r="100">100</button>
          <button class="rounds-btn" data-r="500">500</button>
          <button class="rounds-btn active" data-r="1000">1,000</button>
          <button class="rounds-btn" data-r="5000">5,000</button>
