---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="雷神之錘 II｜RTP 體感模擬器 — 神之力量降臨 - GAME8LA"
  description="雷神之錘 II 是一台教育用模擬器，讓你自己設定 RTP 和波動度，親手體驗倍數球鎖定、Free Game 連鎖的數學真相。"
  currentPage="tools"
  noindex={true}
>
<div class="sim-wrap">
  <!-- === 頂部說明 === -->
  <div class="sim-header">
    <a href="/tools/" style="color:var(--text-muted);font-size:0.85rem;text-decoration:none">← 回工具箱</a>
    <h1>⚡ 雷神之錘 II<span>RTP 體感模擬器</span></h1>
    <p class="sim-disclaimer">⚠️ 這不是賭博遊戲，沒有真錢、沒有儲值、沒有獎金。這是一台讓你「當老虎機的神」的教育模擬器——自己設定 RTP，看倍數球如何在免費遊戲中狂增。</p>
  </div>

  <!-- === 控制面板 === -->
  <div class="ctrl-panel">
    <div class="ctrl-group">
      <label>🎯 RTP（你是神，你決定）</label>
      <div class="ctrl-row">
        <input type="range" id="rtp-slider" min="80" max="99" value="97" step="1" />
        <span id="rtp-val" class="ctrl-val">97%</span>
      </div>
      <div class="rtp-hint" id="rtp-hint">接近真實老虎機水準</div>
    </div>
    <div class="ctrl-group">
      <label>🌊 波動度</label>
      <div class="vol-btns">
        <button class="vol-btn" data-vol="low">低波</button>
        <button class="vol-btn active" data-vol="mid">中波</button>
        <button class="vol-btn" data-vol="high">高波</button>
      </div>
    </div>
    <div class="ctrl-group">
      <label>💰 單注金額</label>
      <div class="ctrl-row">
        <button class="bet-btn" data-d="-10">-</button>
        <span id="bet-val" class="ctrl-val" style="min-width:60px;text-align:center">20</span>
        <button class="bet-btn" data-d="+10">+</button>
      </div>
    </div>
    <div class="ctrl-group">
      <label>🏦 餘額</label>
      <span id="balance-val" class="ctrl-val balance-display">10,000</span>
    </div>
    <div class="ctrl-group">
      <label>✨ Extra Bet</label>
      <button id="btn-extra-bet" class="extra-bet-toggle">OFF</button>
      <span class="extra-bet-info">+20% 下注 = 2x Free Game 機率</span>
    </div>
  </div>

  <!-- === 遊戲盤面 === -->
  <div class="game-area">
    <div class="board-frame">
      <div class="board" id="board">
        <!-- 6 cols × 5 rows = 30 cells, filled by JS -->
      </div>
      <!-- 右上角總倍數計數器 -->
      <div class="multi-counter" id="multi-counter">
        <span class="multi-counter-val" id="multi-value">×0</span>
      </div>
      <!-- 中獎提示 -->
      <div class="win-display" id="win-display" style="display:none">
        <div class="win-amount" id="win-amount">0</div>
        <div class="win-label">WIN</div>
      </div>
    </div>
    <!-- Free Game 提示 -->
    <div class="free-game-bar" id="fg-bar" style="display:none">
      <span>⚡ FREE GAME</span>
      <span id="fg-count">0 / 0</span>
    </div>
    <!-- 按鈕區 -->
    <div class="action-bar">
      <button id="btn-spin" class="btn-spin">SPIN</button>
      <div class="auto-group">
        <button id="btn-auto" class="btn-auto" data-count="50">AUTO ×50</button>
        <button class="btn-auto-opt" data-count="200">×200</button>
        <button class="btn-auto-opt" data-count="500">×500</button>
      </div>
      <button id="btn-reset" class="btn-reset">重置餘額</button>
    </div>
    <!-- Buy Features 按鈕 -->
    <div class="buy-feature-btns">
      <button id="btn-buy-free" class="btn-buy-feature btn-buy-free" title="購買 15 場免費遊戲">🎁 購買 Free Game (100×)</button>
      <button id="btn-buy-super" class="btn-buy-feature btn-buy-super" title="購買超級免費遊戲">💎 購買 Super Free (500×)</button>
      <button id="btn-buy-strike" class="btn-buy-feature btn-buy-strike" title="購買一次全倍數球">⚡ 購買 God Strike (4000×)</button>
    </div>
  </div>

  <!-- === 即時統計 === -->
  <div class="stats-panel">
    <h3>📊 即時數據</h3>
    <div class="stat-row"><span>設定 RTP</span><span id="s-rtp-set">97%</span></div>
    <div class="stat-row"><span>實際 RTP</span><span id="s-rtp-actual" style="color:var(--text-primary)">—</span></div>
    <div class="stat-row"><span>總轉數</span><span id="s-spins">0</span></div>
    <div class="stat-row"><span>總下注</span><span id="s-total-bet">0</span></div>
    <div class="stat-row"><span>總回收</span><span id="s-total-win">0</span></div>
    <div class="stat-row"><span>淨輸贏</span><span id="s-net" style="color:var(--text-muted)">—</span></div>
    <div class="stat-row"><span>最大單次獎金</span><span id="s-max-win" style="color:var(--gold)">0</span></div>
    <div class="stat-row"><span>最長乾旱（連續不中）</span><span id="s-max-drought" style="color:#ff6b6b">0</span></div>
    <div class="stat-row"><span>Free Game 觸發次數</span><span id="s-fg-count">0</span></div>
    <div class="stat-row"><span>Cascade 總次數</span><span id="s-cascade-total">0</span></div>
    <canvas id="balance-chart" width="360" height="180"></canvas>
    <p style="text-align:center;font-size:0.75rem;color:var(--text-muted);margin-top:0.3rem">餘額走勢圖（轉數 vs 餘額）</p>
  </div>

  <!-- === 情境導流 CTA（依輸贏動態切換） === -->
  <div class="context-cta" id="contextCta">
    <div class="cta-hook" id="ctaHook"></div>
    <div class="cta-sub" id="ctaSub"></div>
    <div>
      <a class="cta-btn" id="ctaBtn" href="/articles/seth-rng-myth-busted/">📖 看真相文</a>
      <a class="cta-btn-secondary" id="ctaBtn2" href="/articles/thor-hammer-2-guide/">🎮 雷神完整攻略</a>
    </div>
  </div>

  <!-- === 賠率表 === -->
  <details class="paytable-toggle">
    <summary>📋 符號賠率表（點擊展開）</summary>
    <div class="paytable" id="paytable"></div>
  </details>

  <!-- === 導流 CTA === -->
  <div class="sim-cta">
    <p>玩完模擬器了？用下面的工具管理你在真實娛樂城的體驗：</p>
    <div class="cta-links">
      <a href="/tools/rtp-tracker/">🎰 RTP 實測紀錄器</a>
      <a href="/tools/bankroll-calculator/">🧮 資金管理計算器</a>
      <a href="/casino-check/">🛡️ 娛樂城體檢工具</a>
    </div>
  </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script is:inline>
(function(){
  'use strict';

  /* ===== 符號定義（雷神之錘 II） ===== */
  const SYMS = [
    { id:'helmet',  label:'⛑️',  name:'雷神頭盔', color:'#f5b800', bg:'#3d2f0a', pay:{8:200, 10:500, 12:1000}, tier:1 },
    { id:'hammer',  label:'🔨',  name:'雷神戰錘', color:'#f5b800', bg:'#3d2f0a', pay:{8:50,  10:200, 12:500},  tier:1 },
    { id:'shield',  label:'🛡️',  name:'雷神神盾', color:'#c0c0c0', bg:'#2a2a2a', pay:{8:40,  10:100, 12:300},  tier:2 },
    { id:'coins',   label:'🪙',  name:'金幣',     color:'#f5b800', bg:'#3d2f0a', pay:{8:30,  10:40,  12:240},  tier:2 },
    { id:'red-gem', label:'🔴',  name:'紅寶石',   color:'#ef4444', bg:'#2a0505', pay:{8:20,  10:30,  12:200},  tier:3 },
    { id:'pur-gem', label:'🟣',  name:'紫寶石',   color:'#a855f7', bg:'#1a0a2e', pay:{8:16,  10:24,  12:160},  tier:3 },
    { id:'yel-gem', label:'🟡',  name:'金珠',     color:'#eab308', bg:'#2a1a00', pay:{8:10,  10:20,  12:100},  tier:4 },
    { id:'grn-gem', label:'🟢',  name:'綠寶石',   color:'#22c55e', bg:'#0a1a0a', pay:{8:8,   10:10,  12:80},   tier:4 },
    { id:'blu-gem', label:'🔵',  name:'藍鑽',     color:'#3b82f6', bg:'#0a1a2e', pay:{8:5,   10:15,  12:40},   tier:4 },
  ];
  const BONUS = { id:'bonus', label:'⚡', name:'獎勵符號', color:'#f59e0b', bg:'#3d2f0a' };
  const SUPER_BONUS = { id:'super-bonus', label:'🌩️', name:'超級獎勵', color:'#ff6b6b', bg:'#4a0a0a' };

  // 倍數球：固定值（不升級，但在 Free Game 中會鎖定並累積）
  const MULTI_BALLS = [
    { id:'multi-g', value:2,    color:'#39ff14', bg:'#0a2a0a', glow:'rgba(57,255,20,0.5)',   name:'綠倍數球', ring:'#22c55e' },
    { id:'multi-b', value:12,   color:'#60a5fa', bg:'#0a1a3a', glow:'rgba(96,165,250,0.5)',  name:'藍倍數球', ring:'#3b82f6' },
    { id:'multi-p', value:50,   color:'#c084fc', bg:'#1a0a3a', glow:'rgba(192,132,252,0.5)', name:'紫倍數球', ring:'#a855f7' },
    { id:'multi-r', value:100,  color:'#fb7185', bg:'#3a0a1a', glow:'rgba(251,113,133,0.5)', name:'紅倍數球', ring:'#ef4444' },
    { id:'multi-gold', value:1000, color:'#fbbf24', bg:'#4a3a0a', glow:'rgba(251,191,36,0.6)', name:'金虹倍數球', ring:'#f59e0b' },
  ];

  const ROWS = 5, COLS = 6, TOTAL = ROWS * COLS;

  /* ===== 遊戲狀態 ===== */
  let balance = 10000, bet = 20;
  let totalBet = 0, totalWin = 0, spinCount = 0;
  let maxSingleWin = 0, currentDrought = 0, maxDrought = 0;
  let fgTriggered = 0, cascadeTotal = 0;
  let board = [];
  let multiOnBoard = [];
  let gameState = 'idle';
  let freeSpinsLeft = 0, freeSpinsTotal = 0;
  let lockedMultis = [];
  let isAutoSpin = false, autoRemaining = 0, autoTotal = 0;
  function autoDelay(ms) { return delay(isAutoSpin ? Math.max(ms * 0.25, 30) : ms); }
  let spinWin = 0;
  let cascadeCount = 0;
  let extraBetEnabled = false;
  let inSuperFreeGame = false;
  let godStrikeActive = false;

  // Chart
  let chartData = { labels: [0], datasets: [{ label:'餘額', data:[10000], borderColor:'#4a90d9', backgroundColor:'rgba(74,144,217,0.1)', fill:true, tension:0.3, pointRadius:0 }] };
  let balanceChart;

  /* ===== RTP & 波動度控制 ===== */
  let targetRTP = 97;
  let volatility = 'mid';

  function getRtpDrift() {
    if (totalBet < 60) return 0;
    const actualRTP = (totalWin / totalBet) * 100;
    const diff = actualRTP - targetRTP;
    const raw = diff / 4;
    let d = Math.max(-1.5, Math.min(1.5, raw));
    if (freeSpinsLeft > 0 && d > 0) d = Math.min(1.5, d * 1.5);
    return d;
  }

  function getRtpBase() {
    return Math.max(0, Math.min(1, (targetRTP - 80) / 19));
  }

  function getBaseWeights() {
    return [2, 3, 4, 5, 7, 8, 10, 12, 15];
  }

  function getAdjustedWeights() {
    const base = getBaseWeights();
    const drift = getRtpDrift();
    const adjusted = base.map((w, i) => {
      const tier = SYMS[i].tier;
      if (tier <= 2) {
        let v = w * (1 - drift * 0.6);
        return Math.max(v, 0.3);
      }
      let v = w * (1 + drift * 0.3);
      return v;
    });
    return adjusted;
  }

  function getBonusWeight() {
    const totalSymWeight = getAdjustedWeights().reduce((a,b) => a+b, 0);
    const drift = getRtpDrift();
    const rtpBase = getRtpBase();
    const baseRate = 0.01 + rtpBase * 0.02;
    const rate = baseRate * (1 - Math.max(0, drift) * 0.5);
    return totalSymWeight * Math.max(rate, 0.003);
  }

  function getMultiWeight() {
    const volRates = { low: 0.025, mid: 0.015, high: 0.008 };
    const totalSymWeight = getAdjustedWeights().reduce((a,b) => a+b, 0);
    const drift = getRtpDrift();
    const rtpBase = getRtpBase();
    const volRate = volRates[volatility] || 0.015;
    const baseRate = volRate * (0.2 + rtpBase * 0.8);
    const rate = baseRate * (1 - Math.max(0, drift) * 0.7);
    let weight = totalSymWeight * Math.max(rate, 0.001);

    // Super Free Game 中倍數球出現率翻倍
    if (inSuperFreeGame) weight *= 2;
    return weight;
  }

  function pickSymbol() {
    const weights = getAdjustedWeights();
    const bonusW = getBonusWeight();
    const multiW = getMultiWeight();
    const all = [...weights, bonusW, multiW];
    const total = all.reduce((a,b) => a+b, 0);
    let r = Math.random() * total;
    for (let i = 0; i < all.length; i++) {
      r -= all[i];
      if (r <= 0) {
        if (i < SYMS.length) return { ...SYMS[i], type: 'sym' };
        if (i === SYMS.length) return { ...BONUS, type: 'bonus' };
        if (i === SYMS.length + 1) {
          const ball = MULTI_BALLS[Math.floor(Math.random() * MULTI_BALLS.length)];
          return { ...ball, type: 'multi', label: '×' + ball.value, multiVal: ball.value };
        }
      }
    }
    return { ...SYMS[SYMS.length-1], type: 'sym' };
  }

  /* ===== 盤面操作 ===== */
  function fillBoard() {
    board = [];
    multiOnBoard = [];

    // Free Game 期間倍數球鎖定不消失；Free Game 結束後清空
    if (freeSpinsLeft <= 0) {
      lockedMultis = [];
    }

    const lockedPositions = new Set();
    for (const lm of lockedMultis) {
      const ball = MULTI_BALLS.find(b => b.value === lm.value);
      if (ball) {
        board[lm.pos] = { ...ball, type: 'multi', label: '×' + lm.value, multiVal: lm.value, locked: true };
        multiOnBoard.push({ pos: lm.pos, value: lm.value, locked: true });
        lockedPositions.add(lm.pos);
      }
    }
    for (let i = 0; i < TOTAL; i++) {
      if (lockedPositions.has(i)) continue;
      const s = pickSymbol();
      board[i] = s;
      if (s.type === 'multi') {
        // God Strike: 所有倍數球強制變 1000x
        if (godStrikeActive) {
          const ball = MULTI_BALLS.find(b => b.value === 1000);
          if (ball) {
            board[i] = { ...ball, type: 'multi', label: '×1000', multiVal: 1000, locked: false };
            multiOnBoard.push({ pos: i, value: 1000, locked: false });
          }
        } else {
          multiOnBoard.push({ pos: i, value: s.multiVal, locked: false });
        }
      }
    }
    if (godStrikeActive) godStrikeActive = false;
  }

  function fillEmpty() {
    const newDist = new Array(TOTAL).fill(0);
    for (let c = 0; c < COLS; c++) {
      let emptyCount = 0;
      for (let r = 0; r < ROWS; r++) {
        if (!board[r * COLS + c]) emptyCount++;
      }
      let dropFrom = emptyCount;
      for (let r = 0; r < ROWS; r++) {
        const idx = r * COLS + c;
        if (!board[idx]) {
          let s, attempts = 0;
          do { s = pickSymbol(); attempts++; }
          while (s.type === 'multi' && attempts < 20);
          board[idx] = s;
          newDist[idx] = dropFrom;
          dropFrom--;
        }
      }
    }
    return newDist;
  }

  function cascadeDown() {
    const dropDist = new Array(TOTAL).fill(0);
    for (let c = 0; c < COLS; c++) {
      let writeRow = ROWS - 1;
      for (let r = ROWS - 1; r >= 0; r--) {
        const idx = r * COLS + c;
        if (board[idx]) {
          const writeIdx = writeRow * COLS + c;
          dropDist[writeIdx] = writeRow - r;
          if (writeIdx !== idx) {
            board[writeIdx] = board[idx];
            board[idx] = null;
            const mi = multiOnBoard.findIndex(m => m.pos === idx);
            if (mi >= 0) multiOnBoard[mi].pos = writeIdx;
          }
          writeRow--;
        }
      }
    }
    return dropDist;
  }

  /* ===== 中獎偵測（8+ Scatter Pays） ===== */
  function findMatches() {
    const counts = {};
    for (let i = 0; i < TOTAL; i++) {
      if (!board[i] || board[i].type !== 'sym') continue;
      const id = board[i].id;
      if (!counts[id]) counts[id] = [];
      counts[id].push(i);
    }
    const matches = [];
    for (const [id, positions] of Object.entries(counts)) {
      if (positions.length >= 8) {
        matches.push({ id, positions, count: positions.length });
      }
    }
    return matches;
  }

  function countBonus() {
    let count = 0, superCount = 0;
    const positions = [], superPositions = [];
    for (let i = 0; i < TOTAL; i++) {
      if (board[i] && board[i].type === 'bonus') {
        count++;
        positions.push(i);
      }
      if (board[i] && board[i].type === 'super-bonus') {
        superCount++;
        superPositions.push(i);
      }
    }
    return { count, positions, superCount, superPositions };
  }

  function getPayout(symId, count) {
    const sym = SYMS.find(s => s.id === symId);
    if (!sym) return 0;
    let pay = 0;
    if (count >= 12) pay = sym.pay[12];
    else if (count >= 10) pay = sym.pay[10];
    else if (count >= 8) pay = sym.pay[8];
    const rtpBase = getRtpBase();
    return pay * (0.81 + rtpBase * 0.20);
  }

  function getTotalMultiplier() {
    if (multiOnBoard.length === 0) return 1;
    return multiOnBoard.reduce((sum, m) => sum + m.value, 1);
  }

  function calculateSpinResult(matches) {
    let win = 0;
    for (const m of matches) {
      const payout = getPayout(m.id, m.count);
      win += (bet / 20) * payout;
    }
    return win;
  }

  /* ===== DOM 操作 ===== */
  const $board = document.getElementById('board');
  const $winDisplay = document.getElementById('win-display');
  const $winAmount = document.getElementById('win-amount');
  const $btnSpin = document.getElementById('btn-spin');
  const $btnAuto = document.getElementById('btn-auto');
  const $btnReset = document.getElementById('btn-reset');
  const $fgBar = document.getElementById('fg-bar');
  const $fgCount = document.getElementById('fg-count');
  const $multiCounter = document.getElementById('multi-counter');
  const $multiValue = document.getElementById('multi-value');
  const $rtpSlider = document.getElementById('rtp-slider');
  const $rtpVal = document.getElementById('rtp-val');
  const $rtpHint = document.getElementById('rtp-hint');
  const $betVal = document.getElementById('bet-val');
  const $balanceVal = document.getElementById('balance-val');
  const $btnExtraBet = document.getElementById('btn-extra-bet');
  const $btnBuyFree = document.getElementById('btn-buy-free');
  const $btnBuySuper = document.getElementById('btn-buy-super');
  const $btnBuyStrike = document.getElementById('btn-buy-strike');

  function renderBoard(highlightPositions, removePositions, dropData, spinIn) {
    $board.innerHTML = '';
    for (let i = 0; i < TOTAL; i++) {
      const cell = document.createElement('div');
      cell.className = 'cell';
      const s = board[i];
      if (s) {
        cell.style.background = s.bg;
        cell.style.color = s.color;
        cell.style.borderColor = s.color + '44';
        cell.dataset.type = s.type;

        if (s.type === 'multi') {
          cell.classList.add('cell-multi');
          const glow = s.glow || 'rgba(74,144,217,0.3)';
          const ring = s.ring || s.color;
          cell.style.borderColor = ring + '88';
          cell.style.boxShadow = '0 0 14px ' + glow + ', inset 0 0 10px ' + glow;
          cell.style.background = 'radial-gradient(circle at 35% 35%, ' + s.color + '99, ' + s.bg + ')';
          cell.innerHTML = '<span class="multi-ball-val">' + s.label + '</span>';
          if (s.locked) {
            cell.innerHTML += '<span class="multi-lock-icon">🔒</span>';
            cell.classList.add('cell-locked');
          }
        } else if (s.type === 'bonus') {
          cell.textContent = s.label;
          cell.classList.add('cell-bonus');
          cell.style.borderColor = '#f59e0b66';
          cell.style.boxShadow = '0 0 12px rgba(245,158,11,0.3)';
        } else if (s.type === 'super-bonus') {
          cell.textContent = s.label;
          cell.classList.add('cell-super-bonus');
          cell.style.borderColor = '#ff6b6b99';
          cell.style.boxShadow = '0 0 16px rgba(255,107,107,0.5)';
        } else {
          cell.textContent = s.label;
        }

        if (highlightPositions && highlightPositions.includes(i)) {
          cell.classList.add('cell-matched');
        }
        if (removePositions && removePositions.includes(i)) {
          cell.classList.add('cell-removing');
        }
        if (dropData && dropData[i] > 0) {
          const rows = dropData[i];
          cell.style.setProperty('--drop-rows', rows);
          cell.style.animationDuration = (0.08 + rows * 0.06) + 's';
          cell.classList.add('cell-drop');
        }
      } else {
        cell.style.background = '#111';
        cell.style.opacity = '0.3';
      }
      if (spinIn && !spinIn.has(i)) {
        const col = i % COLS;
        const row = Math.floor(i / COLS);
        const dropRows = ROWS - row + 1;
        cell.style.setProperty('--drop-rows', dropRows);
        cell.style.animationDuration = (0.1 + row * 0.04) + 's';
        cell.style.animationDelay = (col * 0.02) + 's';
        cell.classList.add('cell-drop');
      }
      $board.appendChild(cell);
    }
  }

  function updateStats() {
    document.getElementById('s-rtp-set').textContent = targetRTP + '%';
    const actualRTP = totalBet > 0 ? ((totalWin / totalBet) * 100).toFixed(1) : '—';
    const $actual = document.getElementById('s-rtp-actual');
    $actual.textContent = totalBet > 0 ? actualRTP + '%' : '—';
    if (totalBet > 0) {
      const diff = parseFloat(actualRTP) - targetRTP;
      $actual.style.color = Math.abs(diff) < 5 ? '#39ff14' : '#ff6b6b';
    }
    document.getElementById('s-spins').textContent = spinCount;
    document.getElementById('s-total-bet').textContent = totalBet.toLocaleString();
    document.getElementById('s-total-win').textContent = totalWin.toLocaleString();
    const $net = document.getElementById('s-net');
    if ($net) {
      const net = totalWin - totalBet;
      if (totalBet === 0) {
        $net.textContent = '—';
        $net.style.color = 'var(--text-muted)';
      } else {
        $net.textContent = (net >= 0 ? '+' : '') + net.toLocaleString();
        $net.style.color = net >= 0 ? '#39ff14' : '#ff6b6b';
      }
    }
    document.getElementById('s-max-win').textContent = maxSingleWin.toLocaleString();
    document.getElementById('s-max-drought').textContent = maxDrought;
    document.getElementById('s-fg-count').textContent = fgTriggered;
    document.getElementById('s-cascade-total').textContent = cascadeTotal;
    $balanceVal.textContent = balance.toLocaleString();
    $betVal.textContent = bet;
    updateContextCta();
  }

  function updateContextCta() {
    const $cta = document.getElementById('contextCta');
    const $hook = document.getElementById('ctaHook');
    const $sub = document.getElementById('ctaSub');
    const $btn = document.getElementById('ctaBtn');
    const $btn2 = document.getElementById('ctaBtn2');
    if (!$cta || spinCount < 20) return;
    $cta.classList.add('visible');
    const net = totalWin - totalBet;
    const actualRTP = totalBet > 0 ? (totalWin / totalBet * 100) : 100;
    if (net >= 0) {
      $hook.textContent = '你贏了 ' + net.toLocaleString() + ' 元？先別開心太早。';
      $sub.textContent = '短期波動讓你「感覺」在贏，但數學才是真神。看雷神如何用倍數球的假象欺騙玩家。';
      $btn.textContent = '🔍 看倍數球陷阱';
      $btn.href = '/articles/seth-rng-myth-busted/';
      $btn2.textContent = '⚡ 雷神完整攻略';
      $btn2.href = '/articles/thor-hammer-2-guide/';
    } else {
      $hook.textContent = '已經虧了 ' + Math.abs(net).toLocaleString() + ' 元，Free Game 也救不了。';
      $sub.textContent = '即使倍數球在 Free Game 中鎖定並累積，長期 RTP ' + targetRTP + '% 仍會穩輸。想看看真實數據？';
      $btn.textContent = '💡 看懂為什麼你一直輸';
      $btn.href = '/articles/seth-rng-myth-busted/';
      $btn2.textContent = '📊 用 RTP 紀錄器追蹤實戰';
      $btn2.href = '/tools/rtp-tracker/';
    }
  }

  function updateChart() {
    if (!balanceChart) return;
    chartData.labels.push(spinCount);
    chartData.datasets[0].data.push(balance);
    if (chartData.labels.length > 300) {
      chartData.labels.shift();
      chartData.datasets[0].data.shift();
    }
    if (isAutoSpin && spinCount % 5 !== 0) return;
    balanceChart.update('none');
  }

  let winTimer = null;
  function showWin(amount) {
    if (winTimer) clearTimeout(winTimer);
    $winAmount.textContent = '+' + Math.round(amount).toLocaleString();
    $winDisplay.style.display = 'flex';
    $winDisplay.classList.add('win-pop');
    const dur = isAutoSpin ? 400 : 1500;
    winTimer = setTimeout(() => {
      $winDisplay.classList.remove('win-pop');
      $winDisplay.style.display = 'none';
      winTimer = null;
    }, dur);
  }

  function updateMultiBar() {
    const total = getTotalMultiplier();
    $multiValue.textContent = '×' + (total === 1 ? 0 : total);
    if (total > 1) {
      $multiCounter.classList.add('multi-active');
    } else {
      $multiCounter.classList.remove('multi-active');
    }
  }

  /* ===== 主遊戲流程 === */
  async function spin() {
    if (gameState !== 'idle') return;

    const actualBet = Math.round(bet * (extraBetEnabled ? 1.2 : 1));
    if (balance < actualBet && freeSpinsLeft <= 0) {
      $btnSpin.textContent = '餘額不足';
      setTimeout(() => { $btnSpin.textContent = 'SPIN'; }, 1500);
      isAutoSpin = false;
      return;
    }

    gameState = 'spinning';
    $btnSpin.disabled = true;
    $btnSpin.textContent = '...';
    spinWin = 0;
    cascadeCount = 0;

    if (freeSpinsLeft <= 0) {
      balance -= actualBet;
      totalBet += actualBet;
    } else {
      freeSpinsLeft--;
      $fgCount.textContent = (freeSpinsTotal - freeSpinsLeft) + ' / ' + freeSpinsTotal;
      if (freeSpinsLeft <= 0) {
        $fgBar.style.display = 'none';
        inSuperFreeGame = false;
      }
    }
    spinCount++;

    const lockedPositions = new Set(lockedMultis.map(lm => lm.pos));
    if (!isAutoSpin) {
      const cells = $board.querySelectorAll('.cell');
      cells.forEach((c, i) => {
        if (!lockedPositions.has(i)) c.classList.add('cell-fly-out');
      });
      await delay(180);
    }

    fillBoard();

    // Free Game 核心機制：新出現的倍數球自動鎖定到 lockedMultis
    if (freeSpinsLeft > 0 || freeSpinsTotal > 0) {
      for (const m of multiOnBoard) {
        if (!m.locked && !lockedMultis.find(lm => lm.pos === m.pos)) {
          m.locked = true;
          lockedMultis.push({ pos: m.pos, value: m.value });
          const cell = board[m.pos];
          if (cell) cell.locked = true;
        }
      }
    }

    renderBoard(null, null, null, isAutoSpin ? null : lockedPositions);
    updateMultiBar();
    await autoDelay(350);

    await cascadeLoop();

    const bonusResult = countBonus();
    const extraBetMult = extraBetEnabled ? 2 : 1;

    if (bonusResult.count >= 4 && freeSpinsLeft <= 0) {
      const bonusMultiplier = bonusResult.count === 4 ? 3 : bonusResult.count === 5 ? 5 : 100;
      spinWin += bet * bonusMultiplier;
      balance += bet * bonusMultiplier;
      totalWin += bet * bonusMultiplier;

      freeSpinsLeft = 15 * extraBetMult;
      freeSpinsTotal = 15 * extraBetMult;
      fgTriggered++;
      $fgBar.style.display = 'flex';
      $fgCount.textContent = '0 / ' + freeSpinsTotal;
      renderBoard(bonusResult.positions);
      await autoDelay(800);
    } else if (bonusResult.count >= 3 && freeSpinsLeft > 0) {
      freeSpinsLeft += 5 * extraBetMult;
      freeSpinsTotal += 5 * extraBetMult;
      $fgCount.textContent = (freeSpinsTotal - freeSpinsLeft) + ' / ' + freeSpinsTotal;
      renderBoard(bonusResult.positions);
      await autoDelay(500);
    }

    if (spinWin > 0) {
      let multi = getTotalMultiplier();
      const drift = getRtpDrift();

      if (drift > 0 && multi > 1) {
        multi = 1 + (multi - 1) * Math.max(0, 1 - drift);
      } else if (drift < 0 && multi > 1) {
        multi = multi * (1 + Math.abs(drift) * 0.3);
      }

      spinWin = Math.round(spinWin * multi);

      if (drift > 0.05) {
        const scale = Math.max(0.05, 1 - drift * 0.9);
        spinWin = Math.round(spinWin * scale);
      } else if (drift < -0.1) {
        const boost = 1 + Math.abs(drift) * 0.8;
        spinWin = Math.round(spinWin * boost);
      }

      const maxBetMultiple = drift > 0.5 ? 8 : drift > 0 ? 25 : 150;
      spinWin = Math.min(spinWin, actualBet * maxBetMultiple);

      if (totalBet > 0 && totalBet < 500 * actualBet && spinWin > 0) {
        const cap = (targetRTP * 1.05) / 100;
        const allowed = Math.max(0, cap * totalBet - totalWin);
        spinWin = Math.min(spinWin, allowed);
      }

      if (spinWin > 0) {
        balance += spinWin;
        totalWin += spinWin;
        if (spinWin > maxSingleWin) maxSingleWin = spinWin;
        currentDrought = 0;
        showWin(spinWin);
      } else {
        currentDrought++;
        if (currentDrought > maxDrought) maxDrought = currentDrought;
      }
    } else {
      currentDrought++;
      if (currentDrought > maxDrought) maxDrought = currentDrought;
    }

    renderBoard();
    updateStats();
    updateChart();
    updateMultiBar();

    gameState = 'idle';
    $btnSpin.disabled = false;
    $btnSpin.textContent = freeSpinsLeft > 0 ? 'FREE SPIN' : 'SPIN';
    $btnSpin.classList.toggle('btn-free', freeSpinsLeft > 0);

    if (freeSpinsLeft > 0 || (isAutoSpin && autoRemaining > 0)) {
      if (isAutoSpin && freeSpinsLeft <= 0) {
        autoRemaining--;
        $btnAuto.textContent = 'STOP (' + (autoTotal - autoRemaining) + '/' + autoTotal + ')';
      }
      if (autoRemaining <= 0 && freeSpinsLeft <= 0) {
        stopAuto();
      }
      await autoDelay(freeSpinsLeft > 0 ? 400 : 250);
      if (gameState === 'idle') spin();
    }
  }

  async function cascadeLoop() {
    let hasMatch = true;
    while (hasMatch) {
      const matches = findMatches();
      if (matches.length === 0) {
        hasMatch = false;
        break;
      }
      cascadeCount++;
      cascadeTotal++;

      const cascadeWin = calculateSpinResult(matches);
      spinWin += cascadeWin;

      const allPositions = matches.flatMap(m => m.positions);
      renderBoard(allPositions);
      await autoDelay(400);

      for (const pos of allPositions) {
        const isLocked = multiOnBoard.some(m => m.pos === pos && m.locked);
        if (!isLocked) board[pos] = null;
      }
      multiOnBoard = multiOnBoard.filter(m => board[m.pos] !== null);

      renderBoard(null, allPositions);
      await autoDelay(300);

      updateMultiBar();

      const dropDist = cascadeDown();
      const newDist = fillEmpty();
      const combinedDrop = new Array(TOTAL).fill(0);
      for (let i = 0; i < TOTAL; i++) {
        combinedDrop[i] = dropDist[i] || newDist[i] || 0;
      }
      renderBoard(null, null, combinedDrop);
      await autoDelay(350);
    }
  }

  function delay(ms) { return new Promise(r => setTimeout(r, ms)); }

  /* ===== 事件綁定 ===== */
  $btnSpin.addEventListener('click', () => {
    if (gameState === 'idle') spin();
  });

  let autoCount = 50;

  function startAuto(count) {
    isAutoSpin = true;
    autoCount = count;
    autoRemaining = count;
    autoTotal = count;
    $btnAuto.textContent = 'STOP (0/' + autoTotal + ')';
    $btnAuto.dataset.count = count;
    $btnAuto.classList.add('auto-running');
    document.querySelectorAll('.btn-auto-opt').forEach(b => b.style.display = 'none');
    if (gameState === 'idle') spin();
  }

  function stopAuto() {
    isAutoSpin = false;
    autoRemaining = 0;
    $btnAuto.textContent = 'AUTO ×' + autoCount;
    $btnAuto.classList.remove('auto-running');
    document.querySelectorAll('.btn-auto-opt').forEach(b => b.style.display = '');
  }

  $btnAuto.addEventListener('click', () => {
    if (isAutoSpin) {
      stopAuto();
    } else {
      startAuto(parseInt($btnAuto.dataset.count) || 50);
    }
  });

  document.querySelectorAll('.btn-auto-opt').forEach(btn => {
    btn.addEventListener('click', () => {
      if (isAutoSpin) return;
      startAuto(parseInt(btn.dataset.count));
    });
  });

  $btnReset.addEventListener('click', () => {
    if (gameState !== 'idle') return;
    balance = 10000;
    totalBet = 0; totalWin = 0; spinCount = 0;
    maxSingleWin = 0; currentDrought = 0; maxDrought = 0;
    fgTriggered = 0; freeSpinsLeft = 0; cascadeTotal = 0;
    lockedMultis = [];
    isAutoSpin = false; autoRemaining = 0; autoCount = 50;
    chartData.labels = [0];
    chartData.datasets[0].data = [10000];
    balanceChart && balanceChart.update();
    fillBoard();
    renderBoard();
    updateStats();
    updateMultiBar();
    $fgBar.style.display = 'none';
    $btnSpin.textContent = 'SPIN';
    $btnAuto.textContent = 'AUTO ×50';
    $btnAuto.dataset.count = '50';
    $btnAuto.classList.remove('auto-running');
    document.querySelectorAll('.btn-auto-opt').forEach(b => b.style.display = '');
    var $ctaReset = document.getElementById('contextCta');
    if ($ctaReset) $ctaReset.classList.remove('visible');
  });

  $btnExtraBet.addEventListener('click', () => {
    extraBetEnabled = !extraBetEnabled;
    $btnExtraBet.textContent = extraBetEnabled ? 'ON' : 'OFF';
    $btnExtraBet.classList.toggle('extra-bet-active', extraBetEnabled);
  });

  $btnBuyFree.addEventListener('click', () => {
    const cost = Math.round(bet * 100);
    if (gameState === 'idle' && balance >= cost) {
      balance -= cost;
      totalBet += cost;
      lockedMultis = [];
      freeSpinsLeft = 15;
      freeSpinsTotal = 15;
      fgTriggered++;
      $fgBar.style.display = 'flex';
      $fgCount.textContent = '0 / 15';
      inSuperFreeGame = false;
      updateStats();
      spin();
    }
  });

  $btnBuySuper.addEventListener('click', () => {
    const cost = Math.round(bet * 500);
    if (gameState === 'idle' && balance >= cost) {
      balance -= cost;
      totalBet += cost;
      lockedMultis = [];
      freeSpinsLeft = 15;
      freeSpinsTotal = 15;
      fgTriggered++;
      $fgBar.style.display = 'flex';
      $fgCount.textContent = '0 / 15';
      inSuperFreeGame = true;
      updateStats();
      spin();
    }
  });

  $btnBuyStrike.addEventListener('click', () => {
    const cost = Math.round(bet * 4000);
    if (gameState === 'idle' && balance >= cost) {
      balance -= cost;
      totalBet += cost;
      // God Strike：強制開盤，所有倍數球位置變 1000x
      godStrikeActive = true;
      updateStats();
      spin();
    }
  });

  $rtpSlider.addEventListener('input', function() {
    targetRTP = parseInt(this.value);
    $rtpVal.textContent = targetRTP + '%';
    const hints = {
      80:'黑心娛樂城水準', 81:'黑心娛樂城水準', 82:'黑心娛樂城水準',
      83:'盜版老虎機水準', 84:'盜版老虎機水準', 85:'盜版老虎機水準',
      86:'偏低，玩家虧很快', 87:'偏低，玩家虧很快', 88:'偏低，玩家虧很快',
      89:'實體遊藝場水準', 90:'實體遊藝場水準', 91:'實體遊藝場水準',
      92:'一般線上老虎機', 93:'一般線上老虎機', 94:'一般線上老虎機',
      95:'業界平均水準', 96:'接近真實老虎機水準', 97:'正版大廠水準（ATG/PG/RSG）',
      98:'對玩家非常友好', 99:'幾乎不賺錢的佛心 RTP',
    };
    $rtpHint.textContent = hints[targetRTP] || '';
    document.getElementById('s-rtp-set').textContent = targetRTP + '%';
  });

  document.querySelectorAll('.vol-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.vol-btn').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      volatility = this.dataset.vol;
    });
  });

  document.querySelectorAll('.bet-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const d = parseInt(this.dataset.d);
      bet = Math.max(10, Math.min(500, bet + d));
      $betVal.textContent = bet;
    });
  });

  document.addEventListener('keydown', e => {
    if (e.code === 'Space' && gameState === 'idle') { e.preventDefault(); spin(); }
  });

  /* ===== GA4 事件追蹤 ===== */
  function trackEvent(name, params) {
    if (typeof gtag === 'function') gtag('event', name, params);
  }

  let rtpDebounce = null;
  $rtpSlider.addEventListener('change', function() {
    clearTimeout(rtpDebounce);
    rtpDebounce = setTimeout(() => {
      trackEvent('sim_rtp_adjust', { rtp_value: parseInt(this.value) });
    }, 300);
  });

  document.querySelectorAll('.vol-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      trackEvent('sim_volatility', { volatility: this.dataset.vol });
    });
  });

  $btnSpin.addEventListener('click', () => {
    if (!isAutoSpin && gameState === 'idle') trackEvent('sim_spin', { spin_type: 'manual' });
  });

  $btnAuto.addEventListener('click', () => {
    if (!isAutoSpin) trackEvent('sim_auto_start', { auto_count: parseInt($btnAuto.dataset.count) || 50 });
  });

  document.querySelectorAll('.btn-auto-opt').forEach(btn => {
    btn.addEventListener('click', () => {
      trackEvent('sim_auto_start', { auto_count: parseInt(btn.dataset.count) });
    });
  });

  $btnReset.addEventListener('click', () => trackEvent('sim_reset', {}));

  /* ===== 賠率表渲染 ===== */
  function renderPaytable() {
    const $pt = document.getElementById('paytable');
    let html = '<table><thead><tr><th>符號</th><th>8~9 個</th><th>10~11 個</th><th>12+ 個</th></tr></thead><tbody>';
    for (const s of SYMS) {
      html += '<tr><td><span class="pt-sym" style="background:'+s.bg+';color:'+s.color+'">'+s.label+'</span> '+s.name+'</td>';
      html += '<td>'+s.pay[8]+'</td><td>'+s.pay[10]+'</td><td>'+s.pay[12]+'</td></tr>';
    }
    html += '</tbody></table>';
    html += '<div class="pt-section"><h4>⚡ 倍數球（固定值）</h4>';
    html += '<div class="pt-multi-row">';
    html += '<span class="pt-ball" style="background:#39ff14;color:#000">×2</span> ';
    html += '<span class="pt-ball" style="background:#60a5fa;color:#000">×12</span> ';
    html += '<span class="pt-ball" style="background:#c084fc;color:#000">×50</span> ';
    html += '<span class="pt-ball" style="background:#fb7185;color:#000">×100</span> ';
    html += '<span class="pt-ball" style="background:#fbbf24;color:#000">×1000</span>';
    html += '</div>';
    html += '<p>盤面上出現倍數球，當回合贏分 × 所有倍數球加總。<br>';
    html += '<strong>Free Game 中倍數球鎖定並持續累積到 Free Game 結束。</strong></p></div>';
    html += '<div class="pt-section"><h4>🎁 獎勵符號（Bonus）</h4>';
    html += '<p>4 個：3× bet 獎金 + 15 場 Free Game<br>';
    html += '5 個：5× bet 獎金 + 15 場 Free Game<br>';
    html += '6 個：100× bet 獎金 + 15 場 Free Game（Super Bonus 不計入此）<br>';
    html += 'Free Game 中 3+ Bonus → +5 場免費遊戲</p></div>';
    html += '<div class="pt-section"><h4>🎮 購買功能</h4>';
    html += '<p>購買 Free Game：100× 下注 → 15 場免費遊戲<br>';
    html += '購買 Super Free Game：500× 下注 → 15 場 + 倍數球出現率翻倍<br>';
    html += '購買 God Strike（神運一擊）：4000× 下注 → 一次轉，盤面所有倍數球變成 ×1000</p></div>';
    html += '<div class="pt-section"><h4>✨ Extra Bet</h4>';
    html += '<p>啟動時 +20% 下注成本，但 Free Game 觸發機率翻倍。</p></div>';
    html += '<div class="pt-section"><p>贏分公式：（單注÷20）× 符號賠率 × 盤面總倍數</p></div>';
    $pt.innerHTML = html;
  }

  /* ===== 初始化 ===== */
  function init() {
    fillBoard();
    renderBoard();
    renderPaytable();
    updateStats();

    const ctx = document.getElementById('balance-chart').getContext('2d');
    balanceChart = new Chart(ctx, {
      type: 'line',
      data: chartData,
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { display: false },
          y: { ticks: { color: '#888', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.06)' } }
        },
        animation: false,
      }
    });
  }

  init();
})();
</script>

<style is:global>
/* === 整體佈局 === */
.sim-wrap { max-width:1100px; margin:0 auto; padding:1rem; }
.sim-header { text-align:center; margin-bottom:1.5rem; }
.sim-header h1 { font-size:2rem; margin:0.5rem 0; color:var(--text-primary); }
.sim-header h1 span { display:block; font-size:0.9rem; color:var(--text-muted); font-weight:400; margin-top:0.3rem; }
.sim-disclaimer {
  font-size:0.82rem; color:var(--text-muted); background:rgba(74,144,217,0.06);
  border:1px solid rgba(74,144,217,0.15); border-radius:10px; padding:0.8rem 1rem;
  max-width:700px; margin:0.8rem auto 0; line-height:1.6;
}

/* === 控制面板 === */
.ctrl-panel {
  display:flex; flex-wrap:wrap; gap:1rem; justify-content:center;
  background:var(--bg-card); border:1px solid var(--border); border-radius:14px;
  padding:1rem 1.2rem; margin-bottom:1.2rem;
}
.ctrl-group { flex:1; min-width:150px; }
.ctrl-group label { display:block; font-size:0.8rem; color:var(--text-muted); margin-bottom:0.4rem; }
.ctrl-row { display:flex; align-items:center; gap:0.5rem; }
.ctrl-val { font-size:1.3rem; font-weight:900; color:#4a90d9; }
.balance-display { color:#39ff14 !important; }
.rtp-hint { font-size:0.75rem; color:var(--text-muted); margin-top:0.2rem; }
#rtp-slider { flex:1; accent-color:#4a90d9; }
.vol-btns { display:flex; gap:0.4rem; }
.vol-btn {
  padding:0.4rem 0.8rem; border:1px solid var(--border); border-radius:8px;
  background:transparent; color:var(--text-muted); font-size:0.82rem; cursor:pointer;
  transition:all 0.2s;
}
.vol-btn.active { background:#4a90d9; color:#fff; border-color:#4a90d9; font-weight:700; }
.bet-btn {
  width:36px; height:36px; border:1px solid var(--border); border-radius:8px;
  background:transparent; color:var(--text-primary); font-size:1.2rem; cursor:pointer;
  transition:all 0.2s;
}
.bet-btn:hover { border-color:#4a90d9; color:#4a90d9; }
.extra-bet-toggle {
  padding:0.35rem 0.8rem; border:1px solid var(--border); border-radius:8px;
  background:transparent; color:var(--text-muted); font-size:0.8rem; font-weight:700;
  cursor:pointer; transition:all 0.2s;
}
.extra-bet-toggle.extra-bet-active {
  background:#4a90d9; color:#fff; border-color:#4a90d9;
}
.extra-bet-info { display:block; font-size:0.65rem; color:var(--text-muted); margin-top:0.2rem; }

/* === 遊戲區域 === */
