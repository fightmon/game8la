        '🌌☄️🪐 連十四聖筊！' + pctStr + '！神明已經退休了，現在是你在替祂上班。'
      ],
      15: [
        '🕳️🌌☄️ 十五連聖筊！！！機率 ' + pctStr + '！地球上 80 億人同時擲筊，大概只有你一個人做到。',
        '🕳️🌌☄️ 連十五聖筊！' + pctStr + '！芭樂子決定關機了，這已經超出統計學的服務範圍。'
      ],
      16: [
        '🔮🕳️🌌 十六連聖筊！機率 ' + pctStr + '！你的存在本身就是一個統計異常。截圖吧，沒人會信。',
        '🔮🕳️🌌 連十六聖筊！' + pctStr + '！如果這是真的，你應該去 NASA 報到而不是在這裡擲筊。'
      ],
      17: [
        '🛸🔮🕳️ 十七連聖筊！機率 ' + pctStr + '！外星人已經在觀測你了。',
        '🛸🔮🕳️ 連十七聖筊！' + pctStr + '！你打破了芭樂子認為不可能被打破的紀錄。'
      ],
      18: [
        '🫠🛸🔮 十八連聖筊！！機率 ' + pctStr + '！芭樂子已經沒有形容詞可以用了。你贏了。',
        '🫠🛸🔮 連十八聖筊！' + pctStr + '！這比同時被隕石砸到又中樂透的機率還低。你是誰？？？'
      ],
      19: [
        '💀🫠🛸 十九連聖筊！機率 ' + pctStr + '！芭樂子的亂數產生器表示：「我盡力了。」',
        '💀🫠🛸 連十九聖筊！' + pctStr + '！統計學已死，你把它埋了。R.I.P.'
      ],
      20: [
        '🏴‍☠️💀🫠 二十連聖筊！！！機率 ' + pctStr + '！你已經不是在擲筊了，你在改寫宇宙的物理法則。芭樂子正式封你為「筊神」。',
        '🏴‍☠️💀🫠 連二十聖筊！' + pctStr + '！每一百萬人同時擲 20 次，平均不到一個人做得到。你是那個人。封神。'
      ]
    };
    // 21+ 通用模板
    if (n > 20) {
      return '🏴‍☠️💀🫠🌌 連 ' + n + ' 聖筊！！！機率 ' + pctStr + '！芭樂子已經無話可說了。你不是人，你是數學的例外。請截圖存證，這可能是人類史上最長的連續聖筊紀錄。';
    }
    var pool = msgs[n] || msgs[3];
    return pool[Math.floor(Math.random() * pool.length)];
  }

  var RESULT_NAMES = ['聖筊', '笑筊', '陰筊'];
  var RESULT_DESC = [
    '一陰一陽——神明同意了',
    '兩陽朝上——神明在笑',
    '兩陰朝上——神明不同意'
  ];
  var RESULT_CLASS = ['sheng', 'xiao', 'yin-result'];
  var LOG_CLASS = ['sheng', 'xiao', 'yin-badge'];

  // =================================================================
  // localStorage helpers
  // =================================================================
  var STORAGE_KEY = 'bless_history_' + new Date().toISOString().slice(0,10);

  function saveToStorage() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({
        throwCount: throwCount,
        consecutiveSheng: consecutiveSheng,
        logs: logs
      }));
    } catch(e) {}
  }

  function loadFromStorage() {
    try {
      var data = JSON.parse(localStorage.getItem(STORAGE_KEY));
      if (data && data.throwCount) {
        throwCount = data.throwCount;
        consecutiveSheng = data.consecutiveSheng || 0;
        logs = data.logs || [];
        return true;
      }
    } catch(e) {}
    return false;
  }

  // Clean up old days (keep only today)
  function cleanOldStorage() {
    try {
      var today = STORAGE_KEY;
      for (var i = 0; i < localStorage.length; i++) {
        var key = localStorage.key(i);
        if (key && key.startsWith('bless_history_') && key !== today) {
          localStorage.removeItem(key);
          i--; // adjust index after removal
        }
      }
    } catch(e) {}
  }

  // =================================================================
  // State
  // =================================================================
  var currentQ = 0;
  var isCustom = false;
  var throwCount = { sheng: 0, xiao: 0, yin: 0 };
  var consecutiveSheng = 0;
  var logs = [];
  var isThrowing = false;
  var lastResult = null; // for share card

  // =================================================================
  // DOM
  // =================================================================
  var questionSelect = document.getElementById('questionSelect');
  var throwBtn = document.getElementById('throwBtn');
  var againBtn = document.getElementById('againBtn');
  var block1 = document.getElementById('block1');
  var block2 = document.getElementById('block2');
  var resultHeader = document.getElementById('resultHeader');
  var resultFooter = document.getElementById('resultFooter');
  var resultTypeEl = document.getElementById('resultType');
  var resultDescEl = document.getElementById('resultDesc');

  // Question selection
  questionSelect.addEventListener('change', function() {
    var val = questionSelect.value;
    if (val === 'heart') {
      isCustom = true;
      currentQ = -1;
    } else {
      isCustom = false;
      currentQ = parseInt(val);
    }
  });
  // Default: 心裡告知 = custom mode
  isCustom = true;
  currentQ = -1;

  // =================================================================
  // Audio — 筊杯落地音效 (Web Audio API generated)
  // =================================================================
  var audioCtx = null;
  function playBlockSound() {
    try {
      if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      // 木頭撞擊音：短促的低頻 + 噪音
      var duration = 0.12;
      var osc = audioCtx.createOscillator();
      var gain = audioCtx.createGain();
      osc.type = 'triangle';
      osc.frequency.setValueAtTime(180, audioCtx.currentTime);
      osc.frequency.exponentialRampToValueAtTime(60, audioCtx.currentTime + duration);
      gain.gain.setValueAtTime(0.3, audioCtx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + duration);
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      osc.start(audioCtx.currentTime);
      osc.stop(audioCtx.currentTime + duration);
    } catch(e) {}
  }

  // =================================================================
  // Throw logic
  // =================================================================
  function getResult() {
    // 聖筊=50%, 笑筊=25%, 陰筊=25% (realistic distribution)
    var b1 = Math.random() < 0.5 ? 0 : 1; // 0=yang, 1=yin
    var b2 = Math.random() < 0.5 ? 0 : 1;
    if (b1 !== b2) return { type: 0, b1: b1, b2: b2 }; // 聖筊
    if (b1 === 0) return { type: 1, b1: 0, b2: 0 };    // 笑筊 (both yang)
    return { type: 2, b1: 1, b2: 1 };                    // 陰筊 (both yin)
  }

  function doThrow() {
    if (isThrowing) return;
    isThrowing = true;
    throwBtn.disabled = true;
    resultFooter.style.display = 'none';
    resultTypeEl.textContent = '🙏 正在擲筊⋯';
    resultTypeEl.className = 'bless-result-type bless-pre-hint';
    resultDescEl.textContent = '';

    var result = getResult();

    // Set final rotation for CSS animation
    // b=0 (yang up) → rotateX(0), b=1 (yin up) → rotateX(180deg)
    var finalX1 = result.b1 === 0 ? '0deg' : '180deg';
    var finalX2 = result.b2 === 0 ? '0deg' : '180deg';

    var inner1 = block1.querySelector('.block-inner');
    var inner2 = block2.querySelector('.block-inner');

    inner1.style.setProperty('--final-x', finalX1);
    inner1.style.setProperty('--final-y', '0deg');
    inner2.style.setProperty('--final-x', finalX2);
    inner2.style.setProperty('--final-y', '0deg');

    // Reset
    block1.className = 'bless-block';
    block2.className = 'bless-block';
    inner1.className = 'block-inner';
    inner2.className = 'block-inner';
    void block1.offsetWidth;

    // 一段式動畫：下蹲 → 拋擲 → 頂點懸停 → 落地
    block1.classList.add('throwing');
    block2.classList.add('throwing-alt');

    // 第一筊落地 (72% of 2.5s = 1800ms)
    setTimeout(function() {
      playBlockSound();
      if (navigator.vibrate) navigator.vibrate(40);
      block1.classList.add('landed');
    }, 1800);

    // 第二筊落地 (72% of 2.65s = 1908ms)
    setTimeout(function() {
      playBlockSound();
      if (navigator.vibrate) navigator.vibrate(40);
      block2.classList.add('landed');
    }, 1910);

    // 顯示結果（兩筊穩定後）
    setTimeout(function() {
      showResult(result);
      isThrowing = false;
      throwBtn.disabled = false;
    }, 2700);
  }

  function showResult(result) {
    var type = result.type; // 0=聖, 1=笑, 2=陰

    // Update streak
    if (type === 0) {
      consecutiveSheng++;
    } else {
      consecutiveSheng = 0;
    }

    // Update counts
    if (type === 0) throwCount.sheng++;
    else if (type === 1) throwCount.xiao++;
    else throwCount.yin++;

    // Get question text
    var qText = isCustom ? '心中默問' : QUESTIONS[currentQ];

    // Get reply
    var replies;
    if (isCustom || currentQ >= REPLIES.length) {
      replies = GENERIC_REPLIES[type];
    } else {
      replies = REPLIES[currentQ][type];
    }
    var reply = replies[Math.floor(Math.random() * replies.length)];

    // Display result — swap header from hint to result
    var resultQuoteEl = document.getElementById('resultQuote');
    resultTypeEl.textContent = RESULT_NAMES[type];
    resultTypeEl.className = 'bless-result-type ' + RESULT_CLASS[type];
    resultDescEl.textContent = RESULT_DESC[type];

    // Streak easter egg — 連 2+ 聖筊時取代普通回覆
    var streakArea = document.getElementById('streakArea');
    if (consecutiveSheng >= 3) {
      var tripleMsg = getStreakMsg(consecutiveSheng);
      streakArea.textContent = tripleMsg;
      streakArea.style.display = 'block';
      resultQuoteEl.style.display = 'none';
      reply = tripleMsg;
    } else if (consecutiveSheng === 2) {
      var pct = (Math.pow(0.5, 2) * 100).toFixed(0); // 25%
      streakArea.textContent = '🔥 加油！你的好運已進入 ' + pct + '% 的門檻，再一筊聖筊，神明就答應了！';
      streakArea.style.display = 'block';
      resultQuoteEl.style.display = 'none';
      reply = '連兩聖筊！再一筊就是三聖筊了！';
    } else {
      resultQuoteEl.textContent = '「' + reply + '」';
      resultQuoteEl.style.display = 'block';
      streakArea.style.display = 'none';
    }

    resultHeader.style.display = 'block';
    resultFooter.style.display = 'block';
    throwBtn.style.display = 'none';

    // Update log
    var now = new Date();
    var timeStr = String(now.getHours()).padStart(2,'0') + ':' + String(now.getMinutes()).padStart(2,'0');
    logs.unshift({ type: type, q: qText, time: timeStr });

    // Save for share card
    lastResult = { type: type, q: qText, reply: reply, streak: consecutiveSheng };

    updateStats();
    updateLog();
    saveToStorage();
  }

  function updateStats() {
    document.getElementById('statSheng').textContent = throwCount.sheng;
    document.getElementById('statXiao').textContent = throwCount.xiao;
    document.getElementById('statYin').textContent = throwCount.yin;
    var total = throwCount.sheng + throwCount.xiao + throwCount.yin;
    document.getElementById('statTotal').textContent = total;
    document.getElementById('historyBadge').textContent = total + ' 次';
  }

  function updateLog() {
    var logArea = document.getElementById('logArea');
    if (logs.length === 0) {
      logArea.innerHTML = '<p class="bless-log-empty">還沒擲過筊，試試看吧！</p>';
      return;
    }
    var html = '';
    var max = Math.min(logs.length, 20);
    for (var i = 0; i < max; i++) {
      var l = logs[i];
      html += '<div class="bless-log-item">' +
        '<span class="log-badge ' + LOG_CLASS[l.type] + '">' + RESULT_NAMES[l.type] + '</span>' +
        '<span class="log-q">' + escapeHtml(l.q) + '</span>' +
        '<span class="log-time">' + l.time + '</span>' +
        '</div>';
    }
    logArea.innerHTML = html;
  }

  function escapeHtml(s) {
    var d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  // =================================================================
  // History toggle (collapsible card)
  // =================================================================
  var historyCard = document.querySelector('.bless-history');
  var historyToggleBtn = document.getElementById('historyToggle');
  historyToggleBtn.addEventListener('click', function() {
    historyCard.classList.toggle('open');
  });

  function updateBadge() {
    var total = throwCount.sheng + throwCount.xiao + throwCount.yin;
    document.getElementById('historyBadge').textContent = total + ' 次';
  }

  // =================================================================
  // Event listeners
  // =================================================================
  throwBtn.addEventListener('click', doThrow);

  againBtn.addEventListener('click', function() {
    resultFooter.style.display = 'none';
    sharePanel.style.display = 'none';
    shareToggle.textContent = '📤 分享結果';
    throwBtn.style.display = '';
    // Reset header back to pre-hint
    resultTypeEl.textContent = '🙏 虔誠默念，準備好再擲';
    resultTypeEl.className = 'bless-result-type bless-pre-hint';
    resultDescEl.textContent = '';
    // Reset block visuals
    block1.className = 'bless-block';
    block2.className = 'bless-block';
    var inner1 = block1.querySelector('.block-inner');
    var inner2 = block2.querySelector('.block-inner');
    inner1.className = 'block-inner';
    inner2.className = 'block-inner';
    inner1.style.removeProperty('--final-x');
    inner1.style.removeProperty('--final-y');
    inner2.style.removeProperty('--final-x');
    inner2.style.removeProperty('--final-y');
  });

  // =================================================================
  // Share Panel (5 社群按鈕)
  // =================================================================
  var shareToggle = document.getElementById('shareToggle');
  var sharePanel = document.getElementById('sharePanel');

  shareToggle.addEventListener('click', function() {
    if (sharePanel.style.display === 'none') {
      sharePanel.style.display = 'block';
      shareToggle.textContent = '✕ 收起';
    } else {
      sharePanel.style.display = 'none';
      shareToggle.textContent = '📤 分享結果';
    }
  });

  function getShareText() {
    if (!lastResult) return { text: '來芭樂擲筊試試你的運氣！', url: 'https://game8la.com/tools/bless-blocks/' };
    var labels = ['聖筊', '笑筊', '陰筊'];
    var url = 'https://game8la.com/tools/bless-blocks/';
    var text = '我在芭樂擲筊問「' + lastResult.q + '」擲到' + labels[lastResult.type] + '！';
    if (lastResult.streak >= 3) text = '我在芭樂擲筊連 ' + lastResult.streak + ' 聖筊！！！';
    text += ' #GAME8LA #芭樂擲筊';
    return { text: text, url: url };
  }

  function openPopup(href) {
    window.open(href, '_blank', 'width=640,height=560,noopener,noreferrer');
  }

  document.querySelectorAll('[data-bless-share]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var kind = btn.getAttribute('data-bless-share');
      var d = getShareText();
      var eUrl = encodeURIComponent(d.url);
      var eText = encodeURIComponent(d.text);

      if (kind === 'facebook') {
        openPopup('https://www.facebook.com/sharer/sharer.php?u=' + eUrl + '&quote=' + eText);
      } else if (kind === 'x') {
        openPopup('https://twitter.com/intent/tweet?url=' + eUrl + '&text=' + eText);
      } else if (kind === 'threads') {
        openPopup('https://www.threads.net/intent/post?text=' + encodeURIComponent(d.text + ' ' + d.url));
      } else if (kind === 'ig') {
        navigator.clipboard.writeText(d.url).then(function() {
          showToast('已複製連結！請貼到 IG 限動或私訊分享 📲');
        }).catch(function() {
          showToast('請手動複製：' + d.url);
        });
        setTimeout(function() { window.open('https://www.instagram.com/', '_blank', 'noopener,noreferrer'); }, 600);
      } else if (kind === 'copy') {
        navigator.clipboard.writeText(d.url).then(function() {
          showToast('✅ 連結已複製到剪貼簿！');
        }).catch(function() {
          showToast('複製失敗，請手動複製：' + d.url);
        });
      }
    });
  });

  function showToast(msg) {
    var existing = document.querySelector('.bless-share-toast');
    if (existing) existing.remove();
    var toast = document.createElement('div');
    toast.className = 'bless-share-toast';
    toast.textContent = msg;
    document.body.appendChild(toast);
    requestAnimationFrame(function() {
      requestAnimationFrame(function() { toast.classList.add('show'); });
    });
    setTimeout(function() {
      toast.classList.remove('show');
      setTimeout(function() { toast.remove(); }, 300);
    }, 2500);
  }

  // =================================================================
  // Init: restore from localStorage
  // =================================================================
  cleanOldStorage();
  if (loadFromStorage()) {
    updateStats();
    updateLog();
    // Auto-open history if there are records
    if (logs.length > 0) {
      historyCard.classList.add('open');
    }
  }

})();
</script>

</BaseLayout>
