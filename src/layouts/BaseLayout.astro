---
import NavBar from '../components/NavBar.astro';
import FooterBar from '../components/FooterBar.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import DailyFortune from '../components/DailyFortune.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogUrl?: string;
  currentPage?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'GAME8LA - 台灣最敢說真話的線上遊戲評測平台。不灌水、不業配，給你最真實的遊戲評價與遊戲攻略。',
  ogImage = 'https://game8la.com/images/og-image.webp',
  ogUrl = Astro.url.href,
  currentPage = 'home',
  noindex = false
} = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script is:inline>try{if(localStorage.getItem('fabsCollapsed')==='1')document.documentElement.classList.add('fabs-collapsed')}catch(e){}</script>
    <title>{title}</title>
    <meta name="description" content={description}>
    {noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow, noarchive" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="website">
    <meta property="og:url" content={ogUrl}>
    <meta property="og:image" content={ogImage}>
    <meta property="og:site_name" content="GAME8LA">
    <meta property="og:locale" content="zh_TW">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={ogImage}>

    <!-- Favicon -->
    <link rel="icon" type="image/webp" href="/images/index/favicon_32x32.webp">
    <link rel="icon" type="image/webp" sizes="192x192" href="/images/index/icon-192.webp">
    <link rel="apple-touch-icon" href="/images/index/apple-touch-icon_180x180.webp">

    <!-- Google Analytics 4 (延後到首次互動或 3 秒後才載，改善 LCP/TBT) -->
    <!-- 開發環境(localhost / 127.0.0.1 / .pages.dev / 區網)完全不載入 GA；
         另支援「個人退出」：在自己的瀏覽器連一次 ?noga=1 之後，這台裝置永遠不送 GA（?noga=0 可還原） -->
    <script is:inline>
      (function(){
        var h = location.hostname;
        var optout = false;
        try {
          var p = new URLSearchParams(location.search);
          if (p.get('noga') === '1') localStorage.setItem('g8_noga', '1');
          else if (p.get('noga') === '0') localStorage.removeItem('g8_noga');
          optout = localStorage.getItem('g8_noga') === '1';
        } catch (e) {}
        var isDev = optout
          || h === 'localhost' || h === '127.0.0.1' || h.endsWith('.local')
          || h.endsWith('.pages.dev') || h.startsWith('192.168.') || h.startsWith('10.');
        if (isDev) {
          window.gtag = function(){}; // no-op，避免文章內部呼叫 gtag 報錯
          return;
        }
        window.dataLayer = window.dataLayer || [];
        window.gtag = function(){window.dataLayer.push(arguments);};
        var loaded = false;
        function loadGA(){
          if (loaded) return; loaded = true;
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-DN9QHEM3GQ';
          document.head.appendChild(s);
          gtag('js', new Date());
          gtag('config', 'G-DN9QHEM3GQ');
        }
        ['scroll','mousemove','touchstart','keydown','click'].forEach(function(ev){
          window.addEventListener(ev, loadGA, {once:true, passive:true});
        });
        setTimeout(loadGA, 4000);
      })();
    </script>

    <meta name="theme-color" content="#121212">
    <link rel="canonical" href={ogUrl}>
    <link rel="alternate" hreflang="zh-TW" href={ogUrl}>
    <link rel="alternate" hreflang="x-default" href={ogUrl}>

    <!-- Organization Schema (全站) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Game8la",
      "alternateName": "GAME8LA 真評價",
      "url": "https://game8la.com",
      "logo": "https://game8la.com/images/index/game8la_logo_21x9.webp",
      "description": "台灣最敢說真話的線上遊戲評測平台",
      "founder": { "@type": "Person", "name": "芭樂子", "url": "https://game8la.com/author/baluazi/" },
      "contactPoint": { "@type": "ContactPoint", "email": "hello@game8la.tw", "contactType": "customer service" }
    })} />

    {/* WebSite + SearchAction — 僅首頁 */}
    {currentPage === 'home' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Game8la",
        "url": "https://game8la.com/",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://game8la.com/?s={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      })} />
    )}

    <!-- Preconnect to external origins -->
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>
    <link rel="preconnect" href="https://www.clarity.ms" crossorigin>

    {/* Preload hero banner image for LCP on homepage */}
    {currentPage === 'home' && (
      <link rel="preload" as="image" href="/images/index/indexBanner001_01.webp" fetchpriority="high" />
    )}

    <!-- Microsoft Clarity (延後載入，不阻塞渲染) -->
    <script is:inline>
      (function(){
        var loaded = false;
        function loadClarity(){
          if (loaded) return; loaded = true;
          (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
          })(window, document, "clarity", "script", "wec58er2i5");
        }
        if ('requestIdleCallback' in window) {
          requestIdleCallback(loadClarity, {timeout: 5000});
        } else {
          setTimeout(loadClarity, 3000);
        }
      })();
    </script>
  </head>
  <body>
    <NavBar currentPage={currentPage} />

    <main>
      <slot />
    </main>

    <FooterBar />
    {currentPage === 'articles' && <ReadingProgress />}
    <DailyFortune />
    <ScrollToTop />

    <!-- Global FAQ accordion toggle -->
    <script is:inline>
      document.addEventListener('click', function(e) {
        var q = e.target.closest('.faq-q');
        if (!q) return;
        var item = q.closest('.faq-item');
        if (!item) return;
        item.classList.toggle('open');
      });
    </script>
  </body>
</html>

<style is:global>
  main {
    min-height: calc(100vh - 70px - 300px);
    margin-top: 70px;
  }
</style>
